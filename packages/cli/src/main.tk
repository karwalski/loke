// F1.3 — Main CLI entry point
// Compiled to the `loke` binary via ooke.

i=t:shared.types;
i=cfg:shared.config;
i=log:shared.log;
i=cmd:cli.commands;
i=out:cli.output;
i=health:cli.health;
i=str:std.str;

pub f=main(args:@(str)):i32{
  let cid=log.new_correlation_id();

  let config=cfg.load_config("~/.loke/config.toml")|{
    $ok:v v;
    $err:e cfg.default_config()
  };

  log.info("loke cli starting";"cli";cid);

  let command=cmd.parse(args);

  command|{
    $ask:prompt;
      out.print_line(str.concat("Ask: ";prompt));
      out.print_line("Pipeline not yet connected — use browser mode for full pipeline");
      <0
    $pipeline:prompt;
      out.print_line(str.concat("Pipeline stages for: ";prompt));
      out.print_pipeline_stage("1 privacy filter";"pending";"PII detection and anonymisation");
      out.print_pipeline_stage("2 token optimiser";"pending";"prompt compression via LLMLingua");
      out.print_pipeline_stage("3 router";"pending";"model selection by tier and sensitivity");
      out.print_pipeline_stage("4 LLM";"pending";"inference via Ollama or remote provider");
      out.print_pipeline_stage("5 response restoration";"pending";"placeholder substitution and de-anonymisation");
      out.print_pipeline_stage("6 audit";"pending";"logging redacted interaction to local store");
      out.print_pipeline_stage("7 feedback";"pending";"thumbs up/down capture");
      <0
    $queue_list;
      out.print_line("No jobs in queue");
      <0
    $queue_cancel:id;
      out.print_line(str.concat("Queue cancel not yet implemented — job id: ";id));
      <0
    $models_list;
      out.print_line("Run: ollama list to see local models");
      <0
    $models_recommend;
      out.print_line("Run loke doctor first to profile your hardware");
      <0
    $memory_search:query;
      out.print_line(str.concat("Memory search not yet implemented — query: ";query));
      <0
    $agents_list;
      out.print_line("No agents registered");
      <0
    $overnight_status;
      out.print_line("No overnight jobs scheduled");
      <0
    $doctor;
      let report=health.check_all(config.ollama_url;config.presidio_url;config.llmlingua_url);
      out.print_line(health.format_report(report));
      report.overall|{
        $ok <0;
        $degraded d <0;
        $down d <1
      }
    $version;
      out.print_line("loke 0.1.0");
      <0
    $help;
      out.print_line(cmd.usage());
      <0
    $unknown:msg;
      out.print_error(msg);
      <1
  }
}
