// F1.6 — Startup and shutdown sequence

i=t:shared.types;
i=cfg:shared.config;
i=log:shared.log;
i=str:std.str;

pub m.$boot_stage{
  $config;
  $logger;
  $database;
  $migrations;
  $settings;
  $health_check;
  $ready
}

pub m.$boot_result{
  stage:$boot_stage;
  ok:bool;
  error:str
}

pub f=boot_sequence(config_path:str):$loke_config|$loke_err{
  let cid=log.new_correlation_id();

  log.info("boot: loading config";"startup";cid);
  let config=cfg.load_config(config_path)|{
    $ok:v v;
    $err:e;
      log.error(str.concat("boot: config load failed — ";e);"startup";cid);
      <$loke_err.$config_err(str.concat("config stage failed: ";e))
  };

  log.info("boot: validating config";"startup";cid);
  if str.len(config.ollama_url)<1{
    log.error("boot: ollama_url is required";"startup";cid);
    <$loke_err.$config_err("config stage failed: ollama_url must not be empty")
  };
  if str.len(config.data_dir)<1{
    log.error("boot: data_dir is required";"startup";cid);
    <$loke_err.$config_err("config stage failed: data_dir must not be empty")
  };

  log.info("boot: config valid";"startup";cid);
  log_boot_summary(config;cid);
  log.info("boot: ready";"startup";cid);

  <config
}

pub f=shutdown_sequence(cid:str):void{
  log.info("shutdown: draining in-flight requests";"startup";cid);
  log.info("shutdown: closing database";"startup";cid);
  log.info("shutdown: cleanup done";"startup";cid);
  <()
}

pub f=log_boot_summary(config:$loke_config;cid:str):void{
  log.info(str.concat("boot summary — port: ";str.from_int(config.port));"startup";cid);
  log.info(str.concat("boot summary — data_dir: ";config.data_dir);"startup";cid);
  log.info(str.concat("boot summary — ollama_url: ";config.ollama_url);"startup";cid);
  log.info(str.concat("boot summary — default_provider: ";config.default_provider);"startup";cid);
  <()
}
