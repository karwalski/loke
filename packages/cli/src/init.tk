// A2.5a — loke init — environment setup

i=t:shared.types;
i=log:shared.log;
i=out:cli.output;
i=file:std.file;
i=str:std.str;
i=http:std.http;
i=env:std.env;

pub m.$init_result{
  shell_profile_updated:bool;
  config_dir_created:bool;
  ollama_found:bool;
  errors:@(str)
}

pub f=detect_shell():str{
  let shell_env=env.get("SHELL")|{
    $ok:v v;
    $err:e ""
  };
  if str.ends_with(shell_env;"zsh"){
    <"zsh"
  };
  if str.ends_with(shell_env;"bash"){
    <"bash"
  };
  <"unknown"
}

pub f=profile_path(shell:str):str{
  if str.eq(shell;"zsh"){
    <"~/.zshrc"
  };
  if str.eq(shell;"bash"){
    <"~/.bashrc"
  };
  <"~/.profile"
}

pub f=loke_shell_snippet():str{
  <str.concat(
    "\n# loke — local intelligence layer\n";
    str.concat(
      "export LOKE_HOME=\"$HOME/.loke\"\n";
      str.concat(
        "export PATH=\"$LOKE_HOME/bin:$PATH\"\n";
        "alias loke-proxy='loke proxy'\n"
      )
    )
  )
}

pub f=run(data_dir:str):$init_result{
  let errors=@();
  let config_dir_created=false;
  let shell_profile_updated=false;
  let ollama_found=false;

  let loke_dir="~/.loke";
  let loke_bin_dir="~/.loke/bin";

  let mkdir_result=file.mkdir(loke_dir)|{
    $ok:v{
      let config_dir_created=true
    };
    $err:e{
      let errors=@(errors;str.concat("could not create config dir: ";e))
    }
  };

  let mkdir_bin_result=file.mkdir(loke_bin_dir)|{
    $ok:v ();
    $err:e{
      let errors=@(errors;str.concat("could not create bin dir: ";e))
    }
  };

  let shell=detect_shell();
  let prof=profile_path(shell);
  let snippet=loke_shell_snippet();

  let profile_result=file.read(prof)|{
    $ok:existing{
      if str.contains(existing;"LOKE_HOME"){
        let shell_profile_updated=false
      };
      if str.eq(str.contains_to_str(existing;"LOKE_HOME");"false"){
        let write_result=file.append(prof;snippet)|{
          $ok:v{
            let shell_profile_updated=true
          };
          $err:e{
            let errors=@(errors;str.concat("could not update shell profile: ";e))
          }
        }
      }
    };
    $err:e{
      let errors=@(errors;str.concat("could not read shell profile: ";e))
    }
  };

  let ollama_result=http.get("http://localhost:11434/api/tags")|{
    $ok:resp{
      if resp.status==200{
        let ollama_found=true
      }
    };
    $err:e{
      let ollama_found=false
    }
  };

  let tick="✓";
  let cross="✗";

  let dir_icon=if config_dir_created{ tick } else { cross };
  out.print_line(str.concat(dir_icon;" Config dir: ~/.loke/"));

  let prof_icon=if shell_profile_updated{ tick } else { cross };
  out.print_line(
    str.concat(
      prof_icon;
      str.concat(" Shell profile: ";prof)
    )
  );

  let ol_icon=if ollama_found{ tick } else { cross };
  out.print_line(str.concat(ol_icon;" Ollama: "));

  if ollama_found{
    out.print_line("    Ollama is running at http://localhost:11434")
  };

  if str.eq(ol_icon;cross){
    out.print_line("    Ollama not found — run: ollama serve")
  };

  <$init_result{
    shell_profile_updated:shell_profile_updated;
    config_dir_created:config_dir_created;
    ollama_found:ollama_found;
    errors:errors
  }
}

pub f=usage():str{
  <str.concat(
    "Usage: loke init\n";
    str.concat(
      "\n";
      str.concat(
        "Sets up loke for the current shell:\n";
        str.concat(
          "  - Creates ~/.loke/ and ~/.loke/bin/\n";
          str.concat(
            "  - Adds LOKE_HOME and PATH entry to your shell profile\n";
            "  - Checks that Ollama is running\n"
          )
        )
      )
    )
  )
}
