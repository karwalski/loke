// F1.3 — CLI command definitions and parser

i=str:std.str;

pub m.$command{
  $ask(str);
  $pipeline(str);
  $queue_list;
  $queue_cancel(str);
  $models_list;
  $models_recommend;
  $memory_search(str);
  $agents_list;
  $overnight_status;
  $doctor;
  $version;
  $help;
  $unknown(str)
}

pub f=parse(args:@(str)):$command{
  let argc=str.len(args);
  if argc<2{
    <$command.$help
  };
  let sub=args[1];
  if str.eq(sub;"--version"){
    <$command.$version
  };
  if str.eq(sub;"help"){
    <$command.$help
  };
  if str.eq(sub;"doctor"){
    <$command.$doctor
  };
  if str.eq(sub;"ask"){
    if argc<3{
      <$command.$unknown("usage: loke ask \"<prompt>\"")
    };
    <$command.$ask(args[2])
  };
  if str.eq(sub;"pipeline"){
    if argc<3{
      <$command.$unknown("usage: loke pipeline \"<prompt>\"")
    };
    <$command.$pipeline(args[2])
  };
  if str.eq(sub;"queue"){
    if argc<3{
      <$command.$unknown("usage: loke queue <list|cancel <id>>")
    };
    let action=args[2];
    if str.eq(action;"list"){
      <$command.$queue_list
    };
    if str.eq(action;"cancel"){
      if argc<4{
        <$command.$unknown("usage: loke queue cancel <id>")
      };
      <$command.$queue_cancel(args[3])
    };
    <$command.$unknown(str.concat("unknown queue action: ";action))
  };
  if str.eq(sub;"models"){
    if argc<3{
      <$command.$unknown("usage: loke models <list|recommend>")
    };
    let action=args[2];
    if str.eq(action;"list"){
      <$command.$models_list
    };
    if str.eq(action;"recommend"){
      <$command.$models_recommend
    };
    <$command.$unknown(str.concat("unknown models action: ";action))
  };
  if str.eq(sub;"memory"){
    if argc<3{
      <$command.$unknown("usage: loke memory search \"<query>\"")
    };
    let action=args[2];
    if str.eq(action;"search"){
      if argc<4{
        <$command.$unknown("usage: loke memory search \"<query>\"")
      };
      <$command.$memory_search(args[3])
    };
    <$command.$unknown(str.concat("unknown memory action: ";action))
  };
  if str.eq(sub;"agents"){
    if argc<3{
      <$command.$unknown("usage: loke agents <list>")
    };
    let action=args[2];
    if str.eq(action;"list"){
      <$command.$agents_list
    };
    <$command.$unknown(str.concat("unknown agents action: ";action))
  };
  if str.eq(sub;"overnight"){
    if argc<3{
      <$command.$unknown("usage: loke overnight <status>")
    };
    let action=args[2];
    if str.eq(action;"status"){
      <$command.$overnight_status
    };
    <$command.$unknown(str.concat("unknown overnight action: ";action))
  };
  <$command.$unknown(str.concat("unknown command: ";sub))
}

pub f=usage():str{
  <str.concat(
    "loke — local-first privacy proxy for LLM traffic\n";
    str.concat(
      "\n";
      str.concat(
        "Usage:\n";
        str.concat(
          "  loke ask \"<prompt>\"           send a prompt through the privacy pipeline\n";
          str.concat(
            "  loke pipeline \"<prompt>\"      show pipeline stages for a prompt\n";
            str.concat(
              "  loke queue list                list queued background jobs\n";
              str.concat(
                "  loke queue cancel <id>         cancel a queued job by id\n";
                str.concat(
                  "  loke models list               list available local models\n";
                  str.concat(
                    "  loke models recommend          recommend models for your hardware\n";
                    str.concat(
                      "  loke memory search \"<query>\"   search memory palace\n";
                      str.concat(
                        "  loke agents list               list registered agents\n";
                        str.concat(
                          "  loke overnight status          show overnight job status\n";
                          str.concat(
                            "  loke doctor                    run health check on all subsystems\n";
                            str.concat(
                              "  loke --version                 print version\n";
                              "  loke help                      show this help\n"
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    )
  )
}
