// A2.5b — loke doctor — health diagnostics

i=t:shared.types;
i=out:cli.output;
i=http:std.http;
i=str:std.str;
i=log:shared.log;
i=file:std.file;

pub m.$check{
  name:str;
  ok:bool;
  detail:str;
  fix:str
}

pub f=check_ollama():$check{
  let result=http.get("http://localhost:11434/api/tags")|{
    $ok:resp{
      if resp.status==200{
        <$check{
          name:"Ollama";
          ok:true;
          detail:"running at http://localhost:11434";
          fix:""
        }
      };
      <$check{
        name:"Ollama";
        ok:false;
        detail:str.concat("unexpected status: ";str.int_to_str(resp.status));
        fix:"Run: ollama serve"
      }
    };
    $err:e{
      <$check{
        name:"Ollama";
        ok:false;
        detail:"not reachable";
        fix:"Run: ollama serve"
      }
    }
  };
  <result
}

pub f=check_presidio():$check{
  let result=http.get("http://localhost:5001/health")|{
    $ok:resp{
      if resp.status==200{
        <$check{
          name:"Presidio";
          ok:true;
          detail:"running at http://localhost:5001";
          fix:""
        }
      };
      <$check{
        name:"Presidio";
        ok:false;
        detail:str.concat("unexpected status: ";str.int_to_str(resp.status));
        fix:"Run: docker run -p 5001:3000 mcr.microsoft.com/presidio-analyzer"
      }
    };
    $err:e{
      <$check{
        name:"Presidio";
        ok:false;
        detail:"not reachable";
        fix:"Run: docker run -p 5001:3000 mcr.microsoft.com/presidio-analyzer"
      }
    }
  };
  <result
}

pub f=check_llmlingua():$check{
  let result=http.get("http://localhost:8000/health")|{
    $ok:resp{
      if resp.status==200{
        <$check{
          name:"LLMLingua";
          ok:true;
          detail:"running at http://localhost:8000";
          fix:""
        }
      };
      <$check{
        name:"LLMLingua";
        ok:false;
        detail:str.concat("unexpected status: ";str.int_to_str(resp.status));
        fix:"Run: pip install llmlingua && python -m llmlingua.server"
      }
    };
    $err:e{
      <$check{
        name:"LLMLingua";
        ok:false;
        detail:"not reachable";
        fix:"Run: pip install llmlingua && python -m llmlingua.server"
      }
    }
  };
  <result
}

pub f=check_data_dir():$check{
  let exists=file.exists("~/.loke")|{
    $ok:v v;
    $err:e false
  };
  if exists{
    <$check{
      name:"Data dir";
      ok:true;
      detail:"~/.loke/ exists";
      fix:""
    }
  };
  <$check{
    name:"Data dir";
    ok:false;
    detail:"~/.loke/ not found";
    fix:"Run: loke init"
  }
}

pub f=check_config():$check{
  let exists=file.exists("~/.loke/config.toml")|{
    $ok:v v;
    $err:e false
  };
  if exists{
    <$check{
      name:"Config";
      ok:true;
      detail:"~/.loke/config.toml exists";
      fix:""
    }
  };
  <$check{
    name:"Config";
    ok:false;
    detail:"~/.loke/config.toml not found";
    fix:"Run: loke init"
  }
}

pub f=run_all():@($check){
  let ollama=check_ollama();
  let presidio=check_presidio();
  let llmlingua=check_llmlingua();
  let data_dir=check_data_dir();
  let config=check_config();
  <@(ollama;presidio;llmlingua;data_dir;config)
}

pub f=format_report(checks:@($check)):str{
  let total=str.len(checks);
  let passed=0;
  let i=0;
  let report="";
  loop i<total{
    let c=checks[i];
    let icon=if c.ok{ "✓" } else { "✗" };
    let line=str.concat(
      icon;
      str.concat(
        " ";
        str.concat(
          c.name;
          str.concat(
            ": ";
            str.concat(c.detail;"\n")
          )
        )
      )
    );
    let report=str.concat(report;line);
    if c.ok{
      let passed=passed+1
    };
    if str.eq(c.ok_str;"false"){
      if str.eq(c.fix;""){
        ()
      };
      let fix_line=str.concat("    fix: ";str.concat(c.fix;"\n"));
      let report=str.concat(report;fix_line)
    };
    let i=i+1
  };
  let summary=str.concat(
    str.int_to_str(passed);
    str.concat(
      "/";
      str.concat(
        str.int_to_str(total);
        " checks passed\n"
      )
    )
  );
  <str.concat(report;summary)
}

pub f=run():i32{
  let checks=run_all();
  let report=format_report(checks);
  out.print_line(report);
  let total=str.len(checks);
  let passed=0;
  let i=0;
  loop i<total{
    let c=checks[i];
    if c.ok{
      let passed=passed+1
    };
    let i=i+1
  };
  if passed==total{
    <0
  };
  <1
}
