{! layout("base") !}
{! block("title") !}loke — pipeline{! end !}
{! block("content") !}

<style>
  .pipeline-flow {
    display: flex;
    align-items: stretch;
    gap: 0;
    overflow-x: auto;
    margin-bottom: 24px;
  }
  .pipeline-stage-card {
    flex: 1;
    min-width: 130px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
  }
  .pipeline-stage-card:first-child { border-radius: 10px 0 0 10px; }
  .pipeline-stage-card:last-child  { border-radius: 0 10px 10px 0; }
  .pipeline-stage-card + .pipeline-stage-card { border-left: none; }
  .pipeline-stage-card .stage-name {
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
  }
  .pipeline-stage-card .stage-arrow {
    position: absolute;
    right: -10px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 16px;
    color: var(--border);
    z-index: 1;
  }
  .pipeline-stage-card:last-child .stage-arrow { display: none; }
  .stage-meta { font-size: 0.8em; color: var(--muted); }
  .stage-meta span { display: block; }
  .page-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .page-actions h2 {
    font-size: 1.05em;
    font-weight: 600;
    color: var(--text);
  }
  .btn {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 7px 18px;
    font-size: 0.85em;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn:hover { opacity: 0.85; }
  .live-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85em;
  }
  .live-table th {
    text-align: left;
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    padding: 8px 10px;
    border-bottom: 1px solid var(--border);
  }
  .live-table td {
    padding: 10px 10px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    vertical-align: middle;
  }
  .live-table tr:last-child td { border-bottom: none; }
  .live-table tr:hover td { background: rgba(255,255,255,0.02); }
  .privacy-tag {
    display: inline-block;
    font-size: 0.75em;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    background: rgba(245,158,11,.15);
    color: var(--amber);
  }
  .privacy-tag.clean {
    background: rgba(34,197,94,.12);
    color: var(--green);
  }
</style>

<div class="page-actions">
  <h2>Pipeline visibility</h2>
  <button class="btn" onclick="window.location.reload()">Refresh</button>
</div>

<div class="pipeline-flow">

  <div class="pipeline-stage-card">
    <div class="stage-name">Privacy Filter</div>
    <span class="badge badge-green">active</span>
    <div class="stage-meta">
      <span>Last request: 12s ago</span>
      <span>Avg latency: 18 ms</span>
      <span>Requests today: 142</span>
    </div>
    <span class="stage-arrow">&#x276F;</span>
  </div>

  <div class="pipeline-stage-card">
    <div class="stage-name">Token Optimiser</div>
    <span class="badge badge-green">active</span>
    <div class="stage-meta">
      <span>Last request: 12s ago</span>
      <span>Avg latency: 34 ms</span>
      <span>Requests today: 142</span>
    </div>
    <span class="stage-arrow">&#x276F;</span>
  </div>

  <div class="pipeline-stage-card">
    <div class="stage-name">Governance Gateway</div>
    <span class="badge badge-green">active</span>
    <div class="stage-meta">
      <span>Last request: 12s ago</span>
      <span>Avg latency: 5 ms</span>
      <span>Requests today: 142</span>
    </div>
    <span class="stage-arrow">&#x276F;</span>
  </div>

  <div class="pipeline-stage-card">
    <div class="stage-name">LLM Router</div>
    <span class="badge badge-green">active</span>
    <div class="stage-meta">
      <span>Last request: 12s ago</span>
      <span>Avg latency: 2 ms</span>
      <span>Requests today: 142</span>
    </div>
    <span class="stage-arrow">&#x276F;</span>
  </div>

  <div class="pipeline-stage-card">
    <div class="stage-name">Provider Dispatcher</div>
    <span class="badge badge-amber">idle</span>
    <div class="stage-meta">
      <span>Last request: 12s ago</span>
      <span>Avg latency: 1 240 ms</span>
      <span>Requests today: 142</span>
    </div>
    <span class="stage-arrow">&#x276F;</span>
  </div>

  <div class="pipeline-stage-card">
    <div class="stage-name">Response Restoration</div>
    <span class="badge badge-green">active</span>
    <div class="stage-meta">
      <span>Last request: 12s ago</span>
      <span>Avg latency: 8 ms</span>
      <span>Requests today: 142</span>
    </div>
  </div>

</div>

