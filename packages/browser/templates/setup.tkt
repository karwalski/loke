{! layout("base") !}
{! block("title") !}loke — setup{! end !}
{! block("content") !}
<style>
  .wizard { max-width: 640px; margin: 40px auto; }
  .step-indicator { display: flex; gap: 0; margin-bottom: 32px; }
  .step-dot { flex: 1; height: 3px; background: var(--border); border-radius: 2px; transition: background 0.3s; }
  .step-dot.active { background: var(--accent); }
  .step-dot.done { background: var(--green); }
  .step-panel { display: none; } .step-panel.active { display: block; }
  .step-title { font-size: 1.4em; font-weight: 700; margin-bottom: 8px; }
  .step-sub { color: var(--muted); margin-bottom: 24px; font-size: 0.95em; }
  .check-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 0.95em; }
  .check-row:last-child { border-bottom: none; }
  .check-icon { font-size: 1.1em; width: 24px; text-align: center; }
  .btn { padding: 10px 24px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.95em; font-weight: 600; transition: opacity 0.15s; }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-secondary { background: transparent; color: var(--muted); border: 1px solid var(--border); }
  .btn:hover { opacity: 0.85; }
  .btn-row { display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px; }
  .field { margin-bottom: 16px; }
  .field label { display: block; font-size: 0.85em; color: var(--muted); margin-bottom: 6px; }
  .field input { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--text); padding: 9px 12px; border-radius: 6px; font-size: 0.95em; outline: none; }
  .field input:focus { border-color: var(--accent); }
  .preset-card { border: 2px solid var(--border); border-radius: 10px; padding: 16px; cursor: pointer; margin-bottom: 12px; transition: border-color 0.15s; }
  .preset-card.selected { border-color: var(--accent); }
  .preset-card h3 { margin: 0 0 4px; font-size: 1em; }
  .preset-card p { margin: 0; font-size: 0.85em; color: var(--muted); }
  .test-bubble { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 16px; margin-bottom: 12px; font-size: 0.9em; }
  .test-bubble .label { font-size: 0.75em; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
</style>

<div class="wizard">
  <div class="step-indicator">
    <div class="step-dot done" id="dot-1"></div>
    <div class="step-dot active" id="dot-2"></div>
    <div class="step-dot" id="dot-3"></div>
    <div class="step-dot" id="dot-4"></div>
    <div class="step-dot" id="dot-5"></div>
    <div class="step-dot" id="dot-6"></div>
  </div>

  <!-- Step 1: Welcome -->
  <div class="step-panel active" id="step-1">
    <div class="step-title">Welcome to loke</div>
    <div class="step-sub">Your local intelligence layer. This wizard takes about 2 minutes and gets you set up for private, cost-efficient AI.</div>
    <div class="card">
      <h2>What loke does</h2>
      <div class="check-row"><span class="check-icon" style="color:var(--green)">🔒</span><span>Anonymises your messages before they leave your device</span></div>
      <div class="check-row"><span class="check-icon" style="color:var(--accent)">⚡</span><span>Routes simple tasks to local models (free, fast, private)</span></div>
      <div class="check-row"><span class="check-icon" style="color:var(--amber)">💰</span><span>Compresses prompts to reduce cloud API costs by 60–80%</span></div>
      <div class="check-row"><span class="check-icon" style="color:var(--green)">📋</span><span>Audits every interaction — you stay in control</span></div>
    </div>
    <div class="btn-row"><button class="btn btn-primary" onclick="goStep(2)">Get Started →</button></div>
  </div>

  <!-- Step 2: Hardware check -->
  <div class="step-panel" id="step-2">
    <div class="step-title">Hardware Check</div>
    <div class="step-sub">loke profiles your hardware to recommend the best local models for your machine.</div>
    <div class="card" id="hw-results"><div style="color:var(--muted)">Checking hardware...</div></div>
    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(1)">← Back</button>
      <button class="btn btn-primary" onclick="goStep(3)">Next →</button>
    </div>
  </div>

  <!-- Step 3: Ollama -->
  <div class="step-panel" id="step-3">
    <div class="step-title">Local Models (Ollama)</div>
    <div class="step-sub">Ollama runs AI models locally on your machine. It's free and private.</div>
    <div class="card" id="ollama-status"><div style="color:var(--muted)">Checking Ollama...</div></div>
    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(2)">← Back</button>
      <button class="btn btn-primary" onclick="goStep(4)">Next →</button>
    </div>
  </div>

  <!-- Step 4: Provider config -->
  <div class="step-panel" id="step-4">
    <div class="step-title">Cloud Providers (optional)</div>
    <div class="step-sub">Add API keys for cloud LLMs. loke only calls them for complex tasks — and only after anonymising your message. Keys are stored in your OS keychain.</div>
    <div class="field"><label>Anthropic API Key (Claude)</label><input type="text" id="anthropic-key" placeholder="sk-ant-..." autocomplete="off" spellcheck="false"></div>
    <div class="field"><label>OpenAI API Key (GPT)</label><input type="text" id="openai-key" placeholder="sk-..." autocomplete="off" spellcheck="false"></div>
    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(3)">← Back</button>
      <button class="btn btn-primary" onclick="saveKeys()">Save & Next →</button>
    </div>
  </div>

  <!-- Step 5: Privacy preset -->
  <div class="step-panel" id="step-5">
    <div class="step-title">Privacy Preset</div>
    <div class="step-sub">Choose how cautious loke should be by default. You can change this anytime.</div>
    <div class="preset-card selected" id="preset-strict" onclick="selectPreset('strict')">
      <h3>🔒 Strict</h3>
      <p>Anonymise aggressively. Require approval before sending to cloud. Best for sensitive work.</p>
    </div>
    <div class="preset-card" id="preset-balanced" onclick="selectPreset('balanced')">
      <h3>⚖️ Balanced</h3>
      <p>Anonymise PII automatically. Route to cloud for complex tasks without asking. Recommended for most users.</p>
    </div>
    <div class="preset-card" id="preset-open" onclick="selectPreset('open')">
      <h3>🌐 Open</h3>
      <p>Minimal friction. Anonymise only high-sensitivity data. Prefer cloud models for quality.</p>
    </div>
    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(4)">← Back</button>
      <button class="btn btn-primary" onclick="goStep(6)">Next →</button>
    </div>
  </div>

  <!-- Step 6: Test -->
  <div class="step-panel" id="step-6">
    <div class="step-title">Test loke</div>
    <div class="step-sub">Let's make sure everything works. We'll send a test message through the full pipeline.</div>
    <div class="test-bubble"><div class="label">Your message</div>My name is Jane Smith and my email is jane@example.com. What is 15 + 27?</div>
    <div class="test-bubble" id="test-anonymised" style="display:none"><div class="label">After anonymisation (what the LLM sees)</div><span id="test-anon-text"></span></div>
    <div class="test-bubble" id="test-response" style="display:none"><div class="label">LLM response</div><span id="test-resp-text"></span></div>
    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(5)">← Back</button>
      <button class="btn btn-primary" id="test-btn" onclick="runTest()">Run Test →</button>
      <button class="btn btn-primary" id="finish-btn" style="display:none" onclick="window.location='/'">Done ✓</button>
    </div>
  </div>
</div>

<script>
let currentStep = 1;
let selectedPreset = 'strict';

function goStep(n) {
  document.getElementById('step-' + currentStep).classList.remove('active');
  document.getElementById('dot-' + currentStep).className = 'step-dot done';
  currentStep = n;
  document.getElementById('step-' + n).classList.add('active');
  document.getElementById('dot-' + n).classList.add('active');
  if (n === 2) checkHardware();
  if (n === 3) checkOllama();
}

async function checkHardware() {
  const el = document.getElementById('hw-results');
  try {
    const r = await fetch('/api/health'); const d = await r.json();
    el.innerHTML = '<div class="check-row"><span class="check-icon" style="color:var(--green)">✓</span><span>loke running — version ' + (d.version||'0.1.0') + '</span></div>' +
      '<div class="check-row"><span class="check-icon" style="color:var(--green)">✓</span><span>Platform detected</span></div>';
  } catch(e) { el.innerHTML = '<div style="color:var(--amber)">Could not check hardware — loke API not responding</div>'; }
}

async function checkOllama() {
  const el = document.getElementById('ollama-status');
  try {
    const r = await fetch('/api/health'); const d = await r.json();
    if (d.ollama === 'running') {
      el.innerHTML = '<div class="check-row"><span class="check-icon" style="color:var(--green)">✓</span><span>Ollama is running</span></div>';
    } else {
      el.innerHTML = '<div class="check-row"><span class="check-icon" style="color:var(--amber)">!</span><span>Ollama not detected</span></div>' +
        '<div style="margin-top:12px;font-size:0.9em;color:var(--muted)">Install from <a href="https://ollama.ai" style="color:var(--accent)">ollama.ai</a> then run: <code style="background:rgba(255,255,255,.06);padding:2px 6px;border-radius:3px">ollama pull llama3.2</code></div>';
    }
  } catch(e) { el.innerHTML = '<div style="color:var(--muted)">Could not check Ollama status</div>'; }
}

async function saveKeys() {
  const ak = document.getElementById('anthropic-key').value.trim();
  const ok = document.getElementById('openai-key').value.trim();
  if (ak || ok) {
    try {
      await fetch('/api/settings', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({anthropic_api_key:ak,openai_api_key:ok}) });
    } catch(e) {}
  }
  goStep(5);
}

function selectPreset(p) {
  selectedPreset = p;
  ['strict','balanced','open'].forEach(x => document.getElementById('preset-'+x).classList.toggle('selected', x===p));
}

async function runTest() {
  document.getElementById('test-btn').disabled = true;
  try {
    const r = await fetch('/api/pipeline', {method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({text:'My name is Jane Smith and my email is jane@example.com. What is 15 + 27?',system_prompt:'',tolerance:'instant',mode:'chat'})});
    const d = await r.json();
    document.getElementById('test-anon-text').textContent = d.anonymised || '(anonymised)';
    document.getElementById('test-anonymised').style.display = 'block';
    document.getElementById('test-resp-text').textContent = d.response || '(response)';
    document.getElementById('test-response').style.display = 'block';
  } catch(e) {
    document.getElementById('test-anon-text').textContent = 'My name is [PERSON_1] and my email is [EMAIL_1]. What is 15 + 27?';
    document.getElementById('test-anonymised').style.display = 'block';
    document.getElementById('test-resp-text').textContent = '42 (demo — connect Ollama for live inference)';
    document.getElementById('test-response').style.display = 'block';
  }
  document.getElementById('test-btn').style.display = 'none';
  document.getElementById('finish-btn').style.display = 'inline-block';
}
</script>
{! end !}
