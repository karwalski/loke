{! layout("base") !}
{! block("title") !}loke — review prompt{! end !}
{! block("content") !}
<style>
  .approve-wrap { max-width: 780px; margin: 32px auto; }
  .approve-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .approve-title { font-size: 1.2em; font-weight: 700; }
  .sensitivity-pill { font-size: 0.75em; font-weight: 700; padding: 3px 10px; border-radius: 20px; background: rgba(245,158,11,.15); color: var(--amber); border: 1px solid rgba(245,158,11,.3); }
  .diff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .diff-panel h3 { font-size: 0.8em; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 8px; }
  .diff-original { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 14px; font-size: 0.9em; line-height: 1.6; white-space: pre-wrap; min-height: 200px; }
  .diff-edit { width: 100%; background: var(--surface); border: 1px solid var(--accent); border-radius: 8px; padding: 14px; font-size: 0.9em; line-height: 1.6; font-family: inherit; color: var(--text); resize: vertical; min-height: 200px; outline: none; }
  .pii-list { margin-bottom: 16px; }
  .pii-chip { display: inline-flex; align-items: center; gap: 6px; background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.25); color: var(--amber); border-radius: 4px; padding: 2px 8px; font-size: 0.8em; margin: 2px; }
  .action-row { display: flex; gap: 12px; justify-content: flex-end; }
  .btn { padding: 10px 24px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.95em; font-weight: 600; }
  .btn-approve { background: var(--accent); color: #fff; }
  .btn-cancel { background: transparent; color: var(--red); border: 1px solid rgba(239,68,68,.4); }
  .explainer { font-size: 0.85em; color: var(--muted); margin-bottom: 16px; }
</style>

<div class="approve-wrap">
  <div class="approve-header">
    <div class="approve-title">Review Before Sending</div>
    <div class="sensitivity-pill" id="sensitivity-pill">CONFIDENTIAL</div>
  </div>
  <p class="explainer">This is exactly what will be sent to the LLM. PII has been replaced with placeholders. You can edit the anonymised version before sending.</p>

  <div class="pii-list" id="pii-list"></div>

  <div class="diff-grid">
    <div class="diff-panel">
      <h3>Original</h3>
      <div class="diff-original" id="original-text">Loading...</div>
    </div>
    <div class="diff-panel">
      <h3>Anonymised — editable</h3>
      <textarea class="diff-edit" id="anonymised-text">Loading...</textarea>
    </div>
  </div>

  <div class="action-row">
    <button class="btn btn-cancel" onclick="cancelSend()">Cancel</button>
    <button class="btn btn-approve" onclick="approveSend()">Send to LLM →</button>
  </div>
</div>

<script>
// Reads pending approval from sessionStorage (set by pipeline.js before redirect)
const pending = JSON.parse(sessionStorage.getItem('loke_pending') || '{}');

document.getElementById('original-text').textContent = pending.original || '(no content)';
document.getElementById('anonymised-text').value = pending.anonymised || '(no content)';

const pill = document.getElementById('sensitivity-pill');
const s = pending.sensitivity || 'CONFIDENTIAL';
pill.textContent = s;
if (s === 'RESTRICTED') { pill.style.background='rgba(239,68,68,.15)'; pill.style.color='var(--red)'; pill.style.borderColor='rgba(239,68,68,.3)'; }

const piiList = document.getElementById('pii-list');
if (pending.entities && pending.entities.length) {
  piiList.innerHTML = pending.entities.map(e => '<span class="pii-chip">'+e+'</span>').join('');
}

function cancelSend() {
  sessionStorage.removeItem('loke_pending');
  window.history.back();
}

async function approveSend() {
  const editedAnon = document.getElementById('anonymised-text').value;
  pending.anonymised = editedAnon;
  pending.approved = true;
  sessionStorage.setItem('loke_pending', JSON.stringify(pending));
  // Post to pipeline with approved flag
  try {
    const r = await fetch('/api/pipeline', {method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({...pending, approved:true})});
    const d = await r.json();
    sessionStorage.setItem('loke_result', JSON.stringify(d));
  } catch(e) {}
  window.location = '/';
}
</script>
{! end !}
