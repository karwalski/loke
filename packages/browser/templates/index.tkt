{! layout("base") !}
{! block("title") !}loke — status{! end !}
{! block("content") !}

<div class="card">
  <h2>Pipeline Status</h2>
  <div class="status-row">
    <span>Privacy pipeline</span>
    <span class="badge badge-green">active</span>
  </div>
  <div class="status-row">
    <span>Governance gateway</span>
    <span class="badge badge-green">active</span>
  </div>
  <div class="status-row">
    <span>LLM router</span>
    <span class="badge badge-green">active</span>
  </div>
  <div class="status-row">
    <span>Ollama (local models)</span>
    <span class="badge badge-amber">checking...</span>
  </div>
  <div class="status-row">
    <span>Memory palace</span>
    <span class="badge badge-green">active</span>
  </div>
  <div class="status-row">
    <span>Agent framework</span>
    <span class="badge badge-green">active</span>
  </div>
  <div class="status-row">
    <span>Kill switch</span>
    <span class="badge badge-green">disengaged</span>
  </div>
</div>

<div class="grid">
  <div class="card">
    <h2>Backlog</h2>
    <div class="stat">
      <div class="num">142</div>
      <div class="label">stories Done / Spec done</div>
    </div>
    <div style="margin-top:14px">
      <div class="status-row"><span>Foundation</span><code>55</code></div>
      <div class="status-row"><span>Agentic AI</span><code>8</code></div>
      <div class="status-row"><span>Memory Palace</span><code>7</code></div>
      <div class="status-row"><span>Governance</span><code>5</code></div>
    </div>
  </div>
  <div class="card">
    <h2>ooke Bindings</h2>
    <div class="status-row"><span>std.keychain</span><span class="badge badge-green">23/23</span></div>
    <div class="status-row"><span>std.infer</span><span class="badge badge-green">32/32</span></div>
    <div class="status-row"><span>std.secure_mem</span><span class="badge badge-green">37/37</span></div>
    <div class="status-row"><span>std.webview</span><span class="badge badge-green">16/16</span></div>
    <div class="status-row"><span>std.vecstore</span><span class="badge badge-green">63/63</span></div>
    <div class="status-row"><span>std.mdns</span><span class="badge badge-green">29/29</span></div>
    <div class="status-row"><span>std.tls</span><span class="badge badge-green">37/37</span></div>
  </div>
</div>

<div class="card">
  <h2>Source</h2>
  <div class="status-row"><span>Language</span><code>toke</code></div>
  <div class="status-row"><span>Framework</span><code>ooke 0.1.0</code></div>
  <div class="status-row"><span>Source files</span><code>119 .tk files</code></div>
  <div class="status-row"><span>Packages</span><code>core · shared · browser · cli · mcp-toke · mcp-broker</code></div>
  <div class="status-row"><span>API</span><code>GET /api/health · /api/models · POST /api/pipeline · /api/settings</code></div>
</div>

{! end !}
