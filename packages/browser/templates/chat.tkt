{! layout("base") !}
{! block("title") !}loke — chat{! end !}
{! block("content") !}

<style>
  /* Override base layout constraints for full-height chat */
  main { max-width: none; padding: 0; height: calc(100vh - 57px); display: flex; overflow: hidden; }

  /* Sidebar */
  .chat-sidebar {
    width: 240px; min-width: 240px; background: var(--surface); border-right: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0; overflow-y: auto;
  }
  .sidebar-section { padding: 16px 18px; border-bottom: 1px solid var(--border); }
  .sidebar-section:last-child { border-bottom: none; }
  .sidebar-label {
    font-size: 0.72em; font-weight: 600; text-transform: uppercase; letter-spacing: 0.09em;
    color: var(--muted); margin-bottom: 10px;
  }
  .model-select {
    width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); font-size: 0.88em; padding: 7px 10px; cursor: pointer; outline: none;
  }
  .model-select:focus { border-color: var(--accent); }
  .model-select optgroup { color: var(--muted); font-size: 0.85em; }
  .model-select option { color: var(--text); background: var(--surface); }

  /* Privacy pill */
  .privacy-pill {
    display: flex; align-items: center; gap: 8px; background: rgba(99,102,241,.1);
    border: 1px solid rgba(99,102,241,.25); border-radius: 6px; padding: 8px 10px;
  }
  .privacy-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .privacy-text { font-size: 0.82em; color: var(--text); line-height: 1.3; }
  .privacy-count { font-weight: 700; color: var(--accent); }

  /* Token counter */
  .token-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .token-stat { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; }
  .token-stat .t-num { font-size: 1.1em; font-weight: 700; color: var(--text); }
  .token-stat .t-label { font-size: 0.7em; color: var(--muted); margin-top: 1px; }
  .cost-row { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
  .cost-label { font-size: 0.78em; color: var(--muted); }
  .cost-value { font-size: 0.88em; font-weight: 600; color: var(--green); }

  /* New chat button */
  .btn-new-chat {
    display: block; width: 100%; padding: 9px 14px; background: var(--accent);
    color: #fff; border: none; border-radius: 7px; font-size: 0.88em; font-weight: 600;
    cursor: pointer; text-align: center; letter-spacing: 0.01em;
  }
  .btn-new-chat:hover { opacity: 0.88; }

  /* Main chat area */
  .chat-main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

  /* Message list */
  .messages {
    flex: 1; overflow-y: auto; padding: 28px 32px; display: flex;
    flex-direction: column; gap: 20px;
  }
  .messages::-webkit-scrollbar { width: 5px; }
  .messages::-webkit-scrollbar-track { background: transparent; }
  .messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  /* Message bubbles */
  .msg { display: flex; flex-direction: column; gap: 4px; max-width: 780px; }
  .msg.user { align-self: flex-end; align-items: flex-end; }
  .msg.assistant { align-self: flex-start; align-items: flex-start; }

  .msg-meta { font-size: 0.72em; color: var(--muted); display: flex; align-items: center; gap: 6px; }
  .msg-role { font-weight: 600; }
  .msg-time { opacity: 0.7; }

  .bubble {
    padding: 12px 16px; border-radius: 12px; font-size: 0.93em; line-height: 1.65;
    white-space: pre-wrap; word-break: break-word;
  }
  .msg.user .bubble {
    background: var(--accent); color: #fff; border-bottom-right-radius: 3px;
  }
  .msg.assistant .bubble {
    background: var(--surface); border: 1px solid var(--border); color: var(--text);
    border-bottom-left-radius: 3px;
  }
  .bubble code { background: rgba(255,255,255,.1); padding: 1px 5px; border-radius: 3px; font-size: 0.9em; }
  .msg.assistant .bubble code { background: rgba(255,255,255,.06); }

  /* Feedback row (assistant only) */
  .feedback-row { display: flex; gap: 4px; margin-top: 2px; }
  .fb-btn {
    background: none; border: 1px solid var(--border); border-radius: 5px;
    color: var(--muted); font-size: 0.82em; padding: 2px 8px; cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .fb-btn:hover { border-color: var(--accent); color: var(--accent); }
  .fb-btn.active-up { border-color: var(--green); color: var(--green); }
  .fb-btn.active-down { border-color: var(--red); color: var(--red); }

  /* Typing indicator */
  .typing-indicator { display: none; align-self: flex-start; }
  .typing-indicator.visible { display: flex; }
  .typing-dots { display: flex; gap: 4px; align-items: center; padding: 12px 16px;
    background: var(--surface); border: 1px solid var(--border); border-radius: 12px; border-bottom-left-radius: 3px; }
  .typing-dots span {
    width: 6px; height: 6px; border-radius: 50%; background: var(--muted);
    animation: bounce 1.2s infinite ease-in-out;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-5px); } }

  /* Input bar */
  .input-bar {
    border-top: 1px solid var(--border); padding: 16px 24px; display: flex; gap: 10px;
    align-items: flex-end; background: var(--bg);
  }
  .input-wrap { flex: 1; position: relative; }
  .prompt-input {
    width: 100%; background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    color: var(--text); font-size: 0.93em; line-height: 1.55; padding: 11px 14px;
    resize: none; outline: none; font-family: inherit; min-height: 46px; max-height: 180px;
    overflow-y: auto;
  }
  .prompt-input:focus { border-color: var(--accent); }
  .prompt-input::placeholder { color: var(--muted); }
  .send-btn {
    background: var(--accent); border: none; border-radius: 9px; color: #fff;
    font-size: 0.9em; font-weight: 600; padding: 11px 20px; cursor: pointer;
    white-space: nowrap; align-self: flex-end;
  }
  .send-btn:hover { opacity: 0.88; }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .input-hint { font-size: 0.72em; color: var(--muted); margin-top: 5px; }

  /* Empty state */
  .empty-state {
    flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 10px; color: var(--muted);
  }
  .empty-state h3 { font-size: 1.05em; font-weight: 600; color: var(--text); }
  .empty-state p { font-size: 0.85em; text-align: center; max-width: 320px; line-height: 1.5; }
  .suggestion-chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 6px; }
  .chip {
    background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
    padding: 6px 14px; font-size: 0.82em; color: var(--text); cursor: pointer;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }

  /* Error toast */
  .error-toast {
    display: none; background: rgba(239,68,68,.12); border: 1px solid rgba(239,68,68,.3);
    border-radius: 7px; padding: 10px 14px; margin: 0 32px 12px; font-size: 0.85em;
    color: var(--red);
  }
  .error-toast.visible { display: block; }
</style>

<div class="chat-sidebar">
  <div class="sidebar-section">
    <button class="btn-new-chat" onclick="newChat()">+ New chat</button>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Model</div>
    <select class="model-select" id="model-select">
      <optgroup label="Local (Ollama)">
        <option value="ollama/llama3.2:3b">llama3.2:3b</option>
        <option value="ollama/qwen2.5:0.5b">qwen2.5:0.5b</option>
        <option value="ollama/mistral:7b">mistral:7b</option>
        <option value="ollama/phi3:mini">phi3:mini</option>
      </optgroup>
      <optgroup label="Cloud — Anthropic">
        <option value="anthropic/claude-3-5-haiku-20241022" selected>claude-3-5-haiku</option>
        <option value="anthropic/claude-3-5-sonnet-20241022">claude-3-5-sonnet</option>
      </optgroup>
      <optgroup label="Cloud — OpenAI">
        <option value="openai/gpt-4o-mini">gpt-4o-mini</option>
        <option value="openai/gpt-4o">gpt-4o</option>
      </optgroup>
    </select>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Privacy</div>
    <div class="privacy-pill">
      <div class="privacy-dot"></div>
      <div class="privacy-text">
        <span class="privacy-count" id="entity-count">0</span> entities anonymised this session
      </div>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Tokens</div>
    <div class="token-grid">
      <div class="token-stat">
        <div class="t-num" id="tokens-in">0</div>
        <div class="t-label">prompt</div>
      </div>
      <div class="token-stat">
        <div class="t-num" id="tokens-out">0</div>
        <div class="t-label">response</div>
      </div>
    </div>
    <div class="cost-row">
      <span class="cost-label">Running cost</span>
      <span class="cost-value" id="running-cost">$0.0000</span>
    </div>
  </div>
</div>

<div class="chat-main">
  <div class="messages" id="messages">
    <div class="empty-state" id="empty-state">
      <h3>What can I help you with?</h3>
      <p>Your prompts pass through loke's privacy filter before reaching the model. Sensitive entities are anonymised automatically.</p>
      <div class="suggestion-chips">
        <div class="chip" onclick="useChip(this)">Summarise this document</div>
        <div class="chip" onclick="useChip(this)">Draft an email</div>
        <div class="chip" onclick="useChip(this)">Explain this code</div>
        <div class="chip" onclick="useChip(this)">Review my writing</div>
      </div>
    </div>
  </div>

  <div class="typing-indicator" id="typing-indicator">
    <div class="typing-dots">
      <span></span><span></span><span></span>
    </div>
  </div>

  <div class="error-toast" id="error-toast"></div>

  <div class="input-bar">
    <div class="input-wrap">
      <textarea
        class="prompt-input"
        id="prompt-input"
        rows="1"
        placeholder="Message loke… (Shift+Enter for newline)"
      ></textarea>
      <div class="input-hint">Privacy filter active · responses restored before display</div>
    </div>
    <button class="send-btn" id="send-btn" onclick="sendMessage()">Send</button>
  </div>
</div>

<script>
  // ── State ────────────────────────────────────────────────────────────────
  let messages = [];
  let tokensIn = 0;
  let tokensOut = 0;
  let runningCostUsd = 0;
  let entityCount = 0;
  let isStreaming = false;
  let msgId = 0;

  // Cost per 1k tokens (rough estimates for sidebar counter)
  const COST_PER_1K = {
    'ollama/llama3.2:3b':              0,
    'ollama/qwen2.5:0.5b':             0,
    'ollama/mistral:7b':               0,
    'ollama/phi3:mini':                0,
    'anthropic/claude-3-5-haiku-20241022': 0.00025,
    'anthropic/claude-3-5-sonnet-20241022': 0.003,
    'openai/gpt-4o-mini':              0.00015,
    'openai/gpt-4o':                   0.005,
  };

  // ── DOM helpers ──────────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);

  function scrollToBottom() {
    const el = $('messages');
    el.scrollTop = el.scrollHeight;
  }

  function formatTime(date) {
    return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  function showEmpty(visible) {
    $('empty-state').style.display = visible ? 'flex' : 'none';
  }

  function showError(msg) {
    const el = $('error-toast');
    el.textContent = msg;
    el.classList.add('visible');
    setTimeout(() => el.classList.remove('visible'), 5000);
  }

  function setStreaming(active) {
    isStreaming = active;
    $('send-btn').disabled = active;
    $('typing-indicator').classList.toggle('visible', active);
    if (!active) scrollToBottom();
  }

  // ── Token / cost tracking ────────────────────────────────────────────────
  function addTokens(inToks, outToks) {
    tokensIn += inToks;
    tokensOut += outToks;
    const model = $('model-select').value;
    const rate = COST_PER_1K[model] || 0;
    runningCostUsd += (outToks / 1000) * rate + (inToks / 1000) * (rate * 0.3);
    $('tokens-in').textContent = tokensIn.toLocaleString();
    $('tokens-out').textContent = tokensOut.toLocaleString();
    $('running-cost').textContent = '$' + runningCostUsd.toFixed(4);
  }

  function addEntities(n) {
    entityCount += n;
    $('entity-count').textContent = entityCount;
  }

  // ── Render a message bubble ──────────────────────────────────────────────
  function appendBubble(role, text, id) {
    showEmpty(false);
    const wrap = document.createElement('div');
    wrap.className = 'msg ' + role;
    wrap.dataset.id = id;

    const meta = document.createElement('div');
    meta.className = 'msg-meta';
    meta.innerHTML = `<span class="msg-role">${role === 'user' ? 'You' : 'loke'}</span>
                      <span class="msg-time">${formatTime(new Date())}</span>`;

    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.id = 'bubble-' + id;
    bubble.textContent = text;

    wrap.appendChild(meta);
    wrap.appendChild(bubble);

    if (role === 'assistant') {
      const fbRow = document.createElement('div');
      fbRow.className = 'feedback-row';
      fbRow.innerHTML = `
        <button class="fb-btn" title="Helpful" onclick="feedback(${id},'up',this)">&#128077;</button>
        <button class="fb-btn" title="Not helpful" onclick="feedback(${id},'down',this)">&#128078;</button>`;
      wrap.appendChild(fbRow);
    }

    $('messages').appendChild(wrap);
    scrollToBottom();
    return bubble;
  }

  // ── Feedback ─────────────────────────────────────────────────────────────
  function feedback(id, direction, btn) {
    const row = btn.closest('.feedback-row');
    row.querySelectorAll('.fb-btn').forEach(b => b.classList.remove('active-up', 'active-down'));
    btn.classList.add(direction === 'up' ? 'active-up' : 'active-down');
    // POST feedback to pipeline API (fire-and-forget)
    fetch('/api/pipeline/feedback', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message_id: id, rating: direction }),
    }).catch(() => {});
  }

  // ── Send / stream ─────────────────────────────────────────────────────────
  async function sendMessage() {
    if (isStreaming) return;
    const input = $('prompt-input');
    const prompt = input.value.trim();
    if (!prompt) return;

    const model = $('model-select').value;
    input.value = '';
    input.style.height = 'auto';

    const userMsgId = ++msgId;
    appendBubble('user', prompt, userMsgId);
    messages.push({ role: 'user', content: prompt });

    setStreaming(true);

    const asstMsgId = ++msgId;
    let asstBubble = null;
    let fullText = '';

    try {
      const res = await fetch('/api/pipeline', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt, model, history: messages.slice(-10) }),
      });

      if (!res.ok) {
        const body = await res.text();
        throw new Error(`Pipeline error ${res.status}: ${body}`);
      }

      const contentType = res.headers.get('content-type') || '';

      if (contentType.includes('text/event-stream')) {
        // Streaming SSE path
        asstBubble = appendBubble('assistant', '', asstMsgId);
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop();

          for (const line of lines) {
            if (!line.startsWith('data:')) continue;
            const raw = line.slice(5).trim();
            if (raw === '[DONE]') break;
            try {
              const evt = JSON.parse(raw);
              if (evt.delta) {
                fullText += evt.delta;
                asstBubble.textContent = fullText;
                scrollToBottom();
              }
              if (evt.tokens_in)  addTokens(evt.tokens_in, 0);
              if (evt.tokens_out) addTokens(0, evt.tokens_out);
              if (evt.entities_anonymised) addEntities(evt.entities_anonymised);
            } catch (_) {}
          }
        }
      } else {
        // Non-streaming JSON path
        const data = await res.json();
        asstBubble = appendBubble('assistant', '', asstMsgId);
        fullText = data.response || data.content || JSON.stringify(data);
        asstBubble.textContent = fullText;
        if (data.tokens_in)  addTokens(data.tokens_in, 0);
        if (data.tokens_out) addTokens(0, data.tokens_out);
        if (data.entities_anonymised) addEntities(data.entities_anonymised);
      }

      messages.push({ role: 'assistant', content: fullText });

    } catch (err) {
      showError('Request failed: ' + err.message);
      if (asstBubble) asstBubble.closest('.msg').remove();
    } finally {
      setStreaming(false);
    }
  }

  // ── Suggestion chips ─────────────────────────────────────────────────────
  function useChip(chip) {
    $('prompt-input').value = chip.textContent;
    $('prompt-input').focus();
    autoResize($('prompt-input'));
  }

  // ── New chat ─────────────────────────────────────────────────────────────
  function newChat() {
    messages = [];
    tokensIn = 0; tokensOut = 0; runningCostUsd = 0; entityCount = 0;
    $('tokens-in').textContent = '0';
    $('tokens-out').textContent = '0';
    $('running-cost').textContent = '$0.0000';
    $('entity-count').textContent = '0';
    // Remove all message elements except empty-state
    const msgs = $('messages');
    Array.from(msgs.children).forEach(c => {
      if (c.id !== 'empty-state') c.remove();
    });
    showEmpty(true);
    $('prompt-input').focus();
  }

  // ── Textarea auto-resize ─────────────────────────────────────────────────
  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 180) + 'px';
  }

  $('prompt-input').addEventListener('input', function() { autoResize(this); });

  $('prompt-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // ── Init: show empty state ────────────────────────────────────────────────
  showEmpty(true);
  $('prompt-input').focus();
</script>

{! end !}
