{! layout("base") !}
{! block("title") !}loke — savings{! end !}
{! block("content") !}

<style>
  .savings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .savings-header h2 {
    font-size: 1.05em;
    font-weight: 600;
    color: var(--text);
  }
  .period-selector {
    display: flex;
    gap: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px;
  }
  .period-selector button {
    background: none;
    border: none;
    border-radius: 4px;
    padding: 5px 12px;
    font-size: 0.8em;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .period-selector button.active {
    background: var(--accent);
    color: #fff;
  }
  .period-selector button:not(.active):hover {
    background: rgba(255,255,255,0.05);
    color: var(--text);
  }
  .stat-grid-4 {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 14px;
    margin-bottom: 20px;
  }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat-card .s-label {
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
  }
  .stat-card .s-value {
    font-size: 2em;
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
  }
  .stat-card .s-sub {
    font-size: 0.78em;
    color: var(--muted);
    margin-top: 2px;
  }
  .chart-placeholder {
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 8px;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: 0.85em;
    margin-top: 4px;
  }
  .provider-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85em;
  }
  .provider-table th {
    text-align: left;
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    padding: 8px 10px;
    border-bottom: 1px solid var(--border);
  }
  .provider-table td {
    padding: 10px 10px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  .provider-table tr:last-child td { border-bottom: none; }
  .provider-table tr:hover td { background: rgba(255,255,255,0.02); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }
</style>

<div class="savings-header">
  <h2>Cost &amp; token savings</h2>
  <div class="period-selector">
    <button class="active">Today</button>
    <button>7 days</button>
    <button>30 days</button>
    <button>All time</button>
  </div>
</div>

<div class="stat-grid-4">
  <div class="stat-card">
    <div class="s-label">Tokens saved</div>
    <div class="s-value">24 810</div>
    <div class="s-sub">via cache + optimiser</div>
  </div>
  <div class="stat-card">
    <div class="s-label">Cost saved</div>
    <div class="s-value">$1.47</div>
    <div class="s-sub">USD today</div>
  </div>
  <div class="stat-card">
    <div class="s-label">Cache hit rate</div>
    <div class="s-value">38%</div>
    <div class="s-sub">semantic cache</div>
  </div>
  <div class="stat-card">
    <div class="s-label">Privacy actions</div>
    <div class="s-value">19</div>
    <div class="s-sub">entities redacted today</div>
  </div>
</div>

<div class="card">
  <h2>Token savings over time</h2>
  <div class="chart-placeholder">chart will render here</div>
</div>

<div class="card">
  <h2>Breakdown by provider</h2>
  <table class="provider-table">
    <thead>
      <tr>
        <th>Provider</th>
        <th>Requests</th>
        <th>Tokens in</th>
        <th>Tokens out</th>
        <th>Est. cost</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Anthropic</td>
        <td>61</td>
        <td>18 420</td>
        <td>5 230</td>
        <td>$0.72</td>
      </tr>
      <tr>
        <td>OpenAI</td>
        <td>38</td>
        <td>11 340</td>
        <td>3 870</td>
        <td>$0.43</td>
      </tr>
      <tr>
        <td>Ollama</td>
        <td>43</td>
        <td>9 100</td>
        <td>4 450</td>
        <td>$0.00</td>
      </tr>
    </tbody>
  </table>
</div>

<div class="two-col">

  <div class="card">
    <h2>Semantic cache</h2>
    <div class="status-row">
      <span>Total entries</span>
      <code>847</code>
    </div>
    <div class="status-row">
      <span>Hits</span>
      <code>54</code>
    </div>
    <div class="status-row">
      <span>Misses</span>
      <code>88</code>
    </div>
    <div class="status-row">
      <span>Avg similarity score</span>
      <code>0.91</code>
    </div>
  </div>

  <div class="card">
    <h2>Token optimiser</h2>
    <div class="status-row">
      <span>Compression ratio</span>
      <code>1.31x</code>
    </div>
    <div class="status-row">
      <span>Chars removed</span>
      <code>14 620</code>
    </div>
    <div class="status-row">
      <span>Avg prompt reduction</span>
      <code>24%</code>
    </div>
    <div class="status-row">
      <span>Optimised requests</span>
      <code>142</code>
    </div>
  </div>

</div>

{! end !}
