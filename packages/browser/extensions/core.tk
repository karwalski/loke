// Browser mode ooke extension — initialises the loke core engine at startup.
// Loaded once when the ooke server starts; exports accessor functions for
// pipeline config, router, and loaded config to API page handlers.

i=cfg:shared.config;
i=log:shared.log;
i=pipeline:core.privacy.pipeline;
i=router:core.router.router;
i=str:std.str;
i=gw:core.governance.gateway;
i=disp:core.providers.dispatcher;

// Module-level globals — mutated during init, then read-only at request time
let g_config=cfg.default_config();
let g_pipeline_config=pipeline.new_config(g_config.presidio_url;g_config.ollama_url);
let g_router=router.new(router.new_config(g_config.ollama_url));
let g_cid=str.rand_hex(16);
let g_gateway=$gw.gateway;
let g_dispatcher=$disp.dispatcher;
let g_api_keys=$disp.api_keys;

pub f=init(ooke_cfg:$ookecfg):void{
  // Attempt to load config from user config file; fall back to defaults on error
  let loaded=cfg.load_config("~/.loke/config.toml")|{
    $ok:v v;
    $err:_ cfg.default_config()
  };
  g_config=loaded;
  g_pipeline_config=pipeline.new_config(g_config.presidio_url;g_config.ollama_url);
  g_router=router.new(router.new_config(g_config.ollama_url));
  g_gateway=gw.new();
  g_api_keys=disp.api_keys{anthropic:"";openai:""};
  g_dispatcher=disp.new(g_api_keys;g_config.ollama_url);
  log.info("loke core initialised";"core";g_cid);
  <()
}

pub f=onshutdown():void{
  log.info("loke core shutting down";"core";g_cid);
  <()
}

pub f=get_config():$loke_config{
  <g_config
}

pub f=get_pipeline_config():$pipeline_config{
  <g_pipeline_config
}

pub f=get_router():$router{
  <g_router
}

pub f=get_gateway():$gw.gateway{ <g_gateway }
pub f=get_dispatcher():$disp.dispatcher{ <g_dispatcher }
pub f=set_api_key(provider:str;key:str):void{
  if str.eq(provider;"anthropic"){
    g_api_keys=disp.api_keys{anthropic:key;openai:g_api_keys.openai}
  }else{
    if str.eq(provider;"openai"){
      g_api_keys=disp.api_keys{anthropic:g_api_keys.anthropic;openai:key}
    }else{()}
  };
  g_dispatcher=disp.new(g_api_keys;g_config.ollama_url)
}
