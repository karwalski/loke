m=page.index;
i=http:std.http;
i=tpl:ooke.template;

f=get(req:http.$req):http.$res{
  <tpl.renderfile("templates/index.tkt"; @("page.title":"loke — status"));
}

// legacy full-SPA handler kept below (used when toke cross-package imports are available)
f=_get_spa(req:http.$req):http.$res{
  let html="<!DOCTYPE html>
<html lang=\"en\" data-theme=\"dark\">
<head>
  <meta charset=\"UTF-8\" />
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />
  <title>loke — privacy-first AI</title>
  <link rel=\"stylesheet\" href=\"/static/css/app.css\" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0d1117;
      --card:     #161b22;
      --border:   #30363d;
      --accent:   #58a6ff;
      --accent2:  #3fb950;
      --warn:     #d29922;
      --danger:   #f85149;
      --text:     #e6edf3;
      --muted:    #8b949e;
      --sidebar-w: 220px;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      font-size: 14px;
      line-height: 1.5;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Layout ──────────────────────────────────────────────────────────── */
    #app { display: flex; flex-direction: column; height: 100vh; }

    header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 20px;
      height: 52px;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    header .logo { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; color: var(--accent); }
    header .tagline { font-size: 12px; color: var(--muted); }
    header .health-badge {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--muted);
    }
    header .health-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--muted);
      transition: background 0.3s;
    }
    header .health-dot.ok   { background: var(--accent2); }
    header .health-dot.warn { background: var(--warn); }
    header .health-dot.err  { background: var(--danger); }

    .body-wrap { display: flex; flex: 1; overflow: hidden; }

    /* ── Sidebar ─────────────────────────────────────────────────────────── */
    nav {
      width: var(--sidebar-w);
      background: var(--card);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 12px 0;
      flex-shrink: 0;
    }
    nav .nav-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      padding: 16px 16px 6px;
    }
    nav button.nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px 16px;
      color: var(--muted);
      font-size: 13px;
      text-align: left;
      transition: background 0.15s, color 0.15s;
      border-radius: 0;
    }
    nav button.nav-item:hover { background: rgba(88,166,255,0.07); color: var(--text); }
    nav button.nav-item.active { color: var(--accent); background: rgba(88,166,255,0.12); }
    nav button.nav-item .icon { font-size: 16px; width: 20px; text-align: center; }

    /* ── Content area ────────────────────────────────────────────────────── */
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .panel { display: none; flex-direction: column; flex: 1; overflow: hidden; }
    .panel.active { display: flex; }

    /* ── Pipeline status bar ─────────────────────────────────────────────── */
    .pipeline-bar {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 8px 20px;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      overflow-x: auto;
    }
    .pipeline-bar .stage {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--muted);
      white-space: nowrap;
      padding: 4px 8px;
      border-radius: 4px;
      transition: color 0.2s, background 0.2s;
    }
    .pipeline-bar .stage .dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--border);
      transition: background 0.3s;
    }
    .pipeline-bar .stage.running { color: var(--accent); }
    .pipeline-bar .stage.running .dot { background: var(--accent); animation: pulse 1s infinite; }
    .pipeline-bar .stage.done { color: var(--accent2); }
    .pipeline-bar .stage.done .dot { background: var(--accent2); }
    .pipeline-bar .stage.error { color: var(--danger); }
    .pipeline-bar .stage.error .dot { background: var(--danger); }
    .pipeline-bar .sep { color: var(--border); font-size: 10px; padding: 0 2px; }

    @keyframes pulse {
      0%,100% { opacity: 1; } 50% { opacity: 0.3; }
    }

    /* ── Chat panel ──────────────────────────────────────────────────────── */
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .message {
      max-width: 780px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .message.user { align-self: flex-end; align-items: flex-end; }
    .message.assistant { align-self: flex-start; align-items: flex-start; }
    .message .bubble {
      padding: 10px 14px;
      border-radius: 12px;
      line-height: 1.6;
      max-width: 680px;
      word-break: break-word;
    }
    .message.user .bubble {
      background: var(--accent);
      color: #fff;
      border-bottom-right-radius: 4px;
    }
    .message.assistant .bubble {
      background: var(--card);
      border: 1px solid var(--border);
      color: var(--text);
      border-bottom-left-radius: 4px;
    }
    .message .meta { font-size: 11px; color: var(--muted); padding: 0 4px; }
    .message .pii-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 10px;
      background: rgba(210,153,34,0.15);
      color: var(--warn);
      border: 1px solid rgba(210,153,34,0.3);
    }
    .message .pii-badge.clean {
      background: rgba(63,185,80,0.1);
      color: var(--accent2);
      border-color: rgba(63,185,80,0.25);
    }

    .empty-state {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      color: var(--muted);
    }
    .empty-state .big { font-size: 48px; opacity: 0.3; }
    .empty-state h2 { font-size: 18px; color: var(--text); font-weight: 500; }
    .empty-state p { font-size: 13px; max-width: 320px; text-align: center; }

    /* ── Input area ──────────────────────────────────────────────────────── */
    .input-area {
      padding: 16px 20px;
      background: var(--card);
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex-shrink: 0;
    }
    .input-row { display: flex; gap: 10px; align-items: flex-end; }
    .input-area textarea {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 14px;
      font-family: inherit;
      padding: 10px 14px;
      resize: none;
      min-height: 44px;
      max-height: 160px;
      outline: none;
      transition: border-color 0.15s;
    }
    .input-area textarea:focus { border-color: var(--accent); }
    .input-area textarea::placeholder { color: var(--muted); }
    .btn-send {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 0.15s;
    }
    .btn-send:hover { opacity: 0.85; }
    .btn-send:disabled { opacity: 0.4; cursor: not-allowed; }

    .input-opts { display: flex; gap: 12px; align-items: center; }
    .input-opts label { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 6px; }
    .input-opts select {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 12px;
      border-radius: 4px;
      padding: 2px 6px;
      outline: none;
    }

    /* ── Dashboard panel ─────────────────────────────────────────────────── */
    .dashboard { padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; }
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; }
    .stat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .stat-card .label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .stat-card .value { font-size: 28px; font-weight: 700; color: var(--text); }
    .stat-card .sub { font-size: 11px; color: var(--muted); }

    /* ── Pipeline Console panel ──────────────────────────────────────────── */
    .console-wrap { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 12px; }
    .console-entry {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 12px;
      line-height: 1.7;
    }
    .console-entry .req-id { color: var(--muted); }
    .console-entry .stage-row { display: flex; gap: 8px; align-items: center; }
    .console-entry .stage-name { color: var(--accent); min-width: 140px; }
    .console-entry .stage-ok   { color: var(--accent2); }
    .console-entry .stage-skip { color: var(--muted); }
    .console-entry .stage-err  { color: var(--danger); }

    /* ── Models panel ────────────────────────────────────────────────────── */
    .models-wrap { padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; }
    .model-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .model-card .model-name { flex: 1; font-weight: 500; }
    .model-card .model-size { font-size: 12px; color: var(--muted); }
    .model-running-pill {
      font-size: 11px;
      padding: 2px 10px;
      border-radius: 10px;
      background: rgba(63,185,80,0.12);
      color: var(--accent2);
      border: 1px solid rgba(63,185,80,0.25);
    }

    /* ── Settings panel ──────────────────────────────────────────────────── */
    .settings-wrap { padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; max-width: 560px; }
    .settings-group { display: flex; flex-direction: column; gap: 12px; }
    .settings-group h3 { font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .field { display: flex; flex-direction: column; gap: 4px; }
    .field label { font-size: 12px; color: var(--muted); }
    .field input {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 13px;
      border-radius: 6px;
      padding: 8px 10px;
      outline: none;
      transition: border-color 0.15s;
    }
    .field input:focus { border-color: var(--accent); }
    .settings-note {
      font-size: 12px;
      color: var(--muted);
      background: rgba(88,166,255,0.07);
      border: 1px solid rgba(88,166,255,0.15);
      border-radius: 6px;
      padding: 10px 14px;
    }
  </style>
</head>
<body>
<div id=\"app\">

  <!-- ── Header ───────────────────────────────────────────────────────────── -->
  <header>
    <span class=\"logo\">loke</span>
    <span class=\"tagline\">privacy-first AI</span>
    <div class=\"health-badge\">
      <div class=\"health-dot\" id=\"health-dot\"></div>
      <span id=\"health-label\">checking...</span>
    </div>
  </header>

  <div class=\"body-wrap\">

    <!-- ── Sidebar nav ───────────────────────────────────────────────────── -->
    <nav>
      <span class=\"nav-label\">Workspace</span>
      <button class=\"nav-item active\" data-panel=\"chat\">
        <span class=\"icon\">&#x1F4AC;</span> Chat
      </button>
      <button class=\"nav-item\" data-panel=\"dashboard\">
        <span class=\"icon\">&#x1F4CA;</span> Dashboard
      </button>
      <button class=\"nav-item\" data-panel=\"console\">
        <span class=\"icon\">&#x1F50D;</span> Pipeline Console
      </button>
      <span class=\"nav-label\">System</span>
      <button class=\"nav-item\" data-panel=\"models\">
        <span class=\"icon\">&#x1F9E0;</span> Models
      </button>
      <button class=\"nav-item\" data-panel=\"settings\">
        <span class=\"icon\">&#x2699;&#xFE0F;</span> Settings
      </button>
    </nav>

    <!-- ── Main content ─────────────────────────────────────────────────── -->
    <main>

      <!-- Pipeline status bar (shared across panels) -->
      <div class=\"pipeline-bar\" id=\"pipeline-bar\">
        <div class=\"stage\" id=\"ps-privacy\"><div class=\"dot\"></div>Privacy Filter</div>
        <div class=\"sep\">&#x276F;</div>
        <div class=\"stage\" id=\"ps-token\"><div class=\"dot\"></div>Token Optimiser</div>
        <div class=\"sep\">&#x276F;</div>
        <div class=\"stage\" id=\"ps-router\"><div class=\"dot\"></div>Router</div>
        <div class=\"sep\">&#x276F;</div>
        <div class=\"stage\" id=\"ps-llm\"><div class=\"dot\"></div>LLM</div>
        <div class=\"sep\">&#x276F;</div>
        <div class=\"stage\" id=\"ps-restore\"><div class=\"dot\"></div>Restore</div>
        <div class=\"sep\">&#x276F;</div>
        <div class=\"stage\" id=\"ps-guardian\"><div class=\"dot\"></div>Guardian</div>
        <div class=\"sep\">&#x276F;</div>
        <div class=\"stage\" id=\"ps-audit\"><div class=\"dot\"></div>Audit</div>
      </div>

      <!-- ── Chat panel ─────────────────────────────────────────────────── -->
      <div class=\"panel active\" id=\"panel-chat\">
        <div class=\"chat-messages\" id=\"chat-messages\">
          <div class=\"empty-state\" id=\"empty-state\">
            <div class=\"big\">&#x1F512;</div>
            <h2>Your conversations stay local</h2>
            <p>loke anonymises your messages before they leave your device. Type something to get started.</p>
          </div>
        </div>
        <div class=\"input-area\">
          <div class=\"input-opts\">
            <label>Tolerance
              <select id=\"tolerance-select\">
                <option value=\"instant\">Instant</option>
                <option value=\"patient\">Patient</option>
                <option value=\"background\">Background</option>
              </select>
            </label>
            <label>Mode
              <select id=\"mode-select\">
                <option value=\"chat\">Chat</option>
                <option value=\"dashboard\">Dashboard</option>
              </select>
            </label>
          </div>
          <div class=\"input-row\">
            <textarea id=\"chat-input\" placeholder=\"Type a message... (Shift+Enter for new line)\" rows=\"1\"></textarea>
            <button class=\"btn-send\" id=\"btn-send\">Send</button>
          </div>
        </div>
      </div>

      <!-- ── Dashboard panel ────────────────────────────────────────────── -->
      <div class=\"panel\" id=\"panel-dashboard\">
        <div class=\"dashboard\">
          <div class=\"stat-grid\">
            <div class=\"stat-card\">
              <div class=\"label\">Requests</div>
              <div class=\"value\" id=\"stat-requests\">0</div>
              <div class=\"sub\">this session</div>
            </div>
            <div class=\"stat-card\">
              <div class=\"label\">Entities Redacted</div>
              <div class=\"value\" id=\"stat-entities\">0</div>
              <div class=\"sub\">PII items anonymised</div>
            </div>
            <div class=\"stat-card\">
              <div class=\"label\">Highest Sensitivity</div>
              <div class=\"value\" id=\"stat-sensitivity\" style=\"font-size:18px\">PUBLIC</div>
              <div class=\"sub\">across all requests</div>
            </div>
            <div class=\"stat-card\">
              <div class=\"label\">Ollama</div>
              <div class=\"value\" id=\"stat-ollama\" style=\"font-size:18px\">—</div>
              <div class=\"sub\">local model server</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Pipeline Console panel ─────────────────────────────────────── -->
      <div class=\"panel\" id=\"panel-console\">
        <div class=\"console-wrap\" id=\"console-entries\">
          <div style=\"color:var(--muted);font-size:13px;\">Pipeline runs will appear here after each request.</div>
        </div>
      </div>

      <!-- ── Models panel ───────────────────────────────────────────────── -->
      <div class=\"panel\" id=\"panel-models\">
        <div class=\"models-wrap\" id=\"models-list\">
          <div style=\"color:var(--muted)\">Loading models...</div>
        </div>
      </div>

      <!-- ── Settings panel ─────────────────────────────────────────────── -->
      <div class=\"panel\" id=\"panel-settings\">
        <div class=\"settings-wrap\" id=\"settings-wrap\">
          <div style=\"color:var(--muted)\">Loading settings...</div>
        </div>
      </div>

    </main>
  </div><!-- .body-wrap -->
</div><!-- #app -->

<script>
(function () {
  'use strict';

  // ── State ────────────────────────────────────────────────────────────────
  const state = {
    requests: 0,
    totalEntities: 0,
    highestSensitivity: 'PUBLIC',
    sensitivityRank: { PUBLIC: 0, INTERNAL: 1, CONFIDENTIAL: 2, RESTRICTED: 3 },
  };

  // ── Nav ──────────────────────────────────────────────────────────────────
  document.querySelectorAll('.nav-item').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const panel = document.getElementById('panel-' + btn.dataset.panel);
      if (panel) panel.classList.add('active');
      if (btn.dataset.panel === 'models') loadModels();
      if (btn.dataset.panel === 'settings') loadSettings();
    });
  });

  // ── Pipeline bar helpers ─────────────────────────────────────────────────
  const STAGES = ['ps-privacy','ps-token','ps-router','ps-llm','ps-restore','ps-guardian','ps-audit'];

  function resetPipelineBar() {
    STAGES.forEach(id => {
      const el = document.getElementById(id);
      el.className = 'stage';
    });
  }

  function animatePipeline(onDone) {
    resetPipelineBar();
    let i = 0;
    function step() {
      if (i > 0) document.getElementById(STAGES[i-1]).className = 'stage done';
      if (i >= STAGES.length) { if (onDone) onDone(); return; }
      document.getElementById(STAGES[i]).className = 'stage running';
      i++;
      setTimeout(step, 220);
    }
    step();
  }

  // ── Chat ─────────────────────────────────────────────────────────────────
  const chatMessages = document.getElementById('chat-messages');
  const emptyState   = document.getElementById('empty-state');
  const chatInput    = document.getElementById('chat-input');
  const btnSend      = document.getElementById('btn-send');
  const consoleEntries = document.getElementById('console-entries');

  chatInput.addEventListener('input', () => {
    chatInput.style.height = 'auto';
    chatInput.style.height = Math.min(chatInput.scrollHeight, 160) + 'px';
  });

  chatInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  btnSend.addEventListener('click', sendMessage);

  function appendMessage(role, text, meta) {
    if (emptyState) emptyState.style.display = 'none';
    const el = document.createElement('div');
    el.className = 'message ' + role;
    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.textContent = text;
    el.appendChild(bubble);
    if (meta) {
      const metaEl = document.createElement('div');
      metaEl.className = 'meta';
      metaEl.innerHTML = meta;
      el.appendChild(metaEl);
    }
    chatMessages.appendChild(el);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return el;
  }

  function sensitivityBadge(sensitivity, count) {
    const clean = count === 0;
    const cls = clean ? 'pii-badge clean' : 'pii-badge';
    const label = clean
      ? '&#x2713; No PII detected'
      : sensitivity + ' &bull; ' + count + ' entit' + (count === 1 ? 'y' : 'ies') + ' anonymised';
    return '<span class=\"' + cls + '\">' + label + '</span>';
  }

  function appendConsoleEntry(run) {
    // Remove placeholder text on first real entry
    if (consoleEntries.children.length === 1 && consoleEntries.children[0].tagName !== 'DIV'.toLowerCase() + '') {
      /* keep */
    }
    if (consoleEntries.querySelector('[data-placeholder]')) {
      consoleEntries.innerHTML = '';
    }

    const entry = document.createElement('div');
    entry.className = 'console-entry';

    const stageNames = {
      regex_scan: 'Regex Scan',
      ner_scan: 'NER Scan',
      presidio_scan: 'Presidio Scan',
      dedup: 'Dedup',
      anonymise: 'Anonymise',
      guardian_inject: 'Guardian Inject',
    };

    let html = '<div class=\"req-id\">request_id: ' + escHtml(run.request_id || '—') + '</div>';
    html += '<div>sensitivity: <span style=\"color:var(--warn)\">' + escHtml(run.sensitivity || '—') + '</span>';
    html += ' &nbsp; entities: ' + (run.entities_found || 0) + '</div>';

    if (run.stages && run.stages.length) {
      run.stages.forEach(s => {
        const name = stageNames[s.stage] || s.stage;
        const cls = s.skipped ? 'stage-skip' : 'stage-ok';
        const status = s.skipped ? 'skipped (' + (s.skip_reason || '') + ')' : 'ok &bull; ' + s.entities_found + ' entities';
        html += '<div class=\"stage-row\"><span class=\"stage-name\">' + escHtml(name) + '</span><span class=\"' + cls + '\">' + status + '</span></div>';
      });
    }

    entry.innerHTML = html;
    consoleEntries.prepend(entry);
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');
  }

  function updateDashboard(run) {
    state.requests++;
    state.totalEntities += (run.entities_found || 0);
    const rank = state.sensitivityRank;
    if ((rank[run.sensitivity] || 0) > (rank[state.highestSensitivity] || 0)) {
      state.highestSensitivity = run.sensitivity;
    }
    document.getElementById('stat-requests').textContent = state.requests;
    document.getElementById('stat-entities').textContent = state.totalEntities;
    document.getElementById('stat-sensitivity').textContent = state.highestSensitivity;
  }

  async function sendMessage() {
    const text = chatInput.value.trim();
    if (!text) return;

    chatInput.value = '';
    chatInput.style.height = 'auto';
    btnSend.disabled = true;

    appendMessage('user', text, null);

    const tolerance = document.getElementById('tolerance-select').value;
    const mode = document.getElementById('mode-select').value;

    // Animate the pipeline bar while waiting
    let pipelineDone = false;
    animatePipeline(() => { pipelineDone = true; });

    let data;
    try {
      const res = await fetch('/api/pipeline', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, system_prompt: '', tolerance, mode }),
      });
      data = await res.json();
    } catch (err) {
      resetPipelineBar();
      STAGES.forEach(id => document.getElementById(id).className = 'stage error');
      appendMessage('assistant', 'Error: could not reach loke API. Is the server running?', null);
      btnSend.disabled = false;
      return;
    }

    // Ensure pipeline bar completes visually
    STAGES.forEach(id => document.getElementById(id).className = 'stage done');

    if (!data.ok) {
      appendMessage('assistant', 'Error: ' + (data.error || 'unknown error'), null);
      btnSend.disabled = false;
      return;
    }

    const badge = sensitivityBadge(data.sensitivity, data.entities_found || 0);
    const meta = badge + ' &nbsp; model: ' + escHtml(data.model_id || '—');
    appendMessage('assistant', data.response || '(no response)', meta);

    appendConsoleEntry(data);
    updateDashboard(data);

    btnSend.disabled = false;
    chatInput.focus();
  }

  // ── Health check ─────────────────────────────────────────────────────────
  async function checkHealth() {
    const dot   = document.getElementById('health-dot');
    const label = document.getElementById('health-label');
    try {
      const res  = await fetch('/api/health');
      const data = await res.json();
      if (data.ok) {
        dot.className = 'health-dot ok';
        label.textContent = 'Ollama ' + (data.ollama || '—');
        document.getElementById('stat-ollama').textContent = data.ollama || '—';
      } else {
        dot.className = 'health-dot warn';
        label.textContent = 'degraded';
      }
    } catch (_) {
      dot.className = 'health-dot err';
      label.textContent = 'unreachable';
    }
  }
  checkHealth();
  setInterval(checkHealth, 30000);

  // ── Models ───────────────────────────────────────────────────────────────
  async function loadModels() {
    const wrap = document.getElementById('models-list');
    wrap.innerHTML = '<div style=\"color:var(--muted)\">Loading models...</div>';
    try {
      const res  = await fetch('/api/models');
      const data = await res.json();
      if (!data.length) {
        wrap.innerHTML = '<div style=\"color:var(--muted)\">No models found. Pull a model with: <code>ollama pull llama3.2</code></div>';
        return;
      }
      wrap.innerHTML = '';
      data.forEach(m => {
        const card = document.createElement('div');
        card.className = 'model-card';
        const gb = m.size ? (m.size / 1e9).toFixed(1) + ' GB' : '—';
        card.innerHTML = '<span class=\"model-name\">' + escHtml(m.id) + '</span>'
          + '<span class=\"model-size\">' + gb + '</span>'
          + (m.running ? '<span class=\"model-running-pill\">running</span>' : '');
        wrap.appendChild(card);
      });
    } catch (_) {
      wrap.innerHTML = '<div style=\"color:var(--danger)\">Failed to load models — is Ollama running?</div>';
    }
  }

  // ── Settings ─────────────────────────────────────────────────────────────
  async function loadSettings() {
    const wrap = document.getElementById('settings-wrap');
    let cfg = {};
    try {
      const res = await fetch('/api/settings');
      cfg = await res.json();
    } catch (_) { /* use defaults */ }

    wrap.innerHTML = '';

    const note = document.createElement('div');
    note.className = 'settings-note';
    note.textContent = 'Settings persistence is coming in the next wave. Changes here are not yet saved to disk.';
    wrap.appendChild(note);

    const fields = [
      { key: 'ollama_url',    label: 'Ollama URL' },
      { key: 'presidio_url',  label: 'Presidio URL' },
      { key: 'llmlingua_url', label: 'LLMLingua URL' },
      { key: 'data_dir',      label: 'Data directory' },
      { key: 'log_level',     label: 'Log level' },
    ];

    const group = document.createElement('div');
    group.className = 'settings-group';
    const h = document.createElement('h3');
    h.textContent = 'Core configuration';
    group.appendChild(h);

    fields.forEach(f => {
      const fieldEl = document.createElement('div');
      fieldEl.className = 'field';
      fieldEl.innerHTML = '<label>' + escHtml(f.label) + '<input type=\"text\" value=\"' + escHtml(cfg[f.key] || '') + '\" /></label>';
      group.appendChild(fieldEl);
    });

    wrap.appendChild(group);
  }

  // Mark placeholder on console
  consoleEntries.firstElementChild && consoleEntries.firstElementChild.setAttribute('data-placeholder', '1');
})();
</script>
<link rel=\"stylesheet\" href=\"/static/css/app.css\" />
<script src=\"/static/js/app.js\"></script>
</body>
</html>";
  <http.res.html(200;html)
}
