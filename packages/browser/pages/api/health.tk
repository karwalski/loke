// GET /api/health — loke health check endpoint.
// Reports service version and the status of the Ollama local model server.

i=http:std.http;
i=json:std.json;
i=str:std.str;
i=core:browser.extensions.core;
i=ollama:core.models.ollama;

pub f=get(req:$http.req):$http.res{
  let config=core.get_config();
  let ollama_client=ollama.new(config.ollama_url);
  let ollama_status=ollama.health_check(ollama_client);

  let ollama_str="unreachable";
  if ollama_status==$running{
    let ollama_str="running"
  }else{
    if ollama_status==$stopped{
      let ollama_str="stopped"
    }else{
      // unreachable — already set
    }
  };

  let port_str=str.from_u16(config.port);

  let resp_body=str.concat("{";
    str.concat("\"ok\":true,";
    str.concat("\"version\":\"0.1.0\",";
    str.concat("\"ollama\":";
    str.concat(json.enc_str(ollama_str);
    str.concat(",\"port\":";
    str.concat(port_str;
    "}")))))));

  <http.res.json(200;resp_body)
}
