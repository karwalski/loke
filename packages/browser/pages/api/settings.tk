// GET /api/settings  — returns current loke config (no secrets)
// POST /api/settings — stub; settings persistence coming in next wave

i=http:std.http;
i=json:std.json;
i=str:std.str;
i=core:browser.extensions.core;

pub f=get(req:$http.req):$http.res{
  let config=core.get_config();

  let port_str=str.from_u16(config.port);

  let resp_body=str.concat("{";
    str.concat("\"port\":";
    str.concat(port_str;
    str.concat(",\"data_dir\":";
    str.concat(json.enc_str(config.data_dir);
    str.concat(",\"log_level\":";
    str.concat(json.enc_str(config.log_level);
    str.concat(",\"ollama_url\":";
    str.concat(json.enc_str(config.ollama_url);
    str.concat(",\"presidio_url\":";
    str.concat(json.enc_str(config.presidio_url);
    str.concat(",\"llmlingua_url\":";
    str.concat(json.enc_str(config.llmlingua_url);
    str.concat(",\"default_provider\":";
    str.concat(json.enc_str(config.default_provider);
    "}"))))))))))));

  <http.res.json(200;resp_body)
}

pub f=post(req:$http.req):$http.res{
  let body=req.body;
  let key=json.get_str(body;"key")|{
    $ok:v v;
    $err:_ ""
  };
  let value=json.get_str(body;"value")|{
    $ok:v v;
    $err:_ ""
  };
  if str.eq(key;"anthropic_api_key"){
    core.set_api_key("anthropic";value)
  }else{
    if str.eq(key;"openai_api_key"){
      core.set_api_key("openai";value)
    }else{()}
  };
  let resp_body=str.concat("{\"ok\":true,\"key\":";
    str.concat(json.enc_str(key);
    str.concat(",\"set\":true}";"")));
  <http.res.json(200;resp_body)
}
