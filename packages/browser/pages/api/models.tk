// GET /api/models — lists models available in the local Ollama instance,
// annotated with their running status from the Ollama /api/ps endpoint.

i=http:std.http;
i=json:std.json;
i=str:std.str;
i=core:browser.extensions.core;
i=ollama:core.models.ollama;

pub f=get(req:$http.req):$http.res{
  let config=core.get_config();
  let client=ollama.new(config.ollama_url);

  // Fetch installed models
  let models_result=ollama.list_models(client)|{
    $ok:v v;
    $err:e{
      <http.res.err(502;"unable to reach Ollama — is it running?")
    }
  };

  // Fetch running models to annotate each installed model
  let running_result=ollama.list_running(client)|{
    $ok:v v;
    $err:_ @()
  };

  // Build JSON array of model objects
  let model_count=models_result.len;
  let running_count=running_result.len;
  let items="";
  let i=0;
  loop{
    if i>=model_count{
      break
    }else{
      let m=str.array_get(models_result;i);

      // Check if this model is currently running
      let is_running=false;
      let ri=0;
      loop{
        if ri>=running_count{
          break
        }else{
          let rm=str.array_get(running_result;ri);
          if str.eq(rm.name;m.name){
            is_running=true;
            ri=running_count
          }else{
            ri=ri+1
          }
        }
      };

      let running_str="false";
      if is_running{
        let running_str="true"
      }else{
        // keep "false"
      };

      let size_str=str.from_u64(m.size);

      let entry=str.concat("{";
        str.concat("\"id\":";
        str.concat(json.enc_str(m.name);
        str.concat(",\"size\":";
        str.concat(size_str;
        str.concat(",\"running\":";
        str.concat(running_str;
        "}")))))));

      if i==0{
        let items=entry
      }else{
        let items=str.concat(items;str.concat(",";entry))
      };
      i=i+1
    }
  };

  let resp_body=str.concat("[";str.concat(items;"]"));
  <http.res.json(200;resp_body)
}
