// Australian open data demo datasets for moke.
// Six representative datasets seeded with realistic synthetic data.
// PII is deliberately present in free-text and name columns so loke's
// anonymisation pipeline can be demonstrated against real-world shapes.

m=moke.data.au_datasets;
i=str:std.string;
i=compute:moke.compute;

// ── Registry type ─────────────────────────────────────────────────────────────

pub m.$dataset_info{
  id:str;
  name:str;
  description:str;
  row_count:i32;
  col_count:i32;
  sensitivity:str;
  category:str
}

// ─────────────────────────────────────────────────────────────────────────────
// Dataset 1 — Medicare Benefits Schedule (MBS)
// ─────────────────────────────────────────────────────────────────────────────
// PII: patient_name, dob, medicare_number, notes
// Anomalies: 2× gap_amount > $500, 1× duplicate claim_id, 3× exceptional_claim=true

pub f=get_medicare():compute.$dataset{
  <compute.$dataset{
    name="Medicare Benefits Schedule";
    headers=@(
      "claim_id";"patient_id";"patient_name";"dob";"medicare_number";
      "provider_id";"provider_name";"item_number";"service_date";
      "benefit_paid";"schedule_fee";"gap_amount";"specialty";
      "facility_type";"state";"postcode";"diagnosis_code";"procedure_code";
      "referral_id";"claim_date";"processed_date";"payment_method";
      "bulk_billed";"exceptional_claim";"notes";"status"
    );
    rows=@(
      @("MBS-2024-000001";"PAT-10041";"John Smith";"1968-03-14";"2134-56789-0";"PROV-8821";"Dr Angela Russo";"23";"2024-07-03";"37.05";"37.05";"0.00";"GP";"Private Rooms";"NSW";"2000";"Z00.0";"10991";"REF-0000";"2024-07-04";"2024-07-06";"EFT";"true";"false";"Patient John Smith presented for routine health assessment. No concerns noted.";"PAID");
