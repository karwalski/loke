// ─────────────────────────────────────────────────────────────────────────────
// Dataset 4 — Sydney Water Quality Readings
// ─────────────────────────────────────────────────────────────────────────────
// PII: operator_name
// Anomalies: 3× turbidity > 4 NTU, 2× ecoli_present=true, 1× ph < 6.5

pub f=get_water():compute.$dataset{
  <compute.$dataset{
    name="Sydney Water Quality Readings";
    headers=@(
      "reading_id";"sensor_id";"sensor_name";"reading_time";"location";
      "suburb";"postcode";"turbidity_ntu";"chlorine_mgl";"ph";"temperature_c";
      "fluoride_mgl";"toc_mgl";"ecoli_present";"total_coliform";"pressure_kpa";
      "flow_rate_ls";"alert_triggered";"operator_id";"operator_name";
      "sample_type";"notes";"status"
    );
    rows=@(
      @("SWR-2024-0001";"SNS-NP-001";"Nepean River Intake A";"2024-07-01 06:00:00";"Nepean River Intake";"Penrith";"2750";"0.42";"0.85";"7.2";"16.4";"0.72";"2.1";"false";"0";"412.3";"182.4";"false";"OPR-441";"David Kowalski";"Continuous";"Normal conditions post-rainfall.";"NORMAL");
