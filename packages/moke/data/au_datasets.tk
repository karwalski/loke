      @("SWR-2024-0004";"SNS-NP-002";"Nepean River Intake B";"2024-07-01 09:00:00";"Nepean River Intake";"Penrith";"2750";"5.31";"0.71";"7.0";"16.6";"0.69";"3.4";"false";"1";"409.8";"178.2";"true";"OPR-441";"David Kowalski";"Grab";"ALERT: turbidity spike following upstream storm event. Increased coagulation applied.";"ALERT");
