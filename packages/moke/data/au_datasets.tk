      @("70011";"Broken Hill High School";"Broken Hill";"2880";"NSW";"Secondary";"Government";"428";"913";"3.8";"8.6";"69.4";"78";"33.7";"47";"Ms Robyn McGregor";"1907";"-31.9577";"141.4646";"Good";"14800";"Regional school, mining industry partnerships for trade pathways.");
      @("70012";"Chatswood High School";"Chatswood";"2067";"NSW";"Secondary";"Government";"1288";"1112";"42.6";"0.7";"88.6";"241";"59.8";"118";"Dr James Ho";"1956";"-33.7972";"151.1838";"Excellent";"13700";"Strong HSC performance, large Chinese-Australian community cohort.");
