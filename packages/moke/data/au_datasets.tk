      @("ABS-EMP-0006";"8311";"Truck Drivers";"Machinery Operators and Drivers";"I";"Transport, Postal and Warehousing";"VIC";"Outer Regional";"44100";"91.2";"8.8";"1390";"50.2";"5.7";"7.3";"2.8";"8.8";"3.8";"22.4";"18.3";"44";"High mean hours reflect logistics industry demands.");
