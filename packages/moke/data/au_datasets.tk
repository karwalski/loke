// ─────────────────────────────────────────────────────────────────────────────
// Registry functions
// ─────────────────────────────────────────────────────────────────────────────

pub f=list_datasets():@($dataset_info){
  <@(
    $dataset_info{
      id="medicare";
      name="Medicare Benefits Schedule";
      description="MBS claims with patient PII, benefit amounts, and provider details";
      row_count=30;
      col_count=26;
      sensitivity="RESTRICTED";
      category="Health"
    };
    $dataset_info{
      id="schools";
      name="NSW Public Schools";
      description="School-level enrolment, ICSEA, ATAR, and principal data for NSW government schools";
      row_count=30;
      col_count=22;
      sensitivity="CONFIDENTIAL";
      category="Education"
    };
    $dataset_info{
      id="opal";
      name="Opal Card Tap Data";
      description="Pseudonymous Opal card journey records across all NSW public transport modes";
      row_count=30;
      col_count=24;
      sensitivity="CONFIDENTIAL";
      category="Transport"
    };
    $dataset_info{
      id="water";
      name="Sydney Water Quality Readings";
      description="Sensor-based water quality measurements across Sydney distribution network";
      row_count=30;
      col_count=23;
      sensitivity="INTERNAL";
      category="Utilities"
    };
    $dataset_info{
      id="property";
      name="NSW Land Registry Property Transactions";
      description="Property sales with vendor and purchaser names, prices, and settlement details";
      row_count=30;
      col_count=25;
      sensitivity="CONFIDENTIAL";
      category="Property"
    };
    $dataset_info{
      id="employment";
      name="ABS Employment by Occupation";
      description="Aggregate employment statistics by ANZSCO occupation and industry — no individual PII";
      row_count=30;
      col_count=22;
      sensitivity="PUBLIC";
      category="Economics"
    }
  )
}

pub f=get_by_id(id:str):compute.$dataset{
  if str.eq(id;"medicare")   { <get_medicare()   };
  if str.eq(id;"schools")    { <get_schools()    };
  if str.eq(id;"opal")       { <get_opal()       };
  if str.eq(id;"water")      { <get_water()      };
  if str.eq(id;"property")   { <get_property()   };
  if str.eq(id;"employment") { <get_employment() };
  <compute.$dataset{
    name="";
    headers=@();
    rows=@()
  }
}
