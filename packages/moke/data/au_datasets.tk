// ─────────────────────────────────────────────────────────────────────────────
// Dataset 6 — ABS Employment by Occupation
// ─────────────────────────────────────────────────────────────────────────────
// No individual PII — aggregate statistical data
// Anomalies: 3× unemployment_rate > 15%, 2× median_weekly_earnings < $500

pub f=get_employment():compute.$dataset{
  <compute.$dataset{
    name="ABS Employment by Occupation";
    headers=@(
      "record_id";"anzsco_code";"occupation_title";"occupation_group";
      "industry_code";"industry_name";"state";"region_type";"employment_count";
      "full_time_pct";"part_time_pct";"median_weekly_earnings";"mean_weekly_hours";
      "unemployment_rate";"underemployment_rate";"youth_pct";"female_pct";
      "indigenous_pct";"migrant_pct";"qualification_pct";"median_age";"notes"
    );
    rows=@(
      @("ABS-EMP-0001";"2613";"Software and Applications Programmers";"Professionals";"J";"Information Media and Telecommunications";"NSW";"Major City";"142800";"88.4";"11.6";"2480";"42.3";"2.1";"3.4";"12.4";"42.8";"1.2";"61.3";"94.7";"34";"Strong demand driven by digital transformation projects.");
