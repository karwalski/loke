// ─────────────────────────────────────────────────────────────────────────────
// Dataset 2 — NSW Public Schools
// ─────────────────────────────────────────────────────────────────────────────
// PII: principal_name, notes (may mention student names)
// Anomalies: 2× ICSEA < 800, 1× enrolment=0, 3× missing ATAR (primary)

pub f=get_schools():compute.$dataset{
  <compute.$dataset{
    name="NSW Public Schools";
    headers=@(
      "school_id";"school_name";"suburb";"postcode";"state";"school_type";
      "sector";"enrolment";"icsea_value";"lbote_pct";"indigenous_pct";
      "atar_median";"yr12_completions";"stem_pct";"staff_count";
      "principal_name";"established_year";"latitude";"longitude";"rating";
      "funding_per_student";"notes"
    );
    rows=@(
      @("70001";"Newtown High School of Performing Arts";"Newtown";"2042";"NSW";"Secondary";"Government";"1042";"1079";"28.4";"3.1";"84.5";"187";"41.2";"98";"Dr Karen Bellingham";"1988";"-33.8966";"151.1780";"Excellent";"14200";"High-achieving selective arts school. Recent grant to expand digital music studio.");
