// ── Dataset 3: network_topology ────────────────────────────────────────────────
// 10 columns, 20 rows — switch/VLAN records.
// Deliberate anomaly: SRV-027 assigned to VLAN-20 (prod DB) instead of VLAN-10 (app).

pub f=get_network():compute.$dataset{
  <compute.$dataset{
    name="network_topology";
    headers=@(
      "record_id";"switch_id";"switch_name";"port";"server_id";
      "vlan_id";"vlan_name";"ip_address";"subnet";"notes"
    );
    rows=@(
      @("NET-001";"SW-SYD-A1";"syd-core-sw-01";"Gi0/1";"SRV-001";"10";"app-prod";"10.10.1.1";"10.10.0.0/16";"");
      @("NET-002";"SW-SYD-A1";"syd-core-sw-01";"Gi0/2";"SRV-002";"10";"app-prod";"10.10.1.2";"10.10.0.0/16";"");
      @("NET-003";"SW-SYD-A1";"syd-core-sw-01";"Gi0/3";"SRV-003";"10";"app-prod";"10.10.1.3";"10.10.0.0/16";"");
      @("NET-004";"SW-SYD-A1";"syd-core-sw-01";"Gi0/4";"SRV-004";"10";"app-prod";"10.10.1.4";"10.10.0.0/16";"");
      @("NET-005";"SW-SYD-B1";"syd-db-sw-01";"Gi0/1";"SRV-013";"20";"db-prod";"10.20.1.1";"10.20.0.0/16";"");
      @("NET-006";"SW-SYD-B1";"syd-db-sw-01";"Gi0/2";"SRV-014";"20";"db-prod";"10.20.1.2";"10.20.0.0/16";"");
      @("NET-007";"SW-SYD-B1";"syd-db-sw-01";"Gi0/3";"SRV-015";"20";"db-prod";"10.20.1.3";"10.20.0.0/16";"");
      @("NET-008";"SW-SYD-B1";"syd-db-sw-01";"Gi0/4";"SRV-016";"20";"db-prod";"10.20.1.4";"10.20.0.0/16";"");
      @("NET-009";"SW-SYD-B1";"syd-db-sw-01";"Gi0/5";"SRV-017";"20";"db-prod";"10.20.1.5";"10.20.0.0/16";"");
      @("NET-010";"SW-SYD-C1";"syd-app-sw-01";"Gi0/1";"SRV-019";"10";"app-prod";"10.10.2.1";"10.10.0.0/16";"");
      @("NET-011";"SW-SYD-C1";"syd-app-sw-01";"Gi0/2";"SRV-020";"10";"app-prod";"10.10.2.2";"10.10.0.0/16";"");
      @("NET-012";"SW-SYD-C1";"syd-app-sw-01";"Gi0/3";"SRV-021";"10";"app-prod";"10.10.2.3";"10.10.0.0/16";"");
      // ANOMALY: SRV-027 (app tier) is on VLAN-20 (db-prod) — misconfiguration
      @("NET-013";"SW-SYD-C1";"syd-app-sw-01";"Gi0/4";"SRV-027";"20";"db-prod";"10.20.2.7";"10.20.0.0/16";"MISCONFIGURATION: app server SRV-027 placed on db-prod VLAN — should be VLAN-10");
      @("NET-014";"SW-SYD-D1";"syd-mgmt-sw-01";"Gi0/1";"SRV-028";"30";"mgmt";"10.30.1.1";"10.30.0.0/16";"");
      @("NET-015";"SW-SYD-D1";"syd-mgmt-sw-01";"Gi0/2";"SRV-029";"30";"mgmt";"10.30.1.2";"10.30.0.0/16";"");
