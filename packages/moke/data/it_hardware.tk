// ── Dataset 2: performance_metrics ────────────────────────────────────────────
// 12 columns, 62 rows (1-2 readings per server).
// Deliberate anomalies:
//   - SRV-021, SRV-023, SRV-037: cpu_pct > 95 (critical load)
//   - SRV-016, SRV-038: ram_pct > 90
//   - 5 rows with alert_level="warning" or "critical"

pub f=get_metrics():compute.$dataset{
  <compute.$dataset{
    name="performance_metrics";
    headers=@(
      "metric_id";"server_id";"timestamp";"cpu_pct";"ram_pct";
      "disk_read_mbps";"disk_write_mbps";"network_in_mbps";"network_out_mbps";
      "load_avg_1m";"process_count";"alert_level"
    );
    rows=@(
      @("MET-001";"SRV-001";"2026-04-18T09:00:00";"23";"41";"45";"22";"120";"95";"2.1";"187";"ok");
      @("MET-002";"SRV-001";"2026-04-18T21:00:00";"18";"40";"38";"18";"98";"72";"1.8";"182";"ok");
      @("MET-003";"SRV-002";"2026-04-18T09:00:00";"31";"48";"55";"30";"145";"112";"3.0";"203";"ok");
