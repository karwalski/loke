      @("NET-017";"SW-MEL-M1";"mel-core-sw-01";"Gi0/2";"SRV-034";"10";"app-prod";"10.40.1.2";"10.40.0.0/16";"MEL DR site");
      @("NET-018";"SW-MEL-M2";"mel-db-sw-01";"Gi0/1";"SRV-037";"20";"db-prod";"10.50.1.1";"10.50.0.0/16";"MEL DR site");
