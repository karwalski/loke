      @("MET-008";"SRV-007";"2026-04-18T09:00:00";"35";"50";"65";"40";"240";"195";"3.4";"218";"ok");
      @("MET-009";"SRV-008";"2026-04-18T09:00:00";"29";"46";"50";"28";"180";"140";"2.8";"201";"ok");
      @("MET-010";"SRV-009";"2026-04-18T09:00:00";"67";"71";"125";"90";"420";"360";"6.4";"298";"warning");
      @("MET-011";"SRV-010";"2026-04-18T09:00:00";"42";"58";"80";"55";"290";"240";"4.1";"251";"ok");
      @("MET-012";"SRV-011";"2026-04-18T09:00:00";"38";"53";"72";"48";"260";"210";"3.7";"234";"ok");
      @("MET-013";"SRV-012";"2026-04-18T09:00:00";"25";"44";"48";"25";"150";"115";"2.4";"191";"ok");
      @("MET-014";"SRV-013";"2026-04-18T09:00:00";"55";"74";"180";"140";"95";"42";"5.3";"312";"ok");
      @("MET-015";"SRV-014";"2026-04-18T09:00:00";"47";"69";"150";"115";"78";"35";"4.5";"287";"ok");
      @("MET-016";"SRV-015";"2026-04-18T09:00:00";"62";"78";"210";"165";"110";"55";"6.0";"334";"ok");
