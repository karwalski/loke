// ── Registry ──────────────────────────────────────────────────────────────────

pub f=list_datasets():@(str){
  <@("server_inventory";"performance_metrics";"network_topology";"user_assignments")
}

pub f=get_by_name(name:str):compute.$dataset{
  if name == "server_inventory"    { <get_inventory() };
  if name == "performance_metrics" { <get_metrics() };
  if name == "network_topology"    { <get_network() };
  if name == "user_assignments"    { <get_users() };
  <compute.$dataset{
    name="not_found";
    headers=@();
    rows=@()
  }
}
