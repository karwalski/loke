// MK4.2 — Banksia Digital IT Server Hardware
// 4 linked datasets joinable by server_id or user_id.
// Data centres: SYD-DC1 (32 servers), MEL-DC1 (16 servers).
// PII columns: contact_name, contact_email (server_inventory); full_name (user_assignments).

m=moke.data.it_hardware;
i=compute:moke.compute;

// ── Dataset 1: server_inventory ───────────────────────────────────────────────
// 22 columns, 48 rows.
// Deliberate anomalies:
//   - srv-db-04, srv-db-05, srv-bkp-02: warranty_expiry in the past (expired)
//   - srv-mon-01, srv-arc-01: status="decommissioned" still present in dataset
//   - srv-app-09: cpu_cores=0 (data entry error)

pub f=get_inventory():compute.$dataset{
  <compute.$dataset{
    name="server_inventory";
    headers=@(
      "server_id";"hostname";"model";"manufacturer";"cpu_model";"cpu_cores";
      "ram_gb";"storage_tb";"storage_type";"rack_id";"data_centre";"floor";
      "commissioned_date";"warranty_expiry";"os";"os_version";"role";
      "team_owner";"contact_name";"contact_email";"status";"notes"
    );
    rows=@(
      // ── SYD-DC1 web tier ──────────────────────────────────────────────────
      @("SRV-001";"srv-web-01";"ProLiant DL380 Gen10";"HP";"Intel Xeon Silver 4214R";"24";"64";"1.92";"NVMe";"RACK-A1";"SYD-DC1";"2";"2021-03-15";"2024-03-15";"Ubuntu";"22.04 LTS";"web";"Platform";"James Nguyen";"j.nguyen@banksia.com.au";"active";"");
