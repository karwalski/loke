// ── Dataset 2: wc_orders ──────────────────────────────────────────────────────
// 12 columns, 80 rows.
// Deliberate anomalies:
//   - 22 orders with status="shipped" but no tracking info in notes (SLA breach indicator)
//   - 5 high-value orders (total_amount > 500) with status="refunded"

pub f=get_orders():compute.$dataset{
  <compute.$dataset{
    name="wc_orders";
    headers=@(
      "order_id";"user_id";"order_date";"status";"total_amount";
      "item_count";"payment_method";"shipping_state";"shipping_postcode";
      "coupon_code";"fulfilment_centre";"notes"
    );
