// ── Dataset 4: wc_incidents ────────────────────────────────────────────────────
// 9 columns, 22 rows.
// Deliberate anomalies:
//   - INC-003: recurrence_count=5 (recurring P1)
//   - INC-008, INC-014, INC-019: status="open" (unresolved)
//   - INC-011: resolution_time_hours=96 (> 72h SLA breach)

pub f=get_incidents():compute.$dataset{
  <compute.$dataset{
    name="wc_incidents";
    headers=@(
      "incident_id";"date";"title";"severity";"status";
      "team";"resolution_time_hours";"root_cause";"recurrence_count"
    );
    rows=@(
      @("INC-001";"2026-01-05";"Payment gateway timeout";"P2";"resolved";"Payments";"4";"third-party API rate limit";"1");
      @("INC-002";"2026-01-12";"Search index corruption";"P2";"resolved";"Platform";"6";"unhandled exception during re-index";"1");
      // ANOMALY: recurring P1 — recurrence_count=5
      @("INC-003";"2026-01-20";"Checkout flow 503 errors";"P1";"resolved";"Platform";"3";"upstream database connection pool exhaustion";"5");
      @("INC-004";"2026-01-28";"Email notification delays";"P3";"resolved";"Ops";"8";"queue backlog from marketing campaign";"2");
      @("INC-005";"2026-02-04";"FC-SYD picking system outage";"P1";"resolved";"Fulfilment";"5";"NFS mount failure";"1");
      @("INC-006";"2026-02-11";"Product image CDN errors";"P3";"resolved";"Platform";"2";"CDN origin misconfiguration after deploy";"1");
      @("INC-007";"2026-02-19";"Fraud detection false positives";"P2";"resolved";"Payments";"12";"model drift — retrained";"2");
      // ANOMALY: unresolved
      @("INC-008";"2026-02-25";"Loyalty points not accruing";"P2";"open";"Platform";"0";"under investigation";"1");
      @("INC-009";"2026-03-04";"Checkout flow 503 errors";"P1";"resolved";"Platform";"2";"database connection pool exhaustion (recurrence)";"5");
      @("INC-010";"2026-03-09";"Coupon code validation bug";"P3";"resolved";"Platform";"14";"regex edge case — discount applied to excluded categories";"1");
      // ANOMALY: resolution_time_hours=96 (> 72h SLA)
      @("INC-011";"2026-03-15";"Order sync failure MEL warehouse";"P1";"resolved";"Fulfilment";"96";"undocumented API change by 3PL partner";"1");
      @("INC-012";"2026-03-20";"User login intermittent failures";"P2";"resolved";"Platform";"7";"JWT secret rotation not propagated to all nodes";"1");
      @("INC-013";"2026-03-26";"Shipping carrier API downtime";"P2";"resolved";"Fulfilment";"9";"carrier partner maintenance (unannounced)";"3");
      // ANOMALY: unresolved
      @("INC-014";"2026-04-01";"Checkout flow 503 errors";"P1";"open";"Platform";"0";"suspected DB connection pool — investigation ongoing";"5");
      @("INC-015";"2026-04-03";"FC-BNE barcode scanner firmware bug";"P3";"resolved";"Fulfilment";"16";"firmware rollback applied";"1");
      @("INC-016";"2026-04-05";"Admin panel RBAC bypass";"P1";"resolved";"Security";"4";"missing middleware on new route";"1");
      @("INC-017";"2026-04-08";"Promotional email batch failure";"P3";"resolved";"Ops";"3";"SMTP quota exceeded";"2");
      @("INC-018";"2026-04-10";"Slow product search QLD region";"P2";"resolved";"Platform";"6";"regional CDN node degraded";"1");
      // ANOMALY: unresolved
      @("INC-019";"2026-04-14";"Returns portal 500 errors";"P2";"open";"Platform";"0";"under investigation";"1");
      @("INC-020";"2026-04-15";"Payment gateway timeout";"P2";"resolved";"Payments";"3";"third-party API rate limit (recurrence)";"1");
      @("INC-021";"2026-04-16";"Inventory discrepancy FC-ADL";"P3";"resolved";"Fulfilment";"10";"manual count reconciliation error";"1");
      @("INC-022";"2026-04-17";"Slow order processing";"P2";"resolved";"Platform";"5";"background job queue deadlock";"1")
    )
  }
}

// ── Dataset 5: wc_feedback ─────────────────────────────────────────────────────
// 7 columns, 40 rows.
// Verbatim quotes — no PII, shows text analysis potential.
// Some verbatim mention delivery delays.

pub f=get_feedback():compute.$dataset{
  <compute.$dataset{
    name="wc_feedback";
    headers=@(
      "feedback_id";"user_id";"date";"nps_score";"category";"verbatim";"sentiment"
    );
    rows=@(
      @("FB-001";"U-001";"2026-03-21";"9";"delivery";"Arrived next day, exactly as described. Very happy.";"positive");
