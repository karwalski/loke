// MK4.3 — Wattle & Co IT Web Platform
// 6 linked datasets for an Australian e-commerce platform.
// PII columns: email, full_name (wc_users).

m=moke.data.it_platform;
i=compute:moke.compute;

// ── Dataset 1: wc_users ────────────────────────────────────────────────────────
// 10 columns, 50 rows.
// PII: email, full_name.
// Some users inactive or suspended.

