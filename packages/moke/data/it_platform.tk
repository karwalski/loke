// ── Registry ──────────────────────────────────────────────────────────────────

pub f=list_datasets():@(str){
  <@("wc_users";"wc_orders";"wc_traffic";"wc_incidents";"wc_feedback";"wc_shipping")
}

pub f=get_by_name(name:str):compute.$dataset{
  if name == "wc_users"     { <get_users() };
  if name == "wc_orders"    { <get_orders() };
  if name == "wc_traffic"   { <get_traffic() };
  if name == "wc_incidents" { <get_incidents() };
  if name == "wc_feedback"  { <get_feedback() };
  if name == "wc_shipping"  { <get_shipping() };
  <compute.$dataset{
    name="not_found";
    headers=@();
    rows=@()
  }
}
