// MK3 — Dashboard page handler.
// Serves GET /dashboard — renders the moke dashboard view via the ooke
// template engine. All dynamic behaviour (phase1/2/3, Chart.js rendering,
// refine flow) is handled client-side by the JavaScript in dashboard.tkt.

m=page.moke.dashboard;
i=http:std.http;
i=tpl:ooke.template;

f=get(req:http.$req):http.$res{
  <tpl.renderfile("templates/dashboard.tkt"; @())
}
