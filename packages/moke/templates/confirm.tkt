{! layout("base") !}
{! block("title") !}moke — confirm{! end !}
{! block("content") !}
<style>
  /* ── layout ── */
  .confirm-wrap { max-width: 1020px; margin: 0 auto; }
  .confirm-header { display: flex; align-items: center; gap: 14px; margin-bottom: 22px; }
  .confirm-title { font-size: 1.25em; font-weight: 700; letter-spacing: -0.02em; }
  .sensitivity-pill {
    font-size: 0.72em; font-weight: 700; padding: 3px 11px; border-radius: 20px;
    background: rgba(239,68,68,.15); color: var(--red);
    border: 1px solid rgba(239,68,68,.35);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .session-id { font-size: 0.78em; color: var(--muted); margin-left: auto; font-family: monospace; }

  /* ── diff grid ── */
  .diff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .diff-panel { display: flex; flex-direction: column; gap: 8px; }
  .diff-panel-head {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.78em; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--muted);
  }
  .diff-panel-head .lock-icon { color: var(--green); font-size: 1em; }
  .diff-panel-head .send-icon { color: var(--amber); font-size: 1em; }
  .diff-box {
    background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
    padding: 14px 16px; font-size: 0.88em; line-height: 1.65;
    white-space: pre-wrap; min-height: 220px; overflow-y: auto; max-height: 340px;
  }
  .diff-box.local-side { border-color: rgba(34,197,94,.25); }
  .diff-box.llm-side   { border-color: rgba(245,158,11,.25); }

  /* redacted spans */
  .redact {
    background: rgba(239,68,68,.18); color: var(--red);
    border-radius: 3px; padding: 1px 5px;
    font-family: monospace; font-size: 0.92em;
  }
  .toon-tag {
    background: rgba(99,102,241,.18); color: #a5b4fc;
    border-radius: 3px; padding: 1px 5px;
    font-family: monospace; font-size: 0.92em;
  }

  /* ── PII summary ── */
  .pii-bar {
    background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
    padding: 14px 18px; margin-bottom: 18px;
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
  }
  .pii-bar-label { font-size: 0.88em; color: var(--muted); margin-right: 4px; }
  .pii-count { font-size: 0.88em; font-weight: 700; color: var(--text); }
  .pii-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.28);
    color: var(--amber); border-radius: 4px; padding: 2px 9px; font-size: 0.78em; font-weight: 600;
  }

  /* ── system prompt preview ── */
  .sysprompt-wrap {
    background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
    margin-bottom: 18px; overflow: hidden;
  }
  .sysprompt-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; border-bottom: 1px solid var(--border); cursor: pointer;
    user-select: none;
  }
  .sysprompt-head span { font-size: 0.8em; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); }
  .sysprompt-head .toggle-caret { color: var(--muted); font-size: 0.85em; transition: transform 0.15s; }
  .sysprompt-head.open .toggle-caret { transform: rotate(90deg); }
  .sysprompt-body {
    display: none; padding: 14px 16px;
    font-size: 0.85em; line-height: 1.65; color: var(--muted);
    white-space: pre-wrap; max-height: 220px; overflow-y: auto;
  }
  .sysprompt-body.visible { display: block; }

  /* ── action row ── */
  .action-row {
    display: flex; align-items: center; gap: 14px; justify-content: flex-end;
    padding-top: 6px;
  }
  .dont-ask-label {
    display: flex; align-items: center; gap: 7px;
    font-size: 0.83em; color: var(--muted); margin-right: auto; cursor: pointer;
  }
  .dont-ask-label input[type="checkbox"] { accent-color: var(--accent); width: 14px; height: 14px; cursor: pointer; }
  .btn { padding: 10px 26px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.95em; font-weight: 600; transition: opacity 0.1s; }
  .btn:hover { opacity: 0.88; }
  .btn-approve { background: var(--accent); color: #fff; }
  .btn-edit    { background: transparent; color: var(--text); border: 1px solid var(--border); }
  .btn-cancel  { background: transparent; color: var(--red); border: 1px solid rgba(239,68,68,.4); }

  /* ── teal accent for moke theme ── */
  :root {
    --accent: #0d9488;       /* teal-600 */
    --accent-muted: rgba(13,148,136,.15);
  }
  .btn-approve { background: var(--accent); }
</style>

<div class="confirm-wrap">

  <!-- header -->
  <div class="confirm-header">
    <div class="confirm-title">Confirm Before Sending</div>
    <div class="sensitivity-pill" id="sensitivity-pill">CONFIDENTIAL</div>
    <div class="session-id" id="session-id-label">session: —</div>
  </div>

  <!-- PII summary bar -->
  <div class="pii-bar">
    <span class="pii-bar-label">Anonymisation:</span>
    <span class="pii-count" id="pii-count-label">— entities detected and anonymised</span>
    <span class="pii-chip" id="pii-chip-name" style="display:none">PERSON</span>
    <span class="pii-chip" id="pii-chip-medicare" style="display:none">MEDICARE_ID</span>
    <span class="pii-chip" id="pii-chip-dob" style="display:none">DATE_OF_BIRTH</span>
    <span class="pii-chip" id="pii-chip-address" style="display:none">ADDRESS</span>
    <span class="pii-chip" id="pii-chip-phone" style="display:none">PHONE</span>
    <span class="pii-chip" id="pii-chip-email" style="display:none">EMAIL</span>
  </div>

  <!-- diff grid -->
  <div class="diff-grid">

    <!-- LEFT: stays local -->
    <div class="diff-panel">
      <div class="diff-panel-head">
        <span class="lock-icon">⬛</span>
        <span>What stays local</span>
      </div>
      <div class="diff-box local-side" id="local-content">
<!-- placeholder: realistic Medicare row -->
patient_id,name,dob,medicare_id,address,phone,query
P-00419,<span class="redact">Margaret Kowalski</span>,<span class="redact">1961-03-14</span>,<span class="redact">2145 8821 3</span>,"<span class="redact">12 Harbour St, Pyrmont NSW 2009</span>",<span class="redact">0412 881 203</span>,"What are common treatment options for stage 2 hypertension?"

Schema profile (raw):
  • patient_id      → categorical   [P-00419, P-00420 …]
  • name            → text          [PII ✗]
  • dob             → datetime      [PII ✗]
  • medicare_id     → categorical   [PII ✗]
  • address         → text          [PII ✗]
  • phone           → categorical   [PII ✗]
  • query           → text          avg_len=52
</div>
    </div>

    <!-- RIGHT: goes to LLM -->
    <div class="diff-panel">
      <div class="diff-panel-head">
        <span class="send-icon">▲</span>
        <span>What goes to the LLM</span>
      </div>
      <div class="diff-box llm-side" id="llm-content">
<!-- placeholder: TOON profile + anonymised prompt -->
TOON profile (no raw values):
  • patient_id      → categorical   unique=1
  • name            → text          [SUPPRESSED]
  • dob             → datetime      [SUPPRESSED]
  • medicare_id     → categorical   [SUPPRESSED]
  • address         → text          [SUPPRESSED]
  • phone           → categorical   [SUPPRESSED]
  • query           → text          avg_len=52

Anonymised prompt:
"What are common treatment options for stage 2 hypertension?"

Substitutions applied:
  <span class="toon-tag">PERSON_1</span> → Margaret Kowalski
  <span class="toon-tag">MEDICARE_1</span> → 2145 8821 3
  <span class="toon-tag">DOB_1</span> → 1961-03-14
  <span class="toon-tag">ADDRESS_1</span> → 12 Harbour St, Pyrmont NSW 2009
  <span class="toon-tag">PHONE_1</span> → 0412 881 203
</div>
    </div>

  </div>

  <!-- system prompt preview (collapsible) -->
  <div class="sysprompt-wrap">
    <div class="sysprompt-head" id="sysprompt-toggle" onclick="toggleSysprompt()">
      <span>System prompt preview</span>
      <span class="toggle-caret">▶</span>
    </div>
    <div class="sysprompt-body" id="sysprompt-body">You are a helpful medical information assistant operating under strict governance constraints.

SCHEMA-FIRST INSTRUCTION: The dataset provided contains 7 columns. Respond only with reference to the anonymised schema profile. Do not request, infer, or reconstruct personal identifiers.

GUARDIAN CONSTRAINT: This request has been routed via loke privacy proxy. All entity tokens (PERSON_1, MEDICARE_1, DOB_1, ADDRESS_1, PHONE_1) are placeholders — do not ask the user to clarify or reveal the underlying values. Treat them as opaque identifiers.

SENSITIVITY: CONFIDENTIAL — responses must not include advice that could identify individuals. Present information in general terms only.</div>
  </div>

  <!-- action row -->
  <div class="action-row">
    <label class="dont-ask-label">
      <input type="checkbox" id="dont-ask-again">
      Don't ask again this session
    </label>
    <button class="btn btn-cancel" onclick="cancelConfirm()">Cancel</button>
    <button class="btn btn-edit"   onclick="editConfirm()">Edit prompt</button>
    <button class="btn btn-approve" onclick="approveConfirm()">Approve &amp; send →</button>
  </div>

</div>

<script>
// ── load pending state from sessionStorage ──
const pending = JSON.parse(sessionStorage.getItem('moke_pending') || '{}');
const sessionId = pending.session_id || 'unknown';

document.getElementById('session-id-label').textContent = 'session: ' + sessionId;

// sensitivity pill
const pill = document.getElementById('sensitivity-pill');
const s = pending.sensitivity || 'CONFIDENTIAL';
pill.textContent = s;
if (s === 'RESTRICTED') {
  pill.style.background = 'rgba(239,68,68,.2)';
  pill.style.borderColor = 'rgba(239,68,68,.5)';
} else if (s === 'INTERNAL') {
  pill.style.background = 'rgba(245,158,11,.15)';
  pill.style.color = 'var(--amber)';
  pill.style.borderColor = 'rgba(245,158,11,.35)';
} else if (s === 'PUBLIC') {
  pill.style.background = 'rgba(34,197,94,.15)';
  pill.style.color = 'var(--green)';
  pill.style.borderColor = 'rgba(34,197,94,.35)';
}

// PII chips
const entities = pending.entities || [];
const entityTypes = pending.entity_types || {};
document.getElementById('pii-count-label').textContent =
  entities.length + ' entit' + (entities.length === 1 ? 'y' : 'ies') + ' detected and anonymised';
const chipMap = {
  PERSON: 'pii-chip-name', MEDICARE_ID: 'pii-chip-medicare',
  DATE_OF_BIRTH: 'pii-chip-dob', ADDRESS: 'pii-chip-address',
  PHONE: 'pii-chip-phone', EMAIL: 'pii-chip-email'
};
Object.entries(chipMap).forEach(([type, id]) => {
  if (entityTypes[type] || entities.some(e => e.startsWith(type))) {
    document.getElementById(id).style.display = 'inline-flex';
  }
});

// live content injection (overrides placeholder if pending has content)
if (pending.local_view) {
  document.getElementById('local-content').textContent = pending.local_view;
}
if (pending.llm_view) {
  document.getElementById('llm-content').textContent = pending.llm_view;
}
if (pending.system_prompt) {
  document.getElementById('sysprompt-body').textContent = pending.system_prompt;
}

// ── collapsible system prompt ──
function toggleSysprompt() {
  const head = document.getElementById('sysprompt-toggle');
  const body = document.getElementById('sysprompt-body');
  head.classList.toggle('open');
  body.classList.toggle('visible');
}

// ── actions ──
function cancelConfirm() {
  sessionStorage.removeItem('moke_pending');
  window.history.back();
}

function editConfirm() {
  // Surface the LLM-side content in an inline editable state.
  // For now redirect to approve page where full editing is supported.
  window.location = '/approve';
}

async function approveConfirm() {
  const dontAsk = document.getElementById('dont-ask-again').checked;
  if (dontAsk) {
    sessionStorage.setItem('moke_skip_confirm_session', '1');
  }
  pending.approved = true;
  pending.dont_ask_session = dontAsk;
  sessionStorage.setItem('moke_pending', JSON.stringify(pending));
  try {
    const res = await fetch('/api/moke/pipeline', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ approved: true, session_id: sessionId, ...pending })
    });
    const data = await res.json();
    sessionStorage.setItem('moke_result', JSON.stringify(data));
  } catch (err) {
    console.error('moke pipeline error', err);
  }
  window.location = '/';
}
</script>
{! end !}
