{! layout("base") !}
{! block("title") !}moke — presentation{! end !}
{! block("content") !}
<style>
  /* ── hide sidebar / app chrome, fill viewport ── */
  .sidebar      { display: none !important; }
  .app-header   { display: none !important; }
  .app-body     { display: block !important; }
  .app-main     { padding: 0 !important; overflow: hidden !important; }
  .main-content { width: 100% !important; max-width: 100% !important; padding: 0 !important; }
  main          { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }

  /* ── presentation shell ── */
  :root {
    --pres-bg:      #090b11;
    --pres-surface: #111520;
    --pres-border:  #1e2235;
    --pres-accent:  #0d9488;   /* moke teal */
    --pres-text:    #e8eaf0;
    --pres-muted:   #4b5563;
    --pres-dim:     rgba(255,255,255,.06);
  }

  body { background: var(--pres-bg); color: var(--pres-text); overflow: hidden; }
  header { display: none !important; }

  #pres-root {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    background: var(--pres-bg);
    user-select: none;
  }

  /* ── top bar ── */
  #pres-topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 24px;
    border-bottom: 1px solid var(--pres-border);
    flex-shrink: 0;
    z-index: 10;
  }
  #pres-wordmark {
    font-size: 0.85em; font-weight: 700; letter-spacing: 0.06em;
    color: var(--pres-accent); text-transform: uppercase;
  }
  #pres-card-title {
    font-size: 0.95em; font-weight: 600; color: var(--pres-text);
    opacity: 0.85; letter-spacing: -0.01em;
  }
  #pres-timer {
    font-size: 0.82em; font-family: monospace; color: var(--pres-muted);
    min-width: 52px; text-align: right;
  }

  /* ── slide stage ── */
  #pres-stage {
    flex: 1;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }

  .pres-slide {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    padding: 48px;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.28s ease, transform 0.28s ease;
    pointer-events: none;
  }
  .pres-slide.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .pres-slide.exit-left {
    opacity: 0;
    transform: translateX(-60px);
  }

  /* ── slide inner card ── */
  .slide-card {
    background: var(--pres-surface);
    border: 1px solid var(--pres-border);
    border-radius: 18px;
    width: 100%; max-width: 900px;
    padding: 52px 60px;
    box-shadow: 0 24px 80px rgba(0,0,0,.55);
    display: flex; flex-direction: column; gap: 28px;
  }

  .slide-label {
    font-size: 0.72em; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--pres-accent);
  }
  .slide-heading {
    font-size: 1.65em; font-weight: 700; letter-spacing: -0.03em;
    line-height: 1.2; color: var(--pres-text);
  }
  .slide-sub {
    font-size: 0.92em; color: var(--pres-muted); line-height: 1.6;
  }

  /* ── metric card variant ── */
  .slide-metric {
    display: flex; flex-direction: column; align-items: center;
    gap: 14px; text-align: center; padding: 20px 0;
  }
  .slide-metric .metric-value {
    font-size: 4em; font-weight: 800; letter-spacing: -0.04em;
    color: var(--pres-accent); line-height: 1;
  }
  .slide-metric .metric-label {
    font-size: 1em; color: var(--pres-muted); font-weight: 500;
  }
  .slide-metric .metric-change {
    font-size: 0.88em; font-weight: 600;
    padding: 4px 14px; border-radius: 20px;
    background: rgba(13,148,136,.15); color: var(--pres-accent);
    border: 1px solid rgba(13,148,136,.3);
  }

  /* ── chart container ── */
  .slide-chart-wrap {
    width: 100%; height: 340px; position: relative;
  }
  .slide-chart-wrap canvas {
    width: 100% !important; height: 100% !important;
  }

  /* ── table variant ── */
  .slide-table-wrap {
    overflow-x: auto;
  }
  .slide-table {
    width: 100%; border-collapse: collapse; font-size: 0.88em;
  }
  .slide-table th {
    text-align: left; padding: 10px 14px;
    border-bottom: 1px solid var(--pres-border);
    font-size: 0.78em; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--pres-muted); font-weight: 600;
  }
  .slide-table td {
    padding: 11px 14px; border-bottom: 1px solid var(--pres-dim);
    color: var(--pres-text);
  }
  .slide-table tr:last-child td { border-bottom: none; }
  .slide-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .rank-badge {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 50%;
    background: rgba(13,148,136,.2); color: var(--pres-accent);
    font-size: 0.75em; font-weight: 700;
  }

  /* ── edge nav arrow overlays ── */
  .edge-arrow {
    position: absolute; top: 0; bottom: 0;
    width: 72px;
    display: flex; align-items: center; justify-content: center;
    background: transparent;
    border: none; cursor: pointer;
    color: rgba(255,255,255,.18);
    font-size: 2.4em;
    transition: color 0.18s, background 0.18s;
    z-index: 5;
  }
  .edge-arrow:hover {
    color: rgba(255,255,255,.7);
    background: linear-gradient(to right, rgba(255,255,255,.04), transparent);
  }
  #edge-prev { left: 0; background: linear-gradient(to right, rgba(0,0,0,.18), transparent); }
  #edge-next { right: 0; background: linear-gradient(to left, rgba(0,0,0,.18), transparent); }
  #edge-prev:hover { background: linear-gradient(to right, rgba(0,0,0,.32), transparent); }
  #edge-next:hover { background: linear-gradient(to left, rgba(0,0,0,.32), transparent); }
  .edge-arrow:disabled { opacity: 0.15; cursor: default; }

  /* ── bottom controls ── */
  #pres-controls {
    display: flex; align-items: center; justify-content: center;
    gap: 14px; padding: 14px 24px;
    border-top: 1px solid var(--pres-border);
    flex-shrink: 0;
    position: relative;
  }
  .pres-btn {
    background: var(--pres-dim); border: 1px solid var(--pres-border);
    color: var(--pres-text); padding: 8px 20px; border-radius: 8px;
    cursor: pointer; font-size: 0.88em; font-weight: 600;
    transition: background 0.15s, border-color 0.15s;
  }
  .pres-btn:hover { background: rgba(13,148,136,.15); border-color: var(--pres-accent); }
  .pres-btn:disabled { opacity: 0.3; cursor: default; }
  .pres-btn.exit-btn { color: var(--pres-muted); font-size: 0.82em; padding: 6px 14px; }
  .pres-btn.play-btn { min-width: 80px; }
  .pres-btn.play-btn.playing {
    background: rgba(13,148,136,.2); border-color: var(--pres-accent);
    color: var(--pres-accent);
  }

  /* ── slide counter ── */
  #pres-counter {
    font-size: 0.82em; color: var(--pres-muted);
    font-variant-numeric: tabular-nums;
    min-width: 48px; text-align: center;
  }

  /* ── dot progress ── */
  #pres-dots { display: flex; gap: 8px; align-items: center; }
  .pres-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--pres-border);
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .pres-dot.active {
    background: var(--pres-accent);
    transform: scale(1.4);
  }

  /* ── auto-cycle progress bar ── */
  #pres-progress-bar-wrap {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px;
    background: transparent;
    overflow: hidden;
    pointer-events: none;
  }
  #pres-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--pres-accent);
    transition: width linear;
  }

  /* ── help overlay ── */
  #help-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 100;
    background: rgba(9,11,17,.88);
    backdrop-filter: blur(6px);
    align-items: center; justify-content: center;
  }
  #help-overlay.visible { display: flex; }
  #help-panel {
    background: var(--pres-surface);
    border: 1px solid var(--pres-border);
    border-radius: 14px;
    padding: 32px 40px;
    max-width: 440px; width: 100%;
    box-shadow: 0 16px 60px rgba(0,0,0,.5);
  }
  #help-panel h3 {
    font-size: 0.78em; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--pres-accent); margin-bottom: 20px;
  }
  .help-row {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 9px 0; border-bottom: 1px solid var(--pres-dim);
    font-size: 0.9em;
  }
  .help-row:last-of-type { border-bottom: none; }
  .help-keys { display: flex; gap: 6px; }
  .help-desc { color: var(--pres-muted); text-align: right; }
  #help-panel kbd {
    background: var(--pres-dim); border: 1px solid var(--pres-border);
    border-radius: 4px; padding: 2px 8px; font-family: monospace;
    font-size: 0.9em; color: var(--pres-text);
  }
  #help-close {
    margin-top: 20px; width: 100%;
    background: none; border: 1px solid var(--pres-border);
    color: var(--pres-muted); border-radius: 8px; padding: 9px;
    cursor: pointer; font-size: 0.85em;
    transition: border-color 0.15s;
  }
  #help-close:hover { border-color: var(--pres-accent); color: var(--pres-text); }

  /* ── no-DDL prompt ── */
  #pres-no-ddl {
    display: none;
    position: fixed; inset: 0; z-index: 200;
    background: var(--pres-bg);
    align-items: center; justify-content: center;
    flex-direction: column; gap: 20px;
    text-align: center; padding: 40px;
  }
  #pres-no-ddl.visible { display: flex; }
  #pres-no-ddl h2 { font-size: 1.4em; font-weight: 700; color: var(--pres-text); }
  #pres-no-ddl p  { color: var(--pres-muted); max-width: 420px; line-height: 1.6; }

  /* ── fullscreen toast ── */
  #fs-toast {
    display: none;
    position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
    background: var(--pres-surface); border: 1px solid var(--pres-border);
    border-radius: 8px; padding: 10px 20px;
    font-size: 0.82em; color: var(--pres-muted);
    z-index: 200; animation: fadeout 2.5s forwards;
  }
  @keyframes fadeout { 0%{opacity:1} 70%{opacity:1} 100%{opacity:0} }
</style>

<!-- No-DDL fallback prompt -->
<div id="pres-no-ddl">
  <h2>No dashboard loaded</h2>
  <p>Go to the Dashboard, generate or load a dashboard, then click <strong>&#9654; Present</strong> to launch presentation mode.</p>
  <button class="pres-btn" onclick="window.location.href='/dashboard'">Go to Dashboard</button>
</div>

<!-- Presentation root -->
<div id="pres-root">

  <!-- Top bar -->
  <div id="pres-topbar">
    <div id="pres-wordmark">moke — presentation</div>
    <div id="pres-card-title">Loading…</div>
    <div id="pres-timer">0:00</div>
  </div>

  <!-- Slide stage -->
  <div id="pres-stage">

    <!-- Edge nav arrows (overlay) -->
    <button class="edge-arrow" id="edge-prev" onclick="navigate(-1)" disabled aria-label="Previous slide">&#8249;</button>
    <button class="edge-arrow" id="edge-next" onclick="navigate(1)" aria-label="Next slide">&#8250;</button>

    <!-- Slide 1: Total Customers metric -->
    <div class="pres-slide active" data-idx="0"
         data-title="Total Customers"
         data-type="metric">
      <div class="slide-card">
        <div class="slide-label">Key Metric</div>
        <div class="slide-heading">Total Customers</div>
        <div class="slide-metric">
          <div class="metric-value" id="metric-total">12,489</div>
          <div class="metric-label">unique customers in dataset</div>
          <div class="metric-change">+8.4% vs prior period</div>
        </div>
        <div class="slide-sub">
          Active dataset: <strong>customers.csv</strong> — 8 columns, last uploaded this session.
          Count computed locally — no data left the device.
        </div>
      </div>
    </div>

    <!-- Slide 2: Customer Clusters scatter chart -->
    <div class="pres-slide" data-idx="1"
         data-title="Customer Clusters"
         data-type="chart">
      <div class="slide-card">
        <div class="slide-label">ML Analysis — K-Means k=4</div>
        <div class="slide-heading">Customer Clusters</div>
        <div class="slide-chart-wrap">
          <canvas id="chart-scatter"></canvas>
        </div>
        <div class="slide-sub">
          Clustered on <strong>total_spend</strong> × <strong>session_count</strong>.
          Computed locally — inertia 142.3, 23 iterations.
        </div>
      </div>
    </div>

    <!-- Slide 3: Revenue Trend line chart -->
    <div class="pres-slide" data-idx="2"
         data-title="Revenue Trend"
         data-type="chart">
      <div class="slide-card">
        <div class="slide-label">Trend Analysis — Daily Revenue</div>
        <div class="slide-heading">Revenue Trend</div>
        <div class="slide-chart-wrap">
          <canvas id="chart-line"></canvas>
        </div>
        <div class="slide-sub">
          30-day rolling sum of <strong>order_value</strong> grouped by <strong>order_date</strong>.
          No raw values sent to LLM.
        </div>
      </div>
    </div>

    <!-- Slide 4: Top Customers table -->
    <div class="pres-slide" data-idx="3"
         data-title="Top Customers"
         data-type="table">
      <div class="slide-card">
        <div class="slide-label">Top-N Analysis</div>
        <div class="slide-heading">Top Customers by Spend</div>
        <div class="slide-table-wrap">
          <table class="slide-table" id="table-top">
            <thead>
              <tr>
                <th>#</th>
                <th>Customer ID</th>
                <th>Segment</th>
                <th style="text-align:right">Total Spend</th>
                <th style="text-align:right">Sessions</th>
              </tr>
            </thead>
            <tbody id="table-top-body">
              <!-- populated by JS -->
            </tbody>
          </table>
        </div>
        <div class="slide-sub">
          Top 10 of 12,489 customers · ranked by <strong>total_spend</strong> ·
          names suppressed by loke privacy filter.
        </div>
      </div>
    </div>

  </div><!-- /pres-stage -->

  <!-- Bottom controls -->
  <div id="pres-controls">
    <button class="pres-btn exit-btn" onclick="exitPresentation()">&#10005; exit</button>
    <button class="pres-btn" id="btn-prev" onclick="navigate(-1)" disabled>&#8249; prev</button>
    <div id="pres-dots"></div>
    <div id="pres-counter">1 / 4</div>
    <button class="pres-btn" id="btn-next" onclick="navigate(1)">next &#8250;</button>
    <button class="pres-btn play-btn" id="btn-play" onclick="toggleAutoCycle()" style="margin-left:8px">&#9654; Play</button>
    <button class="pres-btn" onclick="toggleFullscreen()" style="margin-left:4px" title="Fullscreen (F)">&#x26F6;</button>
    <button class="pres-btn" onclick="toggleHelp()" style="margin-left:4px" title="Keyboard shortcuts (?)">?</button>
    <!-- Auto-cycle progress bar sits at very bottom of controls bar -->
    <div id="pres-progress-bar-wrap"><div id="pres-progress-bar"></div></div>
  </div>

</div><!-- /pres-root -->

<!-- Help overlay (keyboard shortcuts) -->
<div id="help-overlay">
  <div id="help-panel">
    <h3>Keyboard shortcuts</h3>
    <div class="help-row">
      <div class="help-keys"><kbd>&#8592;</kbd> <kbd>&#8594;</kbd></div>
      <div class="help-desc">Navigate cards</div>
    </div>
    <div class="help-row">
      <div class="help-keys"><kbd>Space</kbd> <kbd>P</kbd></div>
      <div class="help-desc">Play / pause auto-cycle</div>
    </div>
    <div class="help-row">
      <div class="help-keys"><kbd>F</kbd></div>
      <div class="help-desc">Toggle fullscreen</div>
    </div>
    <div class="help-row">
      <div class="help-keys"><kbd>ESC</kbd></div>
      <div class="help-desc">Exit presentation</div>
    </div>
    <div class="help-row">
      <div class="help-keys"><kbd>?</kbd></div>
      <div class="help-desc">This help</div>
    </div>
    <button id="help-close" onclick="toggleHelp()">Close  (press ?)</button>
  </div>
</div>

<!-- Fullscreen toast -->
<div id="fs-toast">Press F11 to enter fullscreen</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
// ── DDL from sessionStorage ────────────────────────────────────────────────
(function checkDDL() {
  const raw = sessionStorage.getItem('moke_dashboard_ddl');
  if (!raw) {
    document.getElementById('pres-no-ddl').classList.add('visible');
    document.getElementById('pres-root').style.display = 'none';
  }
  // If DDL is present the static demo slides are shown; a future iteration
  // could render slides dynamically from the DDL cards.
})();

// ── State ─────────────────────────────────────────────────────────────────────
const slides      = Array.from(document.querySelectorAll('.pres-slide'));
const totalSlides = slides.length;
let currentIdx    = 0;
let timerSeconds  = 0;
let timerInterval = null;
let helpOpen      = false;
let chartsReady   = {};

// Auto-cycle state
const AUTO_CYCLE_SECS = 8;
let autoCycling       = false;
let cycleTimeout      = null;
let progressRafId     = null;
let cycleStartedAt    = null;

// Demo table data (anonymised — no PII)
const demoCustomers = [
  { id: 'C-0047', segment: 'Enterprise', spend: '$184,200', sessions: 412 },
  { id: 'C-0112', segment: 'Enterprise', spend: '$141,880', sessions: 388 },
  { id: 'C-0831', segment: 'Mid-Market', spend: ' $98,450', sessions: 201 },
  { id: 'C-0209', segment: 'Mid-Market', spend: ' $87,310', sessions: 178 },
  { id: 'C-1044', segment: 'SMB',        spend: ' $74,920', sessions: 320 },
  { id: 'C-0674', segment: 'Enterprise', spend: ' $69,750', sessions: 144 },
  { id: 'C-0388', segment: 'SMB',        spend: ' $61,040', sessions: 289 },
  { id: 'C-1122', segment: 'Mid-Market', spend: ' $55,880', sessions: 167 },
  { id: 'C-0503', segment: 'SMB',        spend: ' $48,320', sessions: 241 },
  { id: 'C-0714', segment: 'Mid-Market', spend: ' $43,100', sessions: 133 },
];

// Chart.js global defaults for dark theme
Chart.defaults.color           = '#6b7280';
Chart.defaults.borderColor     = '#1e2235';
Chart.defaults.backgroundColor = 'rgba(13,148,136,.2)';

// ── Timer ─────────────────────────────────────────────────────────────────────
function startTimer() {
  timerInterval = setInterval(() => {
    timerSeconds++;
    updateTimerDisplay();
  }, 1000);
}

function updateTimerDisplay() {
  const m = Math.floor(timerSeconds / 60);
  const s = String(timerSeconds % 60).padStart(2, '0');
  document.getElementById('pres-timer').textContent = `${m}:${s}`;
}

// ── Navigation ────────────────────────────────────────────────────────────────
function navigate(delta) {
  const next = (currentIdx + delta + totalSlides) % totalSlides;
  // If at the boundaries without wrap, stop auto-cycle direction cues but
  // still allow manual wrap for auto-cycle. For manual nav don't wrap.
  if (!autoCycling) {
    const clamped = currentIdx + delta;
    if (clamped < 0 || clamped >= totalSlides) return;
    goTo(clamped, delta < 0 ? 'left' : 'right');
  } else {
    goTo(next, delta < 0 ? 'left' : 'right');
  }
}

function goTo(idx, direction) {
  if (idx === currentIdx) return;
  const current = slides[currentIdx];
  const target  = slides[idx];

  current.classList.remove('active');
  current.classList.add('exit-left');
  setTimeout(() => { current.classList.remove('exit-left'); }, 300);

  target.style.transform = direction === 'left' ? 'translateX(-60px)' : 'translateX(60px)';
  target.style.opacity   = '0';
  target.classList.add('active');
  requestAnimationFrame(() => {
    target.style.transform = '';
    target.style.opacity   = '';
  });

  currentIdx = idx;
  updateControls();
  initSlide(idx);
}

function updateControls() {
  document.getElementById('btn-prev').disabled   = currentIdx === 0;
  document.getElementById('btn-next').disabled   = currentIdx === totalSlides - 1;
  document.getElementById('edge-prev').disabled  = currentIdx === 0;
  document.getElementById('edge-next').disabled  = currentIdx === totalSlides - 1;

  // Card title in topbar
  const slide = slides[currentIdx];
  document.getElementById('pres-card-title').textContent = slide.dataset.title || '';

  // Counter at bottom
  document.getElementById('pres-counter').textContent = `${currentIdx + 1} / ${totalSlides}`;

  // Dot indicator
  document.querySelectorAll('.pres-dot').forEach((dot, i) => {
    dot.classList.toggle('active', i === currentIdx);
  });
}

// ── Dot navigation ────────────────────────────────────────────────────────────
function buildDots() {
  const container = document.getElementById('pres-dots');
  slides.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'pres-dot' + (i === 0 ? ' active' : '');
    dot.onclick = () => goTo(i, i > currentIdx ? 'right' : 'left');
    container.appendChild(dot);
  });
}

// ── Auto-cycle ────────────────────────────────────────────────────────────────
function toggleAutoCycle() {
  if (autoCycling) {
    stopAutoCycle();
  } else {
    startAutoCycle();
  }
}

function startAutoCycle() {
  autoCycling = true;
  const btn = document.getElementById('btn-play');
  btn.textContent = '⏸ Pause';
  btn.classList.add('playing');
  scheduleNextSlide();
}

function stopAutoCycle() {
  autoCycling = false;
  clearTimeout(cycleTimeout);
  cancelAnimationFrame(progressRafId);
  cycleTimeout   = null;
  cycleStartedAt = null;
  const btn = document.getElementById('btn-play');
  btn.textContent = '▶ Play';
  btn.classList.remove('playing');
  // Reset progress bar
  const bar = document.getElementById('pres-progress-bar');
  bar.style.transition = 'none';
  bar.style.width = '0%';
}

function scheduleNextSlide() {
  cycleStartedAt = performance.now();
  const durationMs = AUTO_CYCLE_SECS * 1000;

  // Animate the progress bar
  const bar = document.getElementById('pres-progress-bar');
  bar.style.transition = 'none';
  bar.style.width = '0%';
  // Force reflow so transition reset is applied
  void bar.offsetWidth;
  bar.style.transition = `width ${durationMs}ms linear`;
  bar.style.width = '100%';

  cycleTimeout = setTimeout(() => {
    if (!autoCycling) return;
    // Advance (wraps around)
    const next = (currentIdx + 1) % totalSlides;
    goTo(next, 'right');
    scheduleNextSlide();
  }, durationMs);
}

// ── Fullscreen ────────────────────────────────────────────────────────────────
function toggleFullscreen() {
  if (!document.fullscreenElement) {
    document.documentElement.requestFullscreen().catch(() => showFsToast());
  } else {
    document.exitFullscreen();
  }
}

function showFsToast() {
  const t = document.getElementById('fs-toast');
  t.style.display = 'block';
  setTimeout(() => { t.style.display = 'none'; }, 2600);
}

// ── Help overlay ──────────────────────────────────────────────────────────────
function toggleHelp() {
  helpOpen = !helpOpen;
  document.getElementById('help-overlay').classList.toggle('visible', helpOpen);
}

// ── Exit ──────────────────────────────────────────────────────────────────────
function exitPresentation() {
  if (document.fullscreenElement) document.exitFullscreen();
  window.location.href = '/dashboard';
}

// ── Keyboard handling ─────────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (helpOpen && e.key !== '?') { return; }
  switch (e.key) {
    case 'ArrowRight': case 'ArrowDown':
      if (!autoCycling) navigate(1);
      break;
    case 'ArrowLeft':  case 'ArrowUp':
      if (!autoCycling) navigate(-1);
      break;
    case 'Escape':
      if (helpOpen) { toggleHelp(); }
      else           { exitPresentation(); }
      break;
    case 'f': case 'F':
      e.preventDefault();
      toggleFullscreen();
      break;
    case ' ':
      e.preventDefault();
      toggleAutoCycle();
      break;
    case 'p': case 'P':
      toggleAutoCycle();
      break;
    case '?':
      toggleHelp();
      break;
  }
});

// ── Chart rendering ───────────────────────────────────────────────────────────
const TEAL   = 'rgba(13,148,136,1)';
const TEAL_D = 'rgba(13,148,136,.25)';
const PALETTE = [
  'rgba(13,148,136,.85)',
  'rgba(99,102,241,.85)',
  'rgba(245,158,11,.85)',
  'rgba(239,68,68,.85)',
];

function initSlide(idx) {
  if (chartsReady[idx]) return;
  chartsReady[idx] = true;

  const slide = slides[idx];
  const type  = slide.dataset.type;

  if (type === 'chart' && idx === 1) { renderScatter(); }
  if (type === 'chart' && idx === 2) { renderLine();    }
  if (type === 'table' && idx === 3) { renderTable();   }
}

function renderScatter() {
  const ctx = document.getElementById('chart-scatter').getContext('2d');
  const clusterData = [
    { label: 'Cluster 1 — Low spend / High freq',  color: PALETTE[0], points: syntheticCluster(0.2, 0.75, 0.12, 0.1,  40) },
    { label: 'Cluster 2 — High spend / Low freq',  color: PALETTE[1], points: syntheticCluster(0.8, 0.25, 0.1,  0.12, 35) },
    { label: 'Cluster 3 — Mid spend / Mid freq',   color: PALETTE[2], points: syntheticCluster(0.5, 0.5,  0.14, 0.13, 50) },
    { label: 'Cluster 4 — Low spend / Low freq',   color: PALETTE[3], points: syntheticCluster(0.15,0.2,  0.1,  0.09, 30) },
  ];
  new Chart(ctx, {
    type: 'scatter',
    data: {
      datasets: clusterData.map(c => ({
        label: c.label,
        data:  c.points,
        backgroundColor: c.color,
        pointRadius: 5,
        pointHoverRadius: 7,
      }))
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 12 } } },
        tooltip: {
          callbacks: {
            label: ctx => `spend: ${ctx.parsed.x.toFixed(2)}  sessions: ${ctx.parsed.y.toFixed(2)}`
          }
        }
      },
      scales: {
        x: { title: { display: true, text: 'total_spend (normalised)', font: { size: 12 } }, min: 0, max: 1 },
        y: { title: { display: true, text: 'session_count (normalised)', font: { size: 12 } }, min: 0, max: 1 },
      }
    }
  });
}

function renderLine() {
  const ctx = document.getElementById('chart-line').getContext('2d');
  const labels = Array.from({ length: 30 }, (_, i) => `Day ${i + 1}`);
  const data   = syntheticRevenue(30);
  new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [{
        label: 'Daily Revenue',
        data,
        borderColor: TEAL,
        backgroundColor: TEAL_D,
        borderWidth: 2.5,
        pointRadius: 3,
        pointHoverRadius: 6,
        fill: true,
        tension: 0.35,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: { label: ctx => `$${ctx.parsed.y.toLocaleString()}` }
        }
      },
      scales: {
        y: {
          ticks: { callback: v => '$' + (v / 1000).toFixed(0) + 'k' }
        }
      }
    }
  });
}

function renderTable() {
  const tbody = document.getElementById('table-top-body');
  tbody.innerHTML = '';
  demoCustomers.forEach((c, i) => {
    const tr = document.createElement('tr');
    tr.innerHTML =
      `<td><span class="rank-badge">${i + 1}</span></td>` +
      `<td><code style="font-size:0.9em;color:var(--pres-accent)">${c.id}</code></td>` +
      `<td>${c.segment}</td>` +
      `<td class="num">${c.spend}</td>` +
      `<td class="num">${c.sessions}</td>`;
    tbody.appendChild(tr);
  });
}

// ── Synthetic data helpers ────────────────────────────────────────────────────
function syntheticCluster(cx, cy, sx, sy, n) {
  return Array.from({ length: n }, () => ({
    x: Math.max(0, Math.min(1, cx + (Math.random() - 0.5) * 2 * sx)),
    y: Math.max(0, Math.min(1, cy + (Math.random() - 0.5) * 2 * sy)),
  }));
}

function syntheticRevenue(days) {
  const base = 42000;
  let v = base;
  return Array.from({ length: days }, (_, i) => {
    v += (Math.random() - 0.42) * 6000;
    if (i === 13) v -= 8000; // week-3 dip
    if (i === 27) v += 11000; // end-of-month peak
    return Math.max(18000, Math.round(v));
  });
}

// ── Boot ──────────────────────────────────────────────────────────────────────
buildDots();
updateControls();
startTimer();
initSlide(0);
renderTable();  // pre-render table so it's ready when we flip to it
</script>
{! end !}
