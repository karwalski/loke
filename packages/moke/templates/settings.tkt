{! layout("base") !}
{! block("title") !}moke — settings{! end !}
{! block("content") !}
<style>
  /* ── teal accent override ── */
  :root {
    --accent: #0d9488;
    --accent-muted: rgba(13,148,136,.15);
    --accent-border: rgba(13,148,136,.35);
  }

  /* ── page layout ── */
  .settings-wrap { max-width: 620px; margin: 0 auto; }
  .settings-heading { font-size: 1.25em; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 6px; }
  .settings-sub { font-size: 0.88em; color: var(--muted); margin-bottom: 28px; }

  /* ── section ── */
  .settings-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; overflow: hidden; margin-bottom: 20px;
  }
  .section-head {
    padding: 14px 20px; border-bottom: 1px solid var(--border);
    font-size: 0.78em; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.09em; color: var(--muted);
  }
  .section-body { padding: 18px 20px; display: flex; flex-direction: column; gap: 18px; }

  /* ── field row ── */
  .field-row {
    display: flex; align-items: flex-start; gap: 20px;
  }
  .field-label-col { flex: 0 0 200px; padding-top: 2px; }
  .field-label { font-size: 0.88em; font-weight: 600; color: var(--text); display: block; margin-bottom: 3px; }
  .field-hint  { font-size: 0.78em; color: var(--muted); line-height: 1.4; }
  .field-control { flex: 1; }

  /* ── toggle switch ── */
  .toggle-wrap { display: flex; align-items: center; gap: 10px; }
  .toggle-switch {
    position: relative; width: 44px; height: 24px; cursor: pointer;
    flex-shrink: 0;
  }
  .toggle-switch input { opacity: 0; width: 0; height: 0; }
  .toggle-track {
    position: absolute; inset: 0; border-radius: 12px;
    background: var(--border); transition: background 0.2s;
  }
  .toggle-switch input:checked + .toggle-track { background: var(--accent); }
  .toggle-thumb {
    position: absolute; top: 3px; left: 3px;
    width: 18px; height: 18px; border-radius: 50%;
    background: #fff; transition: left 0.2s;
  }
  .toggle-switch input:checked ~ .toggle-thumb { left: 23px; }
  .toggle-state { font-size: 0.85em; color: var(--muted); }

  /* ── radio group ── */
  .radio-group { display: flex; gap: 0; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .radio-group label {
    flex: 1; display: flex; align-items: center; justify-content: center;
    padding: 7px 12px; font-size: 0.83em; cursor: pointer; color: var(--muted);
    background: transparent; border-right: 1px solid var(--border);
    transition: background 0.15s, color 0.15s; text-align: center;
  }
  .radio-group label:last-child { border-right: none; }
  .radio-group label:has(input:checked) {
    background: var(--accent-muted); color: var(--accent);
    font-weight: 600;
  }
  .radio-group label input { display: none; }

  /* ── select ── */
  .field-select {
    background: var(--bg); border: 1px solid var(--border);
    color: var(--text); font-size: 0.88em; border-radius: 6px;
    padding: 8px 10px; outline: none; width: 100%;
    transition: border-color 0.15s; cursor: pointer;
  }
  .field-select:focus { border-color: var(--accent); }
  .field-select optgroup { color: var(--muted); font-style: normal; font-weight: 600; }
  .field-select option { color: var(--text); background: var(--surface); }

  /* ── sensitivity selector ── */
  .sens-radio-group { display: flex; gap: 8px; flex-wrap: wrap; }
  .sens-radio-group label {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.83em; cursor: pointer; color: var(--muted);
    padding: 5px 12px; border-radius: 6px; border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .sens-radio-group label:has(input:checked) { border-color: var(--accent); color: var(--text); }
  .sens-radio-group input[type="radio"] { accent-color: var(--accent); }

  /* ── info note ── */
  .info-note {
    font-size: 0.82em; color: var(--muted);
    background: var(--accent-muted); border: 1px solid var(--accent-border);
    border-radius: 6px; padding: 10px 14px; line-height: 1.5;
  }
  .info-note a { color: var(--accent); }

  /* ── save bar ── */
  .save-bar {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 0;
  }
  .btn-save {
    background: var(--accent); color: #fff;
    padding: 9px 24px; border-radius: 8px; border: none;
    font-size: 0.9em; font-weight: 700; cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-save:hover { opacity: 0.88; }
  .save-status { font-size: 0.82em; color: var(--muted); display: none; }
  .save-status.visible { display: inline; }

  /* ── about section ── */
  .about-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 0.88em; }
  .about-row:last-child { border-bottom: none; }
  .about-key { color: var(--muted); }
  .about-val { color: var(--text); font-weight: 500; }
  .about-val a { color: var(--accent); }
</style>

<div class="settings-wrap">
  <div class="settings-heading">Settings</div>
  <div class="settings-sub">Preferences are saved to <code>localStorage</code> in this browser — session only.</div>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- SESSION SETTINGS                                                    -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <div class="settings-section">
    <div class="section-head">Session settings</div>
    <div class="section-body">

      <!-- Memory mode -->
      <div class="field-row">
        <div class="field-label-col">
          <span class="field-label">Memory mode</span>
          <span class="field-hint">Whether conversation history persists after you close the window.</span>
        </div>
        <div class="field-control">
          <div class="toggle-wrap">
            <label class="toggle-switch" id="toggle-memory-label">
              <input type="checkbox" id="toggle-memory">
              <span class="toggle-track"></span>
              <span class="toggle-thumb"></span>
            </label>
            <span class="toggle-state" id="memory-state-label">Clear on close</span>
          </div>
        </div>
      </div>

      <!-- Pipeline verbosity -->
      <div class="field-row">
        <div class="field-label-col">
          <span class="field-label">Pipeline console verbosity</span>
          <span class="field-hint">How much detail is shown in the pipeline console.</span>
        </div>
        <div class="field-control">
          <div class="radio-group">
            <label><input type="radio" name="verbosity" value="minimal"> Minimal</label>
            <label><input type="radio" name="verbosity" value="standard" checked> Standard</label>
            <label><input type="radio" name="verbosity" value="verbose"> Verbose</label>
          </div>
        </div>
      </div>

      <!-- Default sensitivity -->
      <div class="field-row">
        <div class="field-label-col">
          <span class="field-label">Default sensitivity</span>
          <span class="field-hint">Pre-selected classification when uploading a new dataset.</span>
        </div>
        <div class="field-control">
          <div class="sens-radio-group">
            <label><input type="radio" name="default-sens" value="PUBLIC" checked> PUBLIC</label>
            <label><input type="radio" name="default-sens" value="INTERNAL"> INTERNAL</label>
            <label><input type="radio" name="default-sens" value="CONFIDENTIAL"> CONFIDENTIAL</label>
            <label><input type="radio" name="default-sens" value="RESTRICTED"> RESTRICTED</label>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- LLM SETTINGS                                                        -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <div class="settings-section">
    <div class="section-head">LLM settings</div>
    <div class="section-body">

      <!-- Preferred model -->
      <div class="field-row">
        <div class="field-label-col">
          <span class="field-label">Preferred model</span>
          <span class="field-hint">Default model used for new chat sessions.</span>
        </div>
        <div class="field-control">
          <select class="field-select" id="preferred-model">
            <option value="loke-router">loke router (auto)</option>
            <option value="llama3.2:3b">llama3.2:3b</option>
            <option value="qwen2.5:0.5b">qwen2.5:0.5b</option>
          </select>
        </div>
      </div>

      <!-- Anthropic API key -->
      <div class="field-row">
        <div class="field-label-col">
          <span class="field-label">Anthropic API key</span>
          <span class="field-hint">For Claude models via loke pipeline.</span>
        </div>
        <div class="field-control">
          <input type="password" class="field-select" id="anthropic-api-key" placeholder="sk-ant-…" autocomplete="off" style="margin-bottom:6px;">
          <button class="btn-save" onclick="saveApiKey('anthropic')" style="font-size:0.8em;padding:6px 16px;">Save to loke</button>
          <span class="save-status" id="save-anthropic-status" style="margin-left:8px;"></span>
        </div>
      </div>

      <!-- OpenAI API key -->
      <div class="field-row">
        <div class="field-label-col">
          <span class="field-label">OpenAI API key</span>
          <span class="field-hint">For GPT models via loke pipeline.</span>
        </div>
        <div class="field-control">
          <input type="password" class="field-select" id="openai-api-key" placeholder="sk-…" autocomplete="off" style="margin-bottom:6px;">
          <button class="btn-save" onclick="saveApiKey('openai')" style="font-size:0.8em;padding:6px 16px;">Save to loke</button>
          <span class="save-status" id="save-openai-status" style="margin-left:8px;"></span>
        </div>
      </div>

      <!-- loke connection status -->
      <div class="info-note">
        <span id="loke-settings-status">Checking loke connection…</span>
        <a href="http://127.0.0.1:11430" target="_blank" style="margin-left:8px;">Open loke dashboard &#8599;</a>
      </div>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- ABOUT                                                               -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <div class="settings-section">
    <div class="section-head">About</div>
    <div class="section-body" style="padding-top:6px;padding-bottom:6px;">

      <div class="about-row">
        <span class="about-key">moke version</span>
        <span class="about-val">0.1.0</span>
      </div>
      <div class="about-row">
        <span class="about-key">Built on loke</span>
        <span class="about-val">0.1.0</span>
      </div>
      <div class="about-row">
        <span class="about-key">Source / documentation</span>
        <span class="about-val"><a href="https://github.com/karwalski/loke/tree/main/packages/moke" target="_blank">github.com/karwalski/loke &#8599;</a></span>
      </div>
      <div class="about-row">
        <span class="about-key">loke dashboard</span>
        <span class="about-val"><a href="http://127.0.0.1:11430" target="_blank">Open loke dashboard &#8599;</a></span>
      </div>

    </div>
  </div>

  <!-- save bar -->
  <div class="save-bar">
    <button class="btn-save" id="btn-save">Save settings</button>
    <span class="save-status" id="save-status">Saved to localStorage.</span>
  </div>

</div>

<script>
(function () {
  'use strict';

  const LS_KEY = 'moke_settings';

  // ── defaults ──────────────────────────────────────────────────────────
  const DEFAULTS = {
    memory_persist:  false,
    verbosity:       'standard',
    default_sens:    'PUBLIC',
    preferred_model: 'llama3.2:3b',
  };

  // ── load settings from localStorage ──────────────────────────────────
  function loadSettings() {
    let cfg = Object.assign({}, DEFAULTS);
    try {
      const raw = localStorage.getItem(LS_KEY);
      if (raw) cfg = Object.assign(cfg, JSON.parse(raw));
    } catch (_) { /* use defaults */ }
    return cfg;
  }

  // ── apply loaded settings to form ─────────────────────────────────────
  function applyToForm(cfg) {
    // memory toggle
    const toggle = document.getElementById('toggle-memory');
    toggle.checked = !!cfg.memory_persist;
    updateMemoryLabel(toggle.checked);

    // verbosity
    const verbEl = document.querySelector(`input[name="verbosity"][value="${cfg.verbosity}"]`);
    if (verbEl) verbEl.checked = true;

    // default sensitivity
    const sensEl = document.querySelector(`input[name="default-sens"][value="${cfg.default_sens}"]`);
    if (sensEl) sensEl.checked = true;

    // preferred model
    const modelEl = document.getElementById('preferred-model');
    if (modelEl) modelEl.value = cfg.preferred_model;
  }

  // ── collect form state ────────────────────────────────────────────────
  function collectForm() {
    const verbEl  = document.querySelector('input[name="verbosity"]:checked');
    const sensEl  = document.querySelector('input[name="default-sens"]:checked');
    return {
      memory_persist:  document.getElementById('toggle-memory').checked,
      verbosity:       verbEl  ? verbEl.value  : DEFAULTS.verbosity,
      default_sens:    sensEl  ? sensEl.value  : DEFAULTS.default_sens,
      preferred_model: document.getElementById('preferred-model').value || DEFAULTS.preferred_model,
    };
  }

  // ── memory toggle label ───────────────────────────────────────────────
  function updateMemoryLabel(persist) {
    document.getElementById('memory-state-label').textContent =
      persist ? 'Persist across sessions' : 'Clear on close';
  }

  document.getElementById('toggle-memory').addEventListener('change', e => {
    updateMemoryLabel(e.target.checked);
  });

  // ── save ──────────────────────────────────────────────────────────────
  document.getElementById('btn-save').addEventListener('click', () => {
    const cfg = collectForm();
    try {
      localStorage.setItem(LS_KEY, JSON.stringify(cfg));
    } catch (_) { /* storage unavailable */ }

    const status = document.getElementById('save-status');
    status.classList.add('visible');
    setTimeout(() => status.classList.remove('visible'), 2500);
  });

  // ── loke integration ──────────────────────────────────────────────────
  const LOKE = 'http://127.0.0.1:11430';

  // Populate model selector from loke /api/models
  fetch(LOKE + '/api/models', { mode: 'cors', cache: 'no-store' })
    .then(r => r.json())
    .then(models => {
      if (!Array.isArray(models) || models.length === 0) return;
      const sel = document.getElementById('preferred-model');
      sel.innerHTML = '<option value="loke-router">loke router (auto)</option>';
      models.forEach(m => {
        const opt = document.createElement('option');
        opt.value = m.id;
        opt.textContent = m.id + (m.running ? ' ●' : '');
        sel.appendChild(opt);
      });
      // Re-apply saved preference after populating
      const saved = loadSettings().preferred_model;
      if (saved) sel.value = saved;
    })
    .catch(() => { /* keep static fallback */ });

  // Show loke connection status and config
  const statusEl = document.getElementById('loke-settings-status');
  fetch(LOKE + '/api/health', { mode: 'cors', cache: 'no-store' })
    .then(r => r.json())
    .then(d => {
      if (d && d.ok && statusEl) {
        statusEl.textContent = 'loke v' + d.version + ' connected · Ollama: ' + d.ollama;
        statusEl.style.color = 'var(--accent)';
      }
    })
    .catch(() => {
      if (statusEl) {
        statusEl.textContent = 'loke offline — start loke to save API keys and use cloud models.';
        statusEl.style.color = 'var(--red)';
      }
    });

  // Save API key to loke /api/settings
  window.saveApiKey = function(provider) {
    const inputId  = provider + '-api-key';
    const statusId = 'save-' + provider + '-status';
    const key      = (document.getElementById(inputId) || {}).value || '';
    const sEl      = document.getElementById(statusId);
    if (!key.trim()) {
      if (sEl) { sEl.textContent = 'Key is empty.'; sEl.classList.add('visible'); }
      return;
    }
    fetch(LOKE + '/api/settings', {
      method: 'POST', mode: 'cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: provider + '_api_key', value: key.trim() })
    })
    .then(r => r.json())
    .then(d => {
      if (sEl) {
        sEl.textContent = d.ok ? 'Saved to loke.' : 'Error: ' + (d.error || 'unknown');
        sEl.classList.add('visible');
        setTimeout(() => sEl.classList.remove('visible'), 3000);
      }
    })
    .catch(err => {
      if (sEl) {
        sEl.textContent = 'Could not reach loke: ' + err.message;
        sEl.classList.add('visible');
        setTimeout(() => sEl.classList.remove('visible'), 3000);
      }
    });
  };

  // ── init ──────────────────────────────────────────────────────────────
  applyToForm(loadSettings());

})();
</script>
{! end !}
