<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{! yield("title") !}</title>
  <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d1117; --surface: #161b22; --border: #30363d;
      --text: #e6edf3; --muted: #8b949e; --accent: #14b8a6;
      --green: #3fb950; --amber: #d29922; --red: #f85149;
      --teal: #14b8a6; --teal-dim: rgba(20,184,166,.15);
    }
    body {
      background: var(--bg); color: var(--text);
      font-family: system-ui, sans-serif; font-size: 15px; line-height: 1.6;
      display: flex; flex-direction: column; min-height: 100vh;
    }

    /* ── Header ── */
    .app-header {
      border-bottom: 1px solid var(--border);
      padding: 12px 24px;
      display: flex; align-items: center; gap: 12px;
      flex-shrink: 0; z-index: 100; background: var(--bg);
    }
    .app-header .brand { display: flex; align-items: baseline; gap: 10px; }
    .app-header h1 { font-size: 1.25em; font-weight: 700; letter-spacing: -0.02em; color: var(--teal); }
    .app-header .subtitle { color: var(--muted); font-size: 0.82em; }
    .app-header .spacer { flex: 1; }
    .conn-badge {
      display: flex; align-items: center; gap: 6px;
      font-size: 0.78em; color: var(--muted);
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 20px; padding: 4px 12px;
      text-decoration: none; transition: border-color 0.15s;
    }
    .conn-badge:hover { border-color: var(--teal); color: var(--text); }
    .conn-badge .dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--green); flex-shrink: 0;
      box-shadow: 0 0 6px var(--green);
    }

    /* ── App body: sidebar + main ── */
    .app-body { display: flex; flex: 1; overflow: hidden; }

    /* ── Sidebar ── */
    .sidebar {
      width: 220px; flex-shrink: 0;
      background: var(--surface); border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      overflow-y: auto;
    }
    .sidebar-nav { flex: 1; padding: 12px 0; }
    .sidebar-nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 16px; color: var(--muted);
      text-decoration: none; font-size: 0.9em; font-weight: 500;
      border-left: 3px solid transparent;
      transition: color 0.15s, background 0.15s, border-color 0.15s;
    }
    .sidebar-nav a:hover { color: var(--text); background: rgba(255,255,255,.04); }
    .sidebar-nav a.active {
      color: var(--teal); background: var(--teal-dim);
      border-left-color: var(--teal);
    }
    .sidebar-nav .nav-icon { font-size: 1.1em; width: 20px; text-align: center; flex-shrink: 0; }
    .sidebar-section-label {
      font-size: 0.7em; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted);
      padding: 14px 16px 4px;
    }

    /* ── Sidebar status bar ── */
    .sidebar-status {
      border-top: 1px solid var(--border);
      padding: 12px 16px; font-size: 0.78em;
    }
    .sidebar-status .status-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 3px 0;
    }
    .sidebar-status .label { color: var(--muted); }
    .sidebar-status .value { color: var(--text); font-weight: 500; }
    .privacy-row { display: flex; align-items: center; gap: 5px; }
    .privacy-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--green); box-shadow: 0 0 5px var(--green);
    }
    .badge {
      font-size: 0.72em; font-weight: 600; padding: 1px 7px;
      border-radius: 4px; white-space: nowrap;
    }
    .badge-confidential { background: rgba(248,81,73,.15); color: var(--red); }
    .badge-internal     { background: rgba(210,153,34,.15); color: var(--amber); }
    .badge-public       { background: rgba(63,185,80,.15);  color: var(--green); }
    .badge-teal         { background: var(--teal-dim);      color: var(--teal); }
    .badge-muted        { background: rgba(139,148,158,.12); color: var(--muted); }

    /* ── Main content ── */
    .app-main {
      flex: 1; overflow-y: auto;
      padding: 24px;
    }

    /* ── Mobile sidebar toggle ── */
    .sidebar-toggle {
      display: none; background: none; border: none;
      color: var(--muted); cursor: pointer; padding: 4px; font-size: 1.2em;
    }

    /* ── Utilities ── */
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 20px 24px; margin-bottom: 20px;
    }
    .card-teal { border-color: var(--teal); background: var(--teal-dim); }
    .card h2 {
      font-size: 0.78em; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.09em; color: var(--muted); margin-bottom: 14px;
    }
    code {
      font-family: monospace; background: rgba(255,255,255,.06);
      padding: 1px 5px; border-radius: 3px; font-size: 0.9em;
    }
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 0.85em; font-weight: 600; padding: 7px 16px;
      border-radius: 7px; border: none; cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn:active { transform: scale(0.97); }
    .btn-teal  { background: var(--teal); color: #0d1117; }
    .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text); }
    .btn-ghost:hover { border-color: var(--teal); color: var(--teal); }

    @media (max-width: 768px) {
      .sidebar-toggle { display: block; }
      .sidebar {
        position: fixed; left: -220px; top: 0; bottom: 0;
        z-index: 200; transition: left 0.2s;
      }
      .sidebar.open { left: 0; }
      .app-main { padding: 16px; }
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script>
    // ── Verbose error logging ──
    window.addEventListener('error', function(e) {
      console.error('[moke] Uncaught error:', e.message, '\n  File:', e.filename, 'Line:', e.lineno, 'Col:', e.colno, '\n  Stack:', e.error && e.error.stack);
    });
    window.addEventListener('unhandledrejection', function(e) {
      console.error('[moke] Unhandled promise rejection:', e.reason);
    });
    window.addEventListener('load', function() {
      if (typeof Chart === 'undefined') {
        console.error('[moke] Chart.js did not load from CDN — charts will not render. Check network/CSP.');
      } else {
        console.log('[moke] Chart.js ' + Chart.version + ' ready');
      }
    });
  </script>
</head>
<body>

  <header class="app-header">
    <button class="sidebar-toggle" aria-label="Toggle navigation" onclick="toggleSidebar()">☰</button>
    <div class="brand">
      <h1>moke</h1>
      <span class="subtitle">data analysis on loke · v0.1.0</span>
    </div>
    <div class="spacer"></div>
    <a href="http://127.0.0.1:11430" target="_blank" rel="noopener" class="conn-badge" id="loke-conn-badge">
      <span class="dot" id="loke-conn-dot" style="background:var(--muted);box-shadow:none;"></span>
      <span id="loke-conn-label">loke checking…</span>
    </a>
  </header>

  <div class="app-body">

    <nav class="sidebar" id="sidebar">
      <div class="sidebar-nav">
        <div class="sidebar-section-label">Workspace</div>
        <a href="/"          class="nav-link" data-path="/">
          <span class="nav-icon">🗂️</span> Datasets
        </a>
        <a href="/chat"      class="nav-link" data-path="/chat">
          <span class="nav-icon">💬</span> Analysis
        </a>
        <a href="/dashboard" class="nav-link" data-path="/dashboard">
          <span class="nav-icon">📊</span> Dashboard
        </a>
        <div class="sidebar-section-label">Tools</div>
        <a href="/insight"   class="nav-link" data-path="/insight">
          <span class="nav-icon">🔬</span> Insight Lab
        </a>
        <a href="/upload"    class="nav-link" data-path="/upload">
          <span class="nav-icon">⬆️</span> Upload
        </a>
        <div class="sidebar-section-label">System</div>
        <a href="/settings"  class="nav-link" data-path="/settings">
          <span class="nav-icon">⚙️</span> Settings
        </a>
      </div>

      <div class="sidebar-status">
        <div class="status-row">
          <span class="label">Privacy</span>
          <span class="value">
            <span class="privacy-row">
              <span class="privacy-dot" id="privacy-dot" style="background:var(--muted);box-shadow:none;"></span>
              <span id="privacy-label">checking…</span>
            </span>
          </span>
        </div>
        <div class="status-row">
          <span class="label">Dataset</span>
          <span class="value" id="sidebar-dataset-name">No dataset loaded</span>
        </div>
        <div class="status-row">
          <span class="label">Sensitivity</span>
          <span id="sidebar-sensitivity" class="badge badge-muted">—</span>
        </div>
      </div>
    </nav>

    <main class="app-main">
      {! yield("content") !}
    </main>

  </div>

  <script>
    // ── Active nav link ──
    (function() {
      var path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(function(a) {
        var dp = a.getAttribute('data-path');
        if (dp === '/' ? path === '/' : path.startsWith(dp)) {
          a.classList.add('active');
        }
      });
    })();

    // ── Sidebar dataset status bar ──
    (function() {
      var ds = sessionStorage.getItem('moke_dataset');
      if (ds) {
        try {
          var d = JSON.parse(ds);
          var nameEl = document.getElementById('sidebar-dataset-name');
          var sensEl = document.getElementById('sidebar-sensitivity');
          if (nameEl && d.name) nameEl.textContent = d.name;
          if (sensEl && d.sensitivity) {
            sensEl.textContent = d.sensitivity;
            var cls = {
              'CONFIDENTIAL': 'badge-confidential',
              'INTERNAL':     'badge-internal',
              'PUBLIC':       'badge-public'
            }[d.sensitivity] || 'badge-muted';
            sensEl.className = 'badge ' + cls;
          }
        } catch(e) {}
      }
    })();

    // ── loke health polling ──
    (function() {
      var LOKE = 'http://127.0.0.1:11430';
      var dot   = document.getElementById('loke-conn-dot');
      var label = document.getElementById('loke-conn-label');
      var pdot  = document.getElementById('privacy-dot');
      var plbl  = document.getElementById('privacy-label');

      function setConnected(h) {
        if (dot)  { dot.style.background = 'var(--green)'; dot.style.boxShadow = '0 0 6px var(--green)'; }
        if (label) label.textContent = 'loke v' + (h.version || '?') + (h.ollama === 'running' ? ' · Ollama ready' : ' · Ollama offline');
        if (pdot) { pdot.style.background = 'var(--green)'; pdot.style.boxShadow = '0 0 5px var(--green)'; }
        if (plbl) plbl.textContent = 'ON';
      }
      function setDisconnected() {
        if (dot)  { dot.style.background = 'var(--red)'; dot.style.boxShadow = '0 0 6px var(--red)'; }
        if (label) label.textContent = 'loke offline';
        if (pdot) { pdot.style.background = 'var(--muted)'; pdot.style.boxShadow = 'none'; }
        if (plbl) plbl.textContent = 'OFF';
      }
      function check() {
        fetch(LOKE + '/api/health', { mode: 'cors', cache: 'no-store' })
          .then(function(r) { return r.json(); })
          .then(function(d) { if (d && d.ok) { setConnected(d); } else { setDisconnected(); } })
          .catch(function() { setDisconnected(); });
      }
      check();
      setInterval(check, 15000);
    })();

    // ── Mobile sidebar toggle ──
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
    }
    document.addEventListener('click', function(e) {
      var sb = document.getElementById('sidebar');
      if (sb.classList.contains('open') && !sb.contains(e.target) && !e.target.classList.contains('sidebar-toggle')) {
        sb.classList.remove('open');
      }
    });
  </script>

</body>
</html>
