{! layout("base") !}
{! block("title") !}moke — Dashboard{! end !}
{! block("content") !}

<style>
  /* ── Dashboard page overrides ───────────────────────────────────────────── */
  main { max-width: 1280px; }

  /* ── Page header ────────────────────────────────────────────────────────── */
  .dash-header {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 24px; flex-wrap: wrap;
  }
  .dash-header h1 { font-size: 1.4em; font-weight: 700; letter-spacing: -0.02em; flex: 1; }
  .dash-header .dash-meta { font-size: 0.8em; color: var(--muted); }
  .btn {
    font-size: 0.8em; font-weight: 600; padding: 6px 14px; border-radius: 6px;
    border: 1px solid var(--border); background: var(--surface); color: var(--text);
    cursor: pointer; transition: border-color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .btn:hover { border-color: var(--accent); background: rgba(99,102,241,0.08); }
  .btn-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn-primary:hover { background: #4f52d8; border-color: #4f52d8; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── Prompt bar ─────────────────────────────────────────────────────────── */
  .prompt-bar {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    padding: 18px 20px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 12px;
  }
  .prompt-row { display: flex; gap: 10px; align-items: flex-end; }
  .prompt-bar input[type="text"] {
    flex: 1; background: var(--bg); border: 1px solid var(--border); border-radius: 7px;
    color: var(--text); font-size: 14px; padding: 9px 13px; outline: none;
    transition: border-color 0.15s;
  }
  .prompt-bar input[type="text"]:focus { border-color: var(--accent); }
  .prompt-bar input[type="text"]::placeholder { color: var(--muted); }
  .refine-row { display: none; }
  .refine-row.visible { display: flex; }

  /* ── Phase loading indicator ────────────────────────────────────────────── */
  .phase-bar {
    display: none; align-items: center; gap: 0; padding: 12px 0; margin-bottom: 16px;
  }
  .phase-bar.visible { display: flex; }
  .phase-step {
    display: flex; align-items: center; gap: 7px; font-size: 0.8em;
    color: var(--muted); padding: 5px 10px; border-radius: 6px; transition: color 0.2s;
  }
  .phase-step .ph-dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--border);
    transition: background 0.3s; flex-shrink: 0;
  }
  .phase-step.ph-running { color: var(--accent); }
  .phase-step.ph-running .ph-dot { background: var(--accent); animation: ph-pulse 0.9s infinite; }
  .phase-step.ph-done { color: var(--green); }
  .phase-step.ph-done .ph-dot { background: var(--green); }
  .phase-sep { color: var(--border); font-size: 0.75em; padding: 0 2px; }
  @keyframes ph-pulse { 0%,100%{opacity:1} 50%{opacity:0.25} }

  /* ── Template bar (MK3.4) ────────────────────────────────────────────────── */
  .template-bar {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 16px; margin-bottom: 14px;
  }
  .template-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .template-label {
    font-size: 0.72em; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--muted); white-space: nowrap;
  }
  .template-select {
    background: var(--bg); border: 1px solid var(--border); color: var(--text);
    border-radius: 6px; padding: 4px 10px; font-size: 0.8em; outline: none;
    cursor: pointer; flex: 1; max-width: 260px; transition: border-color 0.15s;
  }
  .template-select:focus { border-color: var(--teal); }
  .template-sep { color: var(--border); margin: 0 2px; }

  /* ── Empty / no-data state ──────────────────────────────────────────────── */
  .empty-dash {
    text-align: center; padding: 64px 32px; color: var(--muted); display: none;
  }
  .empty-dash.visible { display: block; }
  .empty-dash .empty-icon { font-size: 3em; margin-bottom: 14px; opacity: 0.3; }
  .empty-dash p { font-size: 0.9em; max-width: 340px; margin: 0 auto; }

  /* ── Dashboard grid ─────────────────────────────────────────────────────── */
  .dash-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .dash-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    padding: 18px 20px; overflow: hidden;
    transition: border-color 0.15s;
  }
  .dash-card:hover { border-color: rgba(99,102,241,0.35); }
  .dash-card.col-1 { grid-column: span 1; }
  .dash-card.col-2 { grid-column: span 2; }
  .dash-card.col-3 { grid-column: span 3; }
  .card-label {
    font-size: 0.72em; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.09em; color: var(--muted); margin-bottom: 10px;
  }

  /* ── Metric card ────────────────────────────────────────────────────────── */
  .metric-value {
    font-size: 2.4em; font-weight: 700; letter-spacing: -0.03em;
    line-height: 1.1; color: var(--text); margin-bottom: 4px;
  }
  .metric-unit { font-size: 0.65em; font-weight: 400; color: var(--muted); margin-left: 2px; }
  .metric-delta {
    font-size: 0.8em; font-weight: 600; display: inline-flex;
    align-items: center; gap: 3px; margin-top: 6px;
  }
  .metric-delta.up { color: var(--green); }
  .metric-delta.down { color: var(--red); }
  .metric-delta.flat { color: var(--muted); }

  /* ── Chart card ─────────────────────────────────────────────────────────── */
  .chart-wrap { position: relative; height: 220px; margin-top: 8px; }
  .chart-wrap canvas { width: 100% !important; height: 100% !important; }

  /* ── Table card ─────────────────────────────────────────────────────────── */
  .dash-table { width: 100%; border-collapse: collapse; font-size: 0.82em; margin-top: 8px; }
  .dash-table th {
    text-align: left; padding: 6px 10px; font-size: 0.75em; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted);
    border-bottom: 1px solid var(--border); cursor: pointer; user-select: none;
    white-space: nowrap;
  }
  .dash-table th:hover { color: var(--text); }
  .dash-table th .sort-arrow { margin-left: 4px; opacity: 0.4; }
  .dash-table th.sorted-asc .sort-arrow::after { content: "↑"; opacity: 1; }
  .dash-table th.sorted-desc .sort-arrow::after { content: "↓"; opacity: 1; }
  .dash-table th .sort-arrow::after { content: "↕"; }
  .dash-table td {
    padding: 7px 10px; border-bottom: 1px solid rgba(42,45,58,0.6);
    color: var(--text);
  }
  .dash-table tr:last-child td { border-bottom: none; }
  .dash-table tr:hover td { background: rgba(99,102,241,0.04); }

  /* ── Text card (markdown) ───────────────────────────────────────────────── */
  .text-content { font-size: 0.88em; line-height: 1.7; color: var(--text); }
  .text-content strong { font-weight: 600; }
  .text-content em { font-style: italic; color: var(--muted); }
  .text-content ul { padding-left: 18px; margin: 6px 0; }
  .text-content li { margin: 3px 0; }

  /* ── List card ──────────────────────────────────────────────────────────── */
  .list-items { list-style: none; padding: 0; margin: 6px 0 0; }
  .list-items li {
    padding: 5px 0; border-bottom: 1px solid var(--border);
    font-size: 0.88em; display: flex; align-items: center; gap: 8px;
  }
  .list-items li:last-child { border-bottom: none; }
  .list-bullet {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0;
  }

  /* ── Error banner ───────────────────────────────────────────────────────── */
  .error-banner {
    display: none; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
    border-radius: 8px; padding: 12px 16px; font-size: 0.85em; color: var(--red);
    margin-bottom: 16px;
  }
  .error-banner.visible { display: block; }
</style>

<!-- ── Page header ──────────────────────────────────────────────────────────── -->
<div class="dash-header">
  <h1>Dashboard</h1>
  <span class="dash-meta" id="dash-generated-at"></span>
  <button class="btn" id="btn-export-ddl" onclick="exportDDL()" disabled>Export DDL</button>
  <button class="btn" id="btn-export-png" onclick="exportPNG()" disabled>Export PNG</button>
  <button class="btn" id="btn-present" onclick="presentDashboard()" disabled style="margin-left:8px">&#9654; Present</button>
</div>

<!-- ── Prompt bar ───────────────────────────────────────────────────────────── -->
<div class="prompt-bar">
  <div class="prompt-row">
    <input type="text" id="dash-prompt"
      placeholder="Ask a question about your data to generate a dashboard…"
      onkeydown="if(event.key==='Enter')generateDashboard()" />
    <button class="btn btn-primary" id="btn-generate" onclick="generateDashboard()">
      Generate dashboard
    </button>
  </div>
  <div class="prompt-row refine-row" id="refine-row">
    <input type="text" id="refine-prompt"
      placeholder="Refine: e.g. 'add a pie chart for revenue by region', 'remove the table'…"
      onkeydown="if(event.key==='Enter')refineDashboard()" />
    <button class="btn" id="btn-refine" onclick="refineDashboard()">Refine</button>
  </div>
</div>

<!-- ── Template bar (MK3.4) ──────────────────────────────────────────────────── -->
<div class="template-bar" id="template-bar">
  <div class="template-row">
    <span class="template-label">Templates</span>
    <select class="template-select" id="template-select">
      <option value="">— load saved template —</option>
    </select>
    <button class="btn" onclick="loadSavedTemplate()">Load</button>
    <button class="btn" onclick="deleteTemplate()">Delete</button>
    <span class="template-sep">|</span>
    <button class="btn btn-primary" onclick="saveTemplate()">Save current</button>
  </div>
</div>

<!-- ── Phase loading bar ─────────────────────────────────────────────────────── -->
<div class="phase-bar" id="phase-bar">
  <div class="phase-step" id="ph1">
    <span class="ph-dot"></span>Phase 1: Asking LLM to design dashboard…
  </div>
  <span class="phase-sep">›</span>
  <div class="phase-step" id="ph2">
    <span class="ph-dot"></span>Phase 2: Running local computations…
  </div>
  <span class="phase-sep">›</span>
  <div class="phase-step" id="ph3">
    <span class="ph-dot"></span>Phase 3: Rendering…
  </div>
</div>

<!-- ── Error banner ──────────────────────────────────────────────────────────── -->
<div class="error-banner" id="error-banner"></div>

<!-- ── Empty state ───────────────────────────────────────────────────────────── -->
<div class="empty-dash visible" id="empty-dash">
  <div class="empty-icon">&#x1F4CA;</div>
  <p>Load a dataset first to generate a dashboard, or use the demo below.</p>
  <br>
  <button class="btn" onclick="loadDemo()">Load Customer Intelligence demo</button>
</div>

<!-- ── Dashboard grid ────────────────────────────────────────────────────────── -->
<div class="dash-grid" id="dash-grid"></div>

<script>
(function () {
'use strict';

// ── Cluster colour palette ─────────────────────────────────────────────────
const PALETTE = [
  'rgba(99,102,241,0.8)','rgba(34,197,94,0.8)','rgba(245,158,11,0.8)',
  'rgba(239,68,68,0.8)','rgba(59,130,246,0.8)','rgba(168,85,247,0.8)',
  'rgba(20,184,166,0.8)','rgba(251,146,60,0.8)','rgba(236,72,153,0.8)',
  'rgba(132,204,22,0.8)'
];
const PALETTE_BORDER = PALETTE.map(c => c.replace('0.8','1'));

// ── State ──────────────────────────────────────────────────────────────────
let currentDDL = null;      // parsed DDL object (JS)
let chartInstances = {};    // id → Chart.js instance
let sortState = {};         // table-id → { col, asc }

// ── Phase bar helpers ──────────────────────────────────────────────────────
function phaseReset() {
  ['ph1','ph2','ph3'].forEach(id => {
    document.getElementById(id).className = 'phase-step';
  });
  document.getElementById('phase-bar').classList.remove('visible');
}
function phaseStart() {
  phaseReset();
  document.getElementById('phase-bar').classList.add('visible');
}
function phaseRun(id) {
  document.getElementById(id).classList.add('ph-running');
}
function phaseDone(id) {
  const el = document.getElementById(id);
  el.classList.remove('ph-running');
  el.classList.add('ph-done');
}

// ── Error helpers ──────────────────────────────────────────────────────────
function showError(msg) {
  const el = document.getElementById('error-banner');
  el.textContent = msg;
  el.classList.add('visible');
}
function clearError() {
  document.getElementById('error-banner').classList.remove('visible');
}

// ── Escape HTML ────────────────────────────────────────────────────────────
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Simple markdown renderer (bold, italic, lists) ─────────────────────────
function renderMarkdown(md) {
  let html = esc(md);
  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  // Italic
  html = html.replace(/\*(.+?)\*/g,'<em>$1</em>');
  // Bullet lists: lines starting with - or *
  const lines = html.split('\n');
  let out = '';
  let inList = false;
  lines.forEach(line => {
    const m = line.match(/^[-*]\s+(.+)/);
    if (m) {
      if (!inList) { out += '<ul>'; inList = true; }
      out += '<li>' + m[1] + '</li>';
    } else {
      if (inList) { out += '</ul>'; inList = false; }
      out += line + (line.length ? '<br>' : '');
    }
  });
  if (inList) out += '</ul>';
  return out;
}

// ── Extract JSON from LLM response text ───────────────────────────────────
function extractJSON(text) {
  // Try ```json block
  const fenceMatch = text.match(/```json\s*([\s\S]*?)```/);
  if (fenceMatch) {
    try { return JSON.parse(fenceMatch[1].trim()); } catch(_) {}
  }
  // Try bare JSON object
  const start = text.indexOf('{');
  if (start === -1) return null;
  // Walk to find matching brace
  let depth = 0, end = -1;
  for (let i = start; i < text.length; i++) {
    if (text[i] === '{') depth++;
    else if (text[i] === '}') { depth--; if (depth === 0) { end = i; break; } }
  }
  if (end === -1) return null;
  try { return JSON.parse(text.slice(start, end+1)); } catch(_) { return null; }
}

// ── Phase 2: local query resolution ───────────────────────────────────────

// Find column index by name — case-insensitive, falls back to substring match
function getColIndex(headers, colName) {
  if (!colName || !headers) return -1;
  const needle = colName.toLowerCase().trim();
  // Exact match first
  let idx = headers.findIndex(h => h.toLowerCase().trim() === needle);
  if (idx !== -1) return idx;
  // Substring match
  idx = headers.findIndex(h => h.toLowerCase().includes(needle) || needle.includes(h.toLowerCase().trim()));
  return idx;
}

// Parse a value to float; returns NaN for non-numeric
function parseNumeric(val) {
  if (val === null || val === undefined || val === '') return NaN;
  const s = String(val).replace(/[$,\s%]/g, '');
  return parseFloat(s);
}

// Group rows by keyIdx, compute op (count/mean/sum) on valueIdx per group
// Returns { labels: string[], values: number[] }
function groupBy(rows, keyIdx, valueIdx, op) {
  const groups = new Map();
  for (const row of rows) {
    const key = String(row[keyIdx] ?? '(blank)');
    if (!groups.has(key)) groups.set(key, { sum: 0, count: 0 });
    const g = groups.get(key);
    if (op === 'count') {
      if (row[valueIdx] !== null && row[valueIdx] !== undefined && row[valueIdx] !== '') g.count++;
    } else {
      const n = parseNumeric(row[valueIdx]);
      if (!isNaN(n)) { g.sum += n; g.count++; }
    }
  }
  const labels = [], values = [];
  for (const [k, g] of groups) {
    labels.push(k);
    if (op === 'count') values.push(g.count);
    else if (op === 'sum') values.push(g.sum);
    else values.push(g.count > 0 ? g.sum / g.count : 0); // mean
  }
  return { labels, values };
}

// Group rows by year-month bucket of the date column at dateIdx
// Returns { labels: string[], values: number[] }
function bucketDates(rows, dateIdx, valueIdx, op) {
  const buckets = new Map();
  for (const row of rows) {
    const raw = String(row[dateIdx] ?? '');
    // Accept ISO dates or any string beginning with YYYY-MM
    const m = raw.match(/^(\d{4}-\d{2})/);
    const key = m ? m[1] : raw.slice(0, 7) || '(unknown)';
    if (!buckets.has(key)) buckets.set(key, { sum: 0, count: 0 });
    const b = buckets.get(key);
    if (op === 'count') {
      b.count++;
    } else {
      const n = parseNumeric(row[valueIdx]);
      if (!isNaN(n)) { b.sum += n; b.count++; }
    }
  }
  // Sort buckets chronologically
  const sorted = [...buckets.entries()].sort((a, b) => a[0].localeCompare(b[0]));
  const labels = [], values = [];
  for (const [k, b] of sorted) {
    labels.push(k);
    if (op === 'count' || op === 'count_by_day') values.push(b.count);
    else values.push(b.count > 0 ? b.sum / b.count : 0);
  }
  return { labels, values };
}

// Format a number for display in a metric label
function fmtMetricValue(n, unit) {
  if (isNaN(n)) return '—';
  const prefix = (unit === '$') ? '$' : '';
  const suffix = (unit === '%') ? '%' : '';
  let s;
  if (Math.abs(n) >= 1_000_000) s = (n / 1_000_000).toFixed(1) + 'M';
  else if (Math.abs(n) >= 1_000) s = n.toLocaleString(undefined, { maximumFractionDigits: 0 });
  else s = n.toLocaleString(undefined, { maximumFractionDigits: 2 });
  return prefix + s + suffix;
}

// Main Phase 2 resolver — mutates ddlObj in-place, returns it
function resolveQueries(ddlObj, dataset) {
  const rows    = dataset.rows || [];
  const headers = dataset.headers || [];
  if (!rows.length) return ddlObj;

  for (const card of (ddlObj.cards || [])) {
    try {
      if (card.kind === 'metric') {
        const m = card.metric || {};
        const op  = (m.query_op || '').toLowerCase();
        const col = m.query_col || '';
        const idx = getColIndex(headers, col);
        if (idx === -1 || !op) continue;

        let result = NaN;
        const nums = rows.map(r => parseNumeric(r[idx])).filter(n => !isNaN(n));
        if (op === 'count') {
          result = rows.filter(r => r[idx] !== null && r[idx] !== undefined && r[idx] !== '').length;
        } else if (op === 'sum') {
          result = nums.reduce((a, b) => a + b, 0);
        } else if (op === 'mean') {
          result = nums.length ? nums.reduce((a, b) => a + b, 0) / nums.length : NaN;
        } else if (op === 'min') {
          result = nums.length ? Math.min(...nums) : NaN;
        } else if (op === 'max') {
          result = nums.length ? Math.max(...nums) : NaN;
        }

        m.resolved_value = result;
        // Rebuild label with [value] so the existing injectedMatch regex still fires,
        // but also store resolved_value for the updated renderer
        const baseLabel = (m.label || card.title || '').replace(/\s*\[.*?\]$/, '');
        m.label = baseLabel + ' [' + fmtMetricValue(result, m.unit || '') + ']';

      } else if (card.kind === 'chart') {
        const c  = card.chart || {};
        const op = (c.query_op || '').toLowerCase();
        const xIdx = getColIndex(headers, c.x_col);
        const yIdx = getColIndex(headers, c.y_col);
        const topN = parseInt(c.top_n) || 10;
        let resolved = null;

        if (op === 'count_by_group') {
          if (xIdx === -1) continue;
          resolved = groupBy(rows, xIdx, xIdx, 'count');
        } else if (op === 'mean_by_group') {
          if (xIdx === -1 || yIdx === -1) continue;
          resolved = groupBy(rows, xIdx, yIdx, 'mean');
        } else if (op === 'sum_by_group') {
          if (xIdx === -1 || yIdx === -1) continue;
          resolved = groupBy(rows, xIdx, yIdx, 'sum');
        } else if (op === 'count_by_day' || op === 'timeseries') {
          if (xIdx === -1) continue;
          resolved = bucketDates(rows, xIdx, yIdx !== -1 ? yIdx : xIdx, 'count');
        } else if (op === 'top_n') {
          if (yIdx === -1) continue;
          const sorted = [...rows]
            .filter(r => !isNaN(parseNumeric(r[yIdx])))
            .sort((a, b) => parseNumeric(b[yIdx]) - parseNumeric(a[yIdx]))
            .slice(0, topN);
          resolved = {
            labels: sorted.map(r => String(xIdx !== -1 ? r[xIdx] : r[yIdx])),
            values: sorted.map(r => parseNumeric(r[yIdx])),
          };
        }

        if (resolved) {
          // Trim to top_n / 10 entries
          const limit = topN || 10;
          c.resolved_data = {
            labels: resolved.labels.slice(0, limit),
            values: resolved.values.slice(0, limit),
          };
        }

      } else if (card.kind === 'table') {
        const t  = card.table || {};
        const op = (t.query_op || '').toLowerCase();
        const cols = t.columns || [];
        const colIdxs = cols.map(c => getColIndex(headers, c));
        const limit = parseInt(t.limit) || 10;

        let filtered = rows;
        if (op === 'filter') {
          const fIdx = getColIndex(headers, t.filter_col);
          const fVal = String(t.filter_val || '').toLowerCase();
          if (fIdx !== -1 && fVal) {
            filtered = rows.filter(r => String(r[fIdx] ?? '').toLowerCase().includes(fVal));
          }
          filtered = filtered.slice(0, limit);
        } else {
          // top_n: sort by sort_col descending
          const sIdx = getColIndex(headers, t.sort_col);
          if (sIdx !== -1) {
            filtered = [...rows].sort((a, b) => {
              const na = parseNumeric(a[sIdx]), nb = parseNumeric(b[sIdx]);
              if (!isNaN(na) && !isNaN(nb)) return nb - na;
              return String(b[sIdx] ?? '').localeCompare(String(a[sIdx] ?? ''));
            });
          }
          filtered = filtered.slice(0, limit);
        }

        // Build resolved_rows using matched column indices (fall back to raw value)
        t.resolved_rows = filtered.map(row =>
          colIdxs.map(idx => idx !== -1 ? String(row[idx] ?? '') : '')
        );
      }
    } catch (e) {
      // Skip cards that throw — don't break the whole dashboard
      console.warn('[moke] resolveQueries error on card', card.id, e);
    }
  }
  return ddlObj;
}

// ── Destroy Chart.js instances to avoid canvas reuse errors ───────────────
function destroyCharts() {
  Object.values(chartInstances).forEach(c => { try { c.destroy(); } catch(_) {} });
  chartInstances = {};
}

// ── Render a single metric card ────────────────────────────────────────────
function renderMetricCard(card) {
  const m = card.metric || {};
  const unit = m.unit || '';
  let displayLabel, resolvedVal;

  if (m.resolved_value !== undefined && !isNaN(m.resolved_value)) {
    // Phase 2 set resolved_value directly — use it
    displayLabel = (m.label || card.title || '').replace(/\s*\[.*?\]$/, '');
    resolvedVal  = fmtMetricValue(m.resolved_value, unit);
  } else {
    // Fall back to injected [value] in label string
    const rawLabel = m.label || card.title || '';
    const injectedMatch = rawLabel.match(/^(.*?)\s*\[(.+?)\]$/);
    displayLabel = injectedMatch ? injectedMatch[1] : (card.title || m.label || '');
    resolvedVal  = injectedMatch ? injectedMatch[2] : '—';
  }

  return `<div class="card-label">${esc(displayLabel)}</div>
    <div class="metric-value">${esc(resolvedVal)}<span class="metric-unit">${esc(unit)}</span></div>
    <div class="metric-delta flat">&#x2192; computed locally</div>`;
}

// ── Render a chart card (Chart.js) ─────────────────────────────────────────
function renderChartCard(card) {
  const c = card.chart || {};
  const cid = 'canvas-' + card.id;
  return `<div class="card-label">${esc(card.title)}</div>
    <div class="chart-wrap"><canvas id="${esc(cid)}"></canvas></div>`;
}

// Mount Chart.js after DOM insertion
function mountChart(card) {
  const c = card.chart || {};
  const cid = 'canvas-' + card.id;
  const canvas = document.getElementById(cid);
  if (!canvas || typeof Chart === 'undefined') return;

  const chartType = c.chart_type || 'bar';
  const jsType = chartType === 'area' ? 'line' : chartType;

  const xLabel = c.x_col || 'Category';
  const yLabel = c.y_col || 'Value';

  // ── Scatter chart with cluster data (from ML handoff) ──────────────────
  if (jsType === 'scatter' && c.data && c.data.length) {
    const k = c.k || 4;
    // Partition points by cluster
    const byCluster = {};
    c.data.forEach(pt => {
      const cl = pt.cluster !== undefined ? pt.cluster : 0;
      if (!byCluster[cl]) byCluster[cl] = [];
      byCluster[cl].push({ x: pt.x, y: pt.y });
    });
    const datasets = Object.keys(byCluster).map(cl => ({
      label: 'Cluster ' + (parseInt(cl) + 1),
      data: byCluster[cl],
      backgroundColor: PALETTE[parseInt(cl) % PALETTE.length],
      borderColor:     PALETTE_BORDER[parseInt(cl) % PALETTE_BORDER.length],
      pointRadius: 4,
      pointHoverRadius: 6,
    }));
    chartInstances[card.id] = new Chart(canvas, {
      type: 'scatter',
      data: { datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 400 },
        plugins: {
          legend: { display: true, labels: { color: '#6b7280', font: { size: 11 } } },
          tooltip: { callbacks: {
            label: ctx => `Cluster ${ctx.datasetIndex + 1}: (${ctx.parsed.x.toFixed(1)}, ${ctx.parsed.y.toFixed(1)})`
          }},
        },
        scales: {
          x: {
            ticks: { color: '#6b7280', font: { size: 11 } },
            grid:  { color: 'rgba(42,45,58,0.6)' },
            title: { display: true, text: xLabel, color: '#6b7280', font: { size: 11 } },
          },
          y: {
            ticks: { color: '#6b7280', font: { size: 11 } },
            grid:  { color: 'rgba(42,45,58,0.6)' },
            title: { display: true, text: yLabel, color: '#6b7280', font: { size: 11 } },
          },
        },
      },
    });
    return;
  }

  // Use resolved data from Phase 2 if available; otherwise fall back to demo data
  let chartLabels, chartData;
  if (c.resolved_data && c.resolved_data.labels && c.resolved_data.labels.length) {
    chartLabels = c.resolved_data.labels;
    chartData   = c.resolved_data.values;
  } else {
    chartLabels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct'].slice(0,7);
    chartData   = chartLabels.map(() => Math.round(Math.random() * 900 + 100));
  }

  const isPie = jsType === 'pie' || jsType === 'doughnut';
  const dataset = {
    label: yLabel,
    data: chartData,
    backgroundColor: isPie ? PALETTE.slice(0, chartLabels.length) : PALETTE[0],
    borderColor:     isPie ? PALETTE_BORDER.slice(0, chartLabels.length) : PALETTE_BORDER[0],
    borderWidth: 1,
    fill: chartType === 'area',
    tension: 0.35,
    pointRadius: jsType === 'line' ? 3 : 0,
  };

  chartInstances[card.id] = new Chart(canvas, {
    type: jsType,
    data: { labels: chartLabels, datasets: [dataset] },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 400 },
      plugins: {
        legend: { display: isPie, labels: { color: '#6b7280', font: { size: 11 } } },
        tooltip: { mode: 'index', intersect: false },
      },
      scales: isPie ? {} : {
        x: {
          ticks: { color: '#6b7280', font: { size: 11 } },
          grid:  { color: 'rgba(42,45,58,0.6)' },
          title: { display: true, text: xLabel, color: '#6b7280', font: { size: 11 } },
        },
        y: {
          ticks: { color: '#6b7280', font: { size: 11 } },
          grid:  { color: 'rgba(42,45,58,0.6)' },
          title: { display: true, text: yLabel, color: '#6b7280', font: { size: 11 } },
        },
      },
    },
  });
}

// ── Render a table card ────────────────────────────────────────────────────
function renderTableCard(card) {
  const t = card.table || {};
  const cols = t.columns || [];
  sortState[card.id] = sortState[card.id] || { col: t.sort_col || cols[0] || '', asc: false };
  const heatmapCol = t.heatmap_col || null;  // column name to colour-code by value

  let th = cols.map(col => {
    const sorted = sortState[card.id].col === col;
    const cls = sorted ? (sortState[card.id].asc ? 'sorted-asc' : 'sorted-desc') : '';
    return `<th class="${esc(cls)}" onclick="tableSort('${esc(card.id)}','${esc(col)}')">${esc(col)}<span class="sort-arrow"></span></th>`;
  }).join('');

  // Priority: resolved_rows (from Phase 2) > rows (from ML DDL handoff) > placeholder
  let tbody;
  if (t.resolved_rows && t.resolved_rows.length) {
    // Array of arrays from Phase 2 resolveQueries
    tbody = t.resolved_rows.map(row => {
      const cells = row.map(cell => `<td>${esc(cell)}</td>`).join('');
      return `<tr>${cells}</tr>`;
    }).join('');
  } else if (t.rows && t.rows.length) {
    // Array of objects from ML DDL handoff — apply heatmap colouring if requested
    tbody = t.rows.map(rowObj => {
      const cells = cols.map(col => {
        const val = rowObj[col] !== undefined ? rowObj[col] : '';
        if (heatmapCol && col === heatmapCol) {
          const num = parseFloat(val);
          if (!isNaN(num)) {
            const abs = Math.abs(num);
            const hue = num >= 0 ? Math.round(120 * Math.min(abs, 1)) : 0;
            const alpha = (abs * 0.5 + 0.08).toFixed(2);
            const bg = `hsla(${hue},60%,40%,${alpha})`;
            return `<td style="background:${bg};font-family:monospace;text-align:right">${esc(String(val))}</td>`;
          }
        }
        return `<td>${esc(String(val))}</td>`;
      }).join('');
      return `<tr>${cells}</tr>`;
    }).join('');
  } else {
    tbody = Array.from({length: Math.min(t.limit || 5, 5)}, () => {
      const cells = cols.map(() => `<td>—</td>`).join('');
      return `<tr>${cells}</tr>`;
    }).join('');
  }

  return `<div class="card-label">${esc(card.title)}</div>
    <table class="dash-table" id="table-${esc(card.id)}">
      <thead><tr>${th}</tr></thead>
      <tbody id="tbody-${esc(card.id)}">${tbody}</tbody>
    </table>`;
}

function tableSort(cardId, col) {
  const st = sortState[cardId] || { col, asc: false };
  if (st.col === col) { st.asc = !st.asc; } else { st.col = col; st.asc = true; }
  sortState[cardId] = st;
  // Re-render header indicators only (row data comes from phase2 in full impl)
  const table = document.getElementById('table-' + cardId);
  if (!table) return;
  table.querySelectorAll('th').forEach(th => {
    th.classList.remove('sorted-asc','sorted-desc');
    if (th.textContent.trim().startsWith(col)) {
      th.classList.add(st.asc ? 'sorted-asc' : 'sorted-desc');
    }
  });
}

// ── Render a text card ─────────────────────────────────────────────────────
function renderTextCard(card) {
  const md = (card.text && card.text.markdown) ? card.text.markdown : '';
  return `<div class="text-content">${renderMarkdown(md)}</div>`;
}

// ── Render a list card ─────────────────────────────────────────────────────
function renderListCard(card) {
  const li = (card.list && card.list.items) ? card.list.items : [];
  const title = (card.list && card.list.title) ? card.list.title : card.title;
  const items = li.map(item => `<li><span class="list-bullet"></span>${esc(item)}</li>`).join('');
  return `<div class="card-label">${esc(title)}</div>
    <ul class="list-items">${items}</ul>`;
}

// ── Render full dashboard DDL into DOM ─────────────────────────────────────
function renderDashboard(ddlObj) {
  currentDDL = ddlObj;
  destroyCharts();

  const grid = document.getElementById('dash-grid');
  grid.innerHTML = '';
  document.getElementById('empty-dash').classList.remove('visible');

  const cards = ddlObj.cards || [];
  const chartCards = [];

  cards.forEach(card => {
    const colSpan = Math.min(Math.max(parseInt(card.col_span) || 1, 1), 3);
    const el = document.createElement('div');
    el.className = `dash-card col-${colSpan}`;
    el.id = 'dc-' + card.id;

    switch (card.kind) {
      case 'metric': el.innerHTML = renderMetricCard(card); break;
      case 'chart':  el.innerHTML = renderChartCard(card);  chartCards.push(card); break;
      case 'table':  el.innerHTML = renderTableCard(card);  break;
      case 'text':   el.innerHTML = renderTextCard(card);   break;
      case 'list':   el.innerHTML = renderListCard(card);   break;
      default:
        el.innerHTML = `<div class="card-label">${esc(card.kind)}</div><p style="font-size:0.85em;color:var(--muted)">${esc(card.title)}</p>`;
    }
    grid.appendChild(el);
  });

  // Mount Chart.js after all DOM nodes exist
  chartCards.forEach(card => mountChart(card));

  // Update UI state
  const tsEl = document.getElementById('dash-generated-at');
  tsEl.textContent = 'Generated ' + new Date().toLocaleTimeString();
  document.getElementById('btn-export-ddl').disabled = false;
  document.getElementById('btn-export-png').disabled = false;
  document.getElementById('btn-present').disabled = false;
  document.getElementById('refine-row').classList.add('visible');
}

// ── Generate dashboard (phase 1 → 2 → 3) ─────────────────────────────────
async function generateDashboard() {
  const question = document.getElementById('dash-prompt').value.trim();
  if (!question) return;

  clearError();
  phaseStart();
  phaseRun('ph1');
  setBusy(true);

  let ddlObj = null;

  try {
    // Phase 1 — ask LLM
    const rid = 'dash-' + Date.now();
    const res = await fetch('http://127.0.0.1:11430/api/pipeline', {
      method: 'POST',
      mode: 'cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        text: buildPhase1Prompt(question),
        system_prompt: 'You are a dashboard design assistant. Output only valid JSON.',
        tolerance: 'patient',
        mode: 'dashboard',
        request_id: rid,
      }),
    });
    const data = await res.json();
    phaseDone('ph1');

    if (!data.ok) { showError('Phase 1 error: ' + (data.error || 'unknown')); phaseReset(); setBusy(false); return; }

    // Extract DDL from LLM response text
    ddlObj = extractJSON(data.response || '');
    if (!ddlObj) {
      showError('Phase 1: LLM did not return a valid JSON dashboard. Try rephrasing your question.');
      phaseReset(); setBusy(false); return;
    }

    // Phase 2 — local compute
    phaseRun('ph2');
    let mokeDataset = null;
    try { mokeDataset = JSON.parse(sessionStorage.getItem('moke_dataset')); } catch(_) {}
    if (mokeDataset && mokeDataset.rows && mokeDataset.rows.length > 0) {
      ddlObj = resolveQueries(ddlObj, mokeDataset);
    } else {
      console.info('[moke] Phase 2: local data not loaded — showing LLM estimates');
    }
    phaseDone('ph2');

    // Phase 3 — render
    phaseRun('ph3');
    await new Promise(r => setTimeout(r, 200));
    renderDashboard(ddlObj);
    phaseDone('ph3');

  } catch (err) {
    showError('Dashboard generation failed: ' + err.message);
    phaseReset();
  }

  setBusy(false);
}

// ── Refine dashboard ───────────────────────────────────────────────────────
async function refineDashboard() {
  if (!currentDDL) return;
  const instruction = document.getElementById('refine-prompt').value.trim();
  if (!instruction) return;

  clearError();
  phaseStart();
  phaseRun('ph1');
  setBusy(true);

  try {
    const currentJSON = JSON.stringify(currentDDL);
    const prompt = `Refine this dashboard: ${currentJSON}\n\nInstruction: ${instruction}\n\nRespond with ONLY the updated JSON object, no explanation.`;
    const res = await fetch('http://127.0.0.1:11430/api/pipeline', {
      method: 'POST',
      mode: 'cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        text: prompt,
        system_prompt: 'You are a dashboard design assistant. Output only valid JSON.',
        tolerance: 'patient',
        mode: 'dashboard',
      }),
    });
    const data = await res.json();
    phaseDone('ph1');
    if (!data.ok) { showError('Refine error: ' + (data.error || 'unknown')); phaseReset(); setBusy(false); return; }

    const ddlObj = extractJSON(data.response || '');
    if (!ddlObj) { showError('Refine: LLM did not return valid JSON. Try a different instruction.'); phaseReset(); setBusy(false); return; }

    phaseRun('ph2');
    let mokeDataset2 = null;
    try { mokeDataset2 = JSON.parse(sessionStorage.getItem('moke_dataset')); } catch(_) {}
    if (mokeDataset2 && mokeDataset2.rows && mokeDataset2.rows.length > 0) {
      ddlObj = resolveQueries(ddlObj, mokeDataset2);
    } else {
      console.info('[moke] Phase 2 (refine): local data not loaded — showing LLM estimates');
    }
    phaseDone('ph2');

    phaseRun('ph3');
    await new Promise(r => setTimeout(r, 150));
    renderDashboard(ddlObj);
    phaseDone('ph3');
    document.getElementById('refine-prompt').value = '';

  } catch (err) {
    showError('Refine failed: ' + err.message);
    phaseReset();
  }

  setBusy(false);
}

// ── Build prompt (mirrors server-side build_phase1_prompt) ─────────────────
function buildPhase1Prompt(question) {
  return `You have access to this dataset. User asks: ${question}

Design a dashboard as a JSON DDL object with the following top-level fields:
  title (string), summary (string), cards (array).

Each card must have:
  id (unique string), kind (one of: metric, chart, table, text, list),
  title (string), col_span (integer 1-3).

For metric cards include a 'metric' object with: label, query_op, query_col, unit.
For chart cards include a 'chart' object with: chart_type (line/bar/pie/area/scatter), x_col, y_col, query_op.
For table cards include a 'table' object with: columns (string array), query_op, sort_col, limit.

Respond with ONLY the JSON object, no explanation.`;
}

// ── Disable/enable controls during async ops ───────────────────────────────
function setBusy(busy) {
  ['btn-generate','btn-refine','btn-export-ddl','btn-export-png'].forEach(id => {
    const el = document.getElementById(id);
    if (el && id !== 'btn-export-ddl' && id !== 'btn-export-png') el.disabled = busy;
  });
}

// ── Export DDL as JSON file ────────────────────────────────────────────────
function exportDDL() {
  if (!currentDDL) return;
  const blob = new Blob([JSON.stringify(currentDDL, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'dashboard-' + Date.now() + '.ddl.json';
  a.click();
}

// ── Export PNG via html2canvas (falls back to alert if unavailable) ────────
function exportPNG() {
  const grid = document.getElementById('dash-grid');
  if (typeof html2canvas !== 'undefined') {
    html2canvas(grid, { backgroundColor: '#0f1117' }).then(canvas => {
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = 'dashboard-' + Date.now() + '.png';
      a.click();
    });
  } else {
    alert('PNG export requires html2canvas. Add it to /static/ to enable this feature.');
  }
}

// ── Launch presentation mode ───────────────────────────────────────────────
function presentDashboard() {
  if (!currentDDL) return;
  try {
    sessionStorage.setItem('moke_dashboard_ddl', JSON.stringify(currentDDL));
  } catch (e) {
    alert('Could not save dashboard to sessionStorage: ' + e.message);
    return;
  }
  window.location.href = '/presentation';
}

// ── Load Customer Intelligence demo dashboard ──────────────────────────────
function loadDemo() {
  const demo = {
    title: "Customer Intelligence",
    summary: "Key customer metrics, lifetime value distribution, order trends, and top-performer ranking",
    cards: [
      {
        id: "m-total-customers", kind: "metric", title: "Total Customers", col_span: 1,
        metric: { label: "Total Customers [12,483]", query_op: "count", query_col: "customer_id", unit: "", delta_query_op: "count_prev_period" }
      },
      {
        id: "m-avg-ltv", kind: "metric", title: "Avg LTV", col_span: 1,
        metric: { label: "Avg LTV [$3,241]", query_op: "mean", query_col: "lifetime_value", unit: "$", delta_query_op: "mean_prev_period" }
      },
      {
        id: "m-churn", kind: "metric", title: "Churn Rate", col_span: 1,
        metric: { label: "Churn Rate [8.2]", query_op: "mean", query_col: "churned", unit: "%", delta_query_op: "mean_prev_period" }
      },
      {
        id: "m-avg-order", kind: "metric", title: "Avg Order Value", col_span: 1,
        metric: { label: "Avg Order Value [$184]", query_op: "mean", query_col: "order_value", unit: "$", delta_query_op: "mean_prev_period" }
      },
      {
        id: "c-ltv-cluster", kind: "chart", title: "LTV by Cluster", col_span: 2,
        chart: { title: "LTV by Cluster", chart_type: "bar", x_col: "cluster", y_col: "lifetime_value", query_op: "mean_by_group", filter_col: "", filter_val: "", top_n: 10 }
      },
      {
        id: "c-orders-time", kind: "chart", title: "Orders over Time", col_span: 2,
        chart: { title: "Orders over Time", chart_type: "line", x_col: "order_date", y_col: "order_count", query_op: "count_by_day", filter_col: "", filter_val: "", top_n: 0 }
      },
      {
        id: "t-top-customers", kind: "table", title: "Top 10 Customers by LTV", col_span: 3,
        table: { title: "Top 10 Customers by LTV", columns: ["customer_id","name","cluster","lifetime_value","order_count","last_order_date"], query_op: "top_n", sort_col: "lifetime_value", limit: 10 }
      }
    ]
  };
  renderDashboard(demo);
}

// ── MK2.4: Auto-load ML result from Insight Lab handoff ────────────────────
(function autoLoadMLResult() {
  let raw = null;
  try { raw = sessionStorage.getItem('moke_dashboard_ddl'); } catch(_) {}
  if (!raw) return;
  let ddl = null;
  try { ddl = JSON.parse(raw); } catch(_) { return; }
  // Consume the key so refresh doesn't re-load stale ML data
  try { sessionStorage.removeItem('moke_dashboard_ddl'); } catch(_) {}
  // Defer rendering so the DOM (including Chart.js script) is ready
  setTimeout(function() {
    renderDashboard(ddl);
  }, 0);
})();

// ── MK3.4: Dashboard template persistence ─────────────────────────────────
var TEMPLATES_KEY = 'moke_ddl_templates';

function getStoredTemplates() {
  try { return JSON.parse(localStorage.getItem(TEMPLATES_KEY) || '{}'); } catch(_) { return {}; }
}

function putStoredTemplates(tpls) {
  try { localStorage.setItem(TEMPLATES_KEY, JSON.stringify(tpls)); } catch(e) {
    alert('Could not save template: ' + e.message);
  }
}

function renderTemplateSelect() {
  const sel = document.getElementById('template-select');
  if (!sel) return;
  const tpls = getStoredTemplates();
  const names = Object.keys(tpls).sort();
  const current = sel.value;
  sel.innerHTML = '<option value="">— load saved template —</option>';
  names.forEach(name => {
    const opt = document.createElement('option');
    opt.value = name;
    opt.textContent = name;
    sel.appendChild(opt);
  });
  if (current && tpls[current]) sel.value = current;
}

window.saveTemplate = function() {
  if (!currentDDL) { alert('No dashboard to save — generate a dashboard first.'); return; }
  const suggested = (currentDDL.title || 'My Dashboard').replace(/[<>"]/g, '');
  const name = prompt('Save as template:', suggested);
  if (!name || !name.trim()) return;
  const tpls = getStoredTemplates();
  tpls[name.trim()] = JSON.parse(JSON.stringify(currentDDL)); // deep copy
  putStoredTemplates(tpls);
  renderTemplateSelect();
  const sel = document.getElementById('template-select');
  if (sel) sel.value = name.trim();
};

window.loadSavedTemplate = function() {
  const sel = document.getElementById('template-select');
  if (!sel || !sel.value) return;
  const tpls = getStoredTemplates();
  const ddl = tpls[sel.value];
  if (!ddl) { alert('Template not found.'); return; }
  renderDashboard(JSON.parse(JSON.stringify(ddl))); // deep copy before render
};

window.deleteTemplate = function() {
  const sel = document.getElementById('template-select');
  if (!sel || !sel.value) return;
  if (!confirm('Delete template "' + sel.value + '"?')) return;
  const tpls = getStoredTemplates();
  delete tpls[sel.value];
  putStoredTemplates(tpls);
  renderTemplateSelect();
};

// Init — populate template selector on load
renderTemplateSelect();

// ── Expose to global scope for inline onkeydown/onclick handlers ──────────
window.generateDashboard = generateDashboard;
window.refineDashboard   = refineDashboard;
window.exportDDL         = exportDDL;
window.exportPNG         = exportPNG;
window.presentDashboard  = presentDashboard;
window.loadDemo          = loadDemo;
window.tableSort         = tableSort;

})();
</script>

{! end !}
