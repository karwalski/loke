{! layout("base") !}

{! block("title") !}Datasets — moke{! end !}

{! block("content") !}
<style>
  .page-heading { margin-bottom: 6px; font-size: 1.5em; font-weight: 700; letter-spacing: -0.02em; }
  .page-sub { color: var(--muted); font-size: 0.9em; margin-bottom: 24px; }

  /* Privacy banner */
  .privacy-banner {
    background: var(--teal-dim); border: 1px solid var(--teal);
    border-radius: 10px; padding: 14px 20px; margin-bottom: 28px;
    font-size: 0.88em; color: var(--text); display: flex; gap: 12px; align-items: flex-start;
  }
  .privacy-banner .icon { font-size: 1.3em; flex-shrink: 0; margin-top: 1px; }

  /* Section headings */
  .section-heading {
    font-size: 0.78em; font-weight: 700; letter-spacing: 0.09em;
    text-transform: uppercase; color: var(--muted);
    margin: 28px 0 14px; display: flex; align-items: center; gap: 8px;
  }
  .section-heading::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  /* Dataset grid */
  .dataset-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 8px; }
  .dataset-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 8px; }
  .dataset-grid-1 { display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 8px; }

  /* Dataset card */
  .ds-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 18px 20px;
    display: flex; flex-direction: column; gap: 10px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .ds-card:hover { border-color: var(--teal); box-shadow: 0 0 0 1px var(--teal-dim); }
  .ds-card-header { display: flex; align-items: flex-start; gap: 10px; }
  .ds-icon { font-size: 1.6em; flex-shrink: 0; }
  .ds-name { font-size: 0.95em; font-weight: 700; line-height: 1.3; color: var(--text); }
  .ds-desc { font-size: 0.82em; color: var(--muted); line-height: 1.4; flex: 1; }
  .ds-meta {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    font-size: 0.77em; color: var(--muted); border-top: 1px solid var(--border);
    padding-top: 10px; margin-top: 2px;
  }
  .ds-meta .sep { color: var(--border); }
  .ds-footer { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .load-btn {
    font-size: 0.82em; font-weight: 600; padding: 6px 16px;
    background: var(--teal); color: #0d1117; border: none; border-radius: 7px;
    cursor: pointer; transition: opacity 0.15s, transform 0.1s; white-space: nowrap;
  }
  .load-btn:hover { opacity: 0.88; }
  .load-btn:active { transform: scale(0.96); }

  /* Upload section */
  .upload-section {
    margin-top: 28px; border-top: 1px solid var(--border);
    padding-top: 20px; display: flex; align-items: center; justify-content: space-between;
  }
  .upload-section p { color: var(--muted); font-size: 0.88em; }
  .upload-section a {
    font-size: 0.85em; font-weight: 600; color: var(--teal);
    text-decoration: none; display: flex; align-items: center; gap: 6px;
    padding: 7px 16px; border: 1px solid var(--teal); border-radius: 7px;
    transition: background 0.15s;
  }
  .upload-section a:hover { background: var(--teal-dim); }

  @media (max-width: 900px) { .dataset-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .dataset-grid, .dataset-grid-2 { grid-template-columns: 1fr; } }
</style>

<h1 class="page-heading">Choose a dataset to analyse</h1>
<p class="page-sub">All analysis runs locally — raw data never leaves your machine</p>

<div class="privacy-banner">
  <span class="icon">🔒</span>
  <span>
    <strong>Schema-first protocol</strong> — the LLM sees column profiles and statistics, never your raw data.
    All PII is anonymised by loke before any external call.
  </span>
</div>

<!-- ── Government Open Data ── -->
<div class="section-heading">Government Open Data</div>
<div class="dataset-grid">

  <div class="ds-card">
    <div class="ds-card-header">
      <span class="ds-icon">🏥</span>
      <span class="ds-name">Medicare Benefits Schedule</span>
    </div>
    <p class="ds-desc">MBS claims data with patient, provider, and billing information</p>
    <div class="ds-meta">
      <span>30 rows</span><span class="sep">·</span>
      <span>26 cols</span><span class="sep">·</span>
      <span class="badge badge-confidential">CONFIDENTIAL</span>
    </div>
    <div class="ds-footer">
      <button class="load-btn" onclick="loadDataset('au.medicare')">Load dataset</button>
