  function loadDataset(id) {
    var d = DATASETS[id];
    if (!d) return;
    var ds = {
      id: id,
      name: d.name,
      sensitivity: d.sensitivity,
      category: d.category,
      headers: d.headers,
      pii: d.pii,
      rows: d.rows,
      loadedAt: Date.now()
    };
    sessionStorage.setItem('moke_dataset', JSON.stringify(ds));
    window.location.href = '/chat';
  }
