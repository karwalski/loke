{! layout("base") !}

{! block("title") !}Analysis — moke{! end !}

{! block("content") !}
<style>
  /* ── Two-column chat layout ── */
  .chat-layout {
    display: flex; gap: 16px; height: calc(100vh - 120px);
    overflow: hidden;
  }

  /* ── Left panel ── */
  .left-panel {
    width: 300px; flex-shrink: 0; display: flex; flex-direction: column; gap: 14px;
    overflow-y: auto;
  }

  /* Dataset card */
  .ds-info-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 18px;
  }
  .ds-info-card .card-label {
    font-size: 0.72em; font-weight: 700; letter-spacing: 0.09em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 10px;
  }
  .ds-info-name { font-size: 0.95em; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .ds-info-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; font-size: 0.78em; color: var(--muted); margin-bottom: 10px; }
  .ds-info-meta .sep { color: var(--border); }
  .switch-link { font-size: 0.8em; color: var(--teal); text-decoration: none; }
  .switch-link:hover { text-decoration: underline; }

  /* Schema summary */
  .schema-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 18px; flex-shrink: 0;
  }
  .schema-card .card-label {
    font-size: 0.72em; font-weight: 700; letter-spacing: 0.09em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 10px;
  }
  .col-row {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 0; border-bottom: 1px solid var(--border); font-size: 0.82em;
  }
  .col-row:last-child { border-bottom: none; }
  .col-name { flex: 1; color: var(--text); font-family: monospace; font-size: 0.9em; }
  .type-chip {
    font-size: 0.72em; padding: 2px 7px; border-radius: 4px; font-weight: 600;
  }
  .type-numeric  { background: rgba(20,184,166,.15); color: var(--teal); }
  .type-text     { background: rgba(139,148,158,.12); color: var(--muted); }
  .type-date     { background: rgba(63,185,80,.12);   color: var(--green); }
  .type-category { background: rgba(59,130,246,.12);  color: #60a5fa; }
  .type-pii      { background: rgba(248,81,73,.15);   color: var(--red); }

  /* Pipeline console */
  .console-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 0; overflow: hidden; flex-shrink: 0;
  }
  .console-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-bottom: 1px solid var(--border);
    font-size: 0.72em; font-weight: 700; letter-spacing: 0.09em;
    text-transform: uppercase; color: var(--muted);
  }
  .console-clear {
    background: none; border: none; color: var(--muted); cursor: pointer;
    font-size: 0.85em; padding: 2px 6px; border-radius: 4px;
    transition: color 0.15s;
  }
  .console-clear:hover { color: var(--text); }
  .console-body {
    height: 300px; overflow-y: auto; padding: 10px 14px;
    font-family: monospace; font-size: 0.78em; line-height: 1.7;
    background: #0a0e13;
  }
  .log-entry { display: flex; gap: 8px; align-items: baseline; }
  .log-time  { color: #3d4451; flex-shrink: 0; }
  .log-stage { font-weight: 600; flex-shrink: 0; }
  .log-msg   { color: var(--muted); }
  .stage-schema    { color: var(--teal); }
  .stage-profile   { color: #60a5fa; }
  .stage-anonymise { color: var(--amber); }
  .stage-llm       { color: #a78bfa; }
  .stage-compute   { color: var(--green); }
  .stage-restore   { color: var(--muted); }

  /* ── Right panel: chat ── */
  .right-panel {
    flex: 1; display: flex; flex-direction: column;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; overflow: hidden; min-width: 0;
  }

  /* Message history */
  .message-history {
    flex: 1; overflow-y: auto; padding: 20px;
    display: flex; flex-direction: column; gap: 16px;
  }

  /* Prompt chips */
  .prompt-chips {
    display: flex; flex-wrap: wrap; gap: 8px;
    justify-content: center; padding: 32px 20px;
  }
  .prompt-chip {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 20px; padding: 8px 16px;
    font-size: 0.83em; color: var(--muted);
    cursor: pointer; transition: border-color 0.15s, color 0.15s;
  }
  .prompt-chip:hover { border-color: var(--teal); color: var(--teal); }
  .chips-label {
    width: 100%; text-align: center; color: var(--muted);
    font-size: 0.82em; margin-bottom: 8px;
  }

  /* Message bubbles */
  .msg { display: flex; flex-direction: column; max-width: 80%; }
  .msg-user { align-self: flex-end; align-items: flex-end; }
  .msg-assistant { align-self: flex-start; align-items: flex-start; }
  .bubble {
    padding: 12px 16px; border-radius: 12px; font-size: 0.9em;
    line-height: 1.6; word-break: break-word;
  }
  .bubble-user {
    background: var(--teal); color: #0d1117;
    border-bottom-right-radius: 3px;
  }
  .bubble-assistant {
    background: var(--bg); border: 1px solid var(--border);
    color: var(--text); border-bottom-left-radius: 3px;
  }
  .msg-actions {
    display: flex; align-items: center; gap: 8px; margin-top: 6px;
    flex-wrap: wrap;
  }
  .msg-btn {
    background: none; border: 1px solid var(--border);
    border-radius: 6px; padding: 3px 10px; font-size: 0.75em;
    color: var(--muted); cursor: pointer; transition: border-color 0.15s, color 0.15s;
  }
  .msg-btn:hover { border-color: var(--teal); color: var(--teal); }
  .msg-btn.active { border-color: var(--teal); color: var(--teal); background: var(--teal-dim); }
  .thumbs { display: flex; gap: 4px; }
  .thumb-btn {
    background: none; border: none; cursor: pointer;
    font-size: 1em; padding: 2px 4px; opacity: 0.5;
    transition: opacity 0.15s, transform 0.1s;
  }
  .thumb-btn:hover { opacity: 1; transform: scale(1.15); }
  .thumb-btn.voted { opacity: 1; }

  /* Pipeline trace */
  .trace-panel {
    background: #0a0e13; border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px;
    font-family: monospace; font-size: 0.77em; line-height: 1.7;
    margin-top: 8px; display: none;
  }
  .trace-panel.open { display: block; }

  /* Typing indicator */
  .typing-indicator { display: flex; align-items: center; gap: 4px; padding: 12px 16px; }
  .typing-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--muted);
    animation: typing-bounce 1.2s infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
  }

  /* Confirm dialog */
  .confirm-dialog {
    margin: 0 20px; padding: 14px 18px;
    background: rgba(20,184,166,.08); border: 1px solid var(--teal);
    border-radius: 10px; font-size: 0.85em; display: none;
  }
  .confirm-dialog.open { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .confirm-dialog p { flex: 1; color: var(--text); }
  .confirm-dialog p strong { color: var(--teal); }
  .confirm-btns { display: flex; gap: 8px; }
  .btn-approve {
    padding: 6px 14px; background: var(--teal); color: #0d1117;
    border: none; border-radius: 7px; cursor: pointer; font-weight: 600; font-size: 0.85em;
  }
  .btn-cancel {
    padding: 6px 14px; background: none; border: 1px solid var(--border);
    color: var(--muted); border-radius: 7px; cursor: pointer; font-size: 0.85em;
  }
  .btn-cancel:hover { border-color: var(--red); color: var(--red); }

  /* Input area */
  .input-area {
    border-top: 1px solid var(--border); padding: 14px 16px;
    display: flex; flex-direction: column; gap: 10px; flex-shrink: 0;
  }
  .input-row { display: flex; gap: 8px; align-items: flex-end; }
  .chat-textarea {
    flex: 1; background: var(--bg); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px; color: var(--text);
    font-family: inherit; font-size: 0.9em; resize: none; min-height: 44px; max-height: 140px;
    outline: none; line-height: 1.5;
    transition: border-color 0.15s;
  }
  .chat-textarea:focus { border-color: var(--teal); }
  .input-actions { display: flex; gap: 8px; flex-direction: column; }
  .send-btn {
    padding: 10px 18px; background: var(--teal); color: #0d1117;
    border: none; border-radius: 8px; cursor: pointer; font-weight: 700;
    font-size: 0.88em; white-space: nowrap; transition: opacity 0.15s;
  }
  .send-btn:hover { opacity: 0.88; }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .input-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .dash-btn {
    background: none; border: 1px solid var(--border); color: var(--muted);
    border-radius: 7px; padding: 5px 12px; font-size: 0.8em; cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .dash-btn:hover { border-color: var(--teal); color: var(--teal); }
  .model-select {
    background: var(--bg); border: 1px solid var(--border); color: var(--text);
    border-radius: 7px; padding: 5px 10px; font-size: 0.8em; outline: none;
    cursor: pointer; transition: border-color 0.15s;
  }
  .model-select:focus { border-color: var(--teal); }
  .char-count { font-size: 0.75em; color: var(--muted); margin-left: auto; }

  @media (max-width: 900px) {
    .chat-layout { flex-direction: column; height: auto; }
    .left-panel { width: 100%; }
    .console-body { height: 180px; }
  }
</style>

<!-- No-dataset banner (shown when sessionStorage has nothing) -->
<div id="no-dataset-banner" style="display:none; margin-bottom:16px;">
  <div style="background:rgba(210,153,34,.1); border:1px solid var(--amber); border-radius:10px; padding:14px 18px; font-size:0.88em; display:flex; align-items:center; gap:12px;">
    <span style="font-size:1.3em;">⚠️</span>
    <span>No dataset loaded. <a href="/" style="color:var(--teal);">Choose a dataset</a> to begin analysis.</span>
  </div>
</div>

<div class="chat-layout">

  <!-- ── Left panel ── -->
  <div class="left-panel">

    <!-- Dataset info card -->
    <div class="ds-info-card">
      <div class="card-label">Active Dataset</div>
      <div class="ds-info-name" id="ds-name">—</div>
      <div class="ds-info-meta">
        <span id="ds-rows">—</span>
        <span class="sep">·</span>
        <span id="ds-cols">—</span>
        <span class="sep">·</span>
        <span class="badge" id="ds-sensitivity-badge">—</span>
      </div>
      <a href="/" class="switch-link">↩ Switch dataset</a>
    </div>

    <!-- Schema summary -->
    <div class="schema-card">
      <div class="card-label">Schema Preview</div>
      <div id="schema-cols">
        <div class="col-row"><span class="col-name muted">Loading schema…</span></div>
      </div>
    </div>

    <!-- Pipeline console -->
    <div class="console-card">
      <div class="console-header">
        Pipeline Console
        <button class="console-clear" onclick="clearConsole()">Clear</button>
      </div>
      <div class="console-body" id="console-body">
        <div class="log-entry">
          <span class="log-time">00:00</span>
          <span class="log-stage stage-schema">Schema Extract</span>
          <span class="log-msg">Ready — awaiting input</span>
        </div>
      </div>
    </div>

  </div>

  <!-- ── Right panel ── -->
  <div class="right-panel">

    <!-- Message history -->
    <div class="message-history" id="message-history">
      <!-- Suggested prompts (shown when empty) -->
      <div class="prompt-chips" id="prompt-chips">
        <div class="chips-label">Suggested prompts</div>
        <button class="prompt-chip" onclick="usePrompt(this)">Summarise this dataset for me</button>
        <button class="prompt-chip" onclick="usePrompt(this)">Which columns contain potential PII?</button>
        <button class="prompt-chip" onclick="usePrompt(this)">Find anomalies in the revenue data</button>
        <button class="prompt-chip" onclick="usePrompt(this)">Generate a dashboard for this dataset</button>
        <button class="prompt-chip" onclick="usePrompt(this)">Cluster customers by spending behaviour</button>
      </div>
    </div>

    <!-- LLM call confirmation dialog -->
    <div class="confirm-dialog" id="confirm-dialog">
      <p>
        <strong>Schema profile</strong> (not raw data) will be sent to the LLM via loke's privacy filter.
        No identifiable records will leave your machine.
      </p>
      <div class="confirm-btns">
        <button class="btn-approve" onclick="approveCall()">Send</button>
        <button class="btn-cancel"  onclick="cancelCall()">Cancel</button>
      </div>
    </div>

    <!-- Input area -->
    <div class="input-area">
      <div class="input-row">
        <textarea
          class="chat-textarea"
          id="chat-input"
          placeholder="Ask a question about your data…"
          rows="2"
          oninput="onInputChange()"
          onkeydown="handleKey(event)"
        ></textarea>
        <div class="input-actions">
          <button class="send-btn" id="send-btn" onclick="submitMessage()">Analyse</button>
        </div>
      </div>
      <div class="input-meta">
        <button class="dash-btn" onclick="generateDashboard()">📊 Generate Dashboard</button>
        <select class="model-select" id="model-select">
          <option value="loke-router">loke router (auto)</option>
          <option value="llama3.2:3b" id="model-fallback-1">llama3.2:3b</option>
          <option value="qwen2.5:0.5b" id="model-fallback-2">qwen2.5:0.5b</option>
        </select>
        <span class="char-count" id="char-count">0 / 4000</span>
      </div>
    </div>

  </div>

</div>

<script>
(function() {
  /* ── Dataset state ── */
  var dataset = null;
  try { dataset = JSON.parse(sessionStorage.getItem('moke_dataset')); } catch(e) {}

  /* ── MK1.5 Data profiler ── */
  var PII_PATTERN = /_name$|_email$|phone|medicare|dob$|ssn|tfn|card_no|pii_/i;

  function profileColumns(headers, rows) {
    var profile = {};
    headers.forEach(function(col) {
      var p = { type: 'categorical', null_count: 0, distinct_count: 0 };
      var seen = {};
      if (rows && rows.length > 0) {
        var vals = rows.map(function(r) { return r[col]; });
        var nonNull = [];
        vals.forEach(function(v) {
          if (v === null || v === undefined || v === '') { p.null_count++; }
          else { nonNull.push(v); seen[String(v)] = true; }
        });
        p.distinct_count = Object.keys(seen).length;
        var n = nonNull.length;
        if (n > 0) {
          // numeric?
          var numParsed = nonNull.filter(function(v) { return !isNaN(parseFloat(v)) && isFinite(v); });
          if (numParsed.length / n > 0.8) {
            p.type = 'numeric';
            var nums = numParsed.map(parseFloat);
            p.min = Math.min.apply(null, nums);
            p.max = Math.max.apply(null, nums);
            p.mean = nums.reduce(function(a, b) { return a + b; }, 0) / nums.length;
          } else {
            // datetime?
            var DT_RE = /^\d{4}-\d{2}-\d{2}|^\d{2}[\/\-]\d{2}[\/\-]\d{4}|\d{1,2}\/\d{1,2}\/\d{2,4}/;
            var dtHits = nonNull.filter(function(v) { return DT_RE.test(String(v)); });
            if (dtHits.length / n > 0.6) {
              p.type = 'datetime';
            } else {
              // boolean?
              var BOOL_RE = /^(true|false|yes|no|1|0)$/i;
              var boolHits = nonNull.filter(function(v) { return BOOL_RE.test(String(v).trim()); });
              if (boolHits.length / n > 0.9) {
                p.type = 'boolean';
              }
              // else remains categorical
            }
          }
        }
      }
      p.pii = PII_PATTERN.test(col);
      profile[col] = p;
    });
    return profile;
  }

  /* ── MK1.4 Local compute engine ── */
  function getColVals(rows, col) {
    return (rows || []).map(function(r) { return r[col]; }).filter(function(v) {
      return v !== null && v !== undefined && v !== '';
    });
  }
  function getNumVals(rows, col) {
    return getColVals(rows, col).map(parseFloat).filter(function(v) { return !isNaN(v); });
  }

  var compute = {
    count: function(rows, col) {
      if (!col) return rows.length;
      return getColVals(rows, col).length;
    },
    sum: function(rows, col) {
      return getNumVals(rows, col).reduce(function(a, b) { return a + b; }, 0);
    },
    avg: function(rows, col) {
      var nums = getNumVals(rows, col);
      return nums.length ? nums.reduce(function(a, b) { return a + b; }, 0) / nums.length : null;
    },
    min: function(rows, col) {
      var nums = getNumVals(rows, col);
      return nums.length ? Math.min.apply(null, nums) : null;
    },
    max: function(rows, col) {
      var nums = getNumVals(rows, col);
      return nums.length ? Math.max.apply(null, nums) : null;
    },
    group: function(rows, col) {
      var counts = {};
      getColVals(rows, col).forEach(function(v) { counts[v] = (counts[v] || 0) + 1; });
      return Object.keys(counts).map(function(k) { return { value: k, count: counts[k] }; })
        .sort(function(a, b) { return b.count - a.count; });
    },
    countBy: function(rows, col) { return compute.group(rows, col); },
    topN: function(rows, col, n) {
      var copy = rows.slice().filter(function(r) {
        var v = r[col]; return v !== null && v !== undefined && v !== '' && !isNaN(parseFloat(v));
      });
      copy.sort(function(a, b) { return parseFloat(b[col]) - parseFloat(a[col]); });
      return copy.slice(0, n || 10);
    },
    timeseries: function(rows, col, valueCol) {
      var groups = {};
      rows.forEach(function(r) {
        var k = r[col]; if (k === null || k === undefined || k === '') return;
        var kStr = String(k).substring(0, 10); // date part only
        if (!groups[kStr]) groups[kStr] = { count: 0, sum: 0 };
        groups[kStr].count++;
        if (valueCol) {
          var v = parseFloat(r[valueCol]);
          if (!isNaN(v)) groups[kStr].sum += v;
        }
      });
      return Object.keys(groups).sort().map(function(k) {
        return { date: k, count: groups[k].count, sum: groups[k].sum };
      });
    },
    distribution: function(rows, col, buckets) {
      var nums = getNumVals(rows, col);
      if (!nums.length) return [];
      var bk = buckets || 10;
      var mn = Math.min.apply(null, nums), mx = Math.max.apply(null, nums);
      var w = (mx - mn) / bk || 1;
      var hist = [];
      for (var i = 0; i < bk; i++) hist.push({ from: mn + i * w, to: mn + (i + 1) * w, count: 0 });
      nums.forEach(function(v) {
        var idx = Math.min(Math.floor((v - mn) / w), bk - 1);
        hist[idx].count++;
      });
      return hist;
    },
    correlate: function(rows, colA, colB) {
      var pairs = rows.filter(function(r) {
        return r[colA] != null && r[colB] != null &&
               !isNaN(parseFloat(r[colA])) && !isNaN(parseFloat(r[colB]));
      });
      var n = pairs.length;
      if (n < 2) return null;
      var ax = pairs.map(function(r) { return parseFloat(r[colA]); });
      var bx = pairs.map(function(r) { return parseFloat(r[colB]); });
      var meanA = ax.reduce(function(a, b) { return a + b; }, 0) / n;
      var meanB = bx.reduce(function(a, b) { return a + b; }, 0) / n;
      var num = 0, dA = 0, dB = 0;
      for (var i = 0; i < n; i++) {
        var da = ax[i] - meanA, db = bx[i] - meanB;
        num += da * db; dA += da * da; dB += db * db;
      }
      return dA && dB ? num / Math.sqrt(dA * dB) : null;
    },
    percentile: function(rows, col, p) {
      var nums = getNumVals(rows, col).sort(function(a, b) { return a - b; });
      if (!nums.length) return null;
      var idx = (p / 100) * (nums.length - 1);
      var lo = Math.floor(idx), hi = Math.ceil(idx);
      return nums[lo] + (nums[hi] - nums[lo]) * (idx - lo);
    },
    latest: function(rows, col) {
      var vals = getColVals(rows, col).map(function(v) { return String(v); }).sort();
      return vals.length ? vals[vals.length - 1] : null;
    },
    distinct: function(rows, col) {
      var seen = {};
      getColVals(rows, col).forEach(function(v) { seen[String(v)] = true; });
      return Object.keys(seen);
    },
    describe: function(rows, col) {
      var all = (rows || []).map(function(r) { return r[col]; });
      var nulls = all.filter(function(v) { return v === null || v === undefined || v === ''; }).length;
      var nums = getNumVals(rows, col);
      var result = { count: all.length - nulls, nulls: nulls };
      if (nums.length) {
        result.min = Math.min.apply(null, nums);
        result.max = Math.max.apply(null, nums);
        result.mean = nums.reduce(function(a, b) { return a + b; }, 0) / nums.length;
        var variance = nums.reduce(function(a, b) { return a + Math.pow(b - result.mean, 2); }, 0) / nums.length;
        result.stddev = Math.sqrt(variance);
      }
      return result;
    }
  };

  /* ── Compute intent extractor ── */
  var INTENT_PATTERNS = [
    { re: /\baverage\b|\bmean\b|\bavg\b/, op: 'avg' },
    { re: /\bsum\b|\btotal\b/, op: 'sum' },
    { re: /\bcount\b|\bhow many\b/, op: 'count' },
    { re: /\bminimum\b|\bmin\b|\blowest\b|\bsmallest\b/, op: 'min' },
    { re: /\bmaximum\b|\bmax\b|\bhighest\b|\blargest\b/, op: 'max' },
    { re: /\bdistribution\b|\bhistogram\b|\bbuckets?\b/, op: 'distribution' },
    { re: /\btop\s*\d*\b/, op: 'topN' },
    { re: /\bcorrelat/, op: 'correlate' },
    { re: /\bpercentile\b|\bp\d{2}\b/, op: 'percentile' },
    { re: /\bgroup\b|\bgroup by\b|\bbreak\s*down\b/, op: 'group' },
    { re: /\bdescribe\b|\bsummary\b|\bstats\b|\bstatistics\b/, op: 'describe' }
  ];

  function detectIntent(text) {
    var lower = text.toLowerCase();
    for (var i = 0; i < INTENT_PATTERNS.length; i++) {
      if (INTENT_PATTERNS[i].re.test(lower)) return INTENT_PATTERNS[i].op;
    }
    return null;
  }

  function findCol(text, headers) {
    // Try exact match first, then substring
    var lower = text.toLowerCase();
    var exact = headers.filter(function(h) { return lower.indexOf(h.toLowerCase()) !== -1; });
    return exact.length ? exact[0] : null;
  }

  function formatResult(op, col, result) {
    if (result === null || result === undefined) return op + '(' + col + ') = n/a';
    if (typeof result === 'number') {
      var fmt = Number.isInteger(result) ? result : result.toFixed(4);
      return op + '(' + col + ') = ' + fmt;
    }
    if (Array.isArray(result)) {
      if (result.length === 0) return op + '(' + col + ') = (empty)';
      if (result[0] && typeof result[0] === 'object' && 'value' in result[0]) {
        // group result
        var top5 = result.slice(0, 5).map(function(g) { return g.value + ':' + g.count; }).join(', ');
        return op + '(' + col + ') top groups: ' + top5 + (result.length > 5 ? ' …' : '');
      }
      return op + '(' + col + ') = [' + result.slice(0, 5).join(', ') + (result.length > 5 ? '…' : '') + ']';
    }
    if (typeof result === 'object') {
      return op + '(' + col + '): ' + JSON.stringify(result);
    }
    return op + '(' + col + ') = ' + result;
  }

  /* columnProfile populated after consoleLog is defined (see below) */
  var columnProfile = {};

  if (!dataset) {
    document.getElementById('no-dataset-banner').style.display = 'block';
  } else {
    // Populate dataset info card
    document.getElementById('ds-name').textContent = dataset.name || '—';
    document.getElementById('ds-rows').textContent = dataset.rows ? dataset.rows.toLocaleString() + ' rows' : '—';
    document.getElementById('ds-cols').textContent = dataset.cols ? dataset.cols + ' cols' : '—';
    var sensEl = document.getElementById('ds-sensitivity-badge');
    if (dataset.sensitivity) {
      sensEl.textContent = dataset.sensitivity;
      var cls = { 'CONFIDENTIAL':'badge-confidential', 'INTERNAL':'badge-internal', 'PUBLIC':'badge-public' }[dataset.sensitivity] || 'badge-muted';
      sensEl.className = 'badge ' + cls;
    }

    // Schema chips rendered by profiler block below (after consoleLog is available)
  }

  /* ── Populate model selector from loke ── */
  (function() {
    var sel = document.getElementById('model-select');
    fetch('http://127.0.0.1:11430/api/models', { mode: 'cors', cache: 'no-store' })
      .then(function(r) { return r.json(); })
      .then(function(models) {
        if (!Array.isArray(models) || models.length === 0) return;
        // Remove static fallback options, keep loke-router
        while (sel.options.length > 1) sel.remove(1);
        models.forEach(function(m) {
          var opt = document.createElement('option');
          opt.value = m.id;
          opt.textContent = m.id + (m.running ? ' ●' : '');
          sel.appendChild(opt);
        });
      })
      .catch(function() { /* keep static fallback */ });
  })();

  /* ── Console ── */
  var consoleEl = document.getElementById('console-body');
  var consoleStart = Date.now();

  function consoleLog(stage, msg, cls) {
    var elapsed = Math.floor((Date.now() - consoleStart) / 1000);
    var mm = String(Math.floor(elapsed / 60)).padStart(2, '0');
    var ss = String(elapsed % 60).padStart(2, '0');
    var entry = document.createElement('div');
    entry.className = 'log-entry';
    entry.innerHTML =
      '<span class="log-time">' + mm + ':' + ss + '</span>' +
      '<span class="log-stage ' + cls + '">' + stage + '</span>' +
      '<span class="log-msg">' + msg + '</span>';
    consoleEl.appendChild(entry);
    consoleEl.scrollTop = consoleEl.scrollHeight;
  }

  window.clearConsole = function() {
    consoleEl.innerHTML = '';
    consoleStart = Date.now();
    consoleLog('Console', 'Cleared', 'stage-restore');
  };

  /* ── Run profiler now that consoleLog is available ── */
  if (dataset && dataset.headers) {
    columnProfile = profileColumns(dataset.headers, dataset.rows || null);
    var pTypes = Object.keys(columnProfile).map(function(c) {
      return c + ':' + columnProfile[c].type + (columnProfile[c].pii ? '(pii)' : '');
    });
    consoleLog('Profile', 'Column types detected: ' + pTypes.slice(0, 6).join(', ') + (pTypes.length > 6 ? ' …' : ''), 'stage-profile');
    // Re-render schema chips now that profile is populated
    var _schemaEl = document.getElementById('schema-cols');
    if (_schemaEl && dataset.headers.length > 0) {
      var _html = '';
      dataset.headers.slice(0, 10).forEach(function(col) {
        var p = columnProfile[col] || {};
        var chipCls, chipLabel;
        if (p.pii) { chipCls = 'type-pii'; chipLabel = '🔴 PII'; }
        else if (p.type === 'numeric') { chipCls = 'type-numeric'; chipLabel = '📊 numeric'; }
        else if (p.type === 'datetime') { chipCls = 'type-date'; chipLabel = '📅 date'; }
        else if (p.type === 'boolean') { chipCls = 'type-text'; chipLabel = '☑ bool'; }
        else { chipCls = 'type-category'; chipLabel = '🔵 category'; }
        _html += '<div class="col-row"><span class="col-name">' + col + '</span><span class="type-chip ' + chipCls + '">' + chipLabel + '</span></div>';
      });
      if (dataset.headers.length > 10) {
        _html += '<div class="col-row"><span class="col-name muted">…' + (dataset.headers.length - 10) + ' more columns</span></div>';
      }
      _schemaEl.innerHTML = _html;
    }
  }

  /* ── Char count ── */
  var inputEl = document.getElementById('chat-input');
  var charCountEl = document.getElementById('char-count');
  window.onInputChange = function() {
    var len = inputEl.value.length;
    charCountEl.textContent = len + ' / 4000';
    if (len > 3800) charCountEl.style.color = 'var(--amber)';
    else if (len > 4000) charCountEl.style.color = 'var(--red)';
    else charCountEl.style.color = 'var(--muted)';
    // Auto-grow
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 140) + 'px';
  };

  window.handleKey = function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submitMessage(); }
  };

  /* ── Prompt chips ── */
  window.usePrompt = function(btn) {
    inputEl.value = btn.textContent.trim();
    inputEl.focus();
    onInputChange();
  };

  /* ── Message history ── */
  var historyEl = document.getElementById('message-history');
  var chipsEl = document.getElementById('prompt-chips');
  var msgCount = 0;
  var pendingText = null;

  function addUserMessage(text) {
    if (chipsEl) { chipsEl.remove(); chipsEl = null; }
    var msg = document.createElement('div');
    msg.className = 'msg msg-user';
    msg.innerHTML = '<div class="bubble bubble-user">' + escHtml(text) + '</div>';
    historyEl.appendChild(msg);
    historyEl.scrollTop = historyEl.scrollHeight;
  }

  function addAssistantMessage(text, traceLines) {
    var id = 'msg-' + (++msgCount);
    var traceId = 'trace-' + msgCount;
    var msg = document.createElement('div');
    msg.className = 'msg msg-assistant';
    msg.innerHTML =
      '<div class="bubble bubble-assistant" id="' + id + '">' + escHtml(text) + '</div>' +
      '<div class="trace-panel" id="' + traceId + '">' +
        (traceLines || []).map(function(l) { return escHtml(l); }).join('<br>') +
      '</div>' +
      '<div class="msg-actions">' +
        '<button class="msg-btn" onclick="toggleTrace(\'' + traceId + '\', this)">View pipeline trace</button>' +
        '<div class="thumbs">' +
          '<button class="thumb-btn" title="Helpful" onclick="vote(this, \'up\')">👍</button>' +
          '<button class="thumb-btn" title="Not helpful" onclick="vote(this, \'down\')">👎</button>' +
        '</div>' +
        '<button class="msg-btn" onclick="addToDashboard(\'' + id + '\')">Add to Dashboard</button>' +
      '</div>';
    historyEl.appendChild(msg);
    historyEl.scrollTop = historyEl.scrollHeight;
  }

  function addTypingIndicator() {
    var el = document.createElement('div');
    el.className = 'msg msg-assistant';
    el.id = 'typing-indicator';
    el.innerHTML =
      '<div class="bubble bubble-assistant">' +
        '<div class="typing-indicator">' +
          '<div class="typing-dot"></div>' +
          '<div class="typing-dot"></div>' +
          '<div class="typing-dot"></div>' +
        '</div>' +
      '</div>';
    historyEl.appendChild(el);
    historyEl.scrollTop = historyEl.scrollHeight;
    return el;
  }

  function removeTypingIndicator() {
    var el = document.getElementById('typing-indicator');
    if (el) el.remove();
  }

  /* ── Trace toggle ── */
  window.toggleTrace = function(traceId, btn) {
    var panel = document.getElementById(traceId);
    panel.classList.toggle('open');
    btn.textContent = panel.classList.contains('open') ? 'Hide pipeline trace' : 'View pipeline trace';
    btn.classList.toggle('active', panel.classList.contains('open'));
  };

  /* ── Thumbs voting ── */
  window.vote = function(btn, direction) {
    var siblings = btn.parentElement.querySelectorAll('.thumb-btn');
    siblings.forEach(function(b) { b.classList.remove('voted'); });
    btn.classList.add('voted');
  };

  /* ── Add to Dashboard ── */
  window.addToDashboard = function(msgId) {
    var bubble = document.getElementById(msgId);
    if (!bubble) return;
    var cards = [];
    try { cards = JSON.parse(sessionStorage.getItem('moke_dashboard_cards') || '[]'); } catch(e) {}
    cards.push({ id: msgId, text: bubble.textContent, dataset: dataset ? dataset.name : '', addedAt: Date.now() });
    sessionStorage.setItem('moke_dashboard_cards', JSON.stringify(cards));
    var btn = bubble.parentElement.querySelector('[onclick^="addToDashboard"]');
    if (btn) { btn.textContent = '✓ Added'; btn.classList.add('active'); }
  };

  /* ── Confirm dialog ── */
  var confirmDialog = document.getElementById('confirm-dialog');
  var pendingResolve = null;

  function requestConfirm() {
    return new Promise(function(resolve) {
      pendingResolve = resolve;
      confirmDialog.classList.add('open');
      historyEl.scrollTop = historyEl.scrollHeight;
    });
  }

  window.approveCall = function() {
    confirmDialog.classList.remove('open');
    if (pendingResolve) { pendingResolve(true); pendingResolve = null; }
  };
  window.cancelCall = function() {
    confirmDialog.classList.remove('open');
    if (pendingResolve) { pendingResolve(false); pendingResolve = null; }
  };

  /* ── Submit message ── */
  var sending = false;
  window.submitMessage = async function() {
    var text = inputEl.value.trim();
    if (!text || sending) return;

    sending = true;
    document.getElementById('send-btn').disabled = true;
    inputEl.value = '';
    onInputChange();

    addUserMessage(text);

    // Request user approval before LLM call
    var approved = await requestConfirm();
    if (!approved) {
      sending = false;
      document.getElementById('send-btn').disabled = false;
      return;
    }

    consoleLog('Schema Extract', 'Extracting column profiles…', 'stage-schema');
    var typingEl = addTypingIndicator();

    var model = document.getElementById('model-select').value;
    var dsName = dataset ? dataset.name : 'unknown dataset';

    // ── MK1.4: Local compute ──
    var localComputeResult = null;
    var rows = dataset && dataset.rows;
    if (rows && rows.length > 0) {
      var intent = detectIntent(text);
      if (intent) {
        var col = findCol(text, dataset.headers || []);
        try {
          var raw;
          if (intent === 'count') {
            raw = compute.count(rows, col || undefined);
            localComputeResult = formatResult(intent, col || 'all rows', raw);
          } else if (intent === 'correlate') {
            // need two columns — find any two numeric cols mentioned
            var numCols = (dataset.headers || []).filter(function(h) {
              return text.toLowerCase().indexOf(h.toLowerCase()) !== -1 &&
                     columnProfile[h] && columnProfile[h].type === 'numeric';
            });
            if (numCols.length >= 2) {
              raw = compute.correlate(rows, numCols[0], numCols[1]);
              localComputeResult = 'correlate(' + numCols[0] + ', ' + numCols[1] + ') = ' + (raw !== null ? raw.toFixed(4) : 'n/a');
            }
          } else if (intent === 'topN') {
            var nMatch = text.match(/top\s*(\d+)/i);
            var nVal = nMatch ? parseInt(nMatch[1]) : 10;
            if (col) {
              raw = compute.topN(rows, col, nVal);
              localComputeResult = 'topN(' + col + ', ' + nVal + '): ' + raw.length + ' rows returned';
            }
          } else if (intent === 'distribution') {
            if (col) {
              raw = compute.distribution(rows, col, 10);
              localComputeResult = 'distribution(' + col + '): ' + raw.length + ' buckets, max=' +
                Math.max.apply(null, raw.map(function(b) { return b.count; })) + ' in top bucket';
            }
          } else if (intent === 'group') {
            if (col) {
              raw = compute.group(rows, col);
              localComputeResult = formatResult(intent, col, raw);
            }
          } else if (intent === 'describe') {
            if (col) {
              raw = compute.describe(rows, col);
              localComputeResult = 'describe(' + col + '): count=' + raw.count + ', nulls=' + raw.nulls +
                (raw.mean !== undefined ? ', mean=' + raw.mean.toFixed(2) + ', stddev=' + raw.stddev.toFixed(2) : '');
            }
          } else if (col) {
            raw = compute[intent](rows, col);
            localComputeResult = formatResult(intent, col, raw);
          }
        } catch(e) { /* compute failed — skip */ }

        if (localComputeResult) {
          consoleLog('Local Compute', localComputeResult + ' — computed from ' + rows.length + ' rows', 'stage-compute');
        }
      }
    } else if (dataset && !rows) {
      consoleLog('Local Compute', 'Rows not loaded — schema only mode', 'stage-compute');
    }

    // Simulated loading stages while waiting for loke
    setTimeout(function() { consoleLog('Profile', 'Computing descriptive statistics', 'stage-profile'); }, 400);
    setTimeout(function() { consoleLog('Anonymise', 'Sending to loke privacy filter…', 'stage-anonymise'); }, 900);
    setTimeout(function() { consoleLog('LLM Call', 'Routing to model…', 'stage-llm'); }, 1400);

    // Build schema context for loke pipeline
    var schemaCtx = 'You are analysing a dataset called "' + dsName + '".';
    if (dataset && dataset.headers && dataset.headers.length > 0) {
      var colDescs = (dataset.headers || []).map(function(h) {
        var p = columnProfile[h];
        return h + (p ? ' (' + p.type + (p.pii ? ',pii' : '') + ')' : '');
      });
      schemaCtx += ' Columns: ' + colDescs.join(', ') + '.';
    }
    if (dataset && dataset.pii && dataset.pii.length > 0) {
      schemaCtx += ' PII columns (will be redacted): ' + dataset.pii.join(', ') + '.';
    }
    var fullText;
    if (localComputeResult) {
      fullText = 'Dataset: ' + dsName + '. Local computation result: ' + localComputeResult + '. User question: ' + text;
    } else {
      fullText = schemaCtx + (rows ? ' Dataset has ' + rows.length + ' rows.' : ' Row data not loaded — schema only.') + ' User question: ' + text;
    }

    var lokeBody = {
      text: fullText,
      system_prompt: 'You are a concise data analysis assistant. Answer specifically based on the dataset schema provided. Do not fabricate data values.',
      tolerance: 'instant',
      mode: 'chat'
    };
    if (model !== 'loke-router') {
      lokeBody.model = model;
    }

    try {
      var resp = await fetch('http://127.0.0.1:11430/api/pipeline', {
        method: 'POST',
        mode: 'cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(lokeBody)
      });

      removeTypingIndicator();

      var json = await resp.json().catch(function() { return null; });
      var responseText = (json && json.response) ? json.response
        : (json && json.error) ? 'loke error: ' + json.error
        : 'No response — check loke is running on port 11430.';

      // Build trace from real response data
      var traceLines = [
        '→ request_id      : ' + (json && json.request_id ? json.request_id : 'n/a'),
        '→ sensitivity      : ' + (json && json.sensitivity ? json.sensitivity : 'unknown'),
        '→ entities_found   : ' + (json && json.entities_found != null ? json.entities_found : 'n/a'),
        '→ model            : ' + (json && json.model_id ? json.model_id : model),
        '→ provider         : ' + (json && json.provider ? JSON.stringify(json.provider) : 'n/a'),
        '→ tokens_in        : ' + (json && json.tokens_in != null ? json.tokens_in : 'n/a'),
        '→ tokens_out       : ' + (json && json.tokens_out != null ? json.tokens_out : 'n/a'),
        '→ cost_usd         : $' + (json && json.cost_usd != null ? json.cost_usd.toFixed(6) : '0.000000'),
        '→ restore          : complete',
      ];
      addAssistantMessage(responseText, traceLines);

      // Real console logs from response
      consoleLog('Anonymise', 'Entities found: ' + (json && json.entities_found != null ? json.entities_found : 0) + ' · ' + (json && json.sensitivity ? json.sensitivity : 'PUBLIC'), 'stage-anonymise');
      consoleLog('LLM Call', 'Model: ' + (json && json.model_id ? json.model_id : model) + ' · ' + (json && json.tokens_in ? json.tokens_in : 0) + ' tokens in, ' + (json && json.tokens_out ? json.tokens_out : 0) + ' out', 'stage-llm');
      consoleLog('Restore', 'Response verified · cost $' + (json && json.cost_usd != null ? json.cost_usd.toFixed(6) : '0.000000'), 'stage-restore');

    } catch(err) {
      removeTypingIndicator();
      var traceLines = ['→ error: ' + err.message];
      addAssistantMessage('Could not reach loke pipeline (' + err.message + '). Check that loke is running on port 11430.', traceLines);
      consoleLog('Error', err.message, 'stage-restore');
    }

    sending = false;
    document.getElementById('send-btn').disabled = false;
  };

  /* ── Generate dashboard shortcut ── */
  window.generateDashboard = function() {
    inputEl.value = 'Generate a dashboard for this dataset';
    inputEl.focus();
    onInputChange();
  };

  /* ── Utilities ── */
  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
})();
</script>
{! end !}
