// MK3.1 — Dashboard Definition Language (DDL)
// Defines the JSON schema for LLM-generated dashboards, factory helpers,
// validation, serialisation, and a hardcoded demo dashboard used as a
// design template.

m=moke.ddl;
i=str:std.string;

// ── Enumerations ──────────────────────────────────────────────────────────────

pub m.$card_type{ $metric; $chart; $table; $text; $list }

pub m.$chart_type{ $line; $bar; $pie; $area; $scatter }

// ── Card payload structs ──────────────────────────────────────────────────────

pub m.$metric_card{
  label:str;
  query_op:str;
  query_col:str;
  query_group:str;
  unit:str;
  delta_query_op:str
}

pub m.$chart_card{
  title:str;
  chart_type:str;
  x_col:str;
  y_col:str;
  query_op:str;
  filter_col:str;
  filter_val:str;
  top_n:i32
}

pub m.$table_card{
  title:str;
  columns:@(str);
  query_op:str;
  sort_col:str;
  limit:i32
}

pub m.$text_card{
  markdown:str
}

pub m.$list_card{
  title:str;
  items:@(str)
}

// ── Top-level dashboard card and dashboard ────────────────────────────────────

pub m.$dashboard_card{
  id:str;
  kind:str;
  title:str;
  col_span:i32;
  metric:$metric_card;
  chart:$chart_card;
  table:$table_card;
  text:$text_card;
  list:$list_card
}

pub m.$dashboard{
  title:str;
  summary:str;
  cards:@($dashboard_card)
}

// ── Constructors ──────────────────────────────────────────────────────────────

pub f=new_dashboard(title:str;summary:str):$dashboard{
  <$dashboard{
    title=title;
    summary=summary;
    cards=@()
  }
}

pub f=add_card(dash:$dashboard;card:$dashboard_card):$dashboard{
  dash.cards.push(card);
  <dash
}

// ── Card factories ────────────────────────────────────────────────────────────

pub f=new_metric(id:str;title:str;col:i32;op:str;query_col:str):$dashboard_card{
  let mc=$metric_card{
    label=title;
    query_op=op;
    query_col=query_col;
    query_group="";
    unit="";
    delta_query_op=""
  };
  let empty_chart=$chart_card{
    title="";chart_type="";x_col="";y_col="";query_op="";filter_col="";filter_val="";top_n=0
  };
  let empty_table=$table_card{
    title="";columns=@();query_op="";sort_col="";limit=0
  };
  let empty_text=$text_card{ markdown="" };
  let empty_list=$list_card{ title="";items=@() };
  <$dashboard_card{
    id=id;
    kind="metric";
    title=title;
    col_span=col;
    metric=mc;
    chart=empty_chart;
    table=empty_table;
    text=empty_text;
    list=empty_list
  }
}

pub f=new_chart(id:str;title:str;col:i32;chart_type:str;x:str;y:str;op:str):$dashboard_card{
  let empty_metric=$metric_card{
    label="";query_op="";query_col="";query_group="";unit="";delta_query_op=""
  };
  let cc=$chart_card{
    title=title;
    chart_type=chart_type;
    x_col=x;
    y_col=y;
    query_op=op;
    filter_col="";
    filter_val="";
    top_n=10
  };
  let empty_table=$table_card{
    title="";columns=@();query_op="";sort_col="";limit=0
  };
  let empty_text=$text_card{ markdown="" };
  let empty_list=$list_card{ title="";items=@() };
  <$dashboard_card{
    id=id;
    kind="chart";
    title=title;
    col_span=col;
    metric=empty_metric;
    chart=cc;
    table=empty_table;
    text=empty_text;
    list=empty_list
  }
}

pub f=new_table(id:str;title:str;col:i32;columns:@(str);op:str;sort:str;limit:i32):$dashboard_card{
  let empty_metric=$metric_card{
    label="";query_op="";query_col="";query_group="";unit="";delta_query_op=""
  };
  let empty_chart=$chart_card{
    title="";chart_type="";x_col="";y_col="";query_op="";filter_col="";filter_val="";top_n=0
  };
  let tc=$table_card{
    title=title;
    columns=columns;
    query_op=op;
    sort_col=sort;
    limit=limit
  };
  let empty_text=$text_card{ markdown="" };
  let empty_list=$list_card{ title="";items=@() };
  <$dashboard_card{
    id=id;
    kind="table";
    title=title;
    col_span=col;
    metric=empty_metric;
    chart=empty_chart;
    table=tc;
    text=empty_text;
    list=empty_list
  }
}

pub f=new_text(id:str;content:str):$dashboard_card{
  let empty_metric=$metric_card{
    label="";query_op="";query_col="";query_group="";unit="";delta_query_op=""
  };
  let empty_chart=$chart_card{
    title="";chart_type="";x_col="";y_col="";query_op="";filter_col="";filter_val="";top_n=0
  };
  let empty_table=$table_card{
    title="";columns=@();query_op="";sort_col="";limit=0
  };
  let tc=$text_card{ markdown=content };
  let empty_list=$list_card{ title="";items=@() };
  <$dashboard_card{
    id=id;
    kind="text";
    title="";
    col_span=3;
    metric=empty_metric;
    chart=empty_chart;
    table=empty_table;
    text=tc;
    list=empty_list
  }
}

// ── Serialisation ─────────────────────────────────────────────────────────────

// Escape a string for embedding inside a JSON value.
f=json_str(s:str):str{
  let out=str.replace(s;"\\";"\\\\");
  out=str.replace(out;"\"";"\\\"");
  out=str.replace(out;"\n";"\\n");
  out=str.replace(out;"\r";"\\r");
  out=str.replace(out;"\t";"\\t");
  <"\"" + out + "\""
}

// Serialise a string array to a JSON array literal.
f=json_str_arr(arr:@(str)):str{
  let parts=@();
  arr.each(v{
    parts.push(json_str(v));
  });
  <"[" + str.join(parts;",") + "]"
}

pub f=to_json(dash:$dashboard):str{
  let card_jsons=@();
  dash.cards.each(c{
    let kind_block="";
    if c.kind == "metric"{
      kind_block="\"metric\":{\"label\":" + json_str(c.metric.label)
        + ",\"query_op\":" + json_str(c.metric.query_op)
        + ",\"query_col\":" + json_str(c.metric.query_col)
        + ",\"query_group\":" + json_str(c.metric.query_group)
        + ",\"unit\":" + json_str(c.metric.unit)
        + ",\"delta_query_op\":" + json_str(c.metric.delta_query_op)
        + "}";
    };
    if c.kind == "chart"{
      kind_block="\"chart\":{\"title\":" + json_str(c.chart.title)
        + ",\"chart_type\":" + json_str(c.chart.chart_type)
        + ",\"x_col\":" + json_str(c.chart.x_col)
        + ",\"y_col\":" + json_str(c.chart.y_col)
        + ",\"query_op\":" + json_str(c.chart.query_op)
        + ",\"filter_col\":" + json_str(c.chart.filter_col)
        + ",\"filter_val\":" + json_str(c.chart.filter_val)
        + ",\"top_n\":" + str.from_i32(c.chart.top_n)
        + "}";
    };
    if c.kind == "table"{
      kind_block="\"table\":{\"title\":" + json_str(c.table.title)
        + ",\"columns\":" + json_str_arr(c.table.columns)
        + ",\"query_op\":" + json_str(c.table.query_op)
        + ",\"sort_col\":" + json_str(c.table.sort_col)
        + ",\"limit\":" + str.from_i32(c.table.limit)
        + "}";
    };
    if c.kind == "text"{
      kind_block="\"text\":{\"markdown\":" + json_str(c.text.markdown) + "}";
    };
    if c.kind == "list"{
      kind_block="\"list\":{\"title\":" + json_str(c.list.title)
        + ",\"items\":" + json_str_arr(c.list.items)
        + "}";
    };
    let card_json="{\"id\":" + json_str(c.id)
      + ",\"kind\":" + json_str(c.kind)
      + ",\"title\":" + json_str(c.title)
      + ",\"col_span\":" + str.from_i32(c.col_span)
      + "," + kind_block
      + "}";
    card_jsons.push(card_json);
  });
  <"{\"title\":" + json_str(dash.title)
    + ",\"summary\":" + json_str(dash.summary)
    + ",\"cards\":[" + str.join(card_jsons;",") + "]}"
}

// ── Validation ────────────────────────────────────────────────────────────────

pub f=validate(dash:$dashboard):bool{
  if str.len(str.trim(dash.title)) == 0{ <false };
  if dash.cards.len() == 0{ <false };
  let valid=true;
  dash.cards.each(c{
    if str.len(str.trim(c.id)) == 0{ valid=false };
    if str.len(str.trim(c.kind)) == 0{ valid=false };
  });
  <valid
}

// ── Demo dashboard ────────────────────────────────────────────────────────────
// Customer Intelligence demo — 4 metrics, 2 charts, 1 table.
// Used as default template and for UI placeholder rendering.

pub f=demo_dashboard():$dashboard{
  let dash=new_dashboard(
    "Customer Intelligence";
    "Key customer metrics, lifetime value distribution, order trends, and top-performer ranking"
  );

  // ── Metric cards ──────────────────────────────────────────────────────────
  let total_customers=new_metric("m-total-customers";"Total Customers";1;"count";"customer_id");
  let total_customers_m=$metric_card{
    label="Total Customers";
    query_op="count";
    query_col="customer_id";
    query_group="";
    unit="";
    delta_query_op="count_prev_period"
  };
  total_customers.metric=total_customers_m;

  let avg_ltv=new_metric("m-avg-ltv";"Avg LTV";1;"mean";"lifetime_value");
  let avg_ltv_m=$metric_card{
    label="Avg LTV";
    query_op="mean";
    query_col="lifetime_value";
    query_group="";
    unit="$";
    delta_query_op="mean_prev_period"
  };
  avg_ltv.metric=avg_ltv_m;

  let churn_rate=new_metric("m-churn";"Churn Rate";1;"mean";"churned");
  let churn_m=$metric_card{
    label="Churn Rate";
    query_op="mean";
    query_col="churned";
    query_group="";
    unit="%";
    delta_query_op="mean_prev_period"
  };
  churn_rate.metric=churn_m;

  let avg_order=new_metric("m-avg-order";"Avg Order Value";1;"mean";"order_value");
  let avg_order_m=$metric_card{
    label="Avg Order Value";
    query_op="mean";
    query_col="order_value";
    query_group="";
    unit="$";
    delta_query_op="mean_prev_period"
  };
  avg_order.metric=avg_order_m;

  // ── Chart cards ───────────────────────────────────────────────────────────
  let ltv_chart=new_chart("c-ltv-cluster";"LTV by Cluster";2;"bar";"cluster";"lifetime_value";"mean_by_group");
  let orders_chart=new_chart("c-orders-time";"Orders over Time";2;"line";"order_date";"order_count";"count_by_day");

  // ── Table card ────────────────────────────────────────────────────────────
  let top_customers=new_table(
    "t-top-customers";
    "Top 10 Customers by LTV";
    3;
    @("customer_id";"name";"cluster";"lifetime_value";"order_count";"last_order_date");
    "top_n";
    "lifetime_value";
    10
  );

  dash=add_card(dash;total_customers);
  dash=add_card(dash;avg_ltv);
  dash=add_card(dash;churn_rate);
  dash=add_card(dash;avg_order);
  dash=add_card(dash;ltv_chart);
  dash=add_card(dash;orders_chart);
  dash=add_card(dash;top_customers);

  <dash
}
