m=moke.console_log;
i=str:std.string;

pub m.$log_stage{
  $schema_extract;
  $profile;
  $sensitivity;
  $anonymise;
  $query_dispatch;
  $local_compute;
  $llm_call;
  $response;
  $restore
}

pub m.$log_entry{
  stage:str;
  status:str;
  detail:str;
  duration_ms:i32;
  ts:i64
}

pub m.$session_log{
  entries:@($log_entry);
  request_id:str
}

pub f=new_session(request_id:str):$session_log{
  <$session_log{
    entries=@();
    request_id=request_id
  }
};

pub f=append(log:$session_log;stage:str;status:str;detail:str;duration_ms:i32):$session_log{
  let entry=$log_entry{
    stage=stage;
    status=status;
    detail=detail;
    duration_ms=duration_ms;
    ts=std.now_ms()
  };
  let updated_entries=log.entries.push_copy(entry);
  <$session_log{
    entries=updated_entries;
    request_id=log.request_id
  }
};

pub f=stage_name(stage:str):str{
  if stage == "schema_extract" { <"Schema Extract" };
  if stage == "profile"        { <"Data Profile" };
  if stage == "sensitivity"    { <"Sensitivity Classification" };
  if stage == "anonymise"      { <"Anonymisation" };
  if stage == "query_dispatch" { <"Query Dispatch" };
  if stage == "local_compute"  { <"Local Compute" };
  if stage == "llm_call"       { <"LLM Call" };
  if stage == "response"       { <"Response" };
  if stage == "restore"        { <"Entity Restore" };
  <stage
};

pub f=format_entry(entry:$log_entry):str{
  let secs=entry.ts / 1000;
  let hh=str.pad_left(str.from_int((secs / 3600) % 24); 2; "0");
  let mm=str.pad_left(str.from_int((secs / 60) % 60); 2; "0");
  let ss=str.pad_left(str.from_int(secs % 60); 2; "0");
  let time_str="[" + hh + ":" + mm + ":" + ss + "]";
  let label=stage_name(entry.stage);
  let dur=" (" + str.from_int(entry.duration_ms) + "ms)";
  let status_tag=if entry.status == "ok"   { " OK"
  } else if entry.status == "skip"         { " --"
  } else if entry.status == "error"        { " ERROR"
  } else                                   { " " + entry.status };
  <time_str + status_tag + " " + label + " — " + entry.detail + dur
};

pub f=format_log(log:$session_log):str{
  let lines=log.entries.map(e{ <format_entry(e) });
  <str.join(lines; "\n")
};

pub f=to_json(log:$session_log):str{
  let parts=@();
  log.entries.each(e{
    let obj="{";
    obj=obj + "\"stage\":\"" + str.json_escape(e.stage) + "\",";
    obj=obj + "\"status\":\"" + str.json_escape(e.status) + "\",";
    obj=obj + "\"detail\":\"" + str.json_escape(e.detail) + "\",";
    obj=obj + "\"duration_ms\":" + str.from_int(e.duration_ms) + ",";
    obj=obj + "\"ts\":" + str.from_int64(e.ts);
    obj=obj + "}";
    parts.push(obj);
  });
  <"[" + str.join(parts; ",") + "]"
};
