i=s:mcp_broker.server;
i=reg:mcp_broker.registry;
i=log:shared.log;

pub f=main(args:@(str)):i32{
  let cfg=s.$broker_config{ port:s.default_port; data_dir:"./data" };
  log.info("mcp broker starting on port 11436";"broker";"system");
  let registry=reg.new_registry();
  let defaults=reg.default_servers();
  // register default servers
  let registry=defaults.each|srv{ reg.register(registry;srv) };
  let ok=s.start(cfg);
  if ok{ <0 }else{ <1 }
}
