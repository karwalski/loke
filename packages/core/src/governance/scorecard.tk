// G4.3 — Provider scorecard.
// Surfaces per-provider latency, cost, and error rate for governance review.

i=t:shared.types;
i=db:storage.db;
i=str:std.str;

pub m.$provider_stats{
  provider:str;
  requests:i32;
  avg_latency_ms:i32;
  p99_latency_ms:i32;
  error_rate_pct:f64;
  total_cost_usd:f64;
  avg_cost_per_req:f64
}

pub m.$provider_scorecard{
  providers:@($provider_stats);
  generated_at:i64
}

// Builds a provider scorecard with representative stub data for three providers.
// Real aggregation from audit_log will be wired once query helpers are stable.
pub f=build_scorecard(store:db.$store):$provider_scorecard{
  let anthropic=$provider_stats{
    provider:"anthropic";
    requests:89;
    avg_latency_ms:1240;
    p99_latency_ms:3100;
    error_rate_pct:0.5;
    total_cost_usd:0.31;
    avg_cost_per_req:0.31/89.0
  };
  let openai=$provider_stats{
    provider:"openai";
    requests:34;
    avg_latency_ms:980;
    p99_latency_ms:2400;
    error_rate_pct:0.0;
    total_cost_usd:0.18;
    avg_cost_per_req:0.18/34.0
  };
  let ollama=$provider_stats{
    provider:"ollama";
    requests:19;
    avg_latency_ms:420;
    p99_latency_ms:890;
    error_rate_pct:2.1;
    total_cost_usd:0.0;
    avg_cost_per_req:0.0
  };
  <$provider_scorecard{
    providers:@(anthropic;openai;ollama);
    generated_at:std.time.now()
  }
}

// Pads a string with trailing spaces to at least width characters.
f=pad_right(s:str;width:i32):str{
  let len=str.len(s);
  if len >= width{
    <s
  }else{
    let diff=width-len;
    let spaces="                              ";
    let pad=str.slice(spaces;0;diff);
    <str.concat(s;pad)
  }
}

// Renders the provider scorecard as a table.
// Columns: Provider | Requests | Avg ms | P99 ms | Error% | Cost
pub f=format_scorecard(sc:$provider_scorecard):str{
  let header=str.concat(
    "Provider scorecard\n";
    "==================\n"
  );
  let col_header=str.concat(
    pad_right("Provider";12);
    str.concat(
      pad_right("Requests";10);
      str.concat(
        pad_right("Avg ms";8);
        str.concat(
          pad_right("P99 ms";8);
          str.concat(
            pad_right("Error%";8);
            "Cost\n"
          )
        )
      )
    )
  );
  let divider="------------  --------  ------  ------  ------  --------\n";
  let rows="";
  sc.providers.each|p{
    let req_s=str.from_int(p.requests);
    let avg_s=str.from_int(p.avg_latency_ms);
    let p99_s=str.from_int(p.p99_latency_ms);
    let err_s=str.concat(str.from_float(p.error_rate_pct);"%");
    let cost_s=str.concat("$";str.from_float(p.total_cost_usd));
    let row=str.concat(
      pad_right(p.provider;12);
      str.concat(
        pad_right(req_s;10);
        str.concat(
          pad_right(avg_s;8);
          str.concat(
            pad_right(p99_s;8);
            str.concat(
              pad_right(err_s;8);
              str.concat(cost_s;"\n")
            )
          )
        )
      )
    );
    rows=str.concat(rows;row)
  };
  <str.concat(
    str.concat(
      str.concat(
        str.concat(header;col_header);
        divider);
      rows);
    "")
}
