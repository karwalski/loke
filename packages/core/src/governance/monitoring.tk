// G3.1 — Output quality monitoring.
// Records user quality signals (thumbs up/down, coherence, relevance) per model
// and surfaces degradation trends for governance review.

i=t:shared.types;
i=s:core.storage.db;
i=db:std.db;
i=str:std.str;
i=log:shared.log;

pub m.$quality_signal{
  request_id:str;
  model_id:str;
  provider:str;
  use_case:str;
  thumbs_up:bool;
  coherence_score:f64;
  relevance_score:f64
}

pub m.$quality_trend{
  model_id:str;
  period_days:u32;
  thumbs_up_rate:f64;
  avg_coherence:f64;
  avg_relevance:f64;
  total_signals:u32;
  degradation_detected:bool
}

// Creates the quality_signals table if it does not already exist.
pub f=ensure_table(store:$s.store):void|$loke_err{
  let sql="CREATE TABLE IF NOT EXISTS quality_signals (
  id TEXT PRIMARY KEY,
  request_id TEXT NOT NULL,
  model_id TEXT NOT NULL,
  provider TEXT NOT NULL,
  use_case TEXT NOT NULL,
  thumbs_up INTEGER NOT NULL DEFAULT 0,
  coherence_score REAL,
  relevance_score REAL,
  created_at TEXT NOT NULL
)";
  db.exec_params(store.conn;sql;@())|{
    $ok:_ <$ok(void);
    $err:e <$err($loke_err.$storage_err("failed to create quality_signals table"))
  }
}

// Inserts a quality signal for a given model and request.
pub f=record_signal(store:$s.store;signal:$quality_signal):void|$loke_err{
  let id=str.rand_hex(16);
  let thumbs_up_s=if signal.thumbs_up{ "1" }else{ "0" };
  let coherence_s=str.from_float(signal.coherence_score);
  let relevance_s=str.from_float(signal.relevance_score);
  db.exec_params(
    store.conn;
    "INSERT INTO quality_signals (id,request_id,model_id,provider,use_case,thumbs_up,coherence_score,relevance_score,created_at) VALUES (?,?,?,?,?,?,?,?,'now()')";
    @(
      id;
      signal.request_id;
      signal.model_id;
      signal.provider;
      signal.use_case;
      thumbs_up_s;
      coherence_s;
      relevance_s
    )
  )|{
    $ok:_ {
      log.debug(
        str.concat("quality signal recorded for model: ";signal.model_id);
        "monitoring";
        signal.request_id
      );
      <$ok(void)
    };
    $err:e <$err($loke_err.$storage_err(str.concat("failed to record quality signal for: ";signal.model_id)))
  }
}

// Queries quality signals for a model over the past N days and computes trend metrics.
// degradation_detected is set true when thumbs_up_rate < 0.7 over at least 10 signals.
pub f=compute_trend(store:$s.store;model_id:str;days:u32):$quality_trend|$loke_err{
  let days_s=str.from_int(days);
  let sql=str.concat(
    "SELECT thumbs_up,coherence_score,relevance_score FROM quality_signals WHERE model_id=? AND created_at >= datetime('now','-";
    str.concat(days_s;" days')")
  );
  db.query_params(store.conn;sql;@(model_id))|{
    $ok:rows {
      let total=rows.len;
      if total == 0{
        <$ok($quality_trend{
          model_id:model_id;
          period_days:days;
          thumbs_up_rate:0.0;
          avg_coherence:0.0;
          avg_relevance:0.0;
          total_signals:0;
          degradation_detected:false
        })
      }else{
        let thumbs_up_count=0;
        let coherence_sum=0.0;
        let relevance_sum=0.0;
        rows.each|row{
          let tu=json.get_int(row;"thumbs_up");
          if tu == 1{
            thumbs_up_count=thumbs_up_count+1
          }else{};
          coherence_sum=coherence_sum+json.get_float(row;"coherence_score");
          relevance_sum=relevance_sum+json.get_float(row;"relevance_score")
        };
        let total_f=str.to_float(str.from_int(total));
        let thumbs_up_count_f=str.to_float(str.from_int(thumbs_up_count));
        let rate=thumbs_up_count_f/total_f;
        let avg_coh=coherence_sum/total_f;
        let avg_rel=relevance_sum/total_f;
        let degraded=if total >= 10{
          rate < 0.7
        }else{
          false
        };
        log.debug(
          str.concat("trend computed for model: ";model_id);
          "monitoring";
          "system"
        );
        <$ok($quality_trend{
          model_id:model_id;
          period_days:days;
          thumbs_up_rate:rate;
          avg_coherence:avg_coh;
          avg_relevance:avg_rel;
          total_signals:total;
          degradation_detected:degraded
        })
      }
    };
    $err:e <$err($loke_err.$storage_err(str.concat("failed to compute trend for model: ";model_id)))
  }
}

// Returns the percentage of thumbs-down signals for a model over the past N days.
pub f=thumbs_down_rate(store:$s.store;model_id:str;days:u32):f64|$loke_err{
  compute_trend(store;model_id;days)|{
    $ok:trend {
      if trend.total_signals == 0{
        <$ok(0.0)
      }else{
        <$ok(1.0-trend.thumbs_up_rate)
      }
    };
    $err:e <$err(e)
  }
}

// Formats a percentage float (0.0–1.0) as a two-decimal percent string e.g. "94%".
f=pct_str(v:f64):str{
  let pct=v*100.0;
  str.concat(str.from_float(pct);"%")
}

// Pads a string with trailing spaces to at least width characters.
f=pad_right(s:str;width:u32):str{
  let len=str.len(s);
  if len >= width{
    <s
  }else{
    let diff=width-len;
    let spaces="                    ";
    let pad=str.slice(spaces;0;diff);
    <str.concat(s;pad)
  }
}

// Renders a formatted quality report for a list of trends.
// Example output:
//   Quality Report
//   ==============
//   claude-3-5-sonnet   thumbs-up: 94%  coherence: 0.91  relevance: 0.88  (238 signals)
//   [DEGRADED] gpt-4o-mini  thumbs-up: 61%  <- below threshold
pub f=format_quality_report(trends:@($quality_trend)):str{
  let header="Quality Report\n==============\n";
  let body="";
  trends.each|trend{
    let prefix=if trend.degradation_detected{
      "[DEGRADED] "
    }else{
      ""
    };
    let name=str.concat(prefix;trend.model_id);
    let name_padded=pad_right(name;22);
    let rate_s=pct_str(trend.thumbs_up_rate);
    let coh_s=str.from_float(trend.avg_coherence);
    let rel_s=str.from_float(trend.avg_relevance);
    let total_s=str.from_int(trend.total_signals);
    let line=if trend.degradation_detected{
      str.concat(
        str.concat(
          str.concat(
            str.concat(name_padded;"thumbs-up: ");
            rate_s);
          "  <- below threshold\n");
        "")
    }else{
      str.concat(
        str.concat(
          str.concat(
            str.concat(
              str.concat(
                str.concat(
                  str.concat(
                    str.concat(
                      str.concat(name_padded;"thumbs-up: ");
                      rate_s);
                    "  coherence: ");
                  coh_s);
                "  relevance: ");
              rel_s);
            "  (");
          total_s);
        " signals)\n")
    };
    body=str.concat(body;line)
  };
  <str.concat(header;body)
}
