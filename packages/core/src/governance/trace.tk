// G2.1 — Decision trace system.
// Captures the full audit trail of every AI interaction from input to output.
// No raw PII must appear in serialised output.

i=t:shared.types;
i=gt:core.governance.types;
i=str:std.str;
i=log:shared.log;

pub m.$trace_entry{
  step:str;
  detail:str;
  timestamp:str
}

pub m.$decision_trace{
  request_id:str;
  correlation_id:str;
  original_input:str;
  pii_detected:str;
  anonymisation_applied:bool;
  compression_applied:bool;
  risk_classification:str;
  policy_decision:str;
  model_selected:str;
  provider:str;
  prompt_sent:str;
  response_received:str;
  deanonymisation_applied:bool;
  final_output:str;
  steps:@($trace_entry);
  duration_ms:u32
}

// Creates a new decision trace with initial values for a given request.
pub f=new_trace(request_id:str;correlation_id:str;input:str):$decision_trace{
  <$decision_trace{
    request_id:request_id;
    correlation_id:correlation_id;
    original_input:input;
    pii_detected:"none";
    anonymisation_applied:false;
    compression_applied:false;
    risk_classification:"unknown";
    policy_decision:"unknown";
    model_selected:"unknown";
    provider:"unknown";
    prompt_sent:"";
    response_received:"";
    deanonymisation_applied:false;
    final_output:"";
    steps:@();
    duration_ms:0
  }
}

// Appends an audit step to the trace.
pub f=add_step(trace:mut $decision_trace;step:str;detail:str):void{
  let entry=$trace_entry{
    step:step;
    detail:detail;
    timestamp:str.now_iso8601()
  };
  trace.steps=@(trace.steps;entry)
}

// Records PII detection results on the trace.
pub f=record_pii(trace:mut $decision_trace;entities_found:str):void{
  trace.pii_detected=entities_found;
  trace.anonymisation_applied=true
}

// Records which model and provider were selected for this request.
pub f=record_routing(trace:mut $decision_trace;model_id:str;provider:str):void{
  trace.model_selected=model_id;
  trace.provider=provider
}

// Records the raw response received from the LLM provider.
pub f=record_response(trace:mut $decision_trace;response:str):void{
  trace.response_received=response
}

// Marks the trace as complete with a total elapsed duration.
pub f=complete(trace:mut $decision_trace;duration_ms:u32):void{
  trace.duration_ms=duration_ms;
  log.info(
    str.concat("trace complete request_id=";trace.request_id);
    "trace";
    trace.correlation_id
  )
}

// Truncates a string to at most max_len characters, appending "..." if truncated.
f=truncate(s:str;max_len:u32):str{
  if str.len(s)>max_len{
    let prefix=str.slice(s;0;max_len);
    <str.concat(prefix;"...")
  }else{
    <s
  }
}

// Escapes a string for safe embedding inside a JSON string value.
f=json_escape(s:str):str{
  let s2=str.replace(s;"\\";"\\\\ ");
  let s3=str.replace(s2;"\"";"\\\\ \"");
  let s4=str.replace(s3;"\n";"\\n");
  let s5=str.replace(s4;"\r";"\\r");
  let s6=str.replace(s5;"\t";"\\t");
  <s6
}

// Serialises the trace to a JSON string.
// prompt_sent and response_received are truncated to 200 chars to avoid PII leakage.
pub f=to_json(trace:$decision_trace):str{
  let prompt_safe=json_escape(truncate(trace.prompt_sent;200));
  let response_safe=json_escape(truncate(trace.response_received;200));
  let anon_str=if trace.anonymisation_applied{ "true" }else{ "false" };
  let compression_str=if trace.compression_applied{ "true" }else{ "false" };
  let deanon_str=if trace.deanonymisation_applied{ "true" }else{ "false" };
  let duration_str=str.from_u32(trace.duration_ms);

  // Build steps array
  let steps_json="[";
  let count=trace.steps.len;
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let entry=str.array_get(trace.steps;i);
      let step_obj=str.concat(
        str.concat(
          str.concat(
            str.concat(
              str.concat(
                str.concat(
                  str.concat("{\"step\":\"";json_escape(entry.step));
                  "\",\"detail\":\"");
                json_escape(entry.detail));
              "\",\"timestamp\":\"");
            json_escape(entry.timestamp));
          "\"}");
        "");
      "");
      if i==0{
        steps_json=str.concat(steps_json;step_obj)
      }else{
        steps_json=str.concat(str.concat(steps_json;",");step_obj)
      };
      i=i+1
    }
  };
  steps_json=str.concat(steps_json;"]");

  let json=str.concat(
    str.concat(
      str.concat(
        str.concat(
          str.concat(
            str.concat(
              str.concat(
                str.concat(
                  str.concat(
                    str.concat(
                      str.concat(
                        str.concat(
                          str.concat(
                            str.concat(
                              str.concat(
                                str.concat(
                                  str.concat(
                                    str.concat(
                                      str.concat(
                                        str.concat(
                                          str.concat(
                                            str.concat(
                                              str.concat(
                                                str.concat(
                                                  str.concat(
                                                    str.concat(
                                                      str.concat(
                                                        str.concat(
                                                          str.concat(
                                                            str.concat(
                                                              str.concat(
                                                                str.concat(
                                                                  str.concat(
                                                                    str.concat(
                                                                      str.concat(
                                                                        "{\"request_id\":\"";
                                                                        json_escape(trace.request_id));
                                                                      "\",\"correlation_id\":\"");
                                                                    json_escape(trace.correlation_id));
                                                                  "\",\"pii_detected\":\"");
                                                                json_escape(trace.pii_detected));
                                                              "\",\"anonymisation_applied\":");
                                                            anon_str);
                                                          ",\"compression_applied\":");
                                                        compression_str);
                                                      ",\"risk_classification\":\"");
                                                    json_escape(trace.risk_classification));
                                                  "\",\"policy_decision\":\"");
                                                json_escape(trace.policy_decision));
                                              "\",\"model_selected\":\"");
                                            json_escape(trace.model_selected));
                                          "\",\"provider\":\"");
                                        json_escape(trace.provider));
                                      "\",\"prompt_sent\":\"");
                                    prompt_safe);
                                  "\",\"response_received\":\"");
                                response_safe);
                              "\",\"deanonymisation_applied\":");
                            deanon_str);
                          ",\"duration_ms\":");
                        duration_str);
                      ",\"steps\":");
                    steps_json);
                  "}");
                "");
              "");
            "");
          "");
        "");
      "");
    "");
  <json
}

// Returns a one-line human-readable summary of the trace.
pub f=summary(trace:$decision_trace):str{
  let duration_str=str.from_u32(trace.duration_ms);
  <str.concat(
    str.concat(
      str.concat(
        str.concat(
          str.concat(
            str.concat(
              str.concat(
                str.concat(
                  str.concat(
                    str.concat(
                      str.concat(
                        "Trace ";
                        trace.request_id);
                      ": ");
                    trace.model_selected);
                  " via ");
                trace.provider);
              " | PII: ");
            trace.pii_detected);
          " | Policy: ");
        trace.policy_decision);
      " | ");
    duration_str);
  "ms")
}
