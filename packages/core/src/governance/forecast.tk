// G4.5 — Cost forecasting.
// Projects future LLM spend based on historical daily rate from audit_log.

i=t:shared.types;
i=db:storage.db;
i=str:std.str;

pub m.$cost_forecast{
  period_days:i32;
  projected_cost_usd:f64;
  projected_tokens:i32;
  projected_requests:i32;
  confidence:str;
  generated_at:i64
}

// Builds a cost forecast by extrapolating a daily rate over forecast_days.
// Daily rate stub: $0.004/day. Confidence depends on history_days:
//   < 7  → "low"
//   < 30 → "medium"
//   ≥ 30 → "high"
pub f=forecast(store:db.$store;history_days:i32;forecast_days:i32):$cost_forecast{
  let daily_rate_usd=0.004;
  let forecast_days_f=str.to_float(str.from_int(forecast_days));
  let projected_cost=daily_rate_usd*forecast_days_f;

  // Approximate token and request rates based on the stub snapshot values:
  // 18400 tokens / 30 days ≈ 613 tokens/day; 142 requests / 30 days ≈ 4.7 req/day
  let daily_tokens=613.0;
  let daily_requests=4.7;
  let projected_tokens_f=daily_tokens*forecast_days_f;
  let projected_requests_f=daily_requests*forecast_days_f;

  let confidence=if history_days < 7{
    "low"
  }else{
    if history_days < 30{ "medium" }else{ "high" }
  };

  <$cost_forecast{
    period_days:forecast_days;
    projected_cost_usd:projected_cost;
    projected_tokens:str.to_int(str.from_float(projected_tokens_f));
    projected_requests:str.to_int(str.from_float(projected_requests_f));
    confidence:confidence;
    generated_at:std.time.now()
  }
}

// Renders a cost forecast as formatted text showing the projected period,
// cost, tokens, requests, and confidence level.
pub f=format_forecast(fc:$cost_forecast):str{
  let period_s=str.from_int(fc.period_days);
  let cost_s=str.concat("$";str.from_float(fc.projected_cost_usd));
  let tokens_s=str.from_int(fc.projected_tokens);
  let requests_s=str.from_int(fc.projected_requests);

  let header=str.concat(
    "Cost Forecast (next ";
    str.concat(period_s;" days)\n")
  );
  let divider="==============================\n";
  let row1=str.concat("Projected cost:     ";str.concat(cost_s;"\n"));
  let row2=str.concat("Projected tokens:   ";str.concat(tokens_s;"\n"));
  let row3=str.concat("Projected requests: ";str.concat(requests_s;"\n"));
  let row4=str.concat("Confidence:         ";str.concat(fc.confidence;"\n"));

  <str.concat(
    str.concat(
      str.concat(
        str.concat(
          str.concat(
            str.concat(header;divider);
            row1);
          row2);
        row3);
      row4);
    "")
}
