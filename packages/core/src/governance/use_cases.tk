// G1.2 — Use case registry.
// Maintains the set of known AI use cases and their risk profiles.

i=t:shared.types;
i=gt:core.governance.types;
i=str:std.str;

pub m.$use_case_registry{
  entries:@($gt.use_case)
}

// Returns the built-in set of predefined use cases.
pub f=built_in_use_cases():@($gt.use_case){
  let cases=@(
    $gt.use_case{
      id:"chat-completion";
      name:"General chat and Q&A";
      description:"General purpose conversational assistant";
      risk_level:$gt.risk_tier.$low;
      purpose:"Assist with information and questions";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"code-generation";
      name:"Generate code from description";
      description:"Produces code from natural language descriptions";
      risk_level:$gt.risk_tier.$low;
      purpose:"Accelerate software development";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"code-review";
      name:"Review and analyse code";
      description:"Inspects code for quality, bugs, and security issues";
      risk_level:$gt.risk_tier.$medium;
      purpose:"Improve code quality and security";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"summarisation";
      name:"Summarise long documents";
      description:"Condenses lengthy documents into key points";
      risk_level:$gt.risk_tier.$low;
      purpose:"Extract key information";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"data-analysis";
      name:"Analyse datasets";
      description:"Processes and interprets structured or unstructured data";
      risk_level:$gt.risk_tier.$medium;
      purpose:"Derive insights from data";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"classification";
      name:"Classify text into categories";
      description:"Assigns text to predefined categories";
      risk_level:$gt.risk_tier.$low;
      purpose:"Automate categorisation";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"agent-task";
      name:"Automated agent action";
      description:"Executes complex multi-step automated tasks autonomously";
      risk_level:$gt.risk_tier.$high;
      purpose:"Automate complex multi-step tasks";
      approved_models:@("*");
      owner:"loke"
    };
    $gt.use_case{
      id:"mcp-tool-call";
      name:"MCP tool invocation";
      description:"Invokes external tools via the Model Context Protocol";
      risk_level:$gt.risk_tier.$medium;
      purpose:"Enable LLM tool use";
      approved_models:@("*");
      owner:"loke"
    }
  );
  <cases
}

// Creates a new registry pre-populated with built-in use cases.
pub f=new_registry():$use_case_registry{
  let entries=built_in_use_cases();
  <$use_case_registry{entries:entries}
}

// Looks up a use case by its id. Returns the use case or a $loke_err if not found.
pub f=find(registry:$use_case_registry;id:str):$gt.use_case|$loke_err{
  let count=registry.entries.len;
  let i=0;
  loop{
    if i>=count{
      <$loke_err.$unknown_err(str.concat("use case not found: ";id))
    }else{
      let uc=str.array_get(registry.entries;i);
      if str.eq(uc.id;id){
        <uc
      }else{
        i=i+1
      }
    }
  }
}

// Appends a custom use case to the registry.
pub f=register(registry:mut $use_case_registry;uc:$gt.use_case):void{
  registry.entries=@(registry.entries;uc)
}

// Returns all use cases in the registry.
pub f=list(registry:$use_case_registry):@($gt.use_case){
  <registry.entries
}
