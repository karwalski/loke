i=t:shared.types
i=log:shared.log
i=b:eval.bench
i=disp:providers.dispatcher

m.$comparison{
  model_a:str;
  model_b:str;
  run_a:b.$bench_run;
  run_b:b.$bench_run;
  winner:str;
  score_delta:f64;
  cost_delta:f64;
  latency_delta_ms:i32
}

pub f=compare(model_a:str;model_b:str;cases:@(b.$bench_case);disp:disp.$dispatcher):$comparison{
  log.info("compare: running benchmark for " + model_a);
  run_a:b.$bench_run = b.run_benchmark(model_a;cases;disp);
  log.info("compare: running benchmark for " + model_b);
  run_b:b.$bench_run = b.run_benchmark(model_b;cases;disp);
  winner:str = model_a;
  if run_b.avg_score > run_a.avg_score{
    winner = model_b
  };
  if run_b.avg_score == run_a.avg_score{
    if run_b.total_cost_usd < run_a.total_cost_usd{
      winner = model_b
    }
  };
  score_delta:f64 = run_a.avg_score - run_b.avg_score;
  cost_delta:f64 = run_a.total_cost_usd - run_b.total_cost_usd;
  latency_delta:i32 = run_a.avg_latency_ms - run_b.avg_latency_ms;
  <$comparison{
    model_a:model_a;
    model_b:model_b;
    run_a:run_a;
    run_b:run_b;
    winner:winner;
    score_delta:score_delta;
    cost_delta:cost_delta;
    latency_delta_ms:latency_delta
  }
}

pub f=format_comparison(c:$comparison):str{
  w_label:str = "Winner: " + c.winner;
  score_d_str:str = t.f64_to_str(t.f64_abs(c.score_delta);2);
  cost_d_str:str = t.f64_to_str(t.f64_abs(c.cost_delta);2);
  winner_note:str = w_label
    + " (score +" + score_d_str
    + ", cost +$" + cost_d_str + ")";
  col_a:str = t.str_pad(c.model_a;14);
  col_b:str = t.str_pad(c.model_b;14);
  score_a:str = t.str_pad(t.f64_to_str(c.run_a.avg_score;2);14);
  score_b:str = t.str_pad(t.f64_to_str(c.run_b.avg_score;2);14);
  lat_a:str = t.str_pad(t.int_to_str(c.run_a.avg_latency_ms) + "ms";14);
  lat_b:str = t.str_pad(t.int_to_str(c.run_b.avg_latency_ms) + "ms";14);
  cost_a:str = t.str_pad("$" + t.f64_to_str(c.run_a.total_cost_usd;2);14);
  cost_b:str = t.str_pad("$" + t.f64_to_str(c.run_b.total_cost_usd;2);14);
  line_top:str    = "┌─ Model Comparison ──────────────────────────┐\n";
  line_hdr:str    = "│                  " + col_a + col_b + "│\n";
  line_score:str  = "│ Score:           " + score_a + score_b + "│\n";
  line_lat:str    = "│ Avg latency:     " + lat_a + lat_b + "│\n";
  line_cost:str   = "│ Total cost:      " + cost_a + cost_b + "│\n";
  line_winner:str = "│ " + t.str_pad(winner_note;44) + "│\n";
  line_bot:str    = "└──────────────────────────────────────────────┘\n";
  <line_top + line_hdr + line_score + line_lat + line_cost + line_winner + line_bot
}
