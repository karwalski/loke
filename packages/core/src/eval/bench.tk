i=t:shared.types
i=log:shared.log
i=prov:providers.types
i=disp:providers.dispatcher
i=json:std.json

m.$bench_case{
  id:str;
  prompt:str;
  expected_keywords:@(str);
  category:str
}

m.$bench_result{
  case_id:str;
  model:str;
  latency_ms:i32;
  tokens_used:i32;
  cost_usd:f64;
  keywords_matched:i32;
  keywords_total:i32;
  score:f64;
  response_snippet:str
}

m.$bench_run{
  model:str;
  cases_run:i32;
  avg_score:f64;
  avg_latency_ms:i32;
  total_cost_usd:f64;
  results:@($bench_result);
  run_at:i64
}

pub default_cases:@($bench_case) = [
  $bench_case{
    id:"sum-1";
    prompt:"What is 15 + 27?";
    expected_keywords:["42"];
    category:"reasoning"
  };
  $bench_case{
    id:"code-1";
    prompt:"Write a function to reverse a string in Python";
    expected_keywords:["def","return","[::-1]"];
    category:"coding"
  };
  $bench_case{
    id:"analysis-1";
    prompt:"List 3 benefits of caching";
    expected_keywords:["performance","latency","cost"];
    category:"analysis"
  };
  $bench_case{
    id:"reason-1";
    prompt:"If all cats are mammals and Felix is a cat, is Felix a mammal?";
    expected_keywords:["yes","mammal"];
    category:"reasoning"
  };
  $bench_case{
    id:"creative-1";
    prompt:"Write a one-sentence tagline for a privacy-first AI tool";
    expected_keywords:["privacy","AI"];
    category:"creative"
  }
]

pub f=run_case(case:$bench_case;model:str;disp:disp.$dispatcher):$bench_result{
  log.info("bench: running case " + case.id + " on model " + model);
  start_ms:i64 = t.now_ms();
  response:prov.$response = disp.dispatch(disp;model;case.prompt);
  elapsed_ms:i32 = (t.now_ms() - start_ms) as i32;
  resp_lower:str = t.str_lower(response.text);
  matched:i32 = 0;
  total:i32 = case.expected_keywords.len as i32;
  i:i32 = 0;
  loop{
    if i >= total { break };
    kw:str = t.str_lower(case.expected_keywords[i]);
    if t.str_contains(resp_lower;kw){
      matched = matched + 1
    };
    i = i + 1
  };
  sc:f64 = 0.0;
  if total > 0{
    sc = (matched as f64) / (total as f64)
  };
  snippet:str = t.str_slice(response.text;0;120);
  <$bench_result{
    case_id:case.id;
    model:model;
    latency_ms:elapsed_ms;
    tokens_used:response.tokens_used;
    cost_usd:response.cost_usd;
    keywords_matched:matched;
    keywords_total:total;
    score:sc;
    response_snippet:snippet
  }
}

pub f=run_benchmark(model:str;cases:@($bench_case);disp:disp.$dispatcher):$bench_run{
  log.info("bench: starting benchmark for model " + model);
  results:@($bench_result) = [];
  total_score:f64 = 0.0;
  total_latency:i32 = 0;
  total_cost:f64 = 0.0;
  n:i32 = cases.len as i32;
  i:i32 = 0;
  loop{
    if i >= n { break };
    r:$bench_result = run_case(cases[i];model;disp);
    results = t.arr_push(results;r);
    total_score = total_score + r.score;
    total_latency = total_latency + r.latency_ms;
    total_cost = total_cost + r.cost_usd;
    i = i + 1
  };
  avg_sc:f64 = 0.0;
  avg_lat:i32 = 0;
  if n > 0{
    avg_sc = total_score / (n as f64);
    avg_lat = total_latency / n
  };
  <$bench_run{
    model:model;
    cases_run:n;
    avg_score:avg_sc;
    avg_latency_ms:avg_lat;
    total_cost_usd:total_cost;
    results:results;
    run_at:t.now_ms()
  }
}

pub f=format_run(run:$bench_run):str{
  header:str = "Benchmark: " + run.model + "\n";
  sep:str = "─────────────────────────────────────────────────────────\n";
  col_hdr:str = t.str_pad("Case",16) + t.str_pad("Score",8) + t.str_pad("Latency",10) + t.str_pad("Cost",10) + "Keywords\n";
  rows:str = "";
  i:i32 = 0;
  n:i32 = run.results.len as i32;
  loop{
    if i >= n { break };
    r:$bench_result = run.results[i];
    kw_str:str = t.int_to_str(r.keywords_matched) + "/" + t.int_to_str(r.keywords_total);
    row:str = t.str_pad(r.case_id;16)
      + t.str_pad(t.f64_to_str(r.score;2);8)
      + t.str_pad(t.int_to_str(r.latency_ms) + "ms";10)
      + t.str_pad("$" + t.f64_to_str(r.cost_usd;4);10)
      + kw_str + "\n";
    rows = rows + row;
    i = i + 1
  };
  summary:str = sep
    + t.str_pad("AVERAGE",16)
    + t.str_pad(t.f64_to_str(run.avg_score;2);8)
    + t.str_pad(t.int_to_str(run.avg_latency_ms) + "ms";10)
    + t.str_pad("$" + t.f64_to_str(run.total_cost_usd;4);10)
    + t.int_to_str(run.cases_run) + " cases\n";
  <header + sep + col_hdr + sep + rows + summary
}
