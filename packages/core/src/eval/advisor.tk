i=t:shared.types
i=log:shared.log
i=reg:models.registry

m.$local_advice{
  can_run_locally:bool;
  recommended_model:str;
  confidence:str;
  reason:str;
  estimated_quality:str
}

pub f=advise(task_description:str;required_quality:str):$local_advice{
  log.info("advisor: evaluating task for local feasibility");
  lower:str = t.str_lower(task_description);
  if t.str_contains(lower;"code")
    || t.str_contains(lower;"function")
    || t.str_contains(lower;"debug")
    || t.str_contains(lower;"refactor"){
    <$local_advice{
      can_run_locally:true;
      recommended_model:"qwen2.5:7b";
      confidence:"high";
      reason:"Coding tasks are well-handled by local code-specialised models";
      estimated_quality:"good"
    }
  };
  if t.str_contains(lower;"summarise")
    || t.str_contains(lower;"summarize")
    || t.str_contains(lower;"classify")
    || t.str_contains(lower;"extract"){
    <$local_advice{
      can_run_locally:true;
      recommended_model:"llama3.1:8b";
      confidence:"high";
      reason:"Summarisation and classification are strong suits of local instruction-tuned models";
      estimated_quality:"excellent"
    }
  };
  if t.str_contains(lower;"creative")
    || t.str_contains(lower;"write")
    || t.str_contains(lower;"story")
    || t.str_contains(lower;"poem"){
    <$local_advice{
      can_run_locally:true;
      recommended_model:"qwen2.5:72b";
      confidence:"medium";
      reason:"Creative tasks are feasible locally but quality may vary; larger model recommended";
      estimated_quality:"acceptable"
    }
  };
  if t.str_contains(lower;"complex")
    || t.str_contains(lower;"analyse")
    || t.str_contains(lower;"analyze")
    || t.str_contains(lower;"reasoning")
    || t.str_contains(lower;"research"){
    <$local_advice{
      can_run_locally:false;
      recommended_model:"claude-3-5-sonnet-20241022";
      confidence:"high";
      reason:"Task complexity exceeds local model capability";
      estimated_quality:"excellent"
    }
  };
  <$local_advice{
    can_run_locally:true;
    recommended_model:"llama3.1:8b";
    confidence:"low";
    reason:"No strong signal detected; defaulting to a capable general-purpose local model";
    estimated_quality:"acceptable"
  }
}

pub f=format_advice(a:$local_advice):str{
  run_line:str = "  Can run locally:    ";
  if a.can_run_locally{
    run_line = run_line + "YES"
  };
  if !a.can_run_locally{
    run_line = run_line + "NO (cloud recommended)"
  };
  line_top:str     = "┌─ Local Model Advisor ────────────────────────┐\n";
  line_run:str     = "│ " + t.str_pad(run_line;44) + "│\n";
  line_model:str   = "│ " + t.str_pad("  Recommended model: " + a.recommended_model;44) + "│\n";
  line_conf:str    = "│ " + t.str_pad("  Confidence:        " + a.confidence;44) + "│\n";
  line_qual:str    = "│ " + t.str_pad("  Est. quality:      " + a.estimated_quality;44) + "│\n";
  line_reason:str  = "│ " + t.str_pad("  Reason: " + a.reason;44) + "│\n";
  line_bot:str     = "└──────────────────────────────────────────────┘\n";
  <line_top + line_run + line_model + line_conf + line_qual + line_reason + line_bot
}
