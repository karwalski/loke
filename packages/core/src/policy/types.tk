m.$policy_rule{ id:str; description:str; action:str; severity:str }

m.$regulation{ name:str; jurisdiction:str; rules:@($policy_rule); version:str }

m.$policy_set{ name:str; source:str; regulations:@($regulation); loaded_at:i64; hash:str }

m.$policy_violation{ rule_id:str; rule_desc:str; action:str; severity:str; context:str }
