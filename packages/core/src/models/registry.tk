// F2.2 — Model capability registry
// Maps task types to appropriate models, tracks quality and speed benchmarks.

i=t:shared.types;
i=str:std.str;

pub m.$task_type{
  $chat;
  $code_generation;
  $code_review;
  $summarisation;
  $classification;
  $ner;
  $embedding;
  $data_analysis
}

pub m.$model_capability{
  model_id:str;
  provider:$provider;
  task:$task_type;
  quality_score:f64;
  speed_tok_s:f64;
  context_window:u32;
  supports_tools:bool;
  local:bool
}

pub m.$registry{
  entries:@($model_capability)
}

