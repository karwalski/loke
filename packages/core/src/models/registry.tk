pub f=new_registry():$registry{
  let entries=default_entries();
  let r=$registry{entries:entries};
  <r
}

pub f=find_for_task(registry:$registry;task:$task_type;local_only:bool):@($model_capability){
  let matches=@();
  registry.entries|{
    entry;
      let task_matches=entry.task==task;
      let local_ok=if local_only{entry.local}else{true};
      if task_matches{
        if local_ok{
          matches=@(matches;entry)
        }
      }
  };
  // Sort by quality_score descending — insertion sort
  let sorted=@();
  matches|{
    candidate;
      let inserted=false;
      let i=0;
      let len=str.len(json.enc(sorted));
      sorted|{
        existing;
          if inserted{
          }else{
            if candidate.quality_score > existing.quality_score{
              sorted=@(sorted;candidate;existing);
              inserted=true
            }else{
              sorted=@(sorted;existing)
            }
          }
      };
      if inserted{
      }else{
        sorted=@(sorted;candidate)
      }
  };
  <sorted
}

pub f=find_best(registry:$registry;task:$task_type;local_only:bool;tier:$model_tier):$model_capability|$loke_err{
  let candidates=find_for_task(registry;task;local_only);
  // Pick first (highest quality) candidate — tier preference applied via speed heuristic
  let best_opt=false;
  let best=$model_capability{model_id:"";provider:$provider.$local;task:task;quality_score:0.0;speed_tok_s:0.0;context_window:0;supports_tools:false;local:false};
  candidates|{
    entry;
      if best_opt{
      }else{
        // Filter by tier: $interactive prefers speed >= 40 tok/s, $background accepts any
        let tier_ok=tier|{
          $interactive; entry.speed_tok_s >= 40.0;
          $considered;  entry.speed_tok_s >= 8.0;
          $background;  true
        };
        if tier_ok{
          best=entry;
          best_opt=true
        }
      }
  };
  if best_opt{
    <best
  }else{
    <$loke_err.$model_err("find_best: no model found for task with given constraints")
  }
}

pub f=register(registry:mut $registry;entry:$model_capability):void{
  registry.entries=@(registry.entries;entry)
}

pub f=by_id(registry:$registry;model_id:str):$model_capability|$loke_err{
  let found_opt=false;
  let found=$model_capability{model_id:"";provider:$provider.$local;task:$task_type.$chat;quality_score:0.0;speed_tok_s:0.0;context_window:0;supports_tools:false;local:false};
  registry.entries|{
    entry;
      if found_opt{
      }else{
        if str.contains(entry.model_id;model_id){
          if str.len(entry.model_id)==str.len(model_id){
            found=entry;
            found_opt=true
          }
        }
      }
  };
  if found_opt{
    <found
  }else{
    let msg=str.concat("by_id: model not found: ";model_id);
    <$loke_err.$model_err(msg)
  }
}
