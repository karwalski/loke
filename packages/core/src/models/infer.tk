// F2.4 — Native in-process inference
// Manages a pool of loaded in-process models for low-latency inference
// without going through Ollama REST.

i=inf:std.infer;
i=log:shared.log;
i=t:shared.types;

m.$infer_model{
  handle:inf.$model_handle;
  model_id:str;
  model_path:str;
  loaded_at:i64
}

m.$infer_pool{
  models:@($infer_model);
  data_dir:str
}

pub f=new_pool(data_dir:str):$infer_pool{
  <$infer_pool{models:@();data_dir:data_dir}
}

pub f=model_path(pool:$infer_pool;model_id:str):str{
  let base=str.concat(pool.data_dir;"/models/");
  let with_id=str.concat(base;model_id);
  <str.concat(with_id;".gguf")
}

pub f=load(pool:$infer_pool;model_id:str):$infer_pool{
  let path=model_path(pool;model_id);
  let opts=inf.$infer_opts{n_gpu_layers:99;n_threads:4;seed:0};
  let handle=inf.load(path;opts);
  let entry=$infer_model{
    handle:handle;
    model_id:model_id;
    model_path:path;
    loaded_at:std.time.now()
  };
  let updated_models=@(pool.models;entry);
  log.info(str.concat("loaded in-process: ";model_id);"infer";"");
  <$infer_pool{models:updated_models;data_dir:pool.data_dir}
}

pub f=unload(pool:$infer_pool;model_id:str):$infer_pool{
  let remaining=@();
  pool.models|{
    m;
      if str.eq(m.model_id;model_id){
        inf.unload(m.handle)
      }else{
        remaining=@(remaining;m)
      }
  };
  <$infer_pool{models:remaining;data_dir:pool.data_dir}
}

pub f=generate(pool:$infer_pool;model_id:str;prompt:str;max_tokens:i32):str{
  let found_opt=false;
  let result="";
  pool.models|{
    m;
      if found_opt{
      }else{
        if str.eq(m.model_id;model_id){
          result=inf.generate(m.handle;prompt;max_tokens);
          found_opt=true
        }
      }
  };
  <result
}

pub f=embed(pool:$infer_pool;model_id:str;text:str):@(f32){
  let found_opt=false;
  let result=@();
  pool.models|{
    m;
      if found_opt{
      }else{
        if str.eq(m.model_id;model_id){
          result=inf.embed(m.handle;text);
          found_opt=true
        }
      }
  };
  <result
}

pub f=is_loaded(pool:$infer_pool;model_id:str):bool{
  let found=false;
  pool.models|{
    m;
      if str.eq(m.model_id;model_id){
        found=true
      }
  };
  <found
}
