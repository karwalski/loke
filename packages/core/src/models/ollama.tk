// F2.1 — Ollama service manager
// Manages communication with the Ollama process via its REST API.

i=t:shared.types;
i=http:std.http;
i=json:std.json;
i=str:std.str;

pub m.$ollama_model{
  name:str;
  size:u64;
  digest:str
}

pub m.$ollama_status{
  $running;
  $stopped;
  $unreachable
}

pub m.$chat_message{
  role:str;
  content:str
}

pub m.$generate_opts{
  model:str;
  prompt:str;
  system:str;
  num_gpu:i32
}

pub m.$chat_opts{
  model:str;
  messages:@($chat_message);
  system:str;
  num_gpu:i32
}

pub m.$ollama_client{
  base_url:str
}

pub f=new(base_url:str):$ollama_client{
  let client=$ollama_client{base_url:base_url};
  <client
}

pub f=health_check(client:$ollama_client):$ollama_status{
  let url=str.concat(client.base_url;"/api/tags");
  let result=http.get(url);
  result|{
    $http_err e;
      let msg=json.enc(e);
      if str.contains(msg;"connect"){
        <$ollama_status.$unreachable
      }else{
        <$ollama_status.$stopped
      }
    v;
      <$ollama_status.$running
  }
}

pub f=list_models(client:$ollama_client):@($ollama_model)|$loke_err{
  let url=str.concat(client.base_url;"/api/tags");
  let result=http.get(url);
  result|{
    $http_err e;
      <$loke_err.$network_err("ollama list_models: failed to reach /api/tags")
    body;
      let parsed=json.dec(body);
      parsed|{
        $json_err e;
          <$loke_err.$model_err("ollama list_models: failed to parse JSON response")
        obj;
          let raw_arr=json.get_arr(obj;"models");
          let models=@();
          raw_arr|{
            item;
              let name=json.get_str(item;"name");
              let size=json.get_int(item;"size");
              let digest=json.get_str(item;"digest");
              let m=$ollama_model{name:name;size:size;digest:digest};
              models=@(models;m)
          };
          <models
      }
  }
}

pub f=list_running(client:$ollama_client):@($ollama_model)|$loke_err{
  let url=str.concat(client.base_url;"/api/ps");
  let result=http.get(url);
  result|{
    $http_err e;
      <$loke_err.$network_err("ollama list_running: failed to reach /api/ps")
    body;
      let parsed=json.dec(body);
      parsed|{
        $json_err e;
          <$loke_err.$model_err("ollama list_running: failed to parse JSON response")
        obj;
          let raw_arr=json.get_arr(obj;"models");
          let models=@();
          raw_arr|{
            item;
              let name=json.get_str(item;"name");
              let size=json.get_int(item;"size");
              let m=$ollama_model{name:name;size:size;digest:""};
              models=@(models;m)
          };
          <models
      }
  }
}

pub f=generate(client:$ollama_client;opts:$generate_opts):str|$loke_err{
  let url=str.concat(client.base_url;"/api/generate");
  let body_obj=json.enc({model:opts.model;prompt:opts.prompt;system:opts.system;num_gpu:opts.num_gpu;stream:false});
  let result=http.post(url;body_obj;"application/json");
  result|{
    $http_err e;
      <$loke_err.$network_err("ollama generate: failed to reach /api/generate")
    body;
      let parsed=json.dec(body);
      parsed|{
        $json_err e;
          <$loke_err.$model_err("ollama generate: failed to parse JSON response")
        obj;
          let response=json.get_str(obj;"response");
          <response
      }
  }
}

pub f=chat(client:$ollama_client;opts:$chat_opts):str|$loke_err{
  let url=str.concat(client.base_url;"/api/chat");
  let body_obj=json.enc({model:opts.model;messages:opts.messages;system:opts.system;num_gpu:opts.num_gpu;stream:false});
  let result=http.post(url;body_obj;"application/json");
  result|{
    $http_err e;
      <$loke_err.$network_err("ollama chat: failed to reach /api/chat")
    body;
      let parsed=json.dec(body);
      parsed|{
        $json_err e;
          <$loke_err.$model_err("ollama chat: failed to parse JSON response")
        obj;
          let msg=json.get_str(obj;"message");
          let msg_parsed=json.dec(msg);
          msg_parsed|{
            $json_err e;
              <$loke_err.$model_err("ollama chat: failed to parse message field")
            msg_obj;
              let content=json.get_str(msg_obj;"content");
              <content
          }
      }
  }
}

pub f=pull_model(client:$ollama_client;name:str):bool|$loke_err{
  let url=str.concat(client.base_url;"/api/pull");
  let body_obj=json.enc({name:name});
  let result=http.post(url;body_obj;"application/json");
  result|{
    $http_err e;
      <$loke_err.$network_err("ollama pull_model: failed to reach /api/pull")
    body;
      let parsed=json.dec(body);
      parsed|{
        $json_err e;
          <$loke_err.$model_err("ollama pull_model: failed to parse JSON response")
        obj;
          <true
      }
  }
}

pub f=delete_model(client:$ollama_client;name:str):bool|$loke_err{
  let url=str.concat(client.base_url;"/api/delete");
  let body_obj=json.enc({name:name});
  let result=http.post(url;body_obj;"application/json");
  result|{
    $http_err e;
      <$loke_err.$network_err("ollama delete_model: failed to reach /api/delete")
    body;
      <true
  }
}
