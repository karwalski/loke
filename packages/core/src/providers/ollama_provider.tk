// F5.4 — Ollama provider wrapper
// Wraps the core Ollama service manager to implement the unified provider interface.

i=t:shared.types;
i=pt:core.providers.types;
i=ollama:core.models.ollama;
i=str:std.str;
i=log:shared.log;

pub m.$ollama_provider{
  client:$ollama.ollama_client
}

// Creates an Ollama provider pointing at the given base URL.
pub f=new(base_url:str):$ollama_provider{
  let client=ollama.new(base_url);
  <$ollama_provider{client:client}
}

// Calls the Ollama chat API and returns a completion response.
// Cost is always 0.0 for local inference.
// num_gpu=-1 requests automatic GPU selection from Ollama.
pub f=complete(provider:$ollama_provider;req:$pt.completion_request):$pt.completion_response|$loke_err{
  let opts=$ollama.chat_opts{
    model:req.model_id;
    messages:req.messages;
    system:req.system_prompt;
    num_gpu:-1
  };
  let result=ollama.chat(provider.client;opts);
  result|{
    $loke_err e;
      let msg="ollama_provider complete: chat call failed";
      log.error(msg;"ollama_provider";"");
      <$loke_err.$network_err(msg)
    text;
      let resp=$pt.completion_response{
        content:text;
        model_id:req.model_id;
        input_tokens:0;
        output_tokens:0;
        finish_reason:"stop";
        cost_usd:0.0
      };
      log.info(str.concat("ollama_provider complete: ok model=";req.model_id);"ollama_provider";"");
      <resp
  }
}

// Checks whether Ollama is reachable by performing a health check.
pub f=is_available(provider:$ollama_provider):bool{
  let status=ollama.health_check(provider.client);
  status|{
    $ollama_status.$running;  <true;
    $ollama_status.$stopped;  <false;
    $ollama_status.$unreachable; <false
  }
}
