// F5.1 — Intent classifier
// Classifies user input into a task type using keyword matching (fast path, < 1ms)
// with optional embedding-based classification via Ollama as a fallback.

i=t:shared.types;
i=reg:core.models.registry;
i=str:std.str;
i=http:std.http;
i=json:std.json;
i=log:shared.log;

pub m.$intent_result{
  task:$reg.task_type;
  confidence:f64;
  method:str
}

// Converts a string category name to a $task_type variant.
// Defaults to $chat for unrecognised values.
pub f=task_from_str(s:str):$reg.task_type{
  if str.eq(s;"code_generation"){
    <$reg.task_type.$code_generation
  }else{
    if str.eq(s;"code_review"){
      <$reg.task_type.$code_review
    }else{
      if str.eq(s;"summarisation"){
        <$reg.task_type.$summarisation
      }else{
        if str.eq(s;"classification"){
          <$reg.task_type.$classification
        }else{
          if str.eq(s;"ner"){
            <$reg.task_type.$ner
          }else{
            if str.eq(s;"embedding"){
              <$reg.task_type.$embedding
            }else{
              if str.eq(s;"data_analysis"){
                <$reg.task_type.$data_analysis
              }else{
                <$reg.task_type.$chat
              }
            }
          }
        }
      }
    }
  }
}

// F5.1 fast path — keyword-based classification, < 1ms.
// Returns an $intent_result with method "keyword".
pub f=classify_fast(text:str):$intent_result{
  // embedding — highest specificity first
  if str.contains(text;"embed"){
    <$intent_result{task:$reg.task_type.$embedding;confidence:0.90;method:"keyword"}
  }else{
    if str.contains(text;"embedding"){
      <$intent_result{task:$reg.task_type.$embedding;confidence:0.90;method:"keyword"}
    }else{
      if str.contains(text;"vector"){
        <$intent_result{task:$reg.task_type.$embedding;confidence:0.90;method:"keyword"}
      }else{
        if str.contains(text;"similarity"){
          <$intent_result{task:$reg.task_type.$embedding;confidence:0.90;method:"keyword"}
        }else{
          // summarisation
          if str.contains(text;"summarise"){
            <$intent_result{task:$reg.task_type.$summarisation;confidence:0.85;method:"keyword"}
          }else{
            if str.contains(text;"summarize"){
              <$intent_result{task:$reg.task_type.$summarisation;confidence:0.85;method:"keyword"}
            }else{
              if str.contains(text;"tldr"){
                <$intent_result{task:$reg.task_type.$summarisation;confidence:0.85;method:"keyword"}
              }else{
                if str.contains(text;"summary"){
                  <$intent_result{task:$reg.task_type.$summarisation;confidence:0.85;method:"keyword"}
                }else{
                  if str.contains(text;"brief"){
                    <$intent_result{task:$reg.task_type.$summarisation;confidence:0.85;method:"keyword"}
                  }else{
                    // classification
                    if str.contains(text;"categorise"){
                      <$intent_result{task:$reg.task_type.$classification;confidence:0.82;method:"keyword"}
                    }else{
                      if str.contains(text;"categorize"){
                        <$intent_result{task:$reg.task_type.$classification;confidence:0.82;method:"keyword"}
                      }else{
                        if str.contains(text;"classify"){
                          <$intent_result{task:$reg.task_type.$classification;confidence:0.82;method:"keyword"}
                        }else{
                          if str.contains(text;"label"){
                            <$intent_result{task:$reg.task_type.$classification;confidence:0.82;method:"keyword"}
                          }else{
                            if str.contains(text;"which category"){
                              <$intent_result{task:$reg.task_type.$classification;confidence:0.82;method:"keyword"}
                            }else{
                              // code_review — must check before code_generation to catch "review" + code signals
                              let has_review=str.contains(text;"review");
                              let has_check_code=str.contains(text;"check my code");
                              let has_look=str.contains(text;"look at this");
                              let has_code_word=str.contains(text;"code");
                              let has_fn_word=str.contains(text;"function");
                              let has_class_word=str.contains(text;"class");
                              let review_trigger=if has_review{true}else{if has_check_code{true}else{has_look}};
                              let code_signal=if has_code_word{true}else{if has_fn_word{true}else{has_class_word}};
                              if review_trigger{
                                if code_signal{
                                  <$intent_result{task:$reg.task_type.$code_review;confidence:0.78;method:"keyword"}
                                }else{
                                  // review mentioned but no code signal — fall through to code_generation check
                                  if str.contains(text;"code"){
                                    <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                  }else{
                                    if str.contains(text;"function"){
                                      <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                    }else{
                                      if str.contains(text;"class"){
                                        <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                      }else{
                                        if str.contains(text;"def "){
                                          <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                        }else{
                                          if str.contains(text;"implement"){
                                            <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                          }else{
                                            if str.contains(text;"refactor"){
                                              <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                            }else{
                                              if str.contains(text;"debug"){
                                                <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                              }else{
                                                if str.contains(text;"fix the"){
                                                  <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                                }else{
                                                  // data_analysis
                                                  if str.contains(text;"analyse"){
                                                    <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                  }else{
                                                    if str.contains(text;"analyze"){
                                                      <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                    }else{
                                                      if str.contains(text;"data"){
                                                        <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                      }else{
                                                        if str.contains(text;"csv"){
                                                          <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                        }else{
                                                          if str.contains(text;"chart"){
                                                            <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                          }else{
                                                            if str.contains(text;"trend"){
                                                              <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                            }else{
                                                              if str.contains(text;"distribution"){
                                                                <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                              }else{
                                                                // ner
                                                                if str.contains(text;"who is"){
                                                                  <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                }else{
                                                                  if str.contains(text;"what is"){
                                                                    <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                  }else{
                                                                    if str.contains(text;"find the name"){
                                                                      <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                    }else{
                                                                      if str.contains(text;"identify"){
                                                                        <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                      }else{
                                                                        // default
                                                                        <$intent_result{task:$reg.task_type.$chat;confidence:0.60;method:"keyword"}
                                                                      }
                                                                    }
                                                                  }
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }else{
                                // code_generation
                                if str.contains(text;"code"){
                                  <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                }else{
                                  if str.contains(text;"function"){
                                    <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                  }else{
                                    if str.contains(text;"class"){
                                      <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                    }else{
                                      if str.contains(text;"def "){
                                        <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                      }else{
                                        if str.contains(text;"implement"){
                                          <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                        }else{
                                          if str.contains(text;"refactor"){
                                            <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                          }else{
                                            if str.contains(text;"debug"){
                                              <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                            }else{
                                              if str.contains(text;"fix the"){
                                                <$intent_result{task:$reg.task_type.$code_generation;confidence:0.80;method:"keyword"}
                                              }else{
                                                // data_analysis
                                                if str.contains(text;"analyse"){
                                                  <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                }else{
                                                  if str.contains(text;"analyze"){
                                                    <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                  }else{
                                                    if str.contains(text;"data"){
                                                      <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                    }else{
                                                      if str.contains(text;"csv"){
                                                        <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                      }else{
                                                        if str.contains(text;"chart"){
                                                          <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                        }else{
                                                          if str.contains(text;"trend"){
                                                            <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                          }else{
                                                            if str.contains(text;"distribution"){
                                                              <$intent_result{task:$reg.task_type.$data_analysis;confidence:0.78;method:"keyword"}
                                                            }else{
                                                              // ner
                                                              if str.contains(text;"who is"){
                                                                <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                              }else{
                                                                if str.contains(text;"what is"){
                                                                  <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                }else{
                                                                  if str.contains(text;"find the name"){
                                                                    <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                  }else{
                                                                    if str.contains(text;"identify"){
                                                                      <$intent_result{task:$reg.task_type.$ner;confidence:0.70;method:"keyword"}
                                                                    }else{
                                                                      // default
                                                                      <$intent_result{task:$reg.task_type.$chat;confidence:0.60;method:"keyword"}
                                                                    }
                                                                  }
                                                                }
                                                              }
                                                            }
                                                          }
                                                        }
                                                      }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

// F5.1 — classify with optional Ollama fallback.
// If keyword confidence >= 0.80 return immediately (fast path).
// Otherwise POST to Ollama /api/chat for LLM-based classification.
// If Ollama fails, returns the keyword result.
pub f=classify(text:str;ollama_url:str):$intent_result{
  let fast=classify_fast(text);
  if fast.confidence >= 0.80{
    <fast
  }else{
    let chat_url=str.concat(ollama_url;"/api/chat");
    let system_msg="Classify the intent as one of: chat, code_generation, code_review, summarisation, classification, ner, embedding, data_analysis. Reply with just the category name.";
    let body=json.enc({
      model:"qwen2.5:7b";
      stream:false;
      messages:@(
        {role:"system";content:system_msg};
        {role:"user";content:text}
      )
    });
    let resp=http.post(chat_url;body;"application/json");
    resp|{
      $http_err e;
        <fast
      raw;
        let parsed=json.dec(raw);
        parsed|{
          $json_err e;
            <fast
          obj;
            // Ollama /api/chat response: {"message":{"role":"...","content":"..."}, ...}
            let msg_raw=json.get_str(obj;"message");
            let msg_parsed=json.dec(msg_raw);
            msg_parsed|{
              $json_err e;
                <fast
              msg_obj;
                let content=json.get_str(msg_obj;"content");
                let task=task_from_str(content);
                <$intent_result{task:task;confidence:0.72;method:"llm"}
            }
        }
    }
  }
}
