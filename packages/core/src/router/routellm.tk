// F5.5 — RouteLLM signal integration
// Queries the RouteLLM REST service to predict whether a prompt should go to
// a strong (expensive) or weak (cheap) model. Falls back gracefully when the
// service is unavailable.

i=t:shared.types;
i=http:std.http;
i=json:std.json;
i=log:shared.log;

m.$routellm_request{
  prompt:str;
  threshold:f64
}

m.$routellm_response{
  score:f64;
  route:str;
  model_suggestion:str
}

pub m.$routellm_result{
  available:bool;
  score:f64;
  prefer_strong:bool
}

// POST to http://localhost:11431/route with the prompt and threshold.
// Returns a $routellm_result indicating whether to prefer the strong model.
// On HTTP error or connection refused, returns a safe default with available=false.
pub f=query(prompt:str;threshold:f64):$routellm_result{
  let req=$routellm_request{prompt:prompt;threshold:threshold};
  let body=json.encode(req);
  let resp=http.post("http://localhost:11431/route";body);
  resp|{
    $loke_err e;
      log.warn("routellm: service unavailable, skipping signal";"routellm";"");
      <$routellm_result{available:false;score:0.5;prefer_strong:false}
    cap;
      if http.is_error(cap){
        log.warn("routellm: HTTP error from /route";"routellm";"");
        <$routellm_result{available:false;score:0.5;prefer_strong:false}
      }else{
        let parsed=json.decode(cap.body);
        parsed|{
          $loke_err e2;
            log.warn("routellm: failed to parse response";"routellm";"");
            <$routellm_result{available:false;score:0.5;prefer_strong:false}
          rr;
            let is_strong=http.str_eq(rr.route;"strong");
            <$routellm_result{available:true;score:rr.score;prefer_strong:is_strong}
        }
      }
  }
}

// GET http://localhost:11431/health — returns true if the service responds 200.
pub f=is_available():bool{
  let resp=http.get("http://localhost:11431/health");
  resp|{
    $loke_err e;
      <false
    cap;
      <http.is_ok(cap)
  }
}

// Default routing threshold: 0.3 — conservative, only routes to weak model
// when RouteLLM is very confident the query does not require a strong model.
pub f=default_threshold():f64{
  <0.3
}
