// P2.7 — Custom LLM provider registration.
// Allows applications to register additional LLM providers without forking
// providers/dispatcher.tk. Providers are stored in a $provider_store and
// consulted by the dispatcher after the built-in provider list has been
// exhausted, ordered by priority descending so callers can express preference.

m=core.extensions.provider_registry;
i=str:std.string;
i=log:std.log;

// ── Types ─────────────────────────────────────────────────────────────────────

// Capability flags for a custom provider.
pub m.$provider_caps{
  streaming:bool;
  tool_calling:bool;
  embedding:bool;
  max_context:i32
}

// A custom LLM provider entry. priority is compared descending — higher value
// means the provider is tried first when multiple providers match.
pub m.$custom_provider{
  id:str;
  name:str;
  base_url:str;
  caps:$provider_caps;
  priority:i32
}

// Mutable store of registered custom providers.
pub m.$provider_store{
  providers:@($custom_provider)
}

// ── Functions ─────────────────────────────────────────────────────────────────

// Returns an empty provider store.
pub f=new_store():$provider_store{
  <$provider_store{
    providers:@()
  }
}

// Adds a custom provider to the store and returns the updated store.
// If a provider with the same id already exists it is replaced (deduplication
// by id), so callers can safely call register again to update configuration.
pub f=register(store:$provider_store;p:$custom_provider):$provider_store{
  // Build a new list without any existing entry for p.id, then append p.
  let without=@();
  let count=str.array_len(store.providers);
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let existing=str.array_get(store.providers;i);
      if str.eq(existing.id;p.id){
        // Drop the old entry — will be replaced by p below.
        ()
      }else{
        without=@(without;existing)
      };
      i=i+1
    }
  };
  log.info(str.concat("custom provider registered: ";p.id);"provider_registry";"system");
  <$provider_store{
    providers:@(without;p)
  }
}

// Removes the provider with the given id from the store.
// Returns the store unchanged if id is not found.
pub f=unregister(store:$provider_store;id:str):$provider_store{
  let result=@();
  let count=str.array_len(store.providers);
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let existing=str.array_get(store.providers;i);
      if str.eq(existing.id;id){
        ()
      }else{
        result=@(result;existing)
      };
      i=i+1
    }
  };
  log.info(str.concat("custom provider unregistered: ";id);"provider_registry";"system");
  <$provider_store{
    providers:result
  }
}

// Returns the provider with the given id, or none if not found.
pub f=get(store:$provider_store;id:str):?($custom_provider){
  let count=str.array_len(store.providers);
  let i=0;
  let found=?();
  loop{
    if i>=count{
      break
    }else{
      let existing=str.array_get(store.providers;i);
      if str.eq(existing.id;id){
        found=?(existing);
        i=count
      }else{
        i=i+1
      }
    }
  };
  <found
}

// Returns all providers sorted by priority descending (highest priority first).
// Uses insertion sort — provider counts are expected to be small.
pub f=list(store:$provider_store):@($custom_provider){
  let sorted=@();
  let count=str.array_len(store.providers);
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let p=str.array_get(store.providers;i);
      // Find insertion point: first position in sorted where sorted[j].priority < p.priority
      let inserted=false;
      let new_sorted=@();
      let j=0;
      let sorted_len=str.array_len(sorted);
      loop{
        if j>=sorted_len{
          break
        }else{
          let s=str.array_get(sorted;j);
          if inserted{
            new_sorted=@(new_sorted;s);
            j=j+1
          }else{
            if p.priority>s.priority{
              new_sorted=@(new_sorted;p);
              new_sorted=@(new_sorted;s);
              inserted=true;
              j=j+1
            }else{
              new_sorted=@(new_sorted;s);
              j=j+1
            }
          }
        }
      };
      if inserted{
        sorted=new_sorted
      }else{
        sorted=@(new_sorted;p)
      };
      i=i+1
    }
  };
  <sorted
}

// Returns true if a provider with the given id exists in the store.
pub f=has(store:$provider_store;id:str):bool{
  let count=str.array_len(store.providers);
  let i=0;
  let result=false;
  loop{
    if i>=count{
      break
    }else{
      let existing=str.array_get(store.providers;i);
      if str.eq(existing.id;id){
        result=true;
        i=count
      }else{
        i=i+1
      }
    }
  };
  <result
}
