// AG1.7 — Agent latency tolerance.
// Defines latency classes and assigns them to agents to govern acceptable response windows.

i=t:shared.types;
i=log:shared.log;

m.$latency_class{
  name:str;
  max_seconds:i32;
  description:str
}

m.$latency_assignment{
  agent_name:str;
  class_name:str;
  assigned_at:i64
}

// User is waiting — respond within 10 seconds.
pub let latency_interactive=$latency_class{
  name:"interactive";
  max_seconds:10;
  description:"User is waiting — respond within 10s"
}

// Background but prompt — complete within 1 minute.
pub let latency_considered=$latency_class{
  name:"considered";
  max_seconds:60;
  description:"Background but prompt — complete within 1 min"
}

// Overnight batch — complete within 1 hour.
pub let latency_background=$latency_class{
  name:"background";
  max_seconds:3600;
  description:"Overnight batch — complete within 1 hour"
}

// Creates a latency assignment for the given agent and class name.
pub f=assign(agent_name:str;class_name:str):$latency_assignment{
  <$latency_assignment{
    agent_name:agent_name;
    class_name:class_name;
    assigned_at:t.now_i64()
  }
}

// Looks up the latency class for an agent by name.
// Defaults to latency_background if no assignment is found.
pub f=class_for_agent(assignments:@($latency_assignment);agent_name:str):$latency_class{
  let count=assignments.len;
  let i=0;
  let found=false;
  let result=latency_background;
  loop{
    if i>=count{
      break
    }else{
      let a=t.array_get(assignments;i);
      if str.eq(a.agent_name;agent_name){
        if str.eq(a.class_name;"interactive"){
          result=latency_interactive;
          found=true
        }else{
          if str.eq(a.class_name;"considered"){
            result=latency_considered;
            found=true
          }else{
            result=latency_background;
            found=true
          }
        };
        i=count
      }else{
        i=i+1
      }
    }
  };
  <result
}

// Returns true if elapsed_seconds is within the class's maximum tolerance.
pub f=is_within_tolerance(class:$latency_class;elapsed_seconds:i32):bool{
  <elapsed_seconds<=class.max_seconds
}

// Returns a human-readable string describing the agent's latency assignment.
pub f=format_assignment(a:$latency_assignment):str{
  let class=class_for_agent(@(a);a.agent_name);
  let max_str=str.from_i32(class.max_seconds);
  <str.concat(
    str.concat(
      str.concat(
        str.concat("agent:";a.agent_name);
        " → class:");
      a.class_name);
    str.concat(
      " (latency tolerance: ";
      str.concat(max_str;"s)")))
}
