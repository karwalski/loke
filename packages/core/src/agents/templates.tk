// AG1.5 — Built-in agent templates.
// A library of ready-to-use agent definitions for the loke marketplace.

i=t:shared.types;
i=at:core.agents.types;
i=reg:core.agents.registry;
i=str:std.str;
i=log:shared.log;

// Returns all built-in agent templates.
pub f=all_templates():@($at.agent_def){
  // 1. daily-digest
  let daily_digest=$at.agent_def{
    id:"daily-digest";
    name:"Daily Digest";
    description:"Summarises activity from the past 24 hours";
    schedule:"0 7 * * *";
    trigger:$at.trigger_type.$schedule("0 7 * * *");
    model_preference:"qwen2.5:7b";
    latency_tolerance:$t.latency_tolerance.$background;
    risk_level:"low";
    permissions:@(
      $at.agent_permission.$read_file("~/.loke/");
      $at.agent_permission.$model("qwen2.5:7b")
    );
    max_cost_per_run:0.05;
    requires_approval:false;
    owner:"";
    enabled:false;
    prompt_template:"Summarise the key events, decisions, and outputs from the past 24 hours. Be concise and focus on what matters for today's work. Context: {{context}}"
  };

  // 2. nightly-code-reviewer
  let nightly_code_reviewer=$at.agent_def{
    id:"nightly-code-reviewer";
    name:"Nightly Code Reviewer";
    description:"Reviews today's code commits";
    schedule:"0 23 * * *";
    trigger:$at.trigger_type.$schedule("0 23 * * *");
    model_preference:"qwen2.5:72b";
    latency_tolerance:$t.latency_tolerance.$background;
    risk_level:"low";
    permissions:@(
      $at.agent_permission.$read_file("./");
      $at.agent_permission.$model("qwen2.5:72b")
    );
    max_cost_per_run:0.50;
    requires_approval:false;
    owner:"";
    enabled:false;
    prompt_template:"Review the following code changes for quality, security issues, and correctness. Provide specific, actionable feedback. Context: {{context}}"
  };

  // 3. doc-freshness-checker
  let doc_freshness_checker=$at.agent_def{
    id:"doc-freshness-checker";
    name:"Doc Freshness Checker";
    description:"Checks if documentation matches code";
    schedule:"0 1 * * 1";
    trigger:$at.trigger_type.$schedule("0 1 * * 1");
    model_preference:"qwen2.5:72b";
    latency_tolerance:$t.latency_tolerance.$background;
    risk_level:"low";
    permissions:@(
      $at.agent_permission.$read_file("./");
      $at.agent_permission.$model("qwen2.5:72b")
    );
    max_cost_per_run:0.30;
    requires_approval:false;
    owner:"";
    enabled:false;
    prompt_template:"Check if the documentation accurately reflects the current codebase. Identify outdated sections, missing documentation, and inaccurate descriptions. Context: {{context}}"
  };

  // 4. weekly-security-scan
  let weekly_security_scan=$at.agent_def{
    id:"weekly-security-scan";
    name:"Weekly Security Scan";
    description:"Security analysis of dependencies and code";
    schedule:"0 2 * * 0";
    trigger:$at.trigger_type.$schedule("0 2 * * 0");
    model_preference:"qwen2.5:72b";
    latency_tolerance:$t.latency_tolerance.$background;
    risk_level:"medium";
    permissions:@(
      $at.agent_permission.$read_file("./");
      $at.agent_permission.$http_get("https://osv.dev");
      $at.agent_permission.$model("qwen2.5:72b")
    );
    max_cost_per_run:1.00;
    requires_approval:false;
    owner:"";
    enabled:false;
    prompt_template:"Perform a security review of the codebase and dependencies. Look for: common vulnerabilities, hardcoded secrets, insecure patterns, outdated dependencies. Report findings by severity. Context: {{context}}"
  };

  // 5. meeting-prep
  let meeting_prep=$at.agent_def{
    id:"meeting-prep";
    name:"Meeting Prep";
    description:"Prepares briefing before meetings";
    schedule:"";
    trigger:$at.trigger_type.$manual;
    model_preference:"qwen2.5:7b";
    latency_tolerance:$t.latency_tolerance.$patient;
    risk_level:"low";
    permissions:@(
      $at.agent_permission.$read_file("~/.loke/");
      $at.agent_permission.$model("qwen2.5:7b")
    );
    max_cost_per_run:0.10;
    requires_approval:false;
    owner:"";
    enabled:false;
    prompt_template:"Prepare a concise briefing for the upcoming meeting. Include: relevant context from memory, open questions, key decisions needed, suggested agenda. Context: {{context}}"
  };

  // 6. expense-categoriser
  let expense_categoriser=$at.agent_def{
    id:"expense-categoriser";
    name:"Expense Categoriser";
    description:"Categorises expenses from receipts/statements";
    schedule:"";
    trigger:$at.trigger_type.$manual;
    model_preference:"qwen2.5:7b";
    latency_tolerance:$t.latency_tolerance.$patient;
    risk_level:"low";
    permissions:@(
      $at.agent_permission.$model("qwen2.5:7b")
    );
    max_cost_per_run:0.05;
    requires_approval:false;
    owner:"";
    enabled:false;
    prompt_template:"Categorise the following expenses into: Travel, Software, Hardware, Meals, Other. Return a JSON array with amount, merchant, category, date for each item. Context: {{context}}"
  };

  // 7. documentation-updater
  let documentation_updater=$at.agent_def{
    id:"documentation-updater";
    name:"Documentation Updater";
    description:"Updates docs based on code changes";
    schedule:"";
    trigger:$at.trigger_type.$manual;
    model_preference:"qwen2.5:72b";
    latency_tolerance:$t.latency_tolerance.$patient;
    risk_level:"low";
    permissions:@(
      $at.agent_permission.$read_file("./");
      $at.agent_permission.$write_file("./docs/");
      $at.agent_permission.$model("qwen2.5:72b")
    );
    max_cost_per_run:0.50;
    requires_approval:true;
    owner:"";
    enabled:false;
    prompt_template:"Update the documentation to reflect the code changes provided. Maintain the existing style and format. Mark any sections where human review is recommended. Context: {{context}}"
  };

  <@(
    daily_digest;
    nightly_code_reviewer;
    doc_freshness_checker;
    weekly_security_scan;
    meeting_prep;
    expense_categoriser;
    documentation_updater
  )
}

// Find a template by id from all_templates(). Returns $loke_err if not found.
pub f=find_template(id:str):$at.agent_def|$t.loke_err{
  let templates=all_templates();
  let count=templates.len;
  let i=0;
  loop{
    if i>=count{
      <$t.loke_err.$config_err(str.concat("template not found: ";id))
    }else{
      let tmpl=str.array_get(templates;i);
      if str.eq(tmpl.id;id){
        <tmpl
      }else{
        i=i+1
      }
    }
  }
}

// Find template by id, register it in the given registry, and log the installation.
pub f=install(id:str;registry:mut $reg.agent_registry):void|$t.loke_err{
  let tmpl_result=find_template(id);
  tmpl_result|{
    $t.loke_err e;
      <$t.loke_err e;
    tmpl;
      let reg_result=reg.register(registry;tmpl);
      reg_result|{
        $t.loke_err e;
          <$t.loke_err e;
        ok;
          log.info(str.concat("installed agent template: ";id);"templates";id);
          <$ok(void)
      }
  }
}

// Returns a formatted list of all templates for `loke agents templates`.
pub f=list_templates():str{
  let header="Available templates:\n";
  let templates=all_templates();
  let count=templates.len;
  let rows="";
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let tmpl=str.array_get(templates;i);
      let lat=tmpl.latency_tolerance|{
        $t.latency_tolerance.$instant; <"instant";
        $t.latency_tolerance.$patient; <"patient";
        $t.latency_tolerance.$background; <"background"
      };
      let cost_str=str.concat("max $";str.from_float(tmpl.max_cost_per_run));
      let desc_short=str.concat(
        str.concat(
          str.concat(
            str.concat(
              str.concat("(";lat);
              ", "
            );
            tmpl.model_preference
          );
          ", "
        );
        str.concat(cost_str;")")
      );
      let id_pad=str.concat(str.concat("  ";tmpl.id);"  ");
      let desc_line=str.concat(str.concat(tmpl.description;" ");desc_short);
      let row=str.concat(str.concat(str.concat(id_pad;desc_line);"\n");"");
      rows=str.concat(rows;row);
      i=i+1
    }
  };
  let footer="Install with: loke agents install <template-name>";
  <str.concat(str.concat(header;rows);footer)
}
