// AG1.6 — Agent-to-agent communication pipelines.
// Defines ordered sequences of agent runs where each step may pass its output to the next.

i=t:shared.types;
i=log:shared.log;
i=ex:agents.executor;
i=reg:agents.registry;

m.$pipeline_step{
  agent_name:str;
  pass_output:bool;
  transform:str
}

m.$agent_pipeline{
  name:str;
  steps:@($pipeline_step);
  created_at:i64
}

m.$pipeline_run{
  pipeline_name:str;
  step_results:@(str);
  started_at:i64;
  finished_at:i64;
  ok:bool
}

// Constructs a new pipeline from a name and ordered list of steps.
pub f=new_pipeline(name:str;steps:@($pipeline_step)):$agent_pipeline{
  <$agent_pipeline{
    name:name;
    steps:steps;
    created_at:t.now_i64()
  }
}

// Executes pipeline steps in sequence.
// If pass_output is true for a step, that step's output becomes the next step's input.
// Collects results from all steps and returns a run summary.
pub f=run_pipeline(pl:$agent_pipeline;initial_input:str;reg:reg.$agent_registry):$pipeline_run{
  let started=t.now_i64();
  let step_results=@();
  let current_input=initial_input;
  let all_ok=true;
  let count=pl.steps.len;
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let step=t.array_get(pl.steps;i);
      log.info(
        str.concat("pipeline step: ";step.agent_name);
        "agent_pipeline";
        pl.name
      );
      let find_result=reg.find(reg;step.agent_name);
      find_result|{
        $t.loke_err e;
          let err_msg=str.concat("step failed — agent not found: ";step.agent_name);
          log.error(err_msg;"agent_pipeline";pl.name);
          step_results=@(step_results;err_msg);
          all_ok=false;
          i=i+1;
        agent;
          // Agent found — stub execution by echoing input with agent name
          let output=str.concat(
            str.concat(
              str.concat("[";step.agent_name);
              "] processed: ");
            current_input
          );
          step_results=@(step_results;output);
          if step.pass_output{
            current_input=output
          }else{
            // keep current_input unchanged for next step
          };
          i=i+1
      }
    }
  };
  let finished=t.now_i64();
  <$pipeline_run{
    pipeline_name:pl.name;
    step_results:step_results;
    started_at:started;
    finished_at:finished;
    ok:all_ok
  }
}

// Returns a human-readable summary of a pipeline run showing each step result.
pub f=format_pipeline_run(run:$pipeline_run):str{
  let status=if run.ok{ "OK" }else{ "FAILED" };
  let header=str.concat(
    str.concat(
      str.concat("pipeline: ";run.pipeline_name);
      " — ");
    status
  );
  let count=run.step_results.len;
  let i=0;
  let body=header;
  loop{
    if i>=count{
      break
    }else{
      let result=t.array_get(run.step_results;i);
      let step_num=str.from_i32(i+1);
      let line=str.concat(
        str.concat(
          str.concat("\n  step ";step_num);
          ": ");
        result
      );
      body=str.concat(body;line);
      i=i+1
    }
  };
  <body
}
