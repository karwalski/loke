// AG1.1 — Agent registry.
// Manages registration, lookup, enable/disable, and run history for agents.

i=t:shared.types;
i=at:core.agents.types;
i=gov_uc:core.governance.use_cases;
i=str:std.str;
i=log:shared.log;

pub m.$agent_registry{
  agents:@($at.agent_def);
  runs:@($at.agent_run)
}

// Creates an empty agent registry.
pub f=new_registry():$agent_registry{
  <$agent_registry{
    agents:@();
    runs:@()
  }
}

// Validates and registers an agent in the registry.
// Validates: name must not be empty, prompt_template must not be empty.
// Warns if max_cost_per_run > 10.0 but still allows registration.
pub f=register(reg:mut $agent_registry;agent:$at.agent_def):void|$t.loke_err{
  if str.eq(agent.name;""){
    <$t.loke_err.$config_err("agent must have a name")
  }else{
    if str.eq(agent.prompt_template;""){
      <$t.loke_err.$config_err("agent must have a prompt template")
    }else{
      if agent.max_cost_per_run>10.0{
        log.warn(str.concat("agent max_cost_per_run exceeds $10: ";agent.id);"agent_registry";agent.id)
      }else{
        // cost within normal range
      };
      reg.agents=@(reg.agents;agent);
      log.info(str.concat("agent registered: ";agent.id);"agent_registry";agent.id);
      <$ok(void)
    }
  }
}

// Finds an agent by ID. Returns $loke_err if not found.
pub f=find(reg:$agent_registry;id:str):$at.agent_def|$t.loke_err{
  let count=reg.agents.len;
  let i=0;
  loop{
    if i>=count{
      <$t.loke_err.$config_err(str.concat("agent not found: ";id))
    }else{
      let agent=str.array_get(reg.agents;i);
      if str.eq(agent.id;id){
        <agent
      }else{
        i=i+1
      }
    }
  }
}

// Enables an agent by ID. Returns $loke_err if not found.
pub f=enable(reg:mut $agent_registry;id:str):void|$t.loke_err{
  let count=reg.agents.len;
  let i=0;
  let found=false;
  let new_agents=@();
  loop{
    if i>=count{
      break
    }else{
      let agent=str.array_get(reg.agents;i);
      if str.eq(agent.id;id){
        let updated=$at.agent_def{
          id:agent.id;
          name:agent.name;
          description:agent.description;
          schedule:agent.schedule;
          trigger:agent.trigger;
          model_preference:agent.model_preference;
          latency_tolerance:agent.latency_tolerance;
          risk_level:agent.risk_level;
          permissions:agent.permissions;
          max_cost_per_run:agent.max_cost_per_run;
          requires_approval:agent.requires_approval;
          owner:agent.owner;
          enabled:true;
          prompt_template:agent.prompt_template
        };
        new_agents=@(new_agents;updated);
        found=true;
        i=i+1
      }else{
        new_agents=@(new_agents;agent);
        i=i+1
      }
    }
  };
  if found{
    reg.agents=new_agents;
    log.info(str.concat("agent enabled: ";id);"agent_registry";id);
    <$ok(void)
  }else{
    <$t.loke_err.$config_err(str.concat("agent not found: ";id))
  }
}

// Disables an agent by ID. Returns $loke_err if not found.
pub f=disable(reg:mut $agent_registry;id:str):void|$t.loke_err{
  let count=reg.agents.len;
  let i=0;
  let found=false;
  let new_agents=@();
  loop{
    if i>=count{
      break
    }else{
      let agent=str.array_get(reg.agents;i);
      if str.eq(agent.id;id){
        let updated=$at.agent_def{
          id:agent.id;
          name:agent.name;
          description:agent.description;
          schedule:agent.schedule;
          trigger:agent.trigger;
          model_preference:agent.model_preference;
          latency_tolerance:agent.latency_tolerance;
          risk_level:agent.risk_level;
          permissions:agent.permissions;
          max_cost_per_run:agent.max_cost_per_run;
          requires_approval:agent.requires_approval;
          owner:agent.owner;
          enabled:false;
          prompt_template:agent.prompt_template
        };
        new_agents=@(new_agents;updated);
        found=true;
        i=i+1
      }else{
        new_agents=@(new_agents;agent);
        i=i+1
      }
    }
  };
  if found{
    reg.agents=new_agents;
    log.info(str.concat("agent disabled: ";id);"agent_registry";id);
    <$ok(void)
  }else{
    <$t.loke_err.$config_err(str.concat("agent not found: ";id))
  }
}

// Returns all registered agents.
pub f=list(reg:$agent_registry):@($at.agent_def){
  <reg.agents
}

// Returns only enabled agents.
pub f=list_enabled(reg:$agent_registry):@($at.agent_def){
  let result=@();
  let count=reg.agents.len;
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let agent=str.array_get(reg.agents;i);
      if agent.enabled{
        result=@(result;agent)
      }else{
        // skip disabled
      };
      i=i+1
    }
  };
  <result
}

// Appends a run record to the registry.
pub f=record_run(reg:mut $agent_registry;run:$at.agent_run):void{
  reg.runs=@(reg.runs;run)
}

// Returns all runs for a specific agent, most recent first.
pub f=get_runs(reg:$agent_registry;agent_id:str):@($at.agent_run){
  // Collect matching runs
  let matched=@();
  let count=reg.runs.len;
  let i=0;
  loop{
    if i>=count{
      break
    }else{
      let run=str.array_get(reg.runs;i);
      if str.eq(run.agent_id;agent_id){
        matched=@(matched;run)
      }else{
        // skip
      };
      i=i+1
    }
  };
  // Reverse to get most recent first
  let reversed=@();
  let mc=matched.len;
  let j=mc;
  loop{
    if j==0{
      break
    }else{
      j=j-1;
      let run=str.array_get(matched;j);
      reversed=@(reversed;run)
    }
  };
  <reversed
}
