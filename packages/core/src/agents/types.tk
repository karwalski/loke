// AG1.1 / AG1.2 / AG1.3 — Core agent types
// Defines agent definitions, run records, permissions, triggers, and status.

i=t:shared.types;
i=str:std.str;

pub m.$trigger_type{
  $manual;
  $schedule(str);
  $file_change(str);
  $webhook(str);
  $mcp_event(str)
}

pub m.$agent_permission{
  $read_file(str);
  $write_file(str);
  $mcp_tool(str);
  $http_get(str);
  $model(str)
}

pub m.$agent_def{
  id:str;
  name:str;
  description:str;
  schedule:str;
  trigger:$trigger_type;
  model_preference:str;
  latency_tolerance:$t.latency_tolerance;
  risk_level:str;
  permissions:@($agent_permission);
  max_cost_per_run:f64;
  requires_approval:bool;
  owner:str;
  enabled:bool;
  prompt_template:str
}

pub m.$agent_run_status{
  $idle;
  $running;
  $scheduled;
  $paused;
  $errored(str);
  $disabled
}

pub m.$agent_run{
  id:str;
  agent_id:str;
  trigger:str;
  started_at:str;
  completed_at:str;
  duration_ms:u32;
  tokens_used:u32;
  cost_usd:f64;
  outcome:str;
  error:str;
  status:$agent_run_status
}

// Creates an agent definition with safe defaults.
// Trigger: manual. Latency: background. No permissions. max_cost=0.10.
// requires_approval=true. enabled=false.
pub f=new_agent(id:str;name:str;description:str;prompt:str):$agent_def{
  <$agent_def{
    id:id;
    name:name;
    description:description;
    schedule:"";
    trigger:$trigger_type.$manual;
    model_preference:"";
    latency_tolerance:$t.latency_tolerance.$background;
    risk_level:"low";
    permissions:@();
    max_cost_per_run:0.10;
    requires_approval:true;
    owner:"";
    enabled:false;
    prompt_template:prompt
  }
}

// Creates a new run record for the given agent with a generated ID.
pub f=new_run(agent_id:str;trigger:str):$agent_run{
  let id=str.rand_hex(16);
  let now=str.now_iso8601();
  <$agent_run{
    id:id;
    agent_id:agent_id;
    trigger:trigger;
    started_at:now;
    completed_at:"";
    duration_ms:0;
    tokens_used:0;
    cost_usd:0.0;
    outcome:"";
    error:"";
    status:$agent_run_status.$running
  }
}
