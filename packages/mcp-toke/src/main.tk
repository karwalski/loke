// F7.2 — MCP server entry point
// Standalone binary: starts the loke MCP server with default config.

i=srv:mcp_toke.server;
i=log:shared.log;
i=str:std.str;

pub f=main(args:@(str)):i32{
  let cid=log.new_correlation_id();
  log.info("loke MCP server starting";"mcp-toke";cid);
  let config=srv.default_config();
  srv.start(config);
  <0
}
