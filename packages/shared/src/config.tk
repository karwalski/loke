// Configuration types and loader for loke

i=file:std.file;
i=t:shared.types;

pub m.$loke_config{
  port:u16;
  data_dir:str;
  log_level:str;
  ollama_url:str;
  presidio_url:str;
  llmlingua_url:str;
  default_provider:str
}

pub f=default_config():$loke_config{
  <$loke_config{
    port=11430;
    data_dir="~/.loke";
    log_level="info";
    ollama_url="http://localhost:11434";
    presidio_url="http://localhost:5000";
    llmlingua_url="http://localhost:5001";
    default_provider="ollama"
  }
}

pub f=load_config(path:str):$loke_config|$loke_err{
  let raw=file.read(path)|{
    $ok:v v;
    $err:e <$err($config_err(e))
  };
  let defaults=default_config();
  let parsed=file.parse_toml(raw)|{
    $ok:v v;
    $err:e <$err($config_err(e))
  };
  <$ok($loke_config{
    port=parsed.get_u16("server.port")|{
      $ok:v v;
      $err:_ defaults.port
    };
    data_dir=parsed.get_str("project.data_dir")|{
      $ok:v v;
      $err:_ defaults.data_dir
    };
    log_level=parsed.get_str("dev.log_level")|{
      $ok:v v;
      $err:_ defaults.log_level
    };
    ollama_url=parsed.get_str("providers.ollama_url")|{
      $ok:v v;
      $err:_ defaults.ollama_url
    };
    presidio_url=parsed.get_str("privacy.presidio_url")|{
      $ok:v v;
      $err:_ defaults.presidio_url
    };
    llmlingua_url=parsed.get_str("privacy.llmlingua_url")|{
      $ok:v v;
      $err:_ defaults.llmlingua_url
    };
    default_provider=parsed.get_str("providers.default")|{
      $ok:v v;
      $err:_ defaults.default_provider
    }
  })
}
