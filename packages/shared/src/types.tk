// Shared domain types for loke — privacy proxy for LLM traffic

pub m.$sensitivity_level{
  $public;
  $internal;
  $confidential;
  $restricted
}

pub m.$provider{
  $anthropic;
  $openai;
  $google;
  $mistral;
  $openrouter;
  $ollama;
  $local
}

pub m.$model_tier{
  $interactive;
  $considered;
  $background
}

pub m.$latency_tolerance{
  $instant;
  $patient;
  $background
}

pub m.$pii_entity{
  entity_type:str;
  value:str;
  start:u32;
  end:u32;
  confidence:f64;
  placeholder:str
}

pub m.$pii_detection_result{
  original:str;
  anonymised:str;
  entities:@($pii_entity);
  sensitivity:$sensitivity_level
}

pub m.$model_spec{
  id:str;
  provider:$provider;
  context_window:u32;
  cost_per_1k_input:f64;
  cost_per_1k_output:f64;
  tier:$model_tier
}

pub m.$routing_decision{
  model:$model_spec;
  reason:str;
  tier:$model_tier;
  estimated_cost:f64;
  estimated_latency_ms:u32
}

pub m.$pipeline_result{
  original:str;
  anonymised:str;
  routing:$routing_decision;
  sensitivity:$sensitivity_level;
  request_id:str
}

pub m.$loke_err{
  $config_err(str);
  $model_err(str);
  $privacy_err(str);
  $storage_err(str);
  $network_err(str);
  $unknown_err(str)
}
