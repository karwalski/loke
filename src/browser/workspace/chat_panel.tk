// A1.3 — Chat interface / LLM interaction panel.
// Dockable chat panel with transparency bar and pre-send preview.

m=loke.browser.workspace.chat_panel;
i=str:std.string;
i=log:std.log;

pub m.$panel_state{
  visible:bool;
  docked:bool;
  dock_side:str;
  width_px:i32;
  history:@(str)
}

pub m.$transparency_bar{
  pii_count:i32;
  sensitivity:str;
  model_id:str;
  cost_usd:f32;
  visible:bool
}

pub m.$pre_send_preview{
  prompt_text:str;
  anonymised_text:str;
  entities:@(str);
  approved:bool
}

// default_state — returns the default panel configuration (hidden, docked right).
pub f=default_state():$panel_state{
  <$panel_state{
    visible:false;
    docked:true;
    dock_side:"right";
    width_px:400;
    history:@()
  }
}

// show — makes the panel visible.
pub f=show(s:$panel_state):$panel_state{
  <$panel_state{
    visible:true;
    docked:s.docked;
    dock_side:s.dock_side;
    width_px:s.width_px;
    history:s.history
  }
}

// hide — hides the panel.
pub f=hide(s:$panel_state):$panel_state{
  <$panel_state{
    visible:false;
    docked:s.docked;
    dock_side:s.dock_side;
    width_px:s.width_px;
    history:s.history
  }
}

// toggle — flips panel visibility.
pub f=toggle(s:$panel_state):$panel_state{
  if s.visible{
    <hide(s)
  }{
    <show(s)
  }
}

// set_dock — updates the dock side; accepted values: left, right, bottom.
pub f=set_dock(s:$panel_state;side:str):$panel_state{
  let valid=false;
  if side == "left"{
    valid=true
  }{};
  if side == "right"{
    valid=true
  }{};
  if side == "bottom"{
    valid=true
  }{};
  if valid{
    <$panel_state{
      visible:s.visible;
      docked:s.docked;
      dock_side:side;
      width_px:s.width_px;
      history:s.history
    }
  }{
    log.warn("chat_panel: unknown dock side " + side);
    <s
  }
}

// add_message — appends "role: content" to the panel history.
pub f=add_message(s:$panel_state;role:str;content:str):$panel_state{
  let updated:@(str)=@();
  s.history.each(h{
    updated.push(h)
  });
  updated.push(role + ": " + content);
  <$panel_state{
    visible:s.visible;
    docked:s.docked;
    dock_side:s.dock_side;
    width_px:s.width_px;
    history:updated
  }
}

// new_transparency_bar — constructs a transparency bar record (visible by default).
pub f=new_transparency_bar(pii_count:i32;sensitivity:str;model_id:str;cost_usd:f32):$transparency_bar{
  <$transparency_bar{
    pii_count:pii_count;
    sensitivity:sensitivity;
    model_id:model_id;
    cost_usd:cost_usd;
    visible:true
  }
}

// transparency_bar_html — renders the transparency bar as an HTML div.
// Returns an empty string when the bar is not visible.
pub f=transparency_bar_html(tb:$transparency_bar):str{
  if tb.visible{
    <"<div class=\"transparency-bar\">" +
      "<span class=\"sensitivity-badge\">" + tb.sensitivity + "</span>" +
      "<span class=\"pii-count\">" + str.from_i32(tb.pii_count) + " PII entities</span>" +
      "<span class=\"model-id\">" + tb.model_id + "</span>" +
      "<span class=\"cost-usd\">$" + str.from_f32(tb.cost_usd) + "</span>" +
    "</div>"
  }{
    <""
  }
}

// new_preview — constructs a pre-send preview record (not yet approved).
pub f=new_preview(prompt:str;anonymised:str;entities:@(str)):$pre_send_preview{
  <$pre_send_preview{
    prompt_text:prompt;
    anonymised_text:anonymised;
    entities:entities;
    approved:false
  }
}

// preview_html — renders a two-panel diff showing original vs anonymised text.
pub f=preview_html(p:$pre_send_preview):str{
  let entities_html="";
  p.entities.each(e{
    entities_html=entities_html + "<li>" + e + "</li>"
  });
  <"<div class=\"pre-send-preview\">" +
    "<div class=\"preview-original\">" +
      "<h4>Original</h4>" +
      "<pre>" + p.prompt_text + "</pre>" +
    "</div>" +
    "<div class=\"preview-anonymised\">" +
      "<h4>Anonymised</h4>" +
      "<pre>" + p.anonymised_text + "</pre>" +
    "</div>" +
    "<div class=\"preview-entities\">" +
      "<h4>Detected entities</h4>" +
      "<ul>" + entities_html + "</ul>" +
    "</div>" +
  "</div>"
}

// panel_css — returns the CSS for the chat panel components.
pub f=panel_css():str{
  <".chat-panel{" +
    "position:fixed;top:0;height:100%;background:var(--color-surface);" +
    "box-shadow:var(--shadow-lg);display:flex;flex-direction:column;z-index:100;" +
    "width:400px;transition:transform var(--transition-base);" +
  "}" +
  ".panel-header{" +
    "padding:var(--space-3) var(--space-4);border-bottom:1px solid var(--color-border);" +
    "display:flex;align-items:center;justify-content:space-between;flex-shrink:0;" +
  "}" +
  ".panel-messages{" +
    "flex:1;overflow-y:auto;padding:var(--space-4);display:flex;flex-direction:column;gap:var(--space-3);" +
  "}" +
  ".panel-input{" +
    "padding:var(--space-3) var(--space-4);border-top:1px solid var(--color-border);flex-shrink:0;" +
  "}" +
  ".transparency-bar{" +
    "display:flex;align-items:center;gap:var(--space-3);padding:var(--space-2) var(--space-4);" +
    "background:var(--color-surface-2);border-bottom:1px solid var(--color-border);" +
    "font-size:var(--text-xs);flex-shrink:0;" +
  "}" +
  ".sensitivity-badge{" +
    "padding:2px 6px;border-radius:var(--radius-sm);background:var(--color-info-subtle);color:var(--color-info);" +
  "}" +
  ".pii-count,.model-id,.cost-usd{color:var(--color-text-secondary);}"
}
