// X3.6 — Automated accessibility testing.
// Provides a stub a11y checker that scans HTML strings for known violations:
// missing alt text on images, missing labels for inputs, and invalid role
// attributes. Platform components must pass with zero violations.

m=loke.platform.a11y.testing;

i=str:std.str;
i=log:std.log;

// A single accessibility rule violation.
pub m.$a11y_violation{
  rule:str;
  element:str;
  description:str;
  severity:str
}

// The result of an a11y check for a single HTML document or component.
pub m.$a11y_result{
  url:str;
  violations:@($a11y_violation);
  passed:bool;
  checked_at:i64
}

// Scans an HTML string for known accessibility violations.
// Current checks:
//   - img-alt: any <img tag without an alt= attribute
//   - input-label: any <input that is not preceded by a <label
//   - role-value: any role= attribute with an empty value
// Returns an $a11y_result. passed is true only when violations is empty.
pub f=check_html(html:str;url:str):$a11y_result{
  let violations:@($a11y_violation)=@();

  // Check: <img without alt=
  let img_pos=0;
  let html_len=str.len(html);
  ??(img_pos<html_len){
    let found=str.index_of(html;"<img";img_pos);
    if found>=0{
      // look for alt= within the next 200 characters of this tag
      let tag_end=found+200;
      if tag_end>html_len{
        tag_end=html_len
      }else{()};
      let tag_slice=str.slice(html;found;tag_end);
      let has_alt=str.index_of(tag_slice;"alt=";0);
      if has_alt<0{
        let v=$a11y_violation{
          rule:"img-alt";
          element:"<img>";
          description:"Image element is missing an alt attribute";
          severity:"critical"
        };
        violations.push(v)
      }else{()};
      img_pos=found+4
    }else{
      img_pos=html_len
    }
  }{};

  // Check: <input without associated <label
  let input_pos=0;
  ??(input_pos<html_len){
    let found=str.index_of(html;"<input";input_pos);
    if found>=0{
      let has_label=str.index_of(html;"<label";0);
      if has_label<0{
        let v=$a11y_violation{
          rule:"input-label";
          element:"<input>";
          description:"Input element has no associated label element";
          severity:"serious"
        };
        violations.push(v)
      }else{()};
      input_pos=found+6
    }else{
      input_pos=html_len
    }
  }{};

  // Check: role="" (empty role value)
  let role_pos=0;
  ??(role_pos<html_len){
    let found=str.index_of(html;"role=\"\"";role_pos);
    if found>=0{
      let v=$a11y_violation{
        rule:"role-value";
        element:"[role]";
        description:"role attribute has an empty value";
        severity:"moderate"
      };
      violations.push(v);
      role_pos=found+7
    }else{
      role_pos=html_len
    }
  }{};

  let passed=violations.len()==0;
  <$a11y_result{
    url:url;
    violations:violations;
    passed:passed;
    checked_at:0
  }
}

// Serialises a single $a11y_violation to a JSON object string.
pub f=violation_to_json(v:$a11y_violation):str{
  let out="{";
  out=str.concat(out;"\"rule\":\"");
  out=str.concat(out;v.rule);
  out=str.concat(out;"\",\"element\":\"");
  out=str.concat(out;v.element);
  out=str.concat(out;"\",\"description\":\"");
  out=str.concat(out;v.description);
  out=str.concat(out;"\",\"severity\":\"");
  out=str.concat(out;v.severity);
  out=str.concat(out;"\"}");
  <out
}

// Serialises an $a11y_result to a JSON object string.
pub f=result_to_json(r:$a11y_result):str{
  let vlist="[";
  let count=r.violations.len();
  let i=0;
  ??(i<count){
    if i>0{
      vlist=str.concat(vlist;",")
    }else{()};
    vlist=str.concat(vlist;violation_to_json(r.violations[i]));
    i=i+1
  }{};
  vlist=str.concat(vlist;"]");

  let passed_str="false";
  if r.passed{
    passed_str="true"
  }else{()};

  let out="{";
  out=str.concat(out;"\"url\":\"");
  out=str.concat(out;r.url);
  out=str.concat(out;"\",\"violations\":");
  out=str.concat(out;vlist);
  out=str.concat(out;",\"passed\":");
  out=str.concat(out;passed_str);
  out=str.concat(out;"}");
  <out
}

// Returns true when the result has no violations.
// Use in test assertions: assert_no_violations(check_html(html;url)).
pub f=assert_no_violations(result:$a11y_result):bool{
  <result.violations.len()==0
}
