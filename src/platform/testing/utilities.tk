// X4.1 — Test utilities.
// Shared helpers for in-memory databases, test server instances, config
// generators, and HTTP request helpers. Reduces boilerplate in application
// and platform test files. Never imported by production code paths.

m=loke.platform.testing.utilities;

i=str:std.str;
i=log:std.log;

// Configuration for an isolated in-memory test database.
pub m.$test_db{
  path:str;
  in_memory:bool
}

// A test HTTP server instance (stub — not a real bound socket).
pub m.$test_server{
  port:i32;
  base_url:str
}

// Full configuration for a single test run.
pub m.$test_config{
  db:$test_db;
  server:$test_server;
  log_level:str
}

// Returns a $test_db configured for in-memory SQLite.
// Each test that calls this gets an isolated database; there is no shared state.
pub f=in_memory_db():$test_db{
  <$test_db{
    path:":memory:";
    in_memory:true
  }
}

// Returns a $test_server stub bound to the given port.
// base_url is set to http://127.0.0.1:<port>.
pub f=test_server(port:i32):$test_server{
  let base=str.concat("http://127.0.0.1:";str.from_int(port));
  <$test_server{
    port:port;
    base_url:base
  }
}

// Returns the default test configuration used when no custom config is needed.
// Uses an in-memory database, a test server on port 19430, and error-level logging
// so tests are quiet by default.
pub f=default_test_config():$test_config{
  <$test_config{
    db:in_memory_db();
    server:test_server(19430);
    log_level:"error"
  }
}

// Constructs and makes an HTTP request; returns the response body as a string.
// Stub implementation — logs the call and returns an empty JSON object.
// A real implementation would use ooke's native HTTP client binding.
pub f=make_request(base_url:str;method:str;path:str;body:str):str{
  let url=str.concat(base_url;path);
  let msg=str.concat("test.make_request: ";method);
  let msg2=str.concat(msg;" ");
  let msg3=str.concat(msg2;url);
  log.info(msg3);
  <"{}"
}

// Asserts that two strings are equal. Logs PASS or FAIL with the label.
// Use in test functions to report individual assertion outcomes.
pub f=assert_eq(a:str;b:str;label:str){
  if str.eq(a;b){
    let msg=str.concat("PASS [";str.concat(label;"]"));
    log.info(msg)
  }else{
    let msg=str.concat("FAIL [";label);
    let msg2=str.concat(msg;"]: expected=");
    let msg3=str.concat(msg2;b);
    let msg4=str.concat(msg3;" got=");
    let msg5=str.concat(msg4;a);
    log.error(msg5)
  }
}
