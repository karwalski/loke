// X4.2 — Quality gate script.
// Defines the ordered sequence of checks that must all pass before a release
// ships or a PR merges. Run via `ooke run quality-gate` or as a pre-push hook.
// Stops on the first required step that fails.

m=loke.platform.testing.quality_gate;

i=str:std.str;
i=log:std.log;

// A single step in the quality gate pipeline.
pub m.$gate_step{
  name:str;
  command:str;
  required:bool
}

// The result of running a single gate step.
pub m.$gate_result{
  step:str;
  ok:bool;
  output:str;
  duration_ms:i32
}

// Returns the default ordered gate steps.
// All steps are required — any failure stops the gate and blocks the release.
pub f=default_steps():@($gate_step){
  let steps:@($gate_step)=@();
  steps.push($gate_step{name:"lint";command:"ooke lint";required:true});
  steps.push($gate_step{name:"format-check";command:"ooke fmt --check";required:true});
  steps.push($gate_step{name:"dependency-audit";command:"ooke audit";required:true});
  steps.push($gate_step{name:"unit-tests";command:"ooke test";required:true});
  steps.push($gate_step{name:"integration-tests";command:"ooke test --integration";required:true});
  steps.push($gate_step{name:"a11y-tests";command:"ooke test --a11y";required:true});
  steps.push($gate_step{name:"build";command:"ooke build";required:true});
  <steps
}

// Runs a single gate step. Logs the step name and command.
// Stub: always returns ok=true with duration_ms=100.
// A real implementation would invoke the ooke subprocess binding and
// capture stdout/stderr.
pub f=run_step(step:$gate_step):$gate_result{
  let msg=str.concat("quality-gate: running ";step.name);
  let msg2=str.concat(msg;" (");
  let msg3=str.concat(msg2;step.command);
  let msg4=str.concat(msg3;")");
  log.info(msg4);
  <$gate_result{
    step:step.name;
    ok:true;
    output:"";
    duration_ms:100
  }
}

// Runs all default gate steps in order. Stops on the first required failure.
// Returns the results collected up to and including any stopping point.
pub f=run_all():@($gate_result){
  let steps=default_steps();
  let results:@($gate_result)=@();
  let count=steps.len();
  let i=0;
  let stopped=false;
  ??(i<count){
    if stopped==false{
      let step=steps[i];
      let result=run_step(step);
      results.push(result);
      if result.ok==false{
        if step.required{
          let msg=str.concat("quality-gate: required step failed — stopping: ";step.name);
          log.error(msg);
          stopped=true
        }else{()}
      }else{()}
    }else{()};
    i=i+1
  }{};
  <results
}

// Formats gate results as a plain-text table.
// Columns: step name / status (PASS or FAIL) / duration in ms.
pub f=format_results(results:@($gate_result)):str{
  let out="step                   status   duration_ms\n";
  out=str.concat(out;"----------------------------------------------\n");
  let count=results.len();
  let i=0;
  ??(i<count){
    let r=results[i];
    let status="PASS";
    if r.ok==false{
      status="FAIL"
    }else{()};
    let line=str.concat(r.step;"                       ");
    let line2=str.slice(line;0;23);
    let line3=str.concat(line2;status);
    let line4=str.concat(line3;"     ");
    let line5=str.concat(line4;str.from_int(r.duration_ms));
    let line6=str.concat(line5;" ms\n");
    out=str.concat(out;line6);
    i=i+1
  }{};
  <out
}

// Returns true when every result in the slice has ok=true.
pub f=all_passed(results:@($gate_result)):bool{
  let count=results.len();
  let i=0;
  ??(i<count){
    if results[i].ok==false{
      <false
    }else{()};
    i=i+1
  }{};
  <true
}
