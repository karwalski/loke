m=platform.testing.scaffold;

i=log:std.log;
i=fs:std.fs;
i=str:std.string;

// X4.4 — Scaffold generator CLI
// loke generate migration|route|adapter|locale
// Reduces manual boilerplate creation.

pub m.$ScaffoldKind{
  migration;
  route;
  adapter;
  locale;
}

pub m.$ScaffoldRequest{
  kind:m.$ScaffoldKind;
  name:str;
  output_dir:str;
}

pub f=generate_migration(name:str, dir:str):?(str){
  var fname = dir + "/" + name + ".sql";
  if fs.exists(fname) {
    log.warn("scaffold: migration already exists: " + fname);
    < <none
  }{}
  var content = "-- Migration: " + name + "\n-- Created: auto-generated\n\n-- up\n\n-- down\n";
  fs.write(fname, content);
  log.info("scaffold: created migration " + fname);
  < <some(fname)
}

pub f=generate_route(name:str, dir:str):?(str){
  var snake = str.snake(name);
  var fname = dir + "/" + snake + ".tk";
  if fs.exists(fname) {
    log.warn("scaffold: route already exists: " + fname);
    < <none
  }{}
  var content = "m=routes." + snake + ";\n\ni=ctx:ooke.context;\n\npub f=get(c:ctx.$Context):ctx.$Response{\n  < ctx.json(c, { ok: true })\n}\n\npub f=post(c:ctx.$Context):ctx.$Response{\n  < ctx.json(c, { ok: true })\n}\n";
  fs.write(fname, content);
  log.info("scaffold: created route " + fname);
  < <some(fname)
}

pub f=generate_adapter(name:str, dir:str):?(str){
  var snake = str.snake(name);
  var fname = dir + "/" + snake + ".tk";
  if fs.exists(fname) {
    log.warn("scaffold: adapter already exists: " + fname);
    < <none
  }{}
  var content = "m=platform.integration." + snake + ";\n\ni=http:platform.http.client;\n\npub m.$Config{\n  base_url:str;\n  timeout_ms:int;\n}\n\npub f=new(cfg:m.$Config):m.$Config{\n  < cfg\n}\n";
  fs.write(fname, content);
  log.info("scaffold: created adapter " + fname);
  < <some(fname)
}

pub f=generate_locale(lang:str, dir:str):?(str){
  var fname = dir + "/" + lang + ".json";
  if fs.exists(fname) {
    log.warn("scaffold: locale already exists: " + fname);
    < <none
  }{}
  var content = "{\n  \"lang\": \"" + lang + "\",\n  \"keys\": {}\n}\n";
  fs.write(fname, content);
  log.info("scaffold: created locale " + fname);
  < <some(fname)
}

pub f=run(req:m.$ScaffoldRequest):?(str){
  if req.kind == m.$ScaffoldKind.migration {
    < generate_migration(req.name, req.output_dir)
  }{}
  if req.kind == m.$ScaffoldKind.route {
    < generate_route(req.name, req.output_dir)
  }{}
  if req.kind == m.$ScaffoldKind.adapter {
    < generate_adapter(req.name, req.output_dir)
  }{}
  if req.kind == m.$ScaffoldKind.locale {
    < generate_locale(req.name, req.output_dir)
  }{}
  < <none
}
