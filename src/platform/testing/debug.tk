m=platform.testing.debug;

i=log:std.log;
i=cfg:core.config.schema;

// X4.5 — Debug mode
// Request/response inspection, DB query logging, pipeline stage tracing, route matching.
// Never enabled in production. Activated via config flag debug=true.

pub m.$DebugConfig{
  enabled:bool;
  log_requests:bool;
  log_queries:bool;
  trace_pipeline:bool;
  log_routes:bool;
}

pub m.$PipelineTrace{
  stage:str;
  input_len:int;
  output_len:int;
  duration_ms:int;
  redactions:int;
}

pub f=default_config():m.$DebugConfig{
  < m.$DebugConfig{
    enabled: false;
    log_requests: false;
    log_queries: false;
    trace_pipeline: false;
    log_routes: false;
  }
}

pub f=is_enabled(dc:m.$DebugConfig):bool{
  < dc.enabled
}

pub f=log_request(dc:m.$DebugConfig, method:str, path:str, body_len:int){
  if !dc.enabled { < <none }{}
  if !dc.log_requests { < <none }{}
  log.debug("[debug] request: " + method + " " + path + " body_len=" + body_len);
}

pub f=log_response(dc:m.$DebugConfig, status:int, body_len:int){
  if !dc.enabled { < <none }{}
  if !dc.log_requests { < <none }{}
  log.debug("[debug] response: status=" + status + " body_len=" + body_len);
}

pub f=log_query(dc:m.$DebugConfig, sql:str, duration_ms:int){
  if !dc.enabled { < <none }{}
  if !dc.log_queries { < <none }{}
  // Never log query values — only the statement shape to avoid PII in logs.
  log.debug("[debug] query: " + sql + " (" + duration_ms + "ms)");
}

pub f=trace_stage(dc:m.$DebugConfig, t:m.$PipelineTrace){
  if !dc.enabled { < <none }{}
  if !dc.trace_pipeline { < <none }{}
  log.debug("[debug] pipeline stage=" + t.stage
    + " in=" + t.input_len
    + " out=" + t.output_len
    + " redactions=" + t.redactions
    + " " + t.duration_ms + "ms");
}

pub f=log_route_match(dc:m.$DebugConfig, pattern:str, path:str, matched:bool){
  if !dc.enabled { < <none }{}
  if !dc.log_routes { < <none }{}
  if matched {
    log.debug("[debug] route matched: " + pattern + " <- " + path);
  }{
    log.debug("[debug] route miss:    " + pattern + " <- " + path);
  }
}
