// X4.3 — Watch mode for development.
// Configuration and event handling for the file-system watcher that drives
// hot-reload during development. The watcher is invoked by `ooke dev` and
// calls on_change() for each detected file-system event.

m=loke.platform.testing.watch;

i=str:std.str;
i=log:std.log;

// Configuration for the file-system watcher.
pub m.$watch_config{
  dirs:@(str);
  extensions:@(str);
  restart_command:str;
  reload_clients:bool
}

// A single file-system change event.
pub m.$watch_event{
  path:str;
  kind:str;
  ts:i64
}

// Returns the default watch configuration.
// Watches src/, packages/, and templates/ for .tk, .tkt, and .toml changes.
// On any change: restarts via `ooke dev` and signals connected browser clients
// to reload.
pub f=default_config():$watch_config{
  let dirs:@(str)=@();
  dirs.push("src");
  dirs.push("packages");
  dirs.push("templates");

  let exts:@(str)=@();
  exts.push(".tk");
  exts.push(".tkt");
  exts.push(".toml");

  <$watch_config{
    dirs:dirs;
    extensions:exts;
    restart_command:"ooke dev";
    reload_clients:true
  }
}

// Handles a single file-system change event.
// Logs the event kind and path, then returns the restart command to execute.
// The caller (ooke dev runtime) is responsible for actually running the command
// and signalling connected clients.
pub f=on_change(event:$watch_event):str{
  let msg=str.concat("watch: ";event.kind);
  let msg2=str.concat(msg;" → ");
  let msg3=str.concat(msg2;event.path);
  let msg4=str.concat(msg3;" — restarting");
  log.info(msg4);
  let cfg=default_config();
  <cfg.restart_command
}

// Returns the debounce window in milliseconds.
// Multiple file-system events within this window are collapsed into a single
// restart to avoid thrashing during bulk edits (e.g. a git checkout or
// formatter run).
pub f=debounce_ms():i32{
  <200
}
