// F1.7 — /api/health route handler.
// Builds a health report and returns it as JSON.

m=loke.core.health.api;
i=health:loke.core.health.checker;
i=http:std.http;

// get — handles GET /api/health.
// Runs a stub Ollama check and builds the report with built-in probes.
pub f=get(req:http.$req):http.$res{
  // Stub: run the two built-in probes at healthy/0ms
  let db_probe=health.run_probe("Database";"healthy";"ok";0);
  let settings_probe=health.run_probe("Settings";"healthy";"ok";0);
  let probes=@(db_probe;settings_probe);

  // Stub Ollama status
  let ollama_status="running";

  let report=health.build_report("0.1.0";ollama_status;probes);
  <http.res.json(200;health.report_to_json(report))
}
