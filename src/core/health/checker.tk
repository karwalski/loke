// F1.7 — Health check system.
// Subsystem health probes with a global probe registry.
// Built-in probes (database, settings) are registered at module init.

m=loke.core.health.checker;
i=log:std.log;

pub m.$health_status{
  $healthy;
  $degraded;
  $unhealthy
}

pub m.$probe_result{
  name:str;
  status:str;
  message:str;
  latency_ms:i32
}

pub m.$health_report{
  ok:bool;
  status:str;
  version:str;
  ollama:str;
  probes:@($probe_result);
  ts:i64
}

pub m.$probe_entry{
  id:str;
  name:str;
  probe_key:str
}

// Global probe registry — populated at module init and by callers.
let g_probes:@($probe_entry)=@();

pub f=register_probe(id:str;name:str;probe_key:str){
  g_probes.push($probe_entry{ id:id; name:name; probe_key:probe_key })
}

pub f=run_probe(name:str;status:str;message:str;latency_ms:i32):$probe_result{
  <$probe_result{
    name:name;
    status:status;
    message:message;
    latency_ms:latency_ms
  }
}

// aggregate_status — derives overall status from a list of probe results.
// "unhealthy" takes priority over "degraded"; all healthy → "healthy".
pub f=aggregate_status(probes:@($probe_result)):str{
  let has_unhealthy=false;
  let has_degraded=false;
  probes.each(p{
    if p.status == "unhealthy"{
      has_unhealthy=true
    }{
      if p.status == "degraded"{
        has_degraded=true
      }{}
    }
  });
  if has_unhealthy{
    <"unhealthy"
  }{
    if has_degraded{
      <"degraded"
    }{
      <"healthy"
    }
  }
}

pub f=build_report(version:str;ollama_status:str;probes:@($probe_result)):$health_report{
  let status=aggregate_status(probes);
  let all_ok=status == "healthy";
  <$health_report{
    ok:all_ok;
    status:status;
    version:version;
    ollama:ollama_status;
    probes:probes;
    ts:0
  }
}

// report_to_json — serialises a health report to the /api/health JSON shape.
pub f=report_to_json(r:$health_report):str{
  let ok_str=if r.ok{ "true" }{ "false" };
  let probes_json="[";
  let first=true;
  r.probes.each(p{
    if first{
      first=false
    }{
      probes_json=probes_json + ","
    };
    probes_json=probes_json +
      "{\"name\":\"" + p.name + "\"" +
      ",\"status\":\"" + p.status + "\"" +
      ",\"message\":\"" + p.message + "\"" +
      ",\"latency_ms\":" + p.latency_ms +
      "}"
  });
  probes_json=probes_json + "]";
  <"{" +
    "\"ok\":" + ok_str +
    ",\"version\":\"" + r.version + "\"" +
    ",\"ollama\":\"" + r.ollama + "\"" +
    ",\"probes\":" + probes_json +
  "}"
}

// Module init — register built-in stubs for database and settings probes.
register_probe("database";"Database";"builtin.database");
register_probe("settings";"Settings";"builtin.settings");
