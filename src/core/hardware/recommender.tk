// F2.8 â€” Hardware-aware model recommendations: per-model viability assessment.
// Evaluates a curated model list against the detected hardware profile and
// assigns tier badges (interactive / considered / background / not_recommended).

m=loke.core.hardware.recommender;
i=str:std.string;
i=log:std.log;
i=hw:loke.core.hardware.profile;

// Tier badge for a model on the current hardware.
pub m.$tier_badge{
  $interactive;
  $considered;
  $background;
  $not_recommended
}

// A single model recommendation with tier, badge, and reasoning.
pub m.$model_recommendation{
  model_id:str;
  name:str;
  params_b:f32;
  quant:str;
  tier:str;
  badge:str;
  reasoning:str;
  disk_space_gb:i32;
  ok:bool
}

// tier_for_model â€” determines the inference tier for a model given the hardware.
// Uses estimated VRAM (Q4: params_b * 0.6 GB, FP16: params_b * 1.0 GB) vs
// total available memory. NVMe enables background-tier large-model streaming.
pub f=tier_for_model(params_b:f32;quant:str;p:hw.$hardware_profile):str{
  total:i32=hw.total_memory_gb(p);
  total_f:f32=str.to_float(str.from_i32(total));
  estimated_vram_gb:f32=0.0;
  if quant == "fp16"{
    estimated_vram_gb=params_b * 1.0
  }{
    estimated_vram_gb=params_b * 0.6
  };
  ceiling_interactive:f32=total_f * 0.8;
  ceiling_considered:f32=total_f * 1.5;
  if estimated_vram_gb <= ceiling_interactive{
    <"interactive"
  }{
    if estimated_vram_gb <= ceiling_considered{
      <"considered"
    }{
      if p.disk_type == "nvme"{
        <"background"
      }{
        <"not_recommended"
      }
    }
  }
}

// recommend â€” returns a curated list of model recommendations for the hardware.
pub f=recommend(p:hw.$hardware_profile):@($model_recommendation){
  result:@($model_recommendation)=[];
  total:i32=hw.total_memory_gb(p);

  // qwen2.5:0.5b â€” 0.5B Q4, interactive on any hardware
  tier0:str=tier_for_model(0.5;p.disk_type;p);
  r0:$model_recommendation=$model_recommendation{
    model_id:"qwen2.5:0.5b";
    name:"Qwen 2.5 0.5B";
    params_b:0.5;
    quant:"q4";
    tier:tier0;
    badge:tier0;
    reasoning:"0.5B Q4 fits easily in any device memory; ideal for fast completions and low-latency tasks";
    disk_space_gb:1;
    ok:true
  };
  result.push(r0);

  // llama3.2:3b â€” 3B Q4, interactive on 8 GB+, considered on 4 GB
  tier1:str="";
  reasoning1:str="";
  if total >= 8{
    tier1="interactive";
    reasoning1="3B Q4 (~1.8 GB) fits comfortably in " + str.from_i32(total) + " GB; good everyday model"
  }{
    tier1="considered";
    reasoning1="3B Q4 (~1.8 GB) is tight on " + str.from_i32(total) + " GB; may compete with OS memory"
  };
  r1:$model_recommendation=$model_recommendation{
    model_id:"llama3.2:3b";
    name:"Llama 3.2 3B";
    params_b:3.0;
    quant:"q4";
    tier:tier1;
    badge:tier1;
    reasoning:reasoning1;
    disk_space_gb:2;
    ok:true
  };
  result.push(r1);

  // llama3.1:8b â€” 8B Q4, interactive on 16 GB+, considered on 8 GB
  tier2:str="";
  reasoning2:str="";
  if total >= 16{
    tier2="interactive";
    reasoning2="8B Q4 (~4.8 GB) fits well in " + str.from_i32(total) + " GB; strong general-purpose model"
  }{
    if total >= 8{
      tier2="considered";
      reasoning2="8B Q4 (~4.8 GB) is feasible on " + str.from_i32(total) + " GB but leaves limited headroom"
    }{
      tier2=tier_for_model(8.0;"q4";p);
      reasoning2="8B Q4 (~4.8 GB) exceeds available memory (" + str.from_i32(total) + " GB)"
    }
  };
  r2:$model_recommendation=$model_recommendation{
    model_id:"llama3.1:8b";
    name:"Llama 3.1 8B";
    params_b:8.0;
    quant:"q4";
    tier:tier2;
    badge:tier2;
    reasoning:reasoning2;
    disk_space_gb:5;
    ok:true
  };
  result.push(r2);

  // mistral:7b â€” 7B Q4, interactive on 16 GB+, considered on 8 GB
  tier3:str="";
  reasoning3:str="";
  if total >= 16{
    tier3="interactive";
    reasoning3="7B Q4 (~4.2 GB) runs well in " + str.from_i32(total) + " GB; efficient instruction-following model"
  }{
    if total >= 8{
      tier3="considered";
      reasoning3="7B Q4 (~4.2 GB) is usable on " + str.from_i32(total) + " GB with moderate overhead"
    }{
      tier3=tier_for_model(7.0;"q4";p);
      reasoning3="7B Q4 (~4.2 GB) exceeds available memory (" + str.from_i32(total) + " GB)"
    }
  };
  r3:$model_recommendation=$model_recommendation{
    model_id:"mistral:7b";
    name:"Mistral 7B";
    params_b:7.0;
    quant:"q4";
    tier:tier3;
    badge:tier3;
    reasoning:reasoning3;
    disk_space_gb:4;
    ok:true
  };
  result.push(r3);

  // qwen2.5:14b â€” 14B Q4, considered on 16 GB+, background on 8 GB
  tier4:str="";
  reasoning4:str="";
  if total >= 16{
    tier4="considered";
    reasoning4="14B Q4 (~8.4 GB) is feasible on " + str.from_i32(total) + " GB; expect some swapping under load"
  }{
    if p.disk_type == "nvme"{
      tier4="background";
      reasoning4="14B Q4 (~8.4 GB) exceeds " + str.from_i32(total) + " GB RAM; disk-streaming via NVMe required"
    }{
      tier4="not_recommended";
      reasoning4="14B Q4 (~8.4 GB) exceeds " + str.from_i32(total) + " GB RAM and no NVMe available for streaming"
    }
  };
  r4:$model_recommendation=$model_recommendation{
    model_id:"qwen2.5:14b";
    name:"Qwen 2.5 14B";
    params_b:14.0;
    quant:"q4";
    tier:tier4;
    badge:tier4;
    reasoning:reasoning4;
    disk_space_gb:9;
    ok:true
  };
  result.push(r4);

  // llama3.1:70b â€” 70B Q4, background on 32 GB NVMe, not_recommended otherwise
  tier5:str="";
  reasoning5:str="";
  if total >= 32{
    if p.disk_type == "nvme"{
      tier5="background";
      reasoning5="70B Q4 (~42 GB) requires disk-streaming on " + str.from_i32(total) + " GB; NVMe present â€” slow but viable"
    }{
      tier5="not_recommended";
      reasoning5="70B Q4 (~42 GB) requires NVMe for disk-streaming; current disk type is too slow"
    }
  }{
    tier5="not_recommended";
    reasoning5="70B Q4 (~42 GB) requires at least 32 GB RAM with NVMe disk-streaming"
  };
  r5:$model_recommendation=$model_recommendation{
    model_id:"llama3.1:70b";
    name:"Llama 3.1 70B";
    params_b:70.0;
    quant:"q4";
    tier:tier5;
    badge:tier5;
    reasoning:reasoning5;
    disk_space_gb:42;
    ok:true
  };
  result.push(r5);

  // qwen2.5:72b â€” 72B Q4, background on 64 GB NVMe
  tier6:str="";
  reasoning6:str="";
  if total >= 64{
    if p.disk_type == "nvme"{
      tier6="background";
      reasoning6="72B Q4 (~43 GB) is viable via disk-streaming on " + str.from_i32(total) + " GB NVMe system"
    }{
      tier6="not_recommended";
      reasoning6="72B Q4 (~43 GB) requires NVMe for disk-streaming; current disk type is too slow"
    }
  }{
    tier6="not_recommended";
    reasoning6="72B Q4 (~43 GB) requires at least 64 GB RAM with NVMe disk-streaming"
  };
  r6:$model_recommendation=$model_recommendation{
    model_id:"qwen2.5:72b";
    name:"Qwen 2.5 72B";
    params_b:72.0;
    quant:"q4";
    tier:tier6;
    badge:tier6;
    reasoning:reasoning6;
    disk_space_gb:43;
    ok:true
  };
  result.push(r6);

  <result
}

// disk_warning â€” returns a warning if disk streaming is suggested but NVMe is absent.
pub f=disk_warning(p:hw.$hardware_profile):?(str){
  if p.disk_type == "nvme"{
    <none
  }{
    recs:@($model_recommendation)=recommend(p);
    has_background:bool=false;
    recs.each(r{
      if r.tier == "background"{
        has_background=true
      }{}
    });
    if has_background{
      <some("Warning: disk streaming requires NVMe â€” current disk type may be too slow")
    }{
      <none
    }
  }
}

// to_json â€” serialises a single model recommendation to JSON.
pub f=to_json(r:$model_recommendation):str{
  ok_str:str="false";
  if r.ok{
    ok_str="true"
  }{};
  <"{" +
    "\"model_id\":\"" + r.model_id + "\"" +
    ",\"name\":\"" + r.name + "\"" +
    ",\"params_b\":" + str.from_f32(r.params_b) +
    ",\"quant\":\"" + r.quant + "\"" +
    ",\"tier\":\"" + r.tier + "\"" +
    ",\"badge\":\"" + r.badge + "\"" +
    ",\"reasoning\":\"" + r.reasoning + "\"" +
    ",\"disk_space_gb\":" + str.from_i32(r.disk_space_gb) +
    ",\"ok\":" + ok_str +
  "}"
}

// list_to_json â€” serialises a list of recommendations to a JSON array.
pub f=list_to_json(recs:@($model_recommendation)):str{
  out:str="[";
  idx:i32=0;
  recs.each(r{
    if idx > 0{
      out=out + ","
    }{};
    out=out + to_json(r);
    idx=idx + 1
  });
  <out + "]"
}
