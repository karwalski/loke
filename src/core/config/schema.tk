// F1.5 — Configuration schema and validation.
// Hierarchical config via ooke.toml + environment overrides, with schema validation.

m=loke.core.config.schema;
i=log:std.log;

pub m.$loke_config{
  port:i32;
  data_dir:str;
  log_level:str;
  ollama_url:str;
  presidio_url:str;
  llmlingua_url:str;
  default_provider:str;
  privacy_mode:str;
  max_tokens_per_day:i32
}

pub m.$config_source{
  $defaults;
  $file;
  $env;
  $override
}

pub f=defaults():$loke_config{
  <$loke_config{
    port:11430;
    data_dir:"~/.loke";
    log_level:"info";
    ollama_url:"http://127.0.0.1:11434";
    presidio_url:"http://127.0.0.1:5000";
    llmlingua_url:"http://127.0.0.1:5001";
    default_provider:"ollama";
    privacy_mode:"standard";
    max_tokens_per_day:100000
  }
}

// validate — checks required invariants on a config value.
// Returns true if valid; logs the first violation encountered.
pub f=validate(cfg:$loke_config):bool{
  if cfg.port > 0{
    if cfg.data_dir == ""{
      log.warn("config validation failed: data_dir must not be empty");
      <false
    }{
      let valid_levels=@("debug";"info";"warn";"error");
      let level_ok=false;
      valid_levels.each(l{
        if l == cfg.log_level{
          level_ok=true
        }{}
      });
      if level_ok{
        <true
      }{
        log.warn("config validation failed: log_level must be debug, info, warn, or error");
        <false
      }
    }
  }{
    log.warn("config validation failed: port must be greater than 0");
    <false
  }
}

pub f=to_json(cfg:$loke_config):str{
  <"{" +
    "\"port\":" + cfg.port +
    ",\"data_dir\":\"" + cfg.data_dir + "\"" +
    ",\"log_level\":\"" + cfg.log_level + "\"" +
    ",\"ollama_url\":\"" + cfg.ollama_url + "\"" +
    ",\"presidio_url\":\"" + cfg.presidio_url + "\"" +
    ",\"llmlingua_url\":\"" + cfg.llmlingua_url + "\"" +
    ",\"default_provider\":\"" + cfg.default_provider + "\"" +
    ",\"privacy_mode\":\"" + cfg.privacy_mode + "\"" +
    ",\"max_tokens_per_day\":" + cfg.max_tokens_per_day +
  "}"
}
