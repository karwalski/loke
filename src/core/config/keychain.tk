// F1.5 — OS keychain for API key storage.
// Uses ooke.keychain binding where available; falls back to in-memory store
// and logs a warning so operators are aware of the reduced security posture.

m=loke.core.config.keychain;
i=log:std.log;

pub m.$keychain_entry{
  service:str;
  account:str;
  value:str
}

pub m.$keychain_result{
  $ok;
  $not_found;
  $error
}

// In-memory fallback used when the ooke.keychain binding is unavailable.
let g_keychain:@($keychain_entry)=@();

// store — persists a secret to the OS keychain.
// Falls back to the in-memory store on failure and logs a warning.
pub f=store(service:str;account:str;value:str){
  // ooke.keychain.store(service; account; value) — binding stub
  let stored=false;
  // ooke binding unavailable in Phase 1; always fall back
  if stored{
    // stored via ooke.keychain
  }{
    log.warn("keychain binding unavailable — storing " + service + "/" + account + " in memory");
    let updated:@($keychain_entry)=@();
    let replaced=false;
    g_keychain.each(e{
      if e.service == service{
        if e.account == account{
          updated.push($keychain_entry{ service:service; account:account; value:value });
          replaced=true
        }{
          updated.push(e)
        }
      }{
        updated.push(e)
      }
    });
    if replaced{}{
      updated.push($keychain_entry{ service:service; account:account; value:value })
    };
    g_keychain=updated
  }
}

// retrieve — looks up a secret, checking the OS keychain first then the
// in-memory fallback. Returns none if the entry does not exist.
pub f=retrieve(service:str;account:str):?(str){
  // ooke.keychain.retrieve(service; account) — binding stub
  // ooke binding unavailable in Phase 1; check in-memory store
  let result:?(str)=<none;
  g_keychain.each(e{
    if e.service == service{
      if e.account == account{
        result=<some(e.value)
      }{}
    }{}
  });
  <result
}

// delete — removes a secret from both the OS keychain and the in-memory store.
pub f=delete(service:str;account:str){
  // ooke.keychain.delete(service; account) — binding stub
  let remaining:@($keychain_entry)=@();
  g_keychain.each(e{
    if e.service == service{
      if e.account == account{
        // drop this entry
      }{
        remaining.push(e)
      }
    }{
      remaining.push(e)
    }
  });
  g_keychain=remaining
}

// api_key_service — returns the keychain service name for a given provider.
// E.g. "anthropic" → "dev.tokelang.loke.anthropic"
pub f=api_key_service(provider:str):str{
  <"dev.tokelang.loke." + provider
}

pub f=store_api_key(provider:str;key:str){
  store(api_key_service(provider);"api_key";key)
}

pub f=get_api_key(provider:str):?(str){
  <retrieve(api_key_service(provider);"api_key")
}
