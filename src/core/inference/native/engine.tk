// F2.4 — Native in-process inference engine.
// Wraps ooke native llama.cpp bindings for low-latency local inference without
// spawning a separate Ollama process.  All binding calls are stubbed in Phase 1
// (ooke.llama.* not yet wired) and return safe sentinel values so the rest of
// the inference stack can be built and tested against this interface.

m=loke.core.inference.native.engine;

i=str:std.str;
i=log:std.log;
i=json:std.json;

// Configuration for loading a model into the native engine.
pub m.$native_config{
  model_path:str;
  n_threads:i32;
  n_gpu_layers:i32;
  context_len:i32;
  seed:i32
}

// Per-request generation options.
pub m.$generate_opts{
  temperature:f32;
  top_p:f32;
  max_tokens:i32;
  stop_sequences:@(str)
}

// Result returned from a native generate call.
pub m.$generate_result{
  text:str;
  tokens_in:i32;
  tokens_out:i32;
  tok_per_sec:f32;
  stopped_by:str
}

// Returns a $native_config with sensible defaults.
// n_gpu_layers=99 requests full GPU offload (llama.cpp convention for "all layers").
pub f=default_config(model_path:str):$native_config{
  <$native_config{
    model_path:model_path;
    n_threads:4;
    n_gpu_layers:99;
    context_len:4096;
    seed:42
  }
}

// Returns default generation options.
// temperature=0.7, top_p=0.95, max_tokens=2048, no stop sequences.
pub f=default_opts():$generate_opts{
  <$generate_opts{
    temperature:0.7;
    top_p:0.95;
    max_tokens:2048;
    stop_sequences:@()
  }
}

// Returns true when a model is currently loaded into the native engine.
// Stub: always returns false until ooke.llama.is_loaded binding is wired.
pub f=is_loaded():bool{
  log.info("native engine load check";"core.inference.native.engine";"system");
  <false
}

// Loads the model at cfg.model_path into the native engine.
// Stub: logs the intent and returns false (ooke.llama.load not yet wired).
pub f=load(cfg:$native_config):bool{
  log.info(
    str.concat("loading model: ";str.concat(cfg.model_path;" (ooke native binding)"));
    "core.inference.native.engine";
    "system"
  );
  // Real implementation: ooke.llama.load(cfg)
  <false
}

// Generates text for the given prompt with the loaded model.
// Returns a sentinel result when no model is loaded.
// Stub: real implementation calls ooke.llama.generate(prompt; opts).
pub f=generate(prompt:str;opts:$generate_opts):$generate_result{
  if is_loaded(){
    // ooke.llama.generate binding — not yet wired in Phase 1
    <$generate_result{
      text:"";
      tokens_in:0;
      tokens_out:0;
      tok_per_sec:0.0;
      stopped_by:"eos"
    }
  }{
    <$generate_result{
      text:"[native inference not yet bound]";
      tokens_in:0;
      tokens_out:0;
      tok_per_sec:0.0;
      stopped_by:"not_loaded"
    }
  }
}

// Unloads the currently loaded model and frees native resources.
// Stub: logs the intent (ooke.llama.unload not yet wired).
pub f=unload():void{
  log.info("unloading model";"core.inference.native.engine";"system")
}

// Serialises a $generate_result to a JSON string.
pub f=to_json(r:$generate_result):str{
  let tokens_in_str=str.from_i32(r.tokens_in);
  let tokens_out_str=str.from_i32(r.tokens_out);
  let tps_str=str.from_f32(r.tok_per_sec);
  <str.concat("{\"text\":";
    str.concat(json.enc_str(r.text);
    str.concat(",\"tokens_in\":";
    str.concat(tokens_in_str;
    str.concat(",\"tokens_out\":";
    str.concat(tokens_out_str;
    str.concat(",\"tok_per_sec\":";
    str.concat(tps_str;
    str.concat(",\"stopped_by\":";
    str.concat(json.enc_str(r.stopped_by);
    "}")))))))))))
}
