// F2.4 (selector) — Inference path selector.
// Picks the best inference backend for a given model and latency tier:
//   interactive  → Ollama REST  (lowest latency, always responsive)
//   considered   → MLX          (Apple Silicon optimised; fallback Ollama)
//   background   → native       (llama.cpp in-process for maximum throughput)
// Falls back to Ollama when the preferred backend is unavailable.

m=loke.core.inference.native.selector;

i=str:std.str;
i=log:std.log;

// The set of available inference paths.
pub m.$inference_path{
  $ollama;
  $mlx;
  $native;
  $cloud
}

// Stubs — replaced by real availability checks once ooke bindings are wired.
f=mlx_check():bool{
  <false
}

// Selects the best inference path for the given model and latency tier.
// Tier values: "interactive", "considered", "background".
// Returns a path label string: "ollama" / "mlx" / "native" / "cloud".
// Logs the selection for observability.
pub f=select(model_id:str;tier:str):str{
  let path="ollama";
  if str.eq(tier;"interactive"){
    // Ollama is fastest for interactive use — it keeps models warm in memory
    let path="ollama"
  }{
    if str.eq(tier;"considered"){
      // MLX preferred on Apple Silicon; fall back to Ollama when unavailable
      if mlx_check(){
        let path="mlx"
      }{
        let path="ollama"
      }
    }{
      if str.eq(tier;"background"){
        // Native llama.cpp for background throughput
        let path="native"
      }{
        // Unknown tier — safe fallback
        let path="ollama"
      }
    }
  };
  log.info(
    str.concat("inference path selected: ";
      str.concat(path;str.concat(" (model=";str.concat(model_id;str.concat(" tier=";str.concat(tier;")"))))));
    "core.inference.native.selector";
    "system"
  );
  <path
}

// Returns a human-readable label for a path string.
pub f=path_label(path:str):str{
  if str.eq(path;"ollama"){
    <"Ollama REST"
  }{
    if str.eq(path;"mlx"){
      <"MLX (Apple Silicon)"
    }{
      if str.eq(path;"native"){
        <"Native llama.cpp"
      }{
        <"Cloud API"
      }
    }
  }
}
