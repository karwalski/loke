// M1.6 — Agent memory / diaries.
// Each agent gets a dedicated palace wing. Structured diary entries are stored
// after each run, loaded as context on startup, and searchable per agent.
// Older entries are auto-compressed to AAAK closets.

m=loke.memory.agent_diary;

i=str:std.string;
i=log:std.log;
i=json:std.json;

pub m.$diary_entry{
  id:str;
  agent_id:str;
  run_id:str;
  summary:str;
  result:str;
  tokens_used:i32;
  cost_usd:f32;
  duration_ms:i32;
  feedback_received:str;
  ts:i64
}

pub m.$diary{
  agent_id:str;
  wing:str;
  entries:@($diary_entry)
}

// Global store: one diary per agent.
let g_diaries:@($diary)=@();

// Finds or creates the diary for the given agent_id.
// Logs on creation.
pub f=get_or_create_diary(agent_id:str):$diary{
  let found=false;
  let result=$diary{agent_id:agent_id;wing:str.concat("agents.";agent_id);entries:@()};
  g_diaries.each(d{
    if str.eq(d.agent_id;agent_id){
      let result=d;
      let found=true
    }
  });
  if !found{
    log.info(str.concat("diary: created for ";agent_id));
    let g_diaries=g_diaries.push(result)
  };
  <result
}

// Appends a diary entry for the given agent. Replaces the diary in g_diaries.
pub f=append_entry(agent_id:str;entry:$diary_entry){
  let diary=get_or_create_diary(agent_id);
  let updated=$diary{
    agent_id:diary.agent_id;
    wing:diary.wing;
    entries:diary.entries.push(entry)
  };
  let new_diaries=@();
  g_diaries.each(d{
    if str.eq(d.agent_id;agent_id){
      let new_diaries=new_diaries.push(updated)
    }{
      let new_diaries=new_diaries.push(d)
    }
  });
  let g_diaries=new_diaries;
  log.info(str.concat("diary: entry for ";str.concat(agent_id;str.concat(" run=";entry.run_id))))
}

// Returns all diary entries for the agent, most recent first.
pub f=get_entries(agent_id:str):@($diary_entry){
  let diary=get_or_create_diary(agent_id);
  // Reverse the entries array for most-recent-first ordering.
  let reversed=@();
  let i=diary.entries.len() - 1;
  ??(i >= 0){
    let reversed=reversed.push(diary.entries[i]);
    let i=i - 1
  }{};
  <reversed
}

// Returns the last n diary entries for the agent (most recent first).
pub f=get_recent(agent_id:str;n:i32):@($diary_entry){
  let all=get_entries(agent_id);
  let result=@();
  let count=0;
  all.each(e{
    if count < n{
      let result=result.push(e);
      let count=count + 1
    }
  });
  <result
}

// Builds an AAAK-style startup context string from the last max_entries diary entries.
pub f=build_startup_context(agent_id:str;max_entries:i32):str{
  let recent=get_recent(agent_id;max_entries);
  let header=str.concat("AGENT:";str.concat(agent_id;" DIARY_SUMMARY:\n"));
  let body="";
  recent.each(e{
    let line=str.concat("RUN:";str.concat(e.run_id;str.concat(" RESULT:";str.concat(e.result;str.concat(" TOKENS:";str.concat(str.from_i32(e.tokens_used);"\n"))))));
    let body=str.concat(body;line)
  });
  <str.concat(header;body)
}

// Stub: logs that old entries would be compressed. AAAK compression is pending.
pub f=compress_old_entries(agent_id:str;keep_recent:i32){
  log.info(str.concat("diary: compressing entries older than ";str.concat(str.from_i32(keep_recent);" recent (AAAK compression pending)")))
}

// Updates the feedback_received field on the matching run entry.
pub f=record_feedback(agent_id:str;run_id:str;feedback:str){
  let diary=get_or_create_diary(agent_id);
  let updated_entries=@();
  diary.entries.each(e{
    if str.eq(e.run_id;run_id){
      let updated=$diary_entry{
        id:e.id;
        agent_id:e.agent_id;
        run_id:e.run_id;
        summary:e.summary;
        result:e.result;
        tokens_used:e.tokens_used;
        cost_usd:e.cost_usd;
        duration_ms:e.duration_ms;
        feedback_received:feedback;
        ts:e.ts
      };
      let updated_entries=updated_entries.push(updated)
    }{
      let updated_entries=updated_entries.push(e)
    }
  });
  let updated_diary=$diary{
    agent_id:diary.agent_id;
    wing:diary.wing;
    entries:updated_entries
  };
  let new_diaries=@();
  g_diaries.each(d{
    if str.eq(d.agent_id;agent_id){
      let new_diaries=new_diaries.push(updated_diary)
    }{
      let new_diaries=new_diaries.push(d)
    }
  });
  let g_diaries=new_diaries;
  log.info(str.concat("diary: feedback recorded for ";str.concat(agent_id;str.concat(" run=";run_id))))
}

// Serialises a $diary_entry to a JSON string.
pub f=entry_to_json(e:$diary_entry):str{
  <str.concat("{\"id\":\"";str.concat(e.id;str.concat("\",\"agent_id\":\"";str.concat(e.agent_id;str.concat("\",\"run_id\":\"";str.concat(e.run_id;str.concat("\",\"summary\":\"";str.concat(e.summary;str.concat("\",\"result\":\"";str.concat(e.result;str.concat("\",\"tokens_used\":";str.concat(str.from_i32(e.tokens_used);str.concat(",\"cost_usd\":";str.concat(str.from_f32(e.cost_usd);str.concat(",\"duration_ms\":";str.concat(str.from_i32(e.duration_ms);str.concat(",\"feedback_received\":\"";str.concat(e.feedback_received;str.concat("\",\"ts\":";str.concat(str.from_i64(e.ts);"}")))))))))))))))))))
}

// Returns a compact AAAK one-liner for the diary entry.
pub f=to_aaak(e:$diary_entry):str{
  <str.concat("RUN:";str.concat(e.run_id;str.concat(" ";str.concat(e.summary;str.concat(" RESULT:";str.concat(e.result;str.concat(" TOK:";str.concat(str.from_i32(e.tokens_used);str.concat(" COST:$";str.from_f32(e.cost_usd))))))))))
}
