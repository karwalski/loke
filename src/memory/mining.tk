// M2.4 — Memory mining from external sources.
// Import memories from Claude exports, ChatGPT exports, Slack JSON, markdown files,
// and code repos. Mining modes: projects / conversations / general.
// Privacy pipeline scan on all imported content before storage.

m=loke.memory.mining;

i=str:std.string;
i=log:std.log;
i=json:std.json;

pub m.$mining_mode{
  $projects;
  $conversations;
  $general
}

pub m.$mining_source{
  $claude_export;
  $chatgpt_export;
  $slack_json;
  $markdown;
  $code_repo
}

pub m.$mining_job{
  id:str;
  source_path:str;
  source_type:str;
  mode:str;
  status:str;
  items_found:i32;
  items_stored:i32;
  started_at:i64;
  completed_at:i64;
  error:str
}

pub m.$mined_item{
  content:str;
  source:str;
  ts:i64;
  wing:str;
  tags:@(str)
}

// Global job registry.
let g_jobs:@($mining_job)=@();

// Creates a new pending mining job with a UUID id.
pub f=new_job(source_path:str;source_type:str;mode:str):$mining_job{
  <$mining_job{
    id:str.uuid();
    source_path:source_path;
    source_type:source_type;
    mode:mode;
    status:"pending";
    items_found:0;
    items_stored:0;
    started_at:0;
    completed_at:0;
    error:""
  }
}

// Marks a job as running and records the start timestamp.
pub f=start(job:$mining_job):$mining_job{
  log.info(str.concat("mining: starting ";str.concat(job.source_type;str.concat(" from ";job.source_path))));
  <$mining_job{
    id:job.id;
    source_path:job.source_path;
    source_type:job.source_type;
    mode:job.mode;
    status:"running";
    items_found:job.items_found;
    items_stored:job.items_stored;
    started_at:std.now_ms();
    completed_at:job.completed_at;
    error:job.error
  }
}

// Marks a job as complete with item counts and completion timestamp.
pub f=complete(job:$mining_job;found:i32;stored:i32):$mining_job{
  log.info(str.concat("mining: complete — ";str.concat(str.from_i32(stored);str.concat("/";str.concat(str.from_i32(found);" items stored")))));
  <$mining_job{
    id:job.id;
    source_path:job.source_path;
    source_type:job.source_type;
    mode:job.mode;
    status:"complete";
    items_found:found;
    items_stored:stored;
    started_at:job.started_at;
    completed_at:std.now_ms();
    error:job.error
  }
}

// Marks a job as failed with an error message.
pub f=fail(job:$mining_job;error:str):$mining_job{
  log.info(str.concat("mining: failed — ";error));
  <$mining_job{
    id:job.id;
    source_path:job.source_path;
    source_type:job.source_type;
    mode:job.mode;
    status:"error";
    items_found:job.items_found;
    items_stored:job.items_stored;
    started_at:job.started_at;
    completed_at:job.completed_at;
    error:error
  }
}

// Detects source type from file path by extension and name.
pub f=detect_source_type(path:str):str{
  if str.ends_with(path;".json") && str.contains(path;"claude"){
    <"claude_export"
  }{
    if str.ends_with(path;".json") && str.contains(path;"chatgpt"){
      <"chatgpt_export"
    }{
      if str.ends_with(path;".json"){
        <"slack_json"
      }{
        if str.ends_with(path;".md"){
          <"markdown"
        }{
          <"code_repo"
        }
      }
    }
  }
}

// Determines the palace wing based on mining mode and source type.
pub f=assign_wing(mode:str;source_type:str):str{
  if str.eq(mode;"projects"){
    <"projects"
  }{
    if str.eq(mode;"conversations"){
      <"conversations"
    }{
      <"general"
    }
  }
}

// Stub: runs a privacy scan on content before storing.
// Logs the scan. Returns true (ok to store) — real implementation to follow.
pub f=privacy_scan(content:str):bool{
  log.info(str.concat("mining: privacy scan on ";str.concat(str.from_i32(str.len(content));" chars")));
  <true
}

// Stub: parses a markdown file and extracts sections as mined items.
// Real implementation: file read + section extraction.
pub f=mine_markdown(path:str;mode:str):@($mined_item){
  log.info(str.concat("mining: parsing markdown at ";path));
  <@()
}

// Stub: parses a JSON export file (Claude, ChatGPT, or Slack) and extracts items.
// Real implementation: JSON parse + conversation/message extraction.
pub f=mine_json_export(path:str;source_type:str;mode:str):@($mined_item){
  log.info(str.concat("mining: parsing ";str.concat(source_type;str.concat(" at ";path))));
  <@()
}

// Runs the appropriate mining function for the job's source type,
// applies privacy scan to each item, and returns a completed or failed job.
pub f=run(job:$mining_job):$mining_job{
  let running=start(job);
  let items=if str.eq(running.source_type;"markdown"){
    mine_markdown(running.source_path;running.mode)
  }{
    if str.eq(running.source_type;"claude_export") || str.eq(running.source_type;"chatgpt_export") || str.eq(running.source_type;"slack_json"){
      mine_json_export(running.source_path;running.source_type;running.mode)
    }{
      @()
    }
  };
  let found=items.len();
  let stored=0;
  items.each(item{
    if privacy_scan(item.content){
      let stored=stored + 1
    }
  });
  <complete(running;found;stored)
}

// Serialises a $mining_job to a JSON string.
pub f=job_to_json(j:$mining_job):str{
  <str.concat("{\"id\":\"";str.concat(j.id;str.concat("\",\"source_path\":\"";str.concat(j.source_path;str.concat("\",\"source_type\":\"";str.concat(j.source_type;str.concat("\",\"mode\":\"";str.concat(j.mode;str.concat("\",\"status\":\"";str.concat(j.status;str.concat("\",\"items_found\":";str.concat(str.from_i32(j.items_found);str.concat(",\"items_stored\":";str.concat(str.from_i32(j.items_stored);str.concat(",\"started_at\":";str.concat(str.from_i64(j.started_at);str.concat(",\"completed_at\":";str.concat(str.from_i64(j.completed_at);str.concat(",\"error\":\"";str.concat(j.error;"\"}"))))))))))))))))))
}

// Serialises a $mined_item to a JSON string.
pub f=item_to_json(i:$mined_item):str{
  let tags_json="[";
  let first=true;
  i.tags.each(t{
    if first{
      let tags_json=str.concat(tags_json;str.concat("\"";str.concat(t;"\""))); let first=false
    }{
      let tags_json=str.concat(tags_json;str.concat(",\"";str.concat(t;"\"")))
    }
  });
  let tags_json=str.concat(tags_json;"]");
  <str.concat("{\"content\":\"";str.concat(i.content;str.concat("\",\"source\":\"";str.concat(i.source;str.concat("\",\"ts\":";str.concat(str.from_i64(i.ts);str.concat(",\"wing\":\"";str.concat(i.wing;str.concat("\",\"tags\":";str.concat(tags_json;"}")))))))))))
}
