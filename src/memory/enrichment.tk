// M1.4 — Automatic context enrichment.
// Before every LLM call, searches the memory palace for relevant memories and
// prepends the top-N results as AAAK context with a disclosure line.

m=loke.memory.enrichment;

i=str:std.string;
i=log:std.log;
i=json:std.json;

pub m.$enrichment_config{
  enabled:bool;
  max_memories:i32;
  token_budget:i32;
  relevance_threshold:f32;
  anonymise_for_cloud:bool
}

pub m.$enriched_context{
  memories:@(str);
  total_tokens:i32;
  search_query:str;
  memories_found:i32;
  disclosure:str
}

// Returns default enrichment configuration.
pub f=default_config():$enrichment_config{
  <$enrichment_config{
    enabled:true;
    max_memories:5;
    token_budget:2000;
    relevance_threshold:0.75;
    anonymise_for_cloud:true
  }
}

// Extracts key terms from prompt for use as a search query.
// Stub: returns first 100 chars of prompt (real: keyword extraction or embedding).
pub f=build_search_query(prompt:str):str{
  let length=str.len(prompt);
  if length <= 100{
    <prompt
  }{
    <str.slice(prompt;0;100)
  }
}

// Enriches LLM context with relevant memories from the palace.
// Logs the operation and returns an $enriched_context.
// Stub: returns empty memories (real: calls vector search via search_fn_key dispatch).
pub f=enrich(prompt:str;cfg:$enrichment_config;search_fn_key:str):$enriched_context{
  log.info(str.concat("memory: enriching context for prompt (token_budget=";str.concat(str.from_i32(cfg.token_budget);")")));
  let query=build_search_query(prompt);
  <$enriched_context{
    memories:@();
    total_tokens:0;
    search_query:query;
    memories_found:0;
    disclosure:"Memory enrichment: 0 memories added"
  }
}

// Formats enriched context for prepending to an LLM prompt.
// Returns empty string if no memories; otherwise returns a headed block.
pub f=format_for_prompt(ctx:$enriched_context):str{
  if ctx.memories.len() == 0{
    <""
  }{
    let joined=str.join(ctx.memories;"\n---\n");
    <str.concat("# Relevant memories\n";str.concat(joined;"\n\n"))
  }
}

// Returns a human-readable disclosure line for the enrichment result.
pub f=disclosure_text(ctx:$enriched_context):str{
  if ctx.memories_found > 0{
    <str.concat("Added ";str.concat(str.from_i32(ctx.memories_found);" memories from palace"))
  }{
    <""
  }
}

// Serialises an $enriched_context to a JSON string.
pub f=to_json(ctx:$enriched_context):str{
  let mems_json="[";
  let first=true;
  ctx.memories.each(m{
    if first{
      let mems_json=str.concat(mems_json;str.concat("\"";str.concat(m;"\""))); let first=false
    }{
      let mems_json=str.concat(mems_json;str.concat(",\"";str.concat(m;"\"")))
    }
  });
  let mems_json=str.concat(mems_json;"]");
  <str.concat("{\"memories\":";str.concat(mems_json;str.concat(",\"total_tokens\":";str.concat(str.from_i32(ctx.total_tokens);str.concat(",\"search_query\":\"";str.concat(ctx.search_query;str.concat("\",\"memories_found\":";str.concat(str.from_i32(ctx.memories_found);str.concat(",\"disclosure\":\"";str.concat(ctx.disclosure;"\"}"))))))))))
}
