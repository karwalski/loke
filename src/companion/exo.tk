// F8.4 — Exo distributed inference integration.
//
// Exo (github.com/exo-explore/exo) is licensed under GPL-3.0.
// loke integrates with Exo exclusively via its OpenAI-compatible REST API.
// No Exo source code is imported, linked, or embedded in this module.
// GPL-3.0 boundary is fully maintained.
//
// Exo default REST port: 52415.

m=loke.companion.exo;

i=str:std.str;
i=log:std.log;
i=json:std.json;
i=http:std.http;

// Connection configuration for the Exo cluster REST endpoint.
pub m.$exo_config{
  base_url:str;
  timeout_ms:i32
}

// A model shard distributed across the Exo cluster.
pub m.$exo_model{
  id:str;
  shard_count:i32;
  nodes:@(str);
  status:str
}

// Result from a single Exo generation call.
pub m.$exo_result{
  text:str;
  tokens_in:i32;
  tokens_out:i32;
  model_id:str;
  ok:bool;
  error:str
}

// Returns the default Exo configuration pointing at the local Exo node.
// Port 52415 is the Exo default.
pub f=default_config():$exo_config{
  <$exo_config{
    base_url:"http://127.0.0.1:52415";
    timeout_ms:120000
  }
}

// Probes the Exo /health endpoint.
// Returns true when Exo responds with HTTP 200; logs the outcome either way.
pub f=health(cfg:$exo_config):bool{
  let url=cfg.base_url + "/health";
  let res=http.get(url);
  if res.ok{
    log.info("companion: Exo health OK at " + cfg.base_url);
    <true
  }{
    log.warn("companion: Exo health check failed at " + cfg.base_url + " (status=" + str.from_i32(res.status) + ")");
    <false
  }
}

// Fetches the list of models available in the Exo cluster.
// GET /v1/models — parses the OpenAI-compatible models list JSON.
// Returns an empty list on any HTTP or parse failure.
pub f=list_models(cfg:$exo_config):@($exo_model){
  let url=cfg.base_url + "/v1/models";
  let empty:@($exo_model)=@();
  let res=http.get(url);
  if !res.ok{
    log.warn("companion: Exo list_models failed (status=" + str.from_i32(res.status) + ")");
    <empty
  }{
    let parsed=json.dec(res.body);
    let ok=parsed|{
      $ok:_{ <true };
      $err:_{ <false }
    };
    if !ok{
      log.warn("companion: Exo list_models: could not parse response");
      <empty
    }{
      let obj=parsed|{ $ok:o{ <o }; $err:_{ <json.empty_obj() } };
      let data=json.get_array_or(obj;"data";@());
      let models:@($exo_model)=@();
      data.each(item{
        let id=json.get_str_or(item;"id";"unknown");
        models.push($exo_model{
          id:id;
          shard_count:0;
          nodes:@();
          status:"available"
        })
      });
      <models
    }
  }
}

// Runs a chat completion against the Exo cluster using the OpenAI-compatible
// POST /v1/chat/completions endpoint.
// Parses choices[0].message.content from the response.
pub f=generate(cfg:$exo_config;model_id:str;prompt:str;max_tokens:i32):$exo_result{
  let url=cfg.base_url + "/v1/chat/completions";
  let max_tokens_str=str.from_i32(max_tokens);
  let body="{" +
    "\"model\":" + json.enc_str(model_id) +
    ",\"messages\":[{\"role\":\"user\",\"content\":" + json.enc_str(prompt) + "}]" +
    ",\"max_tokens\":" + max_tokens_str +
    ",\"stream\":false" +
  "}";
  let empty=$exo_result{
    text:"";
    tokens_in:0;
    tokens_out:0;
    model_id:model_id;
    ok:false;
    error:"exo_generate_failed"
  };
  let res=http.post(url;body;"application/json");
  if !res.ok{
    log.warn("companion: Exo generate failed (status=" + str.from_i32(res.status) + ")");
    <empty
  }{
    let parsed=json.dec(res.body);
    let parse_ok=parsed|{
      $ok:_{ <true };
      $err:_{ <false }
    };
    if !parse_ok{
      log.warn("companion: Exo generate: could not parse response");
      <empty
    }{
      let obj=parsed|{ $ok:o{ <o }; $err:_{ <json.empty_obj() } };
      let choices=json.get_array_or(obj;"choices";@());
      let text="";
      if choices.len() > 0{
        let first=choices[0];
        let msg=json.get_obj_or(first;"message";json.empty_obj());
        text=json.get_str_or(msg;"content";"")
      }{};
      let usage=json.get_obj_or(obj;"usage";json.empty_obj());
      let tokens_in=json.get_i32_or(usage;"prompt_tokens";0);
      let tokens_out=json.get_i32_or(usage;"completion_tokens";0);
      <$exo_result{
        text:text;
        tokens_in:tokens_in;
        tokens_out:tokens_out;
        model_id:model_id;
        ok:true;
        error:""
      }
    }
  }
}

// Returns the raw JSON topology response from the Exo cluster.
// Useful for monitoring how model shards are distributed across nodes.
// Returns an error message string on failure.
pub f=cluster_status(cfg:$exo_config):str{
  let url=cfg.base_url + "/topology";
  let res=http.get(url);
  if res.ok{
    <res.body
  }{
    <"{\"error\":\"topology unavailable\",\"status\":" + str.from_i32(res.status) + "}"
  }
}

// Serialises a $exo_model to a JSON string.
pub f=model_to_json(m:$exo_model):str{
  let shard_count_str=str.from_i32(m.shard_count);
  let nodes_json="[";
  let first=true;
  m.nodes.each(n{
    if first{
      first=false
    }{
      nodes_json=nodes_json + ","
    };
    nodes_json=nodes_json + json.enc_str(n)
  });
  nodes_json=nodes_json + "]";
  <"{" +
    "\"id\":" + json.enc_str(m.id) +
    ",\"shard_count\":" + shard_count_str +
    ",\"nodes\":" + nodes_json +
    ",\"status\":" + json.enc_str(m.status) +
  "}"
}

// Serialises a $exo_result to a JSON string.
pub f=result_to_json(r:$exo_result):str{
  let ok_str=if r.ok{ "true" }{ "false" };
  let tokens_in_str=str.from_i32(r.tokens_in);
  let tokens_out_str=str.from_i32(r.tokens_out);
  <"{" +
    "\"text\":" + json.enc_str(r.text) +
    ",\"tokens_in\":" + tokens_in_str +
    ",\"tokens_out\":" + tokens_out_str +
    ",\"model_id\":" + json.enc_str(r.model_id) +
    ",\"ok\":" + ok_str +
    ",\"error\":" + json.enc_str(r.error) +
  "}"
}

// Returns the GPL boundary notice for this integration.
// Exo is GPL-3.0; loke calls it only via REST and never imports or links its code.
pub f=gpl_boundary_note():str{
  <"Exo integration uses REST API only. No GPL code is imported or linked. GPL-3.0 boundary maintained."
}
