// A2.5 — Environment integration (`loke init`, `loke doctor`).
// Health checks for the local loke environment and helpers that generate
// shell profile snippets, git hooks, and VS Code configuration.

m=loke.cli.env;
i=str:std.string;
i=log:std.log;
i=http:std.http;

pub m.$check_result{
  name:str;
  ok:bool;
  message:str;
  fix:str
}

pub m.$doctor_report{
  checks:@($check_result);
  all_ok:bool
}

// check_loke_running — verifies the loke daemon is accepting connections.
pub f=check_loke_running():$check_result{
  let res=http.get("http://127.0.0.1:11430/api/health");
  let ok=res.status == 200;
  let message="loke daemon is running";
  if ok{
  }{
    message="loke daemon not reachable on port 11430"
  };
  <$check_result{
    name:"loke daemon";
    ok:ok;
    message:message;
    fix:"Run: loke start"
  }
}

// check_ollama_running — verifies the local Ollama service is available.
pub f=check_ollama_running():$check_result{
  let res=http.get("http://127.0.0.1:11434/api/tags");
  let ok=res.status == 200;
  let message="Ollama is running";
  if ok{
  }{
    message="Ollama not reachable on port 11434"
  };
  <$check_result{
    name:"Ollama";
    ok:ok;
    message:message;
    fix:"Run: ollama serve"
  }
}

// check_port_free — stub: reports that the given port is available.
// Full implementation delegates to the ooke network binding.
pub f=check_port_free(port:i32):$check_result{
  <$check_result{
    name:"port " + str.from_i32(port);
    ok:true;
    message:"port " + str.from_i32(port) + " is free";
    fix:"Change port in ooke.toml"
  }
}

// check_data_dir — stub: reports that the ~/.loke data directory exists.
pub f=check_data_dir():$check_result{
  <$check_result{
    name:"data directory";
    ok:true;
    message:"~/.loke exists";
    fix:"Run: mkdir -p ~/.loke"
  }
}

// run_doctor — executes all environment checks and builds a report.
pub f=run_doctor():$doctor_report{
  let checks:@($check_result)=@();

  let loke_check=check_loke_running();
  if loke_check.ok{
    log.info("doctor: ✓ " + loke_check.name + ": " + loke_check.message)
  }{
    log.warn("doctor: ✗ " + loke_check.name + ": " + loke_check.message)
  };
  checks.push(loke_check);

  let ollama_check=check_ollama_running();
  if ollama_check.ok{
    log.info("doctor: ✓ " + ollama_check.name + ": " + ollama_check.message)
  }{
    log.warn("doctor: ✗ " + ollama_check.name + ": " + ollama_check.message)
  };
  checks.push(ollama_check);

  let port_check=check_port_free(11431);
  if port_check.ok{
    log.info("doctor: ✓ " + port_check.name + ": " + port_check.message)
  }{
    log.warn("doctor: ✗ " + port_check.name + ": " + port_check.message)
  };
  checks.push(port_check);

  let dir_check=check_data_dir();
  if dir_check.ok{
    log.info("doctor: ✓ " + dir_check.name + ": " + dir_check.message)
  }{
    log.warn("doctor: ✗ " + dir_check.name + ": " + dir_check.message)
  };
  checks.push(dir_check);

  let all_ok=true;
  checks.each(c{
    if c.ok{
    }{
      all_ok=false
    }
  });

  <$doctor_report{
    checks:checks;
    all_ok:all_ok
  }
}

// format_report — renders a doctor report for terminal output.
// Passing checks show ✓; failing checks show ✗ with the suggested fix.
pub f=format_report(r:$doctor_report):str{
  let out="loke doctor\n";
  r.checks.each(c{
    if c.ok{
      out=out + "✓ " + c.name + ": " + c.message + "\n"
    }{
      out=out + "✗ " + c.name + ": " + c.message + "\n" +
        "  Fix: " + c.fix + "\n"
    }
  });
  out=out + "\n";
  if r.all_ok{
    out=out + "All checks passed."
  }{
    out=out + "Some checks failed."
  };
  <out
}

// init_shell_profile — returns the shell profile snippet added by `loke init`.
pub f=init_shell_profile():str{
  <"# loke — added by loke init\n" +
    "export PATH=\"$PATH:$HOME/.loke/bin\"\n" +
    "alias loke-chat='loke ask'\n"
}

// init_git_hooks — returns the content of the pre-commit hook installed by
// `loke init`. Scans staged files for secrets before allowing a commit.
pub f=init_git_hooks():str{
  <"#!/bin/sh\n" +
    "# loke git hook: scans staged files for secrets before commit\n" +
    "loke scan --staged --exit-code\n"
}

// init_vscode_config — returns the JSON content for .vscode/settings.json
// that enables the loke proxy integration in VS Code.
pub f=init_vscode_config():str{
  <"{\"loke.proxy.enabled\":true,\"loke.proxy.port\":11431}"
}
