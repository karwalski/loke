// A2.1 — Direct prompting via CLI (`loke ask`).
// Sends a prompt through the loke privacy pipeline and returns a result.
// Supports dry-run, streaming, stdin input, and system prompts.

m=loke.cli.ask;
i=str:std.string;
i=log:std.log;
i=json:std.json;
i=http:std.http;

pub m.$ask_opts{
  model_id:str;
  dry_run:bool;
  stream:bool;
  stdin_input:bool;
  system_prompt:str;
  tolerance:str
}

pub m.$ask_result{
  response:str;
  model_id:str;
  tokens_in:i32;
  tokens_out:i32;
  cost_usd:f32;
  request_id:str;
  sensitivity:str;
  entities_found:i32
}

// default_opts — returns the recommended default options for `loke ask`.
pub f=default_opts():$ask_opts{
  <$ask_opts{
    model_id:"loke-router";
    dry_run:false;
    stream:true;
    stdin_input:false;
    system_prompt:"";
    tolerance:"instant"
  }
}

// run — sends prompt through the loke privacy pipeline and returns a result.
// If dry_run is set, logs a preview and returns a stub result without sending.
pub f=run(prompt:str;opts:$ask_opts):$ask_result{
  if opts.dry_run{
    log.info("ask: dry-run — privacy pipeline preview");
    log.info("ask: prompt would be anonymised → routed → " + opts.model_id);
    log.info("ask: tolerance=" + opts.tolerance);
    <$ask_result{
      response:"[dry-run: prompt would be sent through loke privacy pipeline → " + opts.model_id + "]";
      model_id:opts.model_id;
      tokens_in:0;
      tokens_out:0;
      cost_usd:0.0;
      request_id:"dry-run";
      sensitivity:"none";
      entities_found:0
    }
  }{
    let body="{" +
      "\"text\":" + json.quote(prompt) +
      ",\"system_prompt\":" + json.quote(opts.system_prompt) +
      ",\"tolerance\":" + json.quote(opts.tolerance) +
      ",\"mode\":\"cli\"" +
    "}";
    let res=http.post("http://127.0.0.1:11430/api/pipeline";body;"application/json");
    let response=json.get_str(res.body;"response");
    let model_id=json.get_str(res.body;"model_id");
    let tokens_in=json.get_i32(res.body;"tokens_in");
    let tokens_out=json.get_i32(res.body;"tokens_out");
    let cost_usd=json.get_f32(res.body;"cost_usd");
    let request_id=json.get_str(res.body;"request_id");
    let sensitivity=json.get_str(res.body;"sensitivity");
    let entities_found=json.get_i32(res.body;"entities_found");
    <$ask_result{
      response:response;
      model_id:model_id;
      tokens_in:tokens_in;
      tokens_out:tokens_out;
      cost_usd:cost_usd;
      request_id:request_id;
      sensitivity:sensitivity;
      entities_found:entities_found
    }
  }
}

// format_output — formats an ask result for terminal display.
// verbose mode appends model, token, cost, and sensitivity metadata.
pub f=format_output(r:$ask_result;verbose:bool):str{
  if verbose{
    <r.response +
      "\n\n---\n" +
      "Model: " + r.model_id +
      " | Tokens: " + str.from_i32(r.tokens_in) + "in/" + str.from_i32(r.tokens_out) + "out" +
      " | Cost: $" + str.from_f32(r.cost_usd) +
      " | Sensitivity: " + r.sensitivity
  }{
    <r.response
  }
}

// help_text — returns CLI usage help for `loke ask`.
pub f=help_text():str{
  <"loke ask — send a prompt through the loke privacy pipeline\n\n" +
    "Usage:\n" +
    "  loke ask [options] <prompt>\n" +
    "  echo <prompt> | loke ask --stdin\n\n" +
    "Options:\n" +
    "  --model <id>         Model or router to use (default: loke-router)\n" +
    "  --dry-run            Preview privacy pipeline without sending\n" +
    "  --no-stream          Disable streaming output\n" +
    "  --stdin              Read prompt from stdin\n" +
    "  --system <prompt>    Set a system prompt\n" +
    "  --tolerance <level>  Privacy tolerance: instant|balanced|thorough (default: instant)\n" +
    "  --verbose            Show model, token, cost, and sensitivity metadata\n" +
    "  --help               Show this help\n\n" +
    "Examples:\n" +
    "  loke ask \"Summarise this document\"\n" +
    "  loke ask --model claude-3-5-sonnet --verbose \"Explain recursion\"\n" +
    "  loke ask --dry-run \"What is my API key?\"\n" +
    "  cat notes.txt | loke ask --stdin \"Summarise this\"\n"
}
