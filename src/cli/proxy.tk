// A2.2 — Coding LLM proxy mode (`loke proxy`).
// Intercepts requests from coding assistants (Claude Code, Copilot, Cursor etc.)
// and routes them through the loke privacy pipeline before forwarding upstream.

m=loke.cli.proxy;
i=str:std.string;
i=log:std.log;

pub m.$proxy_config{
  upstream_name:str;
  upstream_url:str;
  listen_port:i32;
  show_indicator:bool;
  intercept_streams:bool
}

pub m.$proxy_stats{
  requests_intercepted:i32;
  pii_detected_total:i32;
  tokens_saved:i32;
  sessions:i32
}

pub m.$indicator_state{
  active:bool;
  current_request_id:str;
  pii_count:i32;
  sensitivity:str
}

// default_config — returns sensible defaults for the named upstream.
// claude-code targets the Anthropic API; everything else targets OpenAI.
pub f=default_config(upstream_name:str):$proxy_config{
  let upstream_url="https://api.openai.com";
  if upstream_name == "claude-code"{
    upstream_url="https://api.anthropic.com"
  }{};
  <$proxy_config{
    upstream_name:upstream_name;
    upstream_url:upstream_url;
    listen_port:11431;
    show_indicator:true;
    intercept_streams:true
  }
}

// new_stats — returns a zeroed stats struct for a fresh proxy session.
pub f=new_stats():$proxy_stats{
  <$proxy_stats{
    requests_intercepted:0;
    pii_detected_total:0;
    tokens_saved:0;
    sessions:0
  }
}

// intercept_request — logs the interception and increments the request counter.
// Returns an updated stats struct; does not mutate the original.
pub f=intercept_request(body_json:str;stats:$proxy_stats):$proxy_stats{
  log.info("proxy: intercepting request → loke pipeline");
  <$proxy_stats{
    requests_intercepted:stats.requests_intercepted + 1;
    pii_detected_total:stats.pii_detected_total;
    tokens_saved:stats.tokens_saved;
    sessions:stats.sessions
  }
}

// render_indicator — builds an ANSI terminal status line for the proxy.
// Begins with \r so repeated renders overwrite the same line.
pub f=render_indicator(state:$indicator_state):str{
  <"\r🔒 loke proxy active | PII: " + str.from_i32(state.pii_count) +
    " | Sensitivity: " + state.sensitivity +
    " | ID: " + state.current_request_id
}

// start_message — returns the banner printed when the proxy starts.
pub f=start_message(cfg:$proxy_config):str{
  <"loke proxy: intercepting " + cfg.upstream_name +
    " on port " + str.from_i32(cfg.listen_port) +
    "\nAll requests routed through loke privacy pipeline." +
    "\nCtrl+C to stop.\n"
}

// stats_summary — formats session statistics for display on proxy exit.
pub f=stats_summary(stats:$proxy_stats):str{
  <"\nloke proxy session summary\n" +
    "---------------------------\n" +
    "Requests intercepted : " + str.from_i32(stats.requests_intercepted) + "\n" +
    "PII instances found  : " + str.from_i32(stats.pii_detected_total) + "\n" +
    "Tokens saved         : " + str.from_i32(stats.tokens_saved) + "\n" +
    "Sessions             : " + str.from_i32(stats.sessions) + "\n"
}
