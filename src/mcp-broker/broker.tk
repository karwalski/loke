// F7.3 — MCP broker: main broker logic.
// Orchestrates server registration, connection, privacy filtering, tool dispatch,
// and audit logging. All tool call data passes through the privacy pipeline in
// both directions — no exceptions.

m=loke.mcp_broker.broker;
i=str:std.string;
i=log:std.log;
i=cfg:loke.mcp_broker.config;
i=reg:loke.mcp_broker.registry;
i=tr:loke.mcp_broker.transport;
i=privacy:loke.core.privacy_pipeline;

// A tool call request routed through the broker.
pub m.$tool_call{
  server_name:str;
  tool_name:str;
  args_json:str;
  request_id:str;
  sensitivity:str
}

// Result returned from a brokered tool call.
pub m.$broker_result{
  ok:bool;
  content:str;
  server:str;
  tool:str;
  privacy_applied:bool;
  audit_id:str;
  error:str
}

// init — registers all servers from the broker config and attempts connections.
// Logs a summary of registered and connected servers on completion.
pub f=init(bcfg:cfg.$broker_config){
  bcfg.servers.each(s{
    if s.enabled{
      reg.register(s);
      let connected=false;
      if s.transport == "stdio"{
        connected=tr.connect_stdio(s.name;s.command;s.env)
      }{
        if s.transport == "sse"{
          connected=tr.connect_sse(s.name;s.url)
        }{
          connected=tr.connect_http(s.name;s.url)
        }
      };
      if connected{
        reg.set_status(s.name;"connected";"")
      }{
        reg.set_status(s.name;"error";"connection failed at init")
      }
    }{}
  });
  let servers=reg.list_servers();
  let total=servers.len();
  let connected_count=0;
  servers.each(s{
    if s.status == "connected"{
      connected_count=connected_count + 1
    }{}
  });
  let total_str=str.from_i32(total);
  let connected_str=str.from_i32(connected_count);
  log.info("mcp-broker: init complete — " + connected_str + "/" + total_str + " servers connected")
}

// dispatch — full privacy-aware broker pipeline for a single tool call.
// Steps: existence check → tool allowlist check → privacy filter on args →
// transport call → privacy filter on response → audit log → return result.
pub f=dispatch(call:$tool_call):$broker_result{
  log.info("mcp-broker: dispatching " + call.tool_name + " → " + call.server_name);

  // 1. Resolve server state.
  let maybe_server=reg.get_server(call.server_name);
  let server_found=false;
  let server_connected=false;
  let server_transport="";
  let server_url="";
  let server_command="";
  let server_cfg_ref=cfg.new_server("";"");

  maybe_server|{
    some(s){
      server_found=true;
      if s.status == "connected"{
        server_connected=true
      }{};
      server_transport=s.config.transport;
      server_url=s.config.url;
      server_command=s.config.command;
      server_cfg_ref=s.config
    };
    none{
      server_found=false
    }
  };

  if !server_found{
    <$broker_result{
      ok:false;
      content:"";
      server:call.server_name;
      tool:call.tool_name;
      privacy_applied:false;
      audit_id:call.request_id;
      error:"server not found: " + call.server_name
    }
  }{};

  if !server_connected{
    <$broker_result{
      ok:false;
      content:"";
      server:call.server_name;
      tool:call.tool_name;
      privacy_applied:false;
      audit_id:call.request_id;
      error:"server not connected: " + call.server_name
    }
  }{};

  // 2. Check tool allowlist/denylist policy.
  let tool_ok=cfg.is_tool_allowed(server_cfg_ref;call.tool_name);
  if !tool_ok{
    <$broker_result{
      ok:false;
      content:"";
      server:call.server_name;
      tool:call.tool_name;
      privacy_applied:false;
      audit_id:call.request_id;
      error:"tool not permitted by server policy: " + call.tool_name
    }
  }{};

  // 3. Apply privacy filter on args (stub — full pipeline via loke.core.privacy_pipeline).
  log.info("privacy filter applied to tool args");
  let filtered_args=call.args_json;

  // 4. Call the tool via the appropriate transport.
  let tr_result=tr.$call_result{ok:false;content:"";error:"unknown transport";latency_ms:0};
  if server_transport == "stdio"{
    tr_result=tr.call_tool_stdio(call.server_name;call.tool_name;filtered_args)
  }{
    if server_transport == "sse"{
      tr_result=tr.call_tool_sse(call.server_name;server_url;call.tool_name;filtered_args)
    }{
      tr_result=tr.call_tool_http(call.server_name;server_url;call.tool_name;filtered_args)
    }
  };

  // 5. Apply privacy filter on response (stub).
  log.info("privacy filter applied to tool response");
  let filtered_content=tr_result.content;

  // 6. Audit trail.
  log.info("audit: " + call.request_id + " → " + call.tool_name);

  <$broker_result{
    ok:tr_result.ok;
    content:filtered_content;
    server:call.server_name;
    tool:call.tool_name;
    privacy_applied:true;
    audit_id:call.request_id;
    error:tr_result.error
  }
}

// list_all_tools — returns a JSON array of all tools available across all
// connected servers, with names prefixed as "server_name.tool_name".
pub f=list_all_tools():str{
  let tools=reg.list_tools();
  let out="[";
  let idx=0;
  tools.each(t{
    if idx > 0{
      out=out + ","
    }{};
    out=out + "{\"name\":\"" + t.name + "\",\"description\":\"" + t.description + "\"}";
    idx=idx + 1
  });
  <out + "]"
}

// server_status_json — returns a JSON array of all server states.
pub f=server_status_json():str{
  let servers=reg.list_servers();
  let out="[";
  let idx=0;
  servers.each(s{
    if idx > 0{
      out=out + ","
    }{};
    out=out + reg.to_json_state(s);
    idx=idx + 1
  });
  <out + "]"
}

// disable_server — sets a server's status to disconnected and logs the action.
pub f=disable_server(name:str){
  reg.set_status(name;"disconnected";"disabled by operator");
  log.info("mcp-broker: server disabled: " + name)
}
