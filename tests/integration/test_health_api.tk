// T14.1 — Health API integration tests.
// Tests the health checker module directly without making HTTP calls.
// Verifies build_report, aggregate_status, report_to_json, register_probe, and run_probe.

m=tests.integration.test_health_api;

i=checker:loke.core.health.checker;
i=api:loke.core.health.api;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T14.1-a: build_report with empty probes returns a report struct (ok field present)
  let empty_probes=@($checker.$probe_result)[];
  let empty_report=checker.build_report("0.1.0";"running";empty_probes);
  // The report struct exists — verify its status field is valid
  let valid_statuses_empty=str.eq(empty_report.status;"healthy")||str.eq(empty_report.status;"degraded")||str.eq(empty_report.status;"unhealthy");
  results=str.array_push(results;assert_true("build_report with empty probes has valid status";valid_statuses_empty));

  // T14.1-b: Report status field is one of healthy/degraded/unhealthy
  let healthy_probe=checker.run_probe("Database";"healthy";"ok";0);
  let one_probe_arr=@($checker.$probe_result)[healthy_probe];
  let one_report=checker.build_report("0.1.0";"running";one_probe_arr);
  let valid_status=str.eq(one_report.status;"healthy")||str.eq(one_report.status;"degraded")||str.eq(one_report.status;"unhealthy");
  results=str.array_push(results;assert_true("report status is a recognised value";valid_status));

  // T14.1-c: aggregate_status on empty probes returns "healthy"
  let agg_empty=checker.aggregate_status(empty_probes);
  results=str.array_push(results;assert_eq("aggregate_status empty probes returns healthy";agg_empty;"healthy"));

  // T14.1-d: aggregate_status with one unhealthy probe returns "unhealthy"
  let bad_probe=checker.run_probe("DB";"unhealthy";"connection refused";50);
  let bad_arr=@($checker.$probe_result)[bad_probe];
  let agg_bad=checker.aggregate_status(bad_arr);
  results=str.array_push(results;assert_eq("aggregate_status unhealthy probe returns unhealthy";agg_bad;"unhealthy"));

  // T14.1-e: aggregate_status with one degraded probe returns "degraded"
  let deg_probe=checker.run_probe("Cache";"degraded";"high latency";200);
  let deg_arr=@($checker.$probe_result)[deg_probe];
  let agg_deg=checker.aggregate_status(deg_arr);
  results=str.array_push(results;assert_eq("aggregate_status degraded probe returns degraded";agg_deg;"degraded"));

  // T14.1-f: report_to_json contains "ok" field
  let json_out=checker.report_to_json(empty_report);
  results=str.array_push(results;assert_true("report_to_json contains ok field";str.contains(json_out;"\"ok\"")));

  // T14.1-g: report_to_json contains "version" or "status" field
  let has_version=str.contains(json_out;"version");
  let has_status=str.contains(json_out;"status");
  results=str.array_push(results;assert_true("report_to_json contains version or status";has_version||has_status));

  // T14.1-h: register_probe increases probe count in global registry
  // The module init already registers 2 probes (database, settings).
  // We register one more and verify no panic occurs.
  checker.register_probe("test-probe";"Test Probe";"builtin.test");
  results=str.array_push(results;pass("register_probe does not error"));

  // T14.1-i: run_probe returns a result struct with non-empty name, status, message
  let probe_result=checker.run_probe("MyProbe";"healthy";"all good";5);
  results=str.array_push(results;assert_true("run_probe result has non-empty name";str.len(probe_result.name)>0));
  results=str.array_push(results;assert_eq("run_probe result status matches";probe_result.status;"healthy"));
  results=str.array_push(results;assert_true("run_probe result has message";str.len(probe_result.message)>0));
  // latency_ms field is present (i32); value we passed is 5
  results=str.array_push(results;assert_true("run_probe result has latency_ms field";probe_result.latency_ms==5));

  // T14.1-j: build_report version field is preserved in JSON
  let versioned_report=checker.build_report("1.2.3";"running";empty_probes);
  let versioned_json=checker.report_to_json(versioned_report);
  results=str.array_push(results;assert_true("report_to_json preserves version";str.contains(versioned_json;"1.2.3")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
