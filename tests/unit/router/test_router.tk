// T2.3 — Router helper function unit tests
// Verifies new_config defaults, provider_from_str, ctx_from_model,
// cost_in_from_model, and estimate_latency behaviour.

m=tests.unit.router.test_router;

i=router:core.router.router;
i=sel:core.router.selector;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_eq_u32(name:str;got:u32;want:u32):$result{
  if got==want{
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(str.from_u32(want);str.concat(" got=";str.from_u32(got)))))
  }
}

f=assert_eq_f64(name:str;got:f64;want:f64):$result{
  if got==want{
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(str.from_float(want);str.concat(" got=";str.from_float(got)))))
  }
}

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T2.3-a: new_config sets prefer_local=true
  let cfg=router.new_config("http://127.0.0.1:11434");
  results=str.array_push(results;assert_true("new_config prefer_local is true";cfg.prefer_local));

  // T2.3-b: new_config sets max_cost_per_1k=0.05
  results=str.array_push(results;assert_eq_f64("new_config max_cost_per_1k is 0.05";cfg.max_cost_per_1k;0.05));

  // T2.3-c: new_config stores the ollama_url
  results=str.array_push(results;assert_eq("new_config ollama_url stored";cfg.ollama_url;"http://127.0.0.1:11434"));

  // T2.3-d: new_config sets default_tolerance to $instant
  results=str.array_push(results;assert_true("new_config default_tolerance is instant";cfg.default_tolerance==$latency_tolerance.$instant));

  // T2.3-e: new returns a router with config and registry fields
  let r=router.new(cfg);
  results=str.array_push(results;assert_true("new router config prefer_local matches";r.config.prefer_local));
  results=str.array_push(results;assert_eq("new router config ollama_url matches";r.config.ollama_url;"http://127.0.0.1:11434"));

  // T2.3-f: tolerance_from_str "patient" → $patient
  let tol_patient=sel.tolerance_from_str("patient");
  results=str.array_push(results;assert_true("tolerance_from_str patient";tol_patient==$latency_tolerance.$patient));

  // T2.3-g: tolerance_from_str "background" → $background
  let tol_bg=sel.tolerance_from_str("background");
  results=str.array_push(results;assert_true("tolerance_from_str background";tol_bg==$latency_tolerance.$background));

  // T2.3-h: tolerance_from_str "instant" → $instant
  let tol_inst=sel.tolerance_from_str("instant");
  results=str.array_push(results;assert_true("tolerance_from_str instant";tol_inst==$latency_tolerance.$instant));

  // T2.3-i: tolerance_from_str unknown value → $instant (default)
  let tol_unknown=sel.tolerance_from_str("unknown-value");
  results=str.array_push(results;assert_true("tolerance_from_str unknown defaults to instant";tol_unknown==$latency_tolerance.$instant));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
