// T2.4 — Escalation unit tests
// Verifies should_escalate, escalation_target, record_escalation,
// format_trigger, and default_policy values.
//
// Note: escalation.tk references prov.$completion_response with fields
// text and usage.completion_tokens. Tests are constructed accordingly.

m=tests.unit.router.test_escalation;

i=esc:core.router.escalation;
i=prov:providers.types;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;val:bool):$result{
  if !val{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T2.4-a: default_policy has min_confidence=0.7
  results=str.array_push(results;assert_true("default_policy min_confidence is 0.7";esc.default_policy.min_confidence==0.7));

  // T2.4-b: default_policy has max_retries=2
  results=str.array_push(results;assert_true("default_policy max_retries is 2";esc.default_policy.max_retries==2));

  // T2.4-c: default_policy has allow_cloud_escalation=true
  results=str.array_push(results;assert_true("default_policy allow_cloud_escalation is true";esc.default_policy.allow_cloud_escalation));

  // T2.4-d: escalation_target for qwen2.5:7b → qwen2.5:72b
  results=str.array_push(results;assert_eq("escalation_target qwen2.5:7b";esc.escalation_target("qwen2.5:7b");"qwen2.5:72b"));

  // T2.4-e: escalation_target for llama3.2:3b → llama3.1:8b
  results=str.array_push(results;assert_eq("escalation_target llama3.2:3b";esc.escalation_target("llama3.2:3b");"llama3.1:8b"));

  // T2.4-f: escalation_target for llama3.1:8b → claude-3-5-haiku-20241022
  results=str.array_push(results;assert_eq("escalation_target llama3.1:8b";esc.escalation_target("llama3.1:8b");"claude-3-5-haiku-20241022"));

  // T2.4-g: escalation_target for qwen2.5:72b → claude-3-5-sonnet-20241022
  results=str.array_push(results;assert_eq("escalation_target qwen2.5:72b";esc.escalation_target("qwen2.5:72b");"claude-3-5-sonnet-20241022"));

  // T2.4-h: escalation_target for unknown model → claude-3-5-sonnet-20241022 (fallback)
  results=str.array_push(results;assert_eq("escalation_target unknown model fallback";esc.escalation_target("some-unknown-model");"claude-3-5-sonnet-20241022"));

  // T2.4-i: record_escalation returns trigger with correct from_model and to_model
  let trigger=esc.record_escalation("qwen2.5:7b";"qwen2.5:72b";"low token count");
  results=str.array_push(results;assert_eq("record_escalation from_model";trigger.from_model;"qwen2.5:7b"));
  results=str.array_push(results;assert_eq("record_escalation to_model";trigger.to_model;"qwen2.5:72b"));
  results=str.array_push(results;assert_eq("record_escalation reason";trigger.reason;"low token count"));

  // T2.4-j: record_escalation triggered_at is non-zero (unix ms timestamp)
  results=str.array_push(results;assert_true("record_escalation triggered_at non-zero";trigger.triggered_at > 0));

  // T2.4-k: format_trigger output contains model names and reason
  let formatted=esc.format_trigger(trigger);
  results=str.array_push(results;assert_true("format_trigger contains from_model";str.contains(formatted;"qwen2.5:7b")));
  results=str.array_push(results;assert_true("format_trigger contains to_model";str.contains(formatted;"qwen2.5:72b")));
  results=str.array_push(results;assert_true("format_trigger contains reason";str.contains(formatted;"low token count")));
  results=str.array_push(results;assert_true("format_trigger contains Escalated";str.contains(formatted;"Escalated")));

  // T2.4-l: format_trigger uses arrow separator between models
  results=str.array_push(results;assert_true("format_trigger contains arrow";str.contains(formatted;"→")));

  // T2.4-m: escalation_policy struct can be constructed with all fields
  let policy=$esc.escalation_policy{
    min_confidence:0.8;
    max_retries:3;
    allow_cloud_escalation:false
  };
  results=str.array_push(results;assert_true("custom policy min_confidence";policy.min_confidence==0.8));
  results=str.array_push(results;assert_true("custom policy max_retries";policy.max_retries==3));
  results=str.array_push(results;assert_false("custom policy no cloud escalation";policy.allow_cloud_escalation));

  // T2.4-n: escalation_trigger struct fields are all present
  let manual_trigger=$esc.escalation_trigger{
    reason:"test reason";
    from_model:"model-a";
    to_model:"model-b";
    triggered_at:1000
  };
  results=str.array_push(results;assert_eq("escalation_trigger reason field";manual_trigger.reason;"test reason"));
  results=str.array_push(results;assert_eq("escalation_trigger from_model field";manual_trigger.from_model;"model-a"));
  results=str.array_push(results;assert_eq("escalation_trigger to_model field";manual_trigger.to_model;"model-b"));
  results=str.array_push(results;assert_true("escalation_trigger triggered_at field";manual_trigger.triggered_at==1000));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
