// T2.1 — Sensitivity scorer unit tests
// Verifies score_from_pii, score_from_content, combine, can_use_cloud, and level_to_str.

m=tests.unit.router.test_sensitivity;

i=sens:core.router.sensitivity;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;val:bool):$result{
  if !val{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T2.1-a: score_from_pii($public, 0) → PUBLIC
  let r_a=sens.score_from_pii($sensitivity_level.$public;0);
  results=str.array_push(results;assert_eq("score_from_pii public 0 entities";sens.level_to_str(r_a);"PUBLIC"));

  // T2.1-b: score_from_pii($confidential, 1) → CONFIDENTIAL (no escalation below 3)
  let r_b=sens.score_from_pii($sensitivity_level.$confidential;1);
  results=str.array_push(results;assert_eq("score_from_pii confidential 1 entity";sens.level_to_str(r_b);"CONFIDENTIAL"));

  // T2.1-c: score_from_pii($confidential, 3) → RESTRICTED (escalation at 3+ entities)
  let r_c=sens.score_from_pii($sensitivity_level.$confidential;3);
  results=str.array_push(results;assert_eq("score_from_pii confidential 3 entities escalates";sens.level_to_str(r_c);"RESTRICTED"));

  // T2.1-d: score_from_pii($confidential, 2) → CONFIDENTIAL (no escalation at exactly 2)
  let r_d=sens.score_from_pii($sensitivity_level.$confidential;2);
  results=str.array_push(results;assert_eq("score_from_pii confidential 2 entities no escalation";sens.level_to_str(r_d);"CONFIDENTIAL"));

  // T2.1-e: score_from_pii($restricted, 1) → RESTRICTED (stays restricted with any entities)
  let r_e=sens.score_from_pii($sensitivity_level.$restricted;1);
  results=str.array_push(results;assert_eq("score_from_pii restricted 1 entity stays restricted";sens.level_to_str(r_e);"RESTRICTED"));

  // T2.1-f: score_from_content("password reset link") → RESTRICTED
  let r_f=sens.score_from_content("password reset link");
  results=str.array_push(results;assert_eq("score_from_content password reset link";sens.level_to_str(r_f);"RESTRICTED"));

  // T2.1-g: score_from_content("bank account number") → RESTRICTED
  let r_g=sens.score_from_content("bank account number");
  results=str.array_push(results;assert_eq("score_from_content bank account number";sens.level_to_str(r_g);"RESTRICTED"));

  // T2.1-h: score_from_content("patient diagnosis notes") → CONFIDENTIAL
  // Contains "diagnosis" which triggers CONFIDENTIAL
  let r_h=sens.score_from_content("patient diagnosis notes");
  results=str.array_push(results;assert_eq("score_from_content patient diagnosis notes";sens.level_to_str(r_h);"CONFIDENTIAL"));

  // T2.1-i: score_from_content("the weather is nice") → PUBLIC
  let r_i=sens.score_from_content("the weather is nice");
  results=str.array_push(results;assert_eq("score_from_content weather is public";sens.level_to_str(r_i);"PUBLIC"));

  // T2.1-j: score_from_content("internal memo") → CONFIDENTIAL
  let r_j=sens.score_from_content("internal memo");
  results=str.array_push(results;assert_eq("score_from_content internal memo";sens.level_to_str(r_j);"CONFIDENTIAL"));

  // T2.1-k: combine($confidential, $restricted) → RESTRICTED
  let r_k=sens.combine($sensitivity_level.$confidential;$sensitivity_level.$restricted);
  results=str.array_push(results;assert_eq("combine confidential+restricted=restricted";sens.level_to_str(r_k);"RESTRICTED"));

  // T2.1-l: combine($public, $internal) → INTERNAL
  let r_l=sens.combine($sensitivity_level.$public;$sensitivity_level.$internal);
  results=str.array_push(results;assert_eq("combine public+internal=internal";sens.level_to_str(r_l);"INTERNAL"));

  // T2.1-m: combine($restricted, $public) → RESTRICTED
  let r_m=sens.combine($sensitivity_level.$restricted;$sensitivity_level.$public);
  results=str.array_push(results;assert_eq("combine restricted+public=restricted";sens.level_to_str(r_m);"RESTRICTED"));

  // T2.1-n: can_use_cloud($restricted) → false
  results=str.array_push(results;assert_false("can_use_cloud restricted is false";sens.can_use_cloud($sensitivity_level.$restricted)));

  // T2.1-o: can_use_cloud($confidential) → true
  results=str.array_push(results;assert_true("can_use_cloud confidential is true";sens.can_use_cloud($sensitivity_level.$confidential)));

  // T2.1-p: can_use_cloud($public) → true
  results=str.array_push(results;assert_true("can_use_cloud public is true";sens.can_use_cloud($sensitivity_level.$public)));

  // T2.1-q: level_to_str($public) → "PUBLIC"
  results=str.array_push(results;assert_eq("level_to_str public";sens.level_to_str($sensitivity_level.$public);"PUBLIC"));

  // T2.1-r: level_to_str($restricted) → "RESTRICTED"
  results=str.array_push(results;assert_eq("level_to_str restricted";sens.level_to_str($sensitivity_level.$restricted);"RESTRICTED"));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
