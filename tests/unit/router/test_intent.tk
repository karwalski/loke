// T2.5 — Intent classifier unit tests
// Verifies classify_fast task detection, confidence bounds,
// task_from_str parsing, and result struct fields.

m=tests.unit.router.test_intent;

i=intent:core.router.intent;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

// Checks that confidence is between 0.0 and 1.0 inclusive
f=check_confidence(name:str;confidence:f64):$result{
  let ok=if confidence >= 0.0{ if confidence <= 1.0{ true }else{ false } }else{ false };
  if ok{ <pass(name) }else{
    <fail(name;str.concat("confidence out of range: ";str.from_float(confidence)))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T2.5-a: classify_fast on code-like text returns $code_generation
  let code_result=intent.classify_fast("write a function to sort a list");
  results=str.array_push(results;assert_true("classify_fast code text returns code_generation";code_result.task==$task_type.$code_generation));
  results=str.array_push(results;check_confidence("classify_fast code confidence in range";code_result.confidence));

  // T2.5-b: classify_fast "implement a binary search" → $code_generation
  let impl_result=intent.classify_fast("implement a binary search algorithm");
  results=str.array_push(results;assert_true("classify_fast implement returns code_generation";impl_result.task==$task_type.$code_generation));

  // T2.5-c: classify_fast "review this code" → $code_review
  let review_result=intent.classify_fast("review this code and suggest improvements");
  results=str.array_push(results;assert_true("classify_fast review code returns code_review";review_result.task==$task_type.$code_review));

  // T2.5-d: classify_fast "summarise this document" → $summarisation
  let summ_result=intent.classify_fast("summarise this document for me");
  results=str.array_push(results;assert_true("classify_fast summarise returns summarisation";summ_result.task==$task_type.$summarisation));

  // T2.5-e: classify_fast "tldr" → $summarisation
  let tldr_result=intent.classify_fast("tldr of the following text");
  results=str.array_push(results;assert_true("classify_fast tldr returns summarisation";tldr_result.task==$task_type.$summarisation));

  // T2.5-f: classify_fast "classify this text" → $classification
  let class_result=intent.classify_fast("classify this text into categories");
  results=str.array_push(results;assert_true("classify_fast classify returns classification";class_result.task==$task_type.$classification));

  // T2.5-g: classify_fast "embed these sentences" → $embedding
  let embed_result=intent.classify_fast("embed these sentences for vector search");
  results=str.array_push(results;assert_true("classify_fast embed returns embedding";embed_result.task==$task_type.$embedding));

  // T2.5-h: classify_fast "analyse the data" → $data_analysis
  let data_result=intent.classify_fast("analyse the data and find trends");
  results=str.array_push(results;assert_true("classify_fast analyse returns data_analysis";data_result.task==$task_type.$data_analysis));

  // T2.5-i: classify_fast generic text → $chat with valid confidence
  let chat_result=intent.classify_fast("hello, how are you today");
  results=str.array_push(results;assert_true("classify_fast generic text returns chat";chat_result.task==$task_type.$chat));
  results=str.array_push(results;check_confidence("classify_fast chat confidence in range";chat_result.confidence));

  // T2.5-j: classify_fast result always has method field as "keyword"
  results=str.array_push(results;assert_eq("classify_fast method is keyword";chat_result.method;"keyword"));

  // T2.5-k: task_from_str round-trips for all known task names
  results=str.array_push(results;assert_true("task_from_str code_generation";intent.task_from_str("code_generation")==$task_type.$code_generation));
  results=str.array_push(results;assert_true("task_from_str code_review";intent.task_from_str("code_review")==$task_type.$code_review));
  results=str.array_push(results;assert_true("task_from_str summarisation";intent.task_from_str("summarisation")==$task_type.$summarisation));
  results=str.array_push(results;assert_true("task_from_str classification";intent.task_from_str("classification")==$task_type.$classification));
  results=str.array_push(results;assert_true("task_from_str ner";intent.task_from_str("ner")==$task_type.$ner));
  results=str.array_push(results;assert_true("task_from_str embedding";intent.task_from_str("embedding")==$task_type.$embedding));
  results=str.array_push(results;assert_true("task_from_str data_analysis";intent.task_from_str("data_analysis")==$task_type.$data_analysis));

  // T2.5-l: task_from_str unknown value → $chat (default)
  results=str.array_push(results;assert_true("task_from_str unknown defaults to chat";intent.task_from_str("unknown-task")==$task_type.$chat));

  // T2.5-m: identify triggers ner
  let ner_result=intent.classify_fast("identify all the entities in this text");
  results=str.array_push(results;assert_true("classify_fast identify returns ner";ner_result.task==$task_type.$ner));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
