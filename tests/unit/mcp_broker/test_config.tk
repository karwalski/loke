// T11.1 — MCP broker config unit tests.
// Tests new_server, is_tool_allowed (allowlist and denylist), and to_json
// on the loke.mcp_broker.config module.

m=tests.unit.mcp_broker.test_config;

i=cfg:loke.mcp_broker.config;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T11.1-a: new_server creates config with correct name field
  let server=cfg.new_server("my_server";"stdio");
  results=str.array_push(results;assert_eq("new_server name field";"my_server";server.name));
  results=str.array_push(results;assert_eq("new_server transport field";"stdio";server.transport));

  // T11.1-b: is_tool_allowed with empty allowlist → true for any tool
  results=str.array_push(results;assert_true("empty allowlist allows any tool";cfg.is_tool_allowed(server;"allowed_tool")));

  // T11.1-c: with allowlist=["read_file"], is_tool_allowed("write_file") → false
  let server_with_allow=cfg.$server_config{
    name:"my_server";
    transport:"stdio";
    command:"";
    url:"";
    env:@();
    tool_allowlist:@("read_file");
    tool_denylist:@();
    max_cost_per_call:0.0;
    require_approval:false;
    enabled:true
  };
  results=str.array_push(results;assert_false("allowlist blocks unlisted tool";cfg.is_tool_allowed(server_with_allow;"write_file")));

  // T11.1-d: with allowlist=["read_file"], is_tool_allowed("read_file") → true
  results=str.array_push(results;assert_true("allowlist permits listed tool";cfg.is_tool_allowed(server_with_allow;"read_file")));

  // T11.1-e: with denylist=["dangerous"], is_tool_allowed("dangerous") → false
  let server_with_deny=cfg.$server_config{
    name:"my_server";
    transport:"stdio";
    command:"";
    url:"";
    env:@();
    tool_allowlist:@();
    tool_denylist:@("dangerous");
    max_cost_per_call:0.0;
    require_approval:false;
    enabled:true
  };
  results=str.array_push(results;assert_false("denylist blocks denied tool";cfg.is_tool_allowed(server_with_deny;"dangerous")));

  // T11.1-f: denylist does not block tools not in the list
  results=str.array_push(results;assert_true("denylist permits non-denied tool";cfg.is_tool_allowed(server_with_deny;"safe_tool")));

  // T11.1-g: to_json contains "name" and "transport" fields
  let json_out=cfg.to_json(server);
  results=str.array_push(results;assert_true("to_json contains name";str.contains(json_out;"name")));
  results=str.array_push(results;assert_true("to_json contains transport";str.contains(json_out;"transport")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
