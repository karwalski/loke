// T11.2 — MCP broker registry unit tests.
// Tests register, list_servers, get_server, set_status, set_tools, and
// list_tools on the loke.mcp_broker.registry module.

m=tests.unit.mcp_broker.test_registry;

i=reg:loke.mcp_broker.registry;
i=cfg:loke.mcp_broker.config;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  // Reset global state
  reg.g_servers=@();

  let results = @($result)[];

  // T11.2-a: list_servers returns empty on fresh state
  let initial=reg.list_servers();
  let initial_len=str.array_len(initial);
  results=str.array_push(results;assert_int_eq("list_servers empty on fresh state";initial_len;0));

  // T11.2-b: after register, list_servers has 1 entry
  let server_config=cfg.new_server("my_server";"stdio");
  reg.register(server_config);
  let after_register=reg.list_servers();
  let after_len=str.array_len(after_register);
  results=str.array_push(results;assert_int_eq("list_servers has 1 entry after register";after_len;1));

  // T11.2-c: get_server("my_server") returns the registered server
  let found_opt=reg.get_server("my_server");
  found_opt|{
    $some:s{
      results=str.array_push(results;assert_eq("get_server returns correct name";"my_server";s.config.name))
    };
    $none:{
      results=str.array_push(results;fail("get_server known name returns some";"returned none"))
    }
  };

  // T11.2-d: get_server("unknown") returns none
  let unknown_opt=reg.get_server("unknown");
  unknown_opt|{
    $some:_s{
      results=str.array_push(results;fail("get_server unknown returns none";"returned some"))
    };
    $none:{
      results=str.array_push(results;pass("get_server unknown returns none"))
    }
  };

  // T11.2-e: set_status updates status
  reg.set_status("my_server";"connected";"");
  let after_status_opt=reg.get_server("my_server");
  after_status_opt|{
    $some:s{
      results=str.array_push(results;assert_eq("set_status updates status";"connected";s.status))
    };
    $none:{
      results=str.array_push(results;fail("get_server after set_status";"returned none"))
    }
  };

  // T11.2-f: after set_tools, list_tools returns prefixed tool names
  let tools=@(reg.$tool_def{
    name:"read_file";
    description:"Reads a file";
    input_schema:"{}"
  });
  reg.set_tools("my_server";tools);
  let all_tools=reg.list_tools();
  let tools_len=str.array_len(all_tools);
  results=str.array_push(results;assert_true("list_tools returns tools after set_tools";tools_len >= 1));

  // T11.2-g: tool names are prefixed with "my_server."
  if tools_len >= 1{
    let first_tool=str.array_get(all_tools;0);
    results=str.array_push(results;assert_true("tool name prefixed with server name";str.contains(first_tool.name;"my_server.")))
  }{
    results=str.array_push(results;fail("tool prefix check skipped";"no tools returned"))
  };

  // T11.2-h: list_servers count matches registered count (1)
  let final_servers=reg.list_servers();
  let final_len=str.array_len(final_servers);
  results=str.array_push(results;assert_int_eq("list_servers count matches registered";final_len;1));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
