// T5.3 — Ephemeral storage unit tests
// Tests: store then retrieve before TTL expiry, wipe removes entry,
// wipe_all empties the store, after wipe retrieve returns none.

m=tests.unit.storage.test_ephemeral;

i=eph:core.storage.ephemeral;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }
f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}
f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}
f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}
f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}
pub f=run_all():bool{
  let results = @($result)[];

  // T5.3-a: store then retrieve returns value before TTL expiry
  let m1 = eph.new_map("session-test-001";3600);
  let m1 = eph.put(m1;"__placeholder_abc__";"original_value_abc");
  let r_retrieve = eph.get(m1;"__placeholder_abc__")|{
    $some:v assert_eq("store then retrieve returns value";v;"original_value_abc");
    $none fail("store then retrieve returns value";"get returned none before TTL expiry")
  };
  let results = str.array_push(results;r_retrieve);

  // T5.3-b: wipe removes entry — after wipe, retrieve returns none
  let m2 = eph.new_map("session-test-002";3600);
  let m2 = eph.put(m2;"__placeholder_xyz__";"secret_value");
  let wiped = eph.wipe(m2);
  let r_wipe_ok = assert_true("wipe returns true";wiped);
  let results = str.array_push(results;r_wipe_ok);

  // After wipe the secure buf is zeroed; a subsequent get should return none
  let r_after_wipe = eph.get(m2;"__placeholder_xyz__")|{
    $some:v fail("after wipe retrieve returns none";"expected none but got a value");
    $none pass("after wipe retrieve returns none")
  };
  let results = str.array_push(results;r_after_wipe);

  // T5.3-c: wipe_all (sweep) empties the store
  let m3 = eph.new_map("session-test-003";3600);
  let m3 = eph.put(m3;"__placeholder_p1__";"val1");
  let m3 = eph.put(m3;"__placeholder_p2__";"val2");
  // sweep() removes all expired/wiped buffers; calling wipe first ensures removal
  eph.wipe(m3);
  let swept = eph.sweep();
  let r_sweep = assert_true("sweep runs without error";swept >= 0);
  let results = str.array_push(results;r_sweep);

  // T5.3-d: a fresh map with no entries returns none for an unknown placeholder
  let m4 = eph.new_map("session-test-004";3600);
  let r_unknown = eph.get(m4;"__no_such_placeholder__")|{
    $some:v fail("unknown placeholder returns none";"expected none but got a value");
    $none pass("unknown placeholder returns none")
  };
  let results = str.array_push(results;r_unknown);

  // T5.3-e: multiple entries survive until explicitly wiped
  let m5 = eph.new_map("session-test-005";3600);
  let m5 = eph.put(m5;"__ph_a__";"alpha");
  let m5 = eph.put(m5;"__ph_b__";"beta");
  let r_multi_a = eph.get(m5;"__ph_a__")|{
    $some:v assert_eq("multi-entry: first survives";v;"alpha");
    $none fail("multi-entry: first survives";"expected alpha but got none")
  };
  let r_multi_b = eph.get(m5;"__ph_b__")|{
    $some:v assert_eq("multi-entry: second survives";v;"beta");
    $none fail("multi-entry: second survives";"expected beta but got none")
  };
  let results = str.array_push(results;r_multi_a);
  let results = str.array_push(results;r_multi_b);

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
