// T5.1 — Settings storage unit tests
// Tests set_str/get_str, set_bool/get_bool, set_int/get_int round-trips,
// missing-key error, key overwrite, and namespace preservation.

m=tests.unit.storage.test_settings;

i=db:core.storage.db;
i=set:core.storage.settings;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }
f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}
f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}
f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}
f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}
pub f=run_all():bool{
  let results = @($result)[];
  let store = db.open(":memory:")|{
    $ok:s s;
    $err:e {
      log.error("failed to open test db");
      <false
    }
  };

  // T5.1-a: set_str / get_str round-trip
  set.set_str(store;"loke.test.str_key";"hello";"test");
  let r_str = get_str(store;"loke.test.str_key")|{
    $ok:v assert_eq("set_str/get_str round-trip";v;"hello");
    $err:e fail("set_str/get_str round-trip";"get_str returned error")
  };
  let results = str.array_push(results;r_str);

  // T5.1-b: set_bool / get_bool round-trip — true
  set.set_bool(store;"loke.test.bool_true";"true";"test");
  let r_bool_true = set.get_bool(store;"loke.test.bool_true")|{
    $ok:v assert_true("set_bool/get_bool true round-trip";v);
    $err:e fail("set_bool/get_bool true round-trip";"get_bool returned error")
  };
  let results = str.array_push(results;r_bool_true);

  // T5.1-c: set_bool / get_bool round-trip — false
  set.set_bool(store;"loke.test.bool_false";false;"test");
  let r_bool_false = set.get_bool(store;"loke.test.bool_false")|{
    $ok:v assert_false("set_bool/get_bool false round-trip";v);
    $err:e fail("set_bool/get_bool false round-trip";"get_bool returned error")
  };
  let results = str.array_push(results;r_bool_false);

  // T5.1-d: set_int / get_int round-trip
  set.set_int(store;"loke.test.int_key";42;"test");
  let r_int = set.get_int(store;"loke.test.int_key")|{
    $ok:v assert_eq("set_int/get_int round-trip";str.from_int(v);"42");
    $err:e fail("set_int/get_int round-trip";"get_int returned error")
  };
  let results = str.array_push(results;r_int);

  // T5.1-e: get_str on missing key returns error variant
  let r_missing = set.get_str(store;"loke.test.no_such_key")|{
    $ok:v fail("get_str missing key";"expected error but got ok");
    $err:e pass("get_str missing key returns error")
  };
  let results = str.array_push(results;r_missing);

  // T5.1-f: get_bool on non-bool key returns type-mismatch error
  set.set_str(store;"loke.test.str_not_bool";"hello";"test");
  let r_type_mismatch = set.get_bool(store;"loke.test.str_not_bool")|{
    $ok:v fail("get_bool on str key";"expected type mismatch error but got ok");
    $err:e pass("get_bool on non-bool key returns error")
  };
  let results = str.array_push(results;r_type_mismatch);

  // T5.1-g: overwriting a key returns the new value on next get
  set.set_str(store;"loke.test.overwrite";"first";"test");
  set.set_str(store;"loke.test.overwrite";"second";"test");
  let r_overwrite = set.get_str(store;"loke.test.overwrite")|{
    $ok:v assert_eq("overwrite key returns new value";v;"second");
    $err:e fail("overwrite key returns new value";"get_str returned error after overwrite")
  };
  let results = str.array_push(results;r_overwrite);

  // T5.1-h: namespace parameter is preserved (list_ns returns only keys in that namespace)
  set.set_str(store;"loke.ns.alpha";"a";"ns_test");
  set.set_str(store;"loke.ns.beta";"b";"ns_test");
  set.set_str(store;"loke.other.key";"x";"other_ns");
  let r_ns = set.list_ns(store;"ns_test")|{
    $ok:keys {
      let n = str.array_len(keys);
      assert_eq("namespace keys count";str.from_int(n);"2")
    };
    $err:e fail("namespace parameter preserved";"list_ns returned error")
  };
  let results = str.array_push(results;r_ns);

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
