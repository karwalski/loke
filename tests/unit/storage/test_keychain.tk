// T5.4 — Keychain unit tests
// Tests: store and retrieve round-trip API key, retrieve unknown service returns
// none, delete makes subsequent retrieve return none, service name preserved exactly.

m=tests.unit.storage.test_keychain;

i=kc:core.storage.keychain;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }
f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}
f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}
f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}
f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}
pub f=run_all():bool{
  let results = @($result)[];

  // T5.4-a: store and retrieve round-trip API key
  let stored = kc.set_api_key("test_provider_t541";"sk-test-abc123");
  let r_store_ok = assert_true("set_api_key returns true";stored);
  let results = str.array_push(results;r_store_ok);

  let r_roundtrip = kc.get_api_key("test_provider_t541")|{
    $some:v assert_eq("set/get_api_key round-trip";v;"sk-test-abc123");
    $none fail("set/get_api_key round-trip";"expected value but got none")
  };
  let results = str.array_push(results;r_roundtrip);

  // T5.4-b: retrieve unknown service returns none
  let r_unknown = kc.get_api_key("__no_such_provider_xyz__")|{
    $some:v fail("retrieve unknown service returns none";"expected none but got a value");
    $none pass("retrieve unknown service returns none")
  };
  let results = str.array_push(results;r_unknown);

  // T5.4-c: delete makes subsequent retrieve return none
  kc.set_api_key("test_provider_t54c";"sk-delete-me");
  let before_delete = kc.get_api_key("test_provider_t54c")|{
    $some:v true;
    $none false
  };
  let r_before = assert_true("key present before delete";before_delete);
  let results = str.array_push(results;r_before);

  kc.delete_key(str.concat("api_key.";"test_provider_t54c"));
  let r_after_delete = kc.get_api_key("test_provider_t54c")|{
    $some:v fail("delete makes retrieve return none";"expected none after delete but got value");
    $none pass("delete makes retrieve return none")
  };
  let results = str.array_push(results;r_after_delete);

  // T5.4-d: service name is preserved exactly in storage
  // Store under a provider name with mixed case and retrieve it back verbatim.
  let exact_provider = "OpenAI_GPT4-Turbo";
  kc.set_api_key(exact_provider;"sk-exact-service-check");
  let r_exact = kc.get_api_key(exact_provider)|{
    $some:v assert_eq("service name preserved exactly";v;"sk-exact-service-check");
    $none fail("service name preserved exactly";"expected value but got none — provider name may have been mangled")
  };
  let results = str.array_push(results;r_exact);

  // T5.4-e: has_key reflects set/delete lifecycle
  kc.set_api_key("test_provider_t54e";"sk-lifecycle");
  let r_has_after_set = assert_true("has_key true after set";kc.has_key(str.concat("api_key.";"test_provider_t54e")));
  let results = str.array_push(results;r_has_after_set);

  kc.delete_key(str.concat("api_key.";"test_provider_t54e"));
  let r_has_after_del = assert_false("has_key false after delete";kc.has_key(str.concat("api_key.";"test_provider_t54e")));
  let results = str.array_push(results;r_has_after_del);

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
