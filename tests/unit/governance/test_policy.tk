// T4.3 — Policy unit tests.
// Verifies classify_risk(), evaluate(), and controls_for_risk() behaviour.

m=tests.unit.governance.test_policy;

i=pol:core.governance.policy;
i=gt:core.governance.types;
i=t:shared.types;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T4.3-a: RESTRICTED sensitivity → always $high regardless of base risk
  let risk_restricted=pol.classify_risk(
    $sensitivity_level.$restricted;
    $gt.risk_tier.$low;
    0.0
  );
  results=str.array_push(results;assert_eq("restricted sensitivity → high risk";"HIGH";gt.risk_label(risk_restricted)));

  // T4.3-b: CONFIDENTIAL + low use-case → escalates to medium
  let risk_conf_low=pol.classify_risk(
    $sensitivity_level.$confidential;
    $gt.risk_tier.$low;
    0.0
  );
  results=str.array_push(results;assert_eq("confidential+low → medium";"MEDIUM";gt.risk_label(risk_conf_low)));

  // T4.3-c: LOW sensitivity + low risk + cost <=1.0 → stays low
  let risk_low_low=pol.classify_risk(
    $sensitivity_level.$public;
    $gt.risk_tier.$low;
    0.5
  );
  results=str.array_push(results;assert_eq("public+low+cheap → low";"LOW";gt.risk_label(risk_low_low)));

  // T4.3-d: LOW sensitivity + low risk + cost >1.0 → escalates to medium
  let risk_cost_escalate=pol.classify_risk(
    $sensitivity_level.$public;
    $gt.risk_tier.$low;
    1.5
  );
  results=str.array_push(results;assert_eq("cost >1 escalates low → medium";"MEDIUM";gt.risk_label(risk_cost_escalate)));

  // T4.3-e: evaluate low risk, public sensitivity → $allow
  let decision_allow=pol.evaluate(
    $gt.risk_tier.$low;
    $sensitivity_level.$public;
    "gpt-4o";
    "chat-completion"
  );
  let allow_label=gt.decision_label(decision_allow);
  results=str.array_push(results;assert_eq("low/public → ALLOW";"ALLOW";allow_label));

  // T4.3-f: evaluate medium risk → allow_with_warning
  let decision_warn=pol.evaluate(
    $gt.risk_tier.$medium;
    $sensitivity_level.$internal;
    "gpt-4o";
    "chat-completion"
  );
  let warn_label=gt.decision_label(decision_warn);
  results=str.array_push(results;assert_eq("medium risk → ALLOW_WITH_WARNING";"ALLOW_WITH_WARNING";warn_label));

  // T4.3-g: evaluate high risk + restricted → require_approval
  let decision_approval=pol.evaluate(
    $gt.risk_tier.$high;
    $sensitivity_level.$restricted;
    "gpt-4o";
    "data-analysis"
  );
  let approval_label=gt.decision_label(decision_approval);
  results=str.array_push(results;assert_eq("high+restricted → REQUIRE_APPROVAL";"REQUIRE_APPROVAL";approval_label));

  // T4.3-h: controls_for_risk low/public — always contains "audit-logging"
  let controls_low=pol.controls_for_risk($gt.risk_tier.$low;$sensitivity_level.$public);
  let has_audit=false;
  let ci=0;
  let cn=str.array_len(controls_low);
  loop{
    if ci>=cn{ break }else{
      let ctrl=str.array_get(controls_low;ci);
      if str.eq(ctrl;"audit-logging"){ let has_audit=true }else{};
      ci=ci+1
    }
  };
  results=str.array_push(results;assert_true("controls always include audit-logging";has_audit));

  // T4.3-i: controls_for_risk high risk — contains "enhanced-audit"
  let controls_high=pol.controls_for_risk($gt.risk_tier.$high;$sensitivity_level.$internal);
  let has_enhanced=false;
  let hi=0;
  let hn=str.array_len(controls_high);
  loop{
    if hi>=hn{ break }else{
      let ctrl=str.array_get(controls_high;hi);
      if str.eq(ctrl;"enhanced-audit"){ let has_enhanced=true }else{};
      hi=hi+1
    }
  };
  results=str.array_push(results;assert_true("high risk controls include enhanced-audit";has_enhanced));

  // T4.3-j: controls_for_risk restricted — contains "local-only-routing"
  let controls_restricted=pol.controls_for_risk($gt.risk_tier.$low;$sensitivity_level.$restricted);
  let has_local=false;
  let ri=0;
  let rn=str.array_len(controls_restricted);
  loop{
    if ri>=rn{ break }else{
      let ctrl=str.array_get(controls_restricted;ri);
      if str.eq(ctrl;"local-only-routing"){ let has_local=true }else{};
      ri=ri+1
    }
  };
  results=str.array_push(results;assert_true("restricted controls include local-only-routing";has_local));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
