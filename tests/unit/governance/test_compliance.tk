// T4.6 — Compliance unit tests.
// Verifies run_gdpr_checks(), run_hipaa_checks(), format_report(), and overall status logic.

m=tests.unit.governance.test_compliance;

i=comp:core.governance.compliance;
i=db:core.storage.db;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let store=db.open(":memory:")|{
    $ok:s s;
    $err:e {
      log.error("failed to open in-memory store for compliance tests");
      <false
    }
  };

  let results=@($result)[];

  // T4.6-a: run_gdpr_checks returns a report with framework="GDPR"
  let gdpr=comp.run_gdpr_checks(store);
  results=str.array_push(results;assert_eq("gdpr report framework";"GDPR";gdpr.framework));

  // T4.6-b: GDPR report has at least one check
  results=str.array_push(results;assert_true("gdpr report has checks";str.array_len(gdpr.checks)>0));

  // T4.6-c: GDPR overall status is non-empty
  results=str.array_push(results;assert_true("gdpr overall non-empty";str.len(gdpr.overall)>0));

  // T4.6-d: GDPR overall is WARN (two checks are WARN, none FAIL per source)
  results=str.array_push(results;assert_eq("gdpr overall=WARN";"WARN";gdpr.overall));

  // T4.6-e: run_hipaa_checks returns a report with framework="HIPAA"
  let hipaa=comp.run_hipaa_checks(store);
  results=str.array_push(results;assert_eq("hipaa report framework";"HIPAA";hipaa.framework));

  // T4.6-f: HIPAA report has at least one check
  results=str.array_push(results;assert_true("hipaa report has checks";str.array_len(hipaa.checks)>0));

  // T4.6-g: HIPAA overall is WARN (two WARN checks per source, no FAIL)
  results=str.array_push(results;assert_eq("hipaa overall=WARN";"WARN";hipaa.overall));

  // T4.6-h: format_report on GDPR report includes "GDPR" in output
  let gdpr_formatted=comp.format_report(gdpr);
  results=str.array_push(results;assert_true("formatted gdpr contains GDPR";str.contains(gdpr_formatted;"GDPR")));

  // T4.6-i: format_report includes the overall status
  results=str.array_push(results;assert_true("formatted gdpr contains overall status";str.contains(gdpr_formatted;gdpr.overall)));

  // T4.6-j: format_report on HIPAA report includes "HIPAA"
  let hipaa_formatted=comp.format_report(hipaa);
  results=str.array_push(results;assert_true("formatted hipaa contains HIPAA";str.contains(hipaa_formatted;"HIPAA")));

  // T4.6-k: format_report includes [PASS] prefix for passing checks
  results=str.array_push(results;assert_true("formatted gdpr contains [PASS]";str.contains(gdpr_formatted;"[PASS]")));

  // T4.6-l: format_report includes [WARN] prefix for warning checks
  results=str.array_push(results;assert_true("formatted gdpr contains [WARN]";str.contains(gdpr_formatted;"[WARN]")));

  // T4.6-m: GDPR report generated_at is non-zero (epoch seconds)
  results=str.array_push(results;assert_true("gdpr generated_at non-zero";gdpr.generated_at>0));

  // T4.6-n: HIPAA report generated_at is non-zero
  results=str.array_push(results;assert_true("hipaa generated_at non-zero";hipaa.generated_at>0));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
