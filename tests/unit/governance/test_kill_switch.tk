// T4.1 — Kill switch unit tests.
// Verifies state load, engage, release, format_widget, and auto_release behaviour.

m=tests.unit.governance.test_kill_switch;

i=ks:core.governance.kill_switch;
i=db:core.storage.db;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let store=db.open(":memory:")|{
    $ok:s s;
    $err:e {
      log.error("failed to open in-memory store for kill_switch tests");
      <false
    }
  };

  let results=@($result)[];

  // T4.1-a: load_state on a fresh store → engaged=false
  let fresh_state=ks.load_state(store);
  results=str.array_push(results;assert_false("fresh store engaged=false";fresh_state.engaged));

  // T4.1-b: after engage(), is_engaged() → true
  ks.engage(store;"test reason";0);
  results=str.array_push(results;assert_true("is_engaged after engage";ks.is_engaged(store)));

  // T4.1-c: after engage() then release(), is_engaged() → false
  ks.release(store);
  results=str.array_push(results;assert_false("is_engaged after release";ks.is_engaged(store)));

  // T4.1-d: engaged state has correct reason field
  ks.engage(store;"compliance-breach";0);
  let engaged_state=ks.load_state(store);
  results=str.array_push(results;assert_eq("engaged state reason field";"compliance-breach";engaged_state.reason));

  // T4.1-e: format_widget on engaged state contains "ENGAGED"
  let widget_on=ks.format_widget(engaged_state);
  results=str.array_push(results;assert_true("format_widget engaged contains ENGAGED";str.contains(widget_on;"ENGAGED")));

  // T4.1-f: format_widget on disengaged state contains "DISENGAGED"
  ks.release(store);
  let disengaged_state=ks.load_state(store);
  let widget_off=ks.format_widget(disengaged_state);
  results=str.array_push(results;assert_true("format_widget disengaged contains DISENGAGED";str.contains(widget_off;"DISENGAGED")));

  // T4.1-g: engage with auto_release_minutes=0 → auto_release_at=0 in state
  ks.engage(store;"manual only";0);
  let manual_state=ks.load_state(store);
  results=str.array_push(results;assert_eq("auto_release_minutes=0 yields auto_release_at=0";"0";str.from_int(manual_state.auto_release_at)));

  // T4.1-h: check_auto_release on a non-auto (manual) state → false
  ks.engage(store;"no auto";0);
  results=str.array_push(results;assert_false("check_auto_release non-auto state is false";ks.check_auto_release(store)));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
