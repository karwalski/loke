// T4.2 — Quota unit tests.
// Verifies check(), record_usage(), set_rule(), list_rules(), and namespace isolation.

m=tests.unit.governance.test_quota;

i=quota:core.governance.quota;
i=db:core.storage.db;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let store=db.open(":memory:")|{
    $ok:s s;
    $err:e {
      log.error("failed to open in-memory store for quota tests");
      <false
    }
  };

  quota.ensure_tables(store);

  let results=@($result)[];

  // T4.2-a: check on scope with no rule → exceeded=false, remaining_pct=100
  let no_rule_status=quota.check(store;"unknown-scope";0;0.0);
  results=str.array_push(results;assert_false("no rule → not exceeded";no_rule_status.exceeded));
  results=str.array_push(results;assert_eq("no rule → remaining 100%";"100";str.from_int(str.to_int(str.from_float(no_rule_status.remaining_pct)))));

  // Insert a rule: 1000 tokens all-time for "team-a"
  let rule_a=quota.$quota_rule{
    id:"rule-team-a";
    scope:"team-a";
    limit_tokens:1000;
    limit_cost_usd:0.0;
    period:"all-time"
  };
  quota.set_rule(store;rule_a);

  // T4.2-b: quota not exceeded when usage is below limit
  let status_below=quota.check(store;"team-a";500;0.0);
  results=str.array_push(results;assert_false("usage below limit → not exceeded";status_below.exceeded));

  // T4.2-c: record usage and check again — remaining_pct should decrease
  quota.record_usage(store;"team-a";500;0.0);
  let status_after=quota.check(store;"team-a";0;0.0);
  results=str.array_push(results;assert_false("after recording 500 tokens not yet exceeded";status_after.exceeded));

  // T4.2-d: record usage up to limit → exceeded
  quota.record_usage(store;"team-a";500;0.0);
  let status_full=quota.check(store;"team-a";0;0.0);
  results=str.array_push(results;assert_true("at-limit → exceeded";status_full.exceeded));

  // T4.2-e: namespace isolation — different scope is unaffected
  let status_other=quota.check(store;"team-b";0;0.0);
  results=str.array_push(results;assert_false("other scope unaffected";status_other.exceeded));

  // T4.2-f: list_rules returns the inserted rule
  let rules=quota.list_rules(store);
  results=str.array_push(results;assert_true("list_rules returns at least one rule";str.array_len(rules)>=1));

  // T4.2-g: set_rule returns true on success
  let rule_b=quota.$quota_rule{
    id:"rule-team-b";
    scope:"team-b";
    limit_tokens:2000;
    limit_cost_usd:0.0;
    period:"daily"
  };
  let set_ok=quota.set_rule(store;rule_b);
  results=str.array_push(results;assert_true("set_rule returns true";set_ok));

  // T4.2-h: record_usage returns false when no rule for scope
  let rec_no_rule=quota.record_usage(store;"no-such-scope";100;0.0);
  results=str.array_push(results;assert_false("record_usage with no rule returns false";rec_no_rule));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
