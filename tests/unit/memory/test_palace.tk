// T6.1 — Memory Palace unit tests
// Verifies palace opening, wing listing, hall listing, room listing, status, and walk output.

m=tests.unit.memory.test_palace;

i=palace:core.memory.palace;
i=mt:core.memory.types;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_gt(n:str;got:i32;min:i32):$result{
  if got > min{ <pass(n) }else{
    <fail(n;str.concat("expected > ";str.concat(str.from_int(min);str.concat(" got ";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T6.1-a: Open a fresh palace in a temp directory — no error
  let tmp_dir = "/tmp/loke_test_palace";
  let open_result = palace.open(tmp_dir);
  let opened = open_result|{ $ok:_ { true }; $err:_ { false } };
  results = str.array_push(results;assert_true("palace opens without error";opened));

  // Proceed only if open succeeded
  if opened{
    let p = open_result|{ $ok:p { p }; $err:_ { $palace{conn:$db_conn{};data_dir:""} } };

    // T6.1-b: A fresh palace has zero drawers (total_drawers == 0)
    let st_result = palace.status(p);
    let total_drawers_zero = st_result|{
      $ok:st { st.total_drawers == 0 };
      $err:_ { false }
    };
    results = str.array_push(results;assert_true("fresh palace has zero drawers";total_drawers_zero));

    // T6.1-c: list_wings returns at least the 4 default wings (merged from mt.default_wings)
    let wings_result = palace.list_wings(p);
    let wings_count_ok = wings_result|{
      $ok:wings { str.array_len(wings) >= 4 };
      $err:_ { false }
    };
    results = str.array_push(results;assert_true("fresh palace has at least 4 default wings";wings_count_ok));

    // T6.1-d: Default wings include "work"
    let has_work_wing = wings_result|{
      $ok:wings {
        let found = false;
        let i = 0;
        let n = str.array_len(wings);
        loop{
          if i >= n{ break }else{
            let w = str.array_get(wings;i);
            if str.eq(w;"work"){ let found = true }else{};
            i = i + 1
          }
        };
        found
      };
      $err:_ { false }
    };
    results = str.array_push(results;assert_true("default wings include work";has_work_wing));

    // T6.1-e: Default wings include "personal"
    let has_personal_wing = wings_result|{
      $ok:wings {
        let found = false;
        let i = 0;
        let n = str.array_len(wings);
        loop{
          if i >= n{ break }else{
            let w = str.array_get(wings;i);
            if str.eq(w;"personal"){ let found = true }else{};
            i = i + 1
          }
        };
        found
      };
      $err:_ { false }
    };
    results = str.array_push(results;assert_true("default wings include personal";has_personal_wing));

    // T6.1-f: walk returns a non-empty string
    let walk_result = palace.walk(p);
    let walk_non_empty = walk_result|{
      $ok:s { str.len(s) > 0 };
      $err:_ { false }
    };
    results = str.array_push(results;assert_true("palace walk returns non-empty string";walk_non_empty));

    // T6.1-g: walk output contains "Wing:"
    let walk_contains_wing = walk_result|{
      $ok:s { str.contains(s;"Wing:") };
      $err:_ { false }
    };
    results = str.array_push(results;assert_true("palace walk output contains Wing:";walk_contains_wing));

    // T6.1-h: list_halls on a known wing returns no error
    let halls_result = palace.list_halls(p;"work");
    let halls_ok = halls_result|{ $ok:_ { true }; $err:_ { false } };
    results = str.array_push(results;assert_true("list_halls on work wing succeeds";halls_ok));

    // T6.1-i: list_rooms on work/Projects returns no error
    let rooms_result = palace.list_rooms(p;"work";"Projects");
    let rooms_ok = rooms_result|{ $ok:_ { true }; $err:_ { false } };
    results = str.array_push(results;assert_true("list_rooms on work/Projects succeeds";rooms_ok));

    // T6.1-j: status total_wings matches list_wings count for fresh palace
    let wings_count = wings_result|{ $ok:wings { str.array_len(wings) }; $err:_ { 0 } };
    let status_wings = st_result|{ $ok:st { st.total_wings }; $err:_ { 99 } };
    // On a fresh palace the DB has no rows yet so total_wings from COUNT(DISTINCT wing) is 0,
    // while list_wings merges defaults. We assert status call succeeds and total_wings >= 0.
    let status_wings_ok = st_result|{ $ok:_ { true }; $err:_ { false } };
    results = str.array_push(results;assert_true("palace status call succeeds";status_wings_ok))
  }else{};

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i + 1
    }
  };
  <all
}
