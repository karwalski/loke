// T6.2 — Knowledge Graph unit tests
// Verifies entity upsert, relation add, neighbour traversal, entity search, and deletion.

m=tests.unit.memory.test_graph;

i=graph:core.memory.graph;
i=mt:core.memory.types;
i=palace:core.memory.palace;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_gt(n:str;got:i32;min:i32):$result{
  if got > min{ <pass(n) }else{
    <fail(n;str.concat("expected > ";str.concat(str.from_int(min);str.concat(" got ";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // Open a fresh in-memory palace for graph tests
  let tmp_dir = "/tmp/loke_test_graph";
  let open_result = palace.open(tmp_dir);
  let opened = open_result|{ $ok:_ { true }; $err:_ { false } };
  results = str.array_push(results;assert_true("palace opens for graph tests";opened));

  if opened{
    let p = open_result|{ $ok:p { p }; $err:_ { $palace{conn:$db_conn{};data_dir:""} } };

    // T6.2-a: upsert_entity returns true on first insert
    let ent_a = $graph.entity{
      id:"node-a";
      name:"Alice";
      kind:"person";
      summary:"Senior engineer";
      confidence:0.9;
      created_at:1700000000
    };
    let upsert_ok = graph.upsert_entity(p;ent_a);
    results = str.array_push(results;assert_true("upsert_entity returns true";upsert_ok));

    // T6.2-b: Upserting a second entity also returns true
    let ent_b = $graph.entity{
      id:"node-b";
      name:"Bob";
      kind:"person";
      summary:"Product manager";
      confidence:0.85;
      created_at:1700000100
    };
    let upsert_b_ok = graph.upsert_entity(p;ent_b);
    results = str.array_push(results;assert_true("upsert_entity second node returns true";upsert_b_ok));

    // T6.2-c: add_relation between existing entities returns true
    let rel = $graph.relation{
      from_id:"node-a";
      to_id:"node-b";
      kind:"works_with";
      weight:0.7;
      created_at:1700000200
    };
    let rel_ok = graph.add_relation(p;rel);
    results = str.array_push(results;assert_true("add_relation returns true";rel_ok));

    // T6.2-d: neighbours from node-a at depth 1 includes both entities
    let nb = graph.neighbours(p;"node-a";1);
    let entities_count = str.array_len(nb.entities);
    results = str.array_push(results;assert_true("neighbours depth 1 returns at least 1 entity";entities_count >= 1));

    // T6.2-e: neighbours result includes at least 1 relation
    let relations_count = str.array_len(nb.relations);
    results = str.array_push(results;assert_true("neighbours depth 1 returns at least 1 relation";relations_count >= 1));

    // T6.2-f: search_entities with matching substring returns results
    let search_results = graph.search_entities(p;"Alice");
    let search_count = str.array_len(search_results);
    results = str.array_push(results;assert_true("search_entities finds Alice";search_count >= 1));

    // T6.2-g: search_entities with non-matching substring returns empty
    let empty_results = graph.search_entities(p;"xyznotfound");
    let empty_count = str.array_len(empty_results);
    results = str.array_push(results;assert_true("search_entities returns empty for unknown query";empty_count == 0));

    // T6.2-h: delete_entity removes node-a and returns true
    let del_ok = graph.delete_entity(p;"node-a");
    results = str.array_push(results;assert_true("delete_entity returns true";del_ok));

    // T6.2-i: search for deleted entity returns empty
    let after_del = graph.search_entities(p;"Alice");
    let after_del_count = str.array_len(after_del);
    results = str.array_push(results;assert_true("search_entities returns empty after deletion";after_del_count == 0));

    // T6.2-j: neighbours on deleted entity returns empty graph_result
    let nb_del = graph.neighbours(p;"node-a";1);
    let nb_del_entities = str.array_len(nb_del.entities);
    results = str.array_push(results;assert_true("neighbours on deleted entity returns zero entities";nb_del_entities == 0))
  }else{};

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i + 1
    }
  };
  <all
}
