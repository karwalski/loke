// T6.4 — AAAK encoder unit tests
// Verifies encode_fact, encode_text, decode, measure_savings, and default_level.

m=tests.unit.memory.test_aaak;

i=aaak:core.memory.aaak;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  let lvl = aaak.default_level();

  // T6.4-a: encode_fact on non-empty input returns non-empty string
  let fact = "Alice is the lead engineer";
  let encoded = aaak.encode_fact(fact;lvl);
  results = str.array_push(results;assert_true("encode_fact returns non-empty string";str.len(encoded) > 0));

  // T6.4-b: encode_fact on "X is Y" pattern produces "X: Y" shorthand
  let encoded_copula = aaak.encode_fact("Alice is the lead engineer";lvl);
  results = str.array_push(results;assert_true("encode_fact copula contains colon";str.contains(encoded_copula;":")));

  // T6.4-c: encode_fact on decision pattern produces "DEC:" prefix
  let decision_fact = "We decided to use Rust because of performance";
  let encoded_dec = aaak.encode_fact(decision_fact;lvl);
  results = str.array_push(results;assert_true("encode_fact decision produces DEC: prefix";str.contains(encoded_dec;"DEC:")));

  // T6.4-d: encode_fact on decision with reason contains the arrow separator
  results = str.array_push(results;assert_true("encode_fact decision with reason contains arrow";str.contains(encoded_dec;"←")));

  // T6.4-e: encode_fact on "X manages Y" pattern produces "(lead):" shorthand
  let manages_fact = "Alice manages the backend team";
  let encoded_manages = aaak.encode_fact(manages_fact;lvl);
  results = str.array_push(results;assert_true("encode_fact manages produces lead shorthand";str.contains(encoded_manages;"(lead):")));

  // T6.4-f: encode_text on multi-sentence input returns $aaak_doc with non-empty raw
  let multi = "Alice is the lead engineer. Bob manages the backend team. We decided to use Rust because of performance";
  let doc = aaak.encode_text(multi;lvl);
  results = str.array_push(results;assert_true("encode_text raw is non-empty";str.len(doc.raw) > 0));

  // T6.4-g: encode_text doc entries array has at least one entry
  let entry_count = str.array_len(doc.entries);
  results = str.array_push(results;assert_true("encode_text produces at least one entry";entry_count >= 1));

  // T6.4-h: encode_text aaak_len <= source_len (compression does not expand)
  results = str.array_push(results;assert_true("encode_text aaak_len <= source_len";doc.aaak_len <= doc.source_len));

  // T6.4-i: measure_savings on empty original returns 0.0
  let savings_empty = aaak.measure_savings("";"");
  results = str.array_push(results;assert_true("measure_savings empty original returns 0.0";savings_empty == 0.0));

  // T6.4-j: measure_savings when aaak is shorter returns positive value
  let long_text = "The quick brown fox jumps over the lazy dog in the park";
  let short_aaak = "quick brown fox jumps lazy dog park";
  let savings_pos = aaak.measure_savings(long_text;short_aaak);
  results = str.array_push(results;assert_true("measure_savings returns positive when aaak is shorter";savings_pos > 0.0));

  // T6.4-k: decode on "DEC: x ← y" expands to "Decision: x, because y"
  let dec_aaak = "DEC: use Rust ← performance";
  let decoded = aaak.decode(dec_aaak);
  results = str.array_push(results;assert_true("decode DEC: prefix expands to Decision:";str.contains(decoded;"Decision:")));
  results = str.array_push(results;assert_true("decode DEC: reason expands to because";str.contains(decoded;"because")));

  // T6.4-l: decode on "TEAM: x" expands to "Team: x"
  let team_aaak = "TEAM: Alice Bob Charlie";
  let decoded_team = aaak.decode(team_aaak);
  results = str.array_push(results;assert_true("decode TEAM: prefix expands to Team:";str.contains(decoded_team;"Team:")));

  // T6.4-m: encode_text multi-sentence joins parts with " | "
  let two_sent = "Alice is the lead. Bob manages backend";
  let two_doc = aaak.encode_text(two_sent;lvl);
  results = str.array_push(results;assert_true("encode_text two sentences joined with pipe";str.contains(two_doc.raw;" | ")));

  // T6.4-n: encode_fact on empty string returns empty string
  let empty_encoded = aaak.encode_fact("";lvl);
  results = str.array_push(results;assert_true("encode_fact empty input returns empty";str.len(empty_encoded) == 0));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i + 1
    }
  };
  <all
}
