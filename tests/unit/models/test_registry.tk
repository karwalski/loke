// T7.1 — Model capability registry unit tests
// Tests registry construction, default entries, task-based lookup,
// by-ID lookup (found and not found), find_best, and register.

m=tests.unit.models.test_registry;

i=reg:models.registry;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=assert_int_eq(name:str;got:i32;want:i32):$result{
  if got == want{ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T7.1-a: new_registry() returns a registry (non-crashing)
  let registry=reg.new_registry();
  results=str.array_push(results;pass("new_registry does not crash"));

  // T7.1-b: registry has at least one model registered
  results=str.array_push(results;assert_true("registry has entries";str.array_len(registry.entries) > 0));

  // T7.1-c: default entries count is >= 10 (many task/model combinations registered)
  results=str.array_push(results;assert_true("registry has at least 10 entries";str.array_len(registry.entries) >= 10));

  // T7.1-d: lookup by known model ID "claude-3-5-sonnet-20241022" returns that model
  let sonnet_result=reg.by_id(registry;"claude-3-5-sonnet-20241022");
  sonnet_result|{
    $ok:m {
      results=str.array_push(results;assert_eq("by_id sonnet model_id";m.model_id;"claude-3-5-sonnet-20241022"));
    };
    $err:e {
      results=str.array_push(results;fail("by_id sonnet found";"expected ok, got error"));
    }
  };

  // T7.1-e: lookup by known model ID "gpt-4o" returns that model
  let gpt4o_result=reg.by_id(registry;"gpt-4o");
  gpt4o_result|{
    $ok:m {
      results=str.array_push(results;assert_eq("by_id gpt-4o model_id";m.model_id;"gpt-4o"));
    };
    $err:e {
      results=str.array_push(results;fail("by_id gpt-4o found";"expected ok, got error"));
    }
  };

  // T7.1-f: lookup by known model ID "qwen2.5:7b" returns a local model
  let qwen_result=reg.by_id(registry;"qwen2.5:7b");
  qwen_result|{
    $ok:m {
      results=str.array_push(results;assert_true("qwen2.5:7b is local";m.local));
    };
    $err:e {
      results=str.array_push(results;fail("by_id qwen2.5:7b found";"expected ok, got error"));
    }
  };

  // T7.1-g: lookup by unknown model ID returns $err
  let unknown_result=reg.by_id(registry;"this-model-does-not-exist-xyz");
  unknown_result|{
    $ok:m {
      results=str.array_push(results;fail("by_id unknown returns err";"expected error, got ok"));
    };
    $err:e {
      results=str.array_push(results;pass("by_id unknown returns error variant"));
    }
  };

  // T7.1-h: find_for_task with $chat returns non-empty results
  let chat_models=reg.find_for_task(registry;reg.$task_type.$chat;false);
  results=str.array_push(results;assert_true("find_for_task chat non-empty";str.array_len(chat_models) > 0));

  // T7.1-i: find_for_task with local_only=true returns only local models
  let local_models=reg.find_for_task(registry;reg.$task_type.$chat;true);
  results=str.array_push(results;assert_true("find_for_task local only non-empty";str.array_len(local_models) > 0));
  // Verify first result is local
  let first_local=str.array_get(local_models;0);
  results=str.array_push(results;assert_true("find_for_task first local model is local";first_local.local));

  // T7.1-j: find_best for $chat $background tier returns a model
  let best_result=reg.find_best(registry;reg.$task_type.$chat;false;$model_tier.$background);
  best_result|{
    $ok:m {
      results=str.array_push(results;assert_true("find_best chat background non-empty model_id";str.len(m.model_id) > 0));
    };
    $err:e {
      results=str.array_push(results;fail("find_best chat background";"expected ok, got error"));
    }
  };

  // T7.1-k: find_best for embedding task finds nomic-embed-text (local, high speed)
  let embed_result=reg.find_best(registry;reg.$task_type.$embedding;true;$model_tier.$background);
  embed_result|{
    $ok:m {
      results=str.array_push(results;assert_true("find_best embedding local non-empty";str.len(m.model_id) > 0));
    };
    $err:e {
      results=str.array_push(results;fail("find_best embedding local";"expected ok, got error"));
    }
  };

  // T7.1-l: register adds a new entry, increasing entry count
  let before_count=str.array_len(registry.entries);
  let new_entry=reg.$model_capability{
    model_id:"test-model-v1";
    provider:$provider.$local;
    task:reg.$task_type.$chat;
    quality_score:0.50;
    speed_tok_s:100.0;
    context_window:4096;
    supports_tools:false;
    local:true
  };
  reg.register(registry;new_entry);
  let after_count=str.array_len(registry.entries);
  results=str.array_push(results;assert_true("register increases entry count";after_count == before_count + 1));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
