// T3.1 — Semantic cache unit tests
// Tests cache configuration defaults, field storage, stats initialisation,
// and the format_stats summary string.

m=tests.unit.optimiser.test_cache;

i=cache:optimiser.cache;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=assert_int_eq(name:str;got:i32;want:i32):$result{
  if got == want{ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=assert_float_eq(name:str;got:f64;want:f64):$result{
  // Compare float representations via string (adequate for known constants)
  let got_s=str.from_float(got);
  let want_s=str.from_float(want);
  if str.eq(got_s;want_s){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want_s;str.concat(" got=";got_s))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T3.1-a: default_config threshold is 0.92
  let cfg=cache.default_config("/tmp/test_cache");
  results=str.array_push(results;assert_float_eq("default threshold";cfg.threshold;0.92));

  // T3.1-b: default_config ttl_seconds is 86400
  results=str.array_push(results;assert_int_eq("default ttl_seconds";cfg.ttl_seconds;86400));

  // T3.1-c: data_dir field is set from parameter
  results=str.array_push(results;assert_eq("data_dir from param";cfg.data_dir;"/tmp/test_cache"));

  // T3.1-d: custom threshold is stored correctly
  let custom=cache.$cache_config{threshold:0.75;ttl_seconds:3600;data_dir:"/var/cache"};
  results=str.array_push(results;assert_float_eq("custom threshold stored";custom.threshold;0.75));

  // T3.1-e: custom ttl_seconds is stored correctly
  results=str.array_push(results;assert_int_eq("custom ttl_seconds stored";custom.ttl_seconds;3600));

  // T3.1-f: custom data_dir is stored correctly
  results=str.array_push(results;assert_eq("custom data_dir stored";custom.data_dir;"/var/cache"));

  // T3.1-g: zero-value stats struct has hits=0
  let stats=cache.$cache_stats{hits:0;misses:0;entries:0;evictions:0};
  results=str.array_push(results;assert_int_eq("stats hits zero";stats.hits;0));

  // T3.1-h: zero-value stats struct has misses=0
  results=str.array_push(results;assert_int_eq("stats misses zero";stats.misses;0));

  // T3.1-i: zero-value stats struct has entries=0
  results=str.array_push(results;assert_int_eq("stats entries zero";stats.entries;0));

  // T3.1-j: zero-value stats struct has evictions=0
  results=str.array_push(results;assert_int_eq("stats evictions zero";stats.evictions;0));

  // T3.1-k: format_stats summary contains "hits"
  let fmt=cache.format_stats(stats);
  results=str.array_push(results;assert_true("format_stats contains hits";str.contains(fmt;"hits")));

  // T3.1-l: format_stats summary contains "misses"
  results=str.array_push(results;assert_true("format_stats contains misses";str.contains(fmt;"misses")));

  // T3.1-m: format_stats summary contains "entries"
  results=str.array_push(results;assert_true("format_stats contains entries";str.contains(fmt;"entries")));

  // T3.1-n: format_stats for known values produces expected string
  let stats2=cache.$cache_stats{hits:42;misses:8;entries:150;evictions:3};
  let fmt2=cache.format_stats(stats2);
  results=str.array_push(results;assert_true("format_stats hit count present";str.contains(fmt2;"42")));
  results=str.array_push(results;assert_true("format_stats miss count present";str.contains(fmt2;"8")));
  results=str.array_push(results;assert_true("format_stats entry count present";str.contains(fmt2;"150")));
  results=str.array_push(results;assert_true("format_stats eviction count present";str.contains(fmt2;"3")));

  // T3.1-o: format_stats output is non-empty
  results=str.array_push(results;assert_true("format_stats non-empty";str.len(fmt2) > 0));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
