// T3.3 — TOON serialiser unit tests
// Tests default_opts, encode/decode round-trips, json_to_toon conversion,
// encode_table format, toon_to_json, and measure_savings.

m=tests.unit.optimiser.test_toon;

i=toon:optimiser.toon;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;v:bool):$result{
  if v{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;v:bool):$result{
  if !v{ <pass(name) }else{ <fail(name;"expected false") }
}

f=assert_int_eq(name:str;got:i32;want:i32):$result{
  if got == want{ <pass(name) }else{
    <fail(name;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T3.3-a: default_opts max_str_len is 200
  let opts=toon.default_opts();
  results=str.array_push(results;assert_true("default max_str_len 200";opts.max_str_len == 200));

  // T3.3-b: default_opts abbreviate_keys is false
  results=str.array_push(results;assert_false("default abbreviate_keys false";opts.abbreviate_keys));

  // T3.3-c: default_opts omit_nulls is true
  results=str.array_push(results;assert_true("default omit_nulls true";opts.omit_nulls));

  // T3.3-d: encode a $str value produces the raw string (no quoting needed for plain text)
  let str_val=toon.$toon_value.$str("hello");
  let encoded=toon.encode(str_val;opts);
  results=str.array_push(results;assert_eq("encode plain str";encoded;"hello"));

  // T3.3-e: encode null produces "~"
  let null_val=toon.$toon_value.$null;
  let enc_null=toon.encode(null_val;opts);
  results=str.array_push(results;assert_eq("encode null is tilde";enc_null;"~"));

  // T3.3-f: encode bool true produces "y"
  let true_val=toon.$toon_value.$bool(true);
  let enc_true=toon.encode(true_val;opts);
  results=str.array_push(results;assert_eq("encode true is y";enc_true;"y"));

  // T3.3-g: encode bool false produces "n"
  let false_val=toon.$toon_value.$bool(false);
  let enc_false=toon.encode(false_val;opts);
  results=str.array_push(results;assert_eq("encode false is n";enc_false;"n"));

  // T3.3-h: encode integer produces decimal string
  let int_val=toon.$toon_value.$int(42);
  let enc_int=toon.encode(int_val;opts);
  results=str.array_push(results;assert_eq("encode int 42";enc_int;"42"));

  // T3.3-i: json_to_toon on a simple JSON object returns non-empty string
  let simple_json="{\"name\":\"Alice\",\"age\":30}";
  let toon_result=toon.json_to_toon(simple_json;opts);
  toon_result|{
    $ok:toon_str {
      results=str.array_push(results;assert_true("json_to_toon non-empty";str.len(toon_str) > 0));
      // T3.3-j: TOON output contains column names from the JSON object
      results=str.array_push(results;assert_true("toon contains name key";str.contains(toon_str;"name")));
      results=str.array_push(results;assert_true("toon contains age key";str.contains(toon_str;"age")));
      // T3.3-k: TOON output contains the value "Alice"
      results=str.array_push(results;assert_true("toon contains Alice value";str.contains(toon_str;"Alice")));
    };
    $err:e {
      results=str.array_push(results;fail("json_to_toon simple object";"unexpected error"));
    }
  };

  // T3.3-l: json_to_toon on a 3-column dataset contains all 3 column names
  let dataset_json="{\"col_a\":\"val1\",\"col_b\":\"val2\",\"col_c\":\"val3\"}";
  let dataset_result=toon.json_to_toon(dataset_json;opts);
  dataset_result|{
    $ok:ds_toon {
      results=str.array_push(results;assert_true("toon contains col_a";str.contains(ds_toon;"col_a")));
      results=str.array_push(results;assert_true("toon contains col_b";str.contains(ds_toon;"col_b")));
      results=str.array_push(results;assert_true("toon contains col_c";str.contains(ds_toon;"col_c")));
    };
    $err:e {
      results=str.array_push(results;fail("json_to_toon 3 columns";"unexpected error"));
    }
  };

  // T3.3-m: encode_table with empty rows returns empty string
  let empty_table=toon.encode_table(@();opts);
  results=str.array_push(results;assert_eq("encode_table empty rows";empty_table;""));

  // T3.3-n: encode_table with one row produces HDR header line
  let row_fields=@(
    toon.$toon_field{key:"id";value:toon.$toon_value.$int(1)};
    toon.$toon_field{key:"label";value:toon.$toon_value.$str("test")}
  );
  let row=toon.$toon_value.$obj(row_fields);
  let table_out=toon.encode_table(@(row);opts);
  results=str.array_push(results;assert_true("encode_table HDR prefix";str.contains(table_out;"HDR[")));
  results=str.array_push(results;assert_true("encode_table contains id column";str.contains(table_out;"id")));
  results=str.array_push(results;assert_true("encode_table contains label column";str.contains(table_out;"label")));

  // T3.3-o: toon_to_json on a simple TOON string returns non-empty string
  let simple_toon="name:Alice|age:30";
  let json_result=toon.toon_to_json(simple_toon);
  json_result|{
    $ok:json_out {
      results=str.array_push(results;assert_true("toon_to_json non-empty";str.len(json_out) > 0));
      results=str.array_push(results;assert_true("toon_to_json contains name";str.contains(json_out;"name")));
    };
    $err:e {
      results=str.array_push(results;fail("toon_to_json simple";"unexpected error"));
    }
  };

  // T3.3-p: measure_savings returns 0.0 when original is empty
  let savings_empty=toon.measure_savings("";"toon");
  results=str.array_push(results;assert_true("measure_savings empty original is 0";savings_empty == 0.0));

  // T3.3-q: measure_savings returns positive value when TOON is shorter than JSON
  let long_json="{\"name\":\"Alice\",\"age\":30,\"city\":\"Sydney\"}";
  let short_toon="name:Alice|age:30|city:Sydney";
  let savings_pos=toon.measure_savings(long_json;short_toon);
  results=str.array_push(results;assert_true("measure_savings positive for compact toon";savings_pos > 0.0));

  // T3.3-r: from_json_str on invalid JSON returns $err
  let bad_result=toon.from_json_str("not json at all {{{");
  bad_result|{
    $ok:_ { results=str.array_push(results;fail("from_json_str invalid json";"expected error, got ok")); };
    $err:_ { results=str.array_push(results;pass("from_json_str invalid json returns err")); }
  };

  // T3.3-s: from_json_str on valid JSON returns $ok
  let good_result=toon.from_json_str("{\"x\":1}");
  good_result|{
    $ok:_ { results=str.array_push(results;pass("from_json_str valid json returns ok")); };
    $err:_ { results=str.array_push(results;fail("from_json_str valid json";"expected ok, got error")); }
  };

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
