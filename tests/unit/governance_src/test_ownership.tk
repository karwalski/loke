// T10.4 — Ownership (governance_src) unit tests.
// Tests assign, get, has_all_owners, missing_roles, and list on the
// loke.governance.ownership module.

m=tests.unit.governance_src.test_ownership;

i=own:loke.governance.ownership;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  // Reset global state
  own.g_ownerships=@();

  let results = @($result)[];

  let alice=own.$owner{
    id:"owner_alice";
    name:"Alice";
    email:"alice@example.com";
    role:"business"
  };

  // T10.4-a: assign stores ownership record
  own.assign("uc_1";"business";alice);
  let uco_opt=own.get("uc_1");
  uco_opt|{
    $some:uco{
      results=str.array_push(results;assert_eq("assign stores use_case_id";"uc_1";uco.use_case_id))
    };
    $none:{
      results=str.array_push(results;fail("assign then get returns some";"returned none"))
    }
  };

  // T10.4-b: get("uc_1") returns Alice's owner in business_owner field
  let uco_opt2=own.get("uc_1");
  uco_opt2|{
    $some:uco{
      uco.business_owner|{
        $some:o{
          results=str.array_push(results;assert_eq("get returns Alice as business owner";"Alice";o.name))
        };
        $none:{
          results=str.array_push(results;fail("business_owner is some after assign";"returned none"))
        }
      }
    };
    $none:{
      results=str.array_push(results;fail("get uc_1 after business assign";"returned none"))
    }
  };

  // T10.4-c: has_all_owners returns false when only business assigned
  let uco_opt3=own.get("uc_1");
  uco_opt3|{
    $some:uco{
      results=str.array_push(results;assert_false("has_all_owners false when roles missing";own.has_all_owners(uco)))
    };
    $none:{
      results=str.array_push(results;fail("get uc_1 for has_all_owners check";"returned none"))
    }
  };

  // T10.4-d: missing_roles returns unassigned roles (technical and risk)
  let uco_opt4=own.get("uc_1");
  uco_opt4|{
    $some:uco{
      let missing=own.missing_roles(uco);
      let missing_len=str.array_len(missing);
      results=str.array_push(results;assert_true("missing_roles returns 2 roles";missing_len == 2))
    };
    $none:{
      results=str.array_push(results;fail("get uc_1 for missing_roles check";"returned none"))
    }
  };

  // T10.4-e: after assigning all required roles, has_all_owners returns true
  let bob=own.$owner{
    id:"owner_bob";
    name:"Bob";
    email:"bob@example.com";
    role:"technical"
  };
  let carol=own.$owner{
    id:"owner_carol";
    name:"Carol";
    email:"carol@example.com";
    role:"risk"
  };
  own.assign("uc_1";"technical";bob);
  own.assign("uc_1";"risk";carol);
  let uco_opt5=own.get("uc_1");
  uco_opt5|{
    $some:uco{
      results=str.array_push(results;assert_true("has_all_owners true when all roles assigned";own.has_all_owners(uco)))
    };
    $none:{
      results=str.array_push(results;fail("get uc_1 after all roles assigned";"returned none"))
    }
  };

  // T10.4-f: missing_roles returns empty when all assigned
  let uco_opt6=own.get("uc_1");
  uco_opt6|{
    $some:uco{
      let missing2=own.missing_roles(uco);
      let missing2_len=str.array_len(missing2);
      results=str.array_push(results;assert_true("missing_roles empty when all assigned";missing2_len == 0))
    };
    $none:{
      results=str.array_push(results;fail("get uc_1 for final missing_roles check";"returned none"))
    }
  };

  // T10.4-g: list returns all assigned owners (at least one record)
  let all_owners=own.list();
  let all_owners_len=str.array_len(all_owners);
  results=str.array_push(results;assert_true("list returns at least one ownership";all_owners_len >= 1));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
