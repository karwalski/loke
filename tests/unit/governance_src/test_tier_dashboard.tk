// T10.5 — Tier dashboard (governance_src) unit tests.
// Tests new_report, update_interactive, recalculate_pcts, report_to_json,
// and divide-by-zero guard on the loke.governance.tier_dashboard module.

m=tests.unit.governance_src.test_tier_dashboard;

i=td:loke.governance.tier_dashboard;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T10.5-a: new_report has all-zero stats
  let report=td.new_report(7);
  results=str.array_push(results;assert_int_eq("new_report interactive_count=0";report.interactive.request_count;0));
  results=str.array_push(results;assert_int_eq("new_report considered_count=0";report.considered.request_count;0));
  results=str.array_push(results;assert_int_eq("new_report background_count=0";report.background.request_count;0));
  results=str.array_push(results;assert_int_eq("new_report total_requests=0";report.total_requests;0));

  // T10.5-b: after update_interactive, interactive request_count = 1
  let report2=td.update_interactive(report;120;4.5;"gpt-4o";50.0;0.02);
  results=str.array_push(results;assert_int_eq("update_interactive increments count";report2.interactive.request_count;1));
  results=str.array_push(results;assert_int_eq("update_interactive increments total";report2.total_requests;1));

  // T10.5-c: after update, recalculate_pcts — interactive_pct > 0
  let report3=td.recalculate_pcts(report2);
  results=str.array_push(results;assert_true("interactive_pct > 0 after recalculate";report3.interactive.request_pct > 0.0));

  // T10.5-d: with only interactive requests, interactive_pct should be 100
  // Check string representation contains "100"
  let pct_str=str.from_f32(report3.interactive.request_pct);
  results=str.array_push(results;assert_true("interactive_pct = 100 when only tier";str.contains(pct_str;"100")));

  // T10.5-e: report_to_json contains "interactive" key
  let json_out=td.report_to_json(report3);
  results=str.array_push(results;assert_true("report_to_json contains interactive";str.contains(json_out;"interactive")));
  results=str.array_push(results;assert_true("report_to_json contains considered";str.contains(json_out;"considered")));
  results=str.array_push(results;assert_true("report_to_json contains background";str.contains(json_out;"background")));

  // T10.5-f: zero total does not crash (divide-by-zero guard)
  let zero_report=td.new_report(7);
  let zero_after=td.recalculate_pcts(zero_report);
  results=str.array_push(results;assert_int_eq("zero total: interactive_count still 0";zero_after.interactive.request_count;0));
  results=str.array_push(results;assert_true("zero total: interactive_pct = 0";zero_after.interactive.request_pct == 0.0));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
