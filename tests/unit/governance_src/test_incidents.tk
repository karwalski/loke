// T10.2 — Incidents (governance_src) unit tests.
// Tests create, append, get, resolve, list_open, list_all, and
// post_incident_template on the loke.governance.incidents module.

m=tests.unit.governance_src.test_incidents;

i=inc:loke.governance.incidents;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  // Reset global state
  inc.g_incidents=@();

  let results = @($result)[];

  // T10.2-a: create returns incident with non-empty id
  let incident=inc.create("data_leak";"critical";"PII exposed";"PII data was exposed in logs";false);
  results=str.array_push(results;assert_true("create returns incident with id";!str.eq(incident.id;"")));

  // T10.2-b: after append, list_all count >= 1
  inc.g_incidents=inc.append(inc.g_incidents;incident);
  let all_after_append=inc.list_all();
  let all_len=str.array_len(all_after_append);
  results=str.array_push(results;assert_true("list_all count >= 1 after append";all_len >= 1));

  // T10.2-c: get(incident.id) returns the incident (check incident_type field)
  let fetched=inc.get(incident.id);
  fetched|{
    $some:i{
      results=str.array_push(results;assert_eq("get returns correct incident_type";"data_leak";i.incident_type))
    };
    $none:{
      results=str.array_push(results;fail("get after append returns some";"returned none"))
    }
  };

  // T10.2-d: resolve sets resolved=true
  inc.resolve(incident.id;"resolved by test");
  let resolved_opt=inc.get(incident.id);
  resolved_opt|{
    $some:i{
      results=str.array_push(results;assert_true("resolve sets resolved=true";i.resolved))
    };
    $none:{
      results=str.array_push(results;fail("resolved incident still retrievable";"returned none"))
    }
  };

  // T10.2-e: list_open excludes resolved incidents
  let open=inc.list_open();
  let open_len=str.array_len(open);
  results=str.array_push(results;assert_true("list_open excludes resolved";open_len == 0));

  // T10.2-f: list_all includes both open and resolved
  let open_incident=inc.create("policy_violation";"high";"Policy breach";"Policy was violated";false);
  inc.g_incidents=inc.append(inc.g_incidents;open_incident);
  let all_both=inc.list_all();
  let all_both_len=str.array_len(all_both);
  results=str.array_push(results;assert_true("list_all includes both open and resolved";all_both_len >= 2));

  // T10.2-g: post_incident_template returns non-empty string containing "incident"
  let tmpl=inc.post_incident_template(incident);
  results=str.array_push(results;assert_true("post_incident_template non-empty";!str.eq(tmpl;"")));
  results=str.array_push(results;assert_true("post_incident_template contains incident";str.contains(tmpl;"incident")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
