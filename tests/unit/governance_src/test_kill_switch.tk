// T10.1 — Kill switch (governance_src) unit tests.
// Tests enable_global, disable_global, enable_provider, is_blocked,
// list_active, and fallback_message on the loke.governance.kill_switch module.

m=tests.unit.governance_src.test_kill_switch;

i=ks:loke.governance.kill_switch;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T10.1-a: is_global_active() returns false on fresh state
  ks.g_global_active=false;
  results=str.array_push(results;assert_false("fresh state global inactive";ks.is_global_active()));

  // T10.1-b: after enable_global, is_global_active() → true
  ks.enable_global("test reason";"tester");
  results=str.array_push(results;assert_true("global active after enable";ks.is_global_active()));

  // T10.1-c: after disable_global, is_global_active() → false
  ks.disable_global();
  results=str.array_push(results;assert_false("global inactive after disable";ks.is_global_active()));

  // T10.1-d: enable_provider("anthropic"), then is_blocked("provider";"anthropic") → true
  ks.enable_provider("anthropic";"test block";"tester");
  results=str.array_push(results;assert_true("anthropic blocked after enable_provider";ks.is_blocked("provider";"anthropic")));

  // T10.1-e: after enable_provider("anthropic"), is_blocked("provider";"ollama") → false
  results=str.array_push(results;assert_false("ollama not blocked when only anthropic blocked";ks.is_blocked("provider";"ollama")));

  // T10.1-f: list_active() returns non-empty array after enable
  let active=ks.list_active();
  let active_len=str.array_len(active);
  results=str.array_push(results;assert_true("list_active non-empty after enable";active_len > 0));

  // T10.1-g: fallback_message() returns non-empty string
  let fb=ks.fallback_message("provider";"anthropic");
  results=str.array_push(results;assert_true("fallback_message non-empty";!str.eq(fb.message;"")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
