// T10.3 — Justification (governance_src) unit tests.
// Tests submit, get, approve, suggest_simpler, and to_json on the
// loke.governance.justification module.

m=tests.unit.governance_src.test_justification;

i=just:loke.governance.justification;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  // Reset global state
  just.g_justifications=@();

  let results = @($result)[];

  // T10.3-a: submit creates a justification (retrievable with get)
  let j=just.$justification{
    use_case_id:"use_case_1";
    purpose:"compliance automation";
    why_ai:"We need this for compliance";
    expected_value:"Reduce compliance overhead";
    identified_risks:"Model drift";
    simpler_alternatives:@();
    submitted_at:0;
    approved:false;
    approver_id:""
  };
  just.submit(j);
  let fetched=just.get("use_case_1");
  fetched|{
    $some:got{
      results=str.array_push(results;assert_eq("submit creates retrievable justification";"use_case_1";got.use_case_id))
    };
    $none:{
      results=str.array_push(results;fail("submit then get returns some";"returned none"))
    }
  };

  // T10.3-b: get returns submitted justification with correct rationale
  let fetched2=just.get("use_case_1");
  fetched2|{
    $some:got{
      results=str.array_push(results;assert_eq("get returns correct why_ai";"We need this for compliance";got.why_ai))
    };
    $none:{
      results=str.array_push(results;fail("get returns correct rationale";"returned none"))
    }
  };

  // T10.3-c: approve sets approved=true
  just.approve("use_case_1";"approver_alice");
  let approved_opt=just.get("use_case_1");
  approved_opt|{
    $some:got{
      results=str.array_push(results;assert_true("approve sets approved=true";got.approved))
    };
    $none:{
      results=str.array_push(results;fail("approved justification still retrievable";"returned none"))
    }
  };

  // T10.3-d: suggest_simpler returns array with >= 1 entry
  let simpler=just.suggest_simpler("compliance automation");
  let simpler_len=str.array_len(simpler);
  results=str.array_push(results;assert_true("suggest_simpler returns >= 1 entry";simpler_len >= 1));

  // T10.3-e: to_json contains "use_case_id" and "why_ai" fields
  let approved_j=just.$justification{
    use_case_id:"use_case_1";
    purpose:"compliance automation";
    why_ai:"We need this for compliance";
    expected_value:"Reduce compliance overhead";
    identified_risks:"Model drift";
    simpler_alternatives:@();
    submitted_at:0;
    approved:true;
    approver_id:"approver_alice"
  };
  let json_out=just.to_json(approved_j);
  results=str.array_push(results;assert_true("to_json contains use_case_id";str.contains(json_out;"use_case_id")));
  results=str.array_push(results;assert_true("to_json contains why_ai (rationale)";str.contains(json_out;"why_ai")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
