// T1.3 — Pattern constant unit tests (maps to T1.4 in epics-and-stories.md)
// Verifies all pat_* constants are non-empty, distinct where expected, and well-formed.

m=tests.unit.privacy.test_patterns;

i=pat:core.privacy.patterns;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;val:bool):$result{
  if !val{ <pass(name) }else{ <fail(name;"expected false") }
}

f=assert_non_empty(name:str;val:str):$result{
  if str.len(val)>0{ <pass(name) }else{ <fail(name;"expected non-empty string") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T1.3-a: pat_email is non-empty
  results=str.array_push(results;assert_non_empty("pat_email non-empty";pat.pat_email));

  // T1.3-b: pat_phone_au is non-empty
  results=str.array_push(results;assert_non_empty("pat_phone_au non-empty";pat.pat_phone_au));

  // T1.3-c: pat_credit_card is non-empty
  results=str.array_push(results;assert_non_empty("pat_credit_card non-empty";pat.pat_credit_card));

  // T1.3-d: pat_au_tfn is non-empty
  results=str.array_push(results;assert_non_empty("pat_au_tfn non-empty";pat.pat_au_tfn));

  // T1.3-e: pat_au_abn is non-empty
  results=str.array_push(results;assert_non_empty("pat_au_abn non-empty";pat.pat_au_abn));

  // T1.3-f: pat_api_key is non-empty
  results=str.array_push(results;assert_non_empty("pat_api_key non-empty";pat.pat_api_key));

  // T1.3-g: pat_email contains "@" character
  results=str.array_push(results;assert_true("pat_email contains @";str.contains(pat.pat_email;"@")));

  // T1.3-h: pat_au_tfn and pat_au_abn are not equal to each other
  results=str.array_push(results;assert_false("pat_au_tfn != pat_au_abn";str.eq(pat.pat_au_tfn;pat.pat_au_abn)));

  // T1.3-i: pat_email and pat_credit_card are not equal to each other
  results=str.array_push(results;assert_false("pat_email != pat_credit_card";str.eq(pat.pat_email;pat.pat_credit_card)));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
