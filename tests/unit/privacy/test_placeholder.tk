// T1.2 — Placeholder generation and map round-trip unit tests
// Verifies make_placeholder format, new_map, add_entry, and restore behaviour.

m=tests.unit.privacy.test_placeholder;

i=ph:core.privacy.placeholder;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_eq_u32(name:str;got:u32;want:u32):$result{
  if got==want{
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(str.from_u32(want);str.concat(" got=";str.from_u32(got)))))
  }
}

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T1.2-a: make_placeholder("email";1) equals "[EMAIL_1]"
  results=str.array_push(results;assert_eq("make_placeholder email 1";ph.make_placeholder("email";1);"[EMAIL_1]"));

  // T1.2-b: make_placeholder("phone_au";3) equals "[PHONE_AU_3]"
  results=str.array_push(results;assert_eq("make_placeholder phone_au 3";ph.make_placeholder("phone_au";3);"[PHONE_AU_3]"));

  // T1.2-c: make_placeholder("credit_card";2) equals "[CREDIT_CARD_2]"
  results=str.array_push(results;assert_eq("make_placeholder credit_card 2";ph.make_placeholder("credit_card";2);"[CREDIT_CARD_2]"));

  // T1.2-d: new_map() returns map with zero entries
  let empty_map=ph.new_map();
  results=str.array_push(results;assert_eq_u32("new_map zero entries";str.array_len(empty_map.entries);0));

  // T1.2-e: After add_entry, map has 1 entry
  let map1=ph.new_map();
  ph.add_entry(map1;"john@example.com";"[EMAIL_1]";"email");
  results=str.array_push(results;assert_eq_u32("add_entry map has 1 entry";str.array_len(map1.entries);1));

  // T1.2-f: restore("[EMAIL_1] called";map) equals "john@example.com called"
  let restored=ph.restore("[EMAIL_1] called";map1);
  results=str.array_push(results;assert_eq("restore single entry";restored;"john@example.com called"));

  // T1.2-g: Restore on text with no placeholder returns text unchanged
  let no_ph_map=ph.new_map();
  ph.add_entry(no_ph_map;"alice@example.com";"[EMAIL_1]";"email");
  let unchanged=ph.restore("Hello world";no_ph_map);
  results=str.array_push(results;assert_eq("restore no placeholder unchanged";unchanged;"Hello world"));

  // T1.2-h: Two entries added — both restored correctly in single restore call
  let map2=ph.new_map();
  ph.add_entry(map2;"bob@example.com";"[EMAIL_1]";"email");
  ph.add_entry(map2;"0412 345 678";"[PHONE_AU_2]";"phone_au");
  let both_restored=ph.restore("[EMAIL_1] rang [PHONE_AU_2]";map2);
  results=str.array_push(results;assert_eq("restore two entries";both_restored;"bob@example.com rang 0412 345 678"));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
