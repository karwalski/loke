// T1.1 — Regex-based PII detection unit tests
// Verifies entity_type, sensitivity level, placeholder format, and entity counts.

m=tests.unit.privacy.test_regex;

i=regex:core.privacy.regex;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_eq(name:str;got:str;want:str):$result{
  if str.eq(got;want){
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;val:bool):$result{
  if !val{ <pass(name) }else{ <fail(name;"expected false") }
}

f=assert_eq_u32(name:str;got:u32;want:u32):$result{
  if got==want{
    <pass(name)
  }else{
    <fail(name;str.concat("want=";str.concat(str.from_u32(want);str.concat(" got=";str.from_u32(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

// Helper: find first entity with matching entity_type; returns empty string if not found
f=first_entity_type(detection:$pii_detection_result;expected_type:str):str{
  let count=str.array_len(detection.entities);
  let i=0;
  let found="";
  loop{
    if i>=count{ break }else{
      let entity=str.array_get(detection.entities;i);
      if str.eq(entity.entity_type;expected_type){
        let found=entity.entity_type;
        i=count
      }else{
        i=i+1
      }
    }
  };
  <found
}

f=first_placeholder(detection:$pii_detection_result):str{
  let count=str.array_len(detection.entities);
  if count==0{
    <""
  }else{
    let entity=str.array_get(detection.entities;0);
    <entity.placeholder
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T1.1-a: Email detected with entity_type "email"
  let email_text="john.smith@example.com";
  let email_det=regex.detect(email_text);
  let email_type=first_entity_type(email_det;"email");
  results=str.array_push(results;assert_eq("email entity_type";email_type;"email"));

  // T1.1-b: Email sensitivity is CONFIDENTIAL
  results=str.array_push(results;assert_true("email sensitivity confidential";email_det.sensitivity==$confidential));

  // T1.1-c: AU phone detected with entity_type "phone_au"
  let phone_text="0412 345 678";
  let phone_det=regex.detect(phone_text);
  let phone_type=first_entity_type(phone_det;"phone_au");
  results=str.array_push(results;assert_eq("phone_au entity_type";phone_type;"phone_au"));

  // T1.1-d: AU phone sensitivity is CONFIDENTIAL
  results=str.array_push(results;assert_true("phone_au sensitivity confidential";phone_det.sensitivity==$confidential));

  // T1.1-e: Credit card detected with entity_type "credit_card"
  let cc_text="4111111111111111";
  let cc_det=regex.detect(cc_text);
  let cc_type=first_entity_type(cc_det;"credit_card");
  results=str.array_push(results;assert_eq("credit_card entity_type";cc_type;"credit_card"));

  // T1.1-f: Credit card sensitivity is RESTRICTED
  results=str.array_push(results;assert_true("credit_card sensitivity restricted";cc_det.sensitivity==$restricted));

  // T1.1-g: AU TFN detected, sensitivity RESTRICTED
  let tfn_text="My TFN is 123 456 789";
  let tfn_det=regex.detect(tfn_text);
  results=str.array_push(results;assert_true("au_tfn sensitivity restricted";tfn_det.sensitivity==$restricted));

  // T1.1-h: API key detected, sensitivity RESTRICTED
  let api_text="sk-ant-abc123xyz456def789ghi012jkl";
  let api_det=regex.detect(api_text);
  results=str.array_push(results;assert_true("api_key sensitivity restricted";api_det.sensitivity==$restricted));

  // T1.1-i: Clean text returns zero entities, sensitivity PUBLIC
  let clean_text="The weather is nice today";
  let clean_det=regex.detect(clean_text);
  results=str.array_push(results;assert_eq_u32("clean text zero entities";str.array_len(clean_det.entities);0));
  results=str.array_push(results;assert_true("clean text sensitivity public";clean_det.sensitivity==$public));

  // T1.1-j: Multiple PII returns 2 entities
  let multi_text="john@example.com and 0412 345 678";
  let multi_det=regex.detect(multi_text);
  results=str.array_push(results;assert_eq_u32("multiple PII entity count";str.array_len(multi_det.entities);2));

  // T1.1-k: Placeholder format for email entity is "[EMAIL_1]"
  let ph_text="contact john@example.com now";
  let ph_det=regex.detect(ph_text);
  let ph_str=first_placeholder(ph_det);
  results=str.array_push(results;assert_eq("email placeholder format";ph_str;"[EMAIL_1]"));

  // T1.1-l: Detection result original field equals input text
  results=str.array_push(results;assert_eq("original field preserved";ph_det.original;"contact john@example.com now"));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
