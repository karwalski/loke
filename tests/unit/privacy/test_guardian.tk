// T1.5 — Guardian system prompt unit tests (maps to T1.6 in epics-and-stories.md)
// Verifies build_system_prompt output and is_guardian_present detection.

m=tests.unit.privacy.test_guardian;

i=guardian:core.privacy.guardian;
i=str:std.str;
i=log:shared.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(name:str):$result{ <$result{name:name;passed:true;message:"ok"} }
f=fail(name:str;msg:str):$result{ <$result{name:name;passed:false;message:msg} }

f=assert_true(name:str;val:bool):$result{
  if val{ <pass(name) }else{ <fail(name;"expected true") }
}

f=assert_false(name:str;val:bool):$result{
  if !val{ <pass(name) }else{ <fail(name;"expected false") }
}

f=assert_non_empty(name:str;val:str):$result{
  if str.len(val)>0{ <pass(name) }else{ <fail(name;"expected non-empty string") }
}

f=log_result(r:$result){
  if r.passed{
    log.info(str.concat("PASS ";r.name))
  }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T1.5-a: build_system_prompt("") returns non-empty string
  let built=guardian.build_system_prompt("");
  results=str.array_push(results;assert_non_empty("build_system_prompt non-empty";built));

  // T1.5-b: is_guardian_present returns true on the built system prompt
  results=str.array_push(results;assert_true("is_guardian_present on built prompt";guardian.is_guardian_present(built)));

  // T1.5-c: is_guardian_present returns false on empty string
  results=str.array_push(results;assert_false("is_guardian_present empty string false";guardian.is_guardian_present("")));

  // T1.5-d: is_guardian_present returns false on unrelated assistant prompt
  results=str.array_push(results;assert_false("is_guardian_present unrelated prompt false";guardian.is_guardian_present("You are a helpful assistant")));

  // T1.5-e: Custom system prompt is included in built prompt
  let custom_built=guardian.build_system_prompt("You are a doctor");
  results=str.array_push(results;assert_true("custom prompt included in built prompt";str.contains(custom_built;"doctor")));

  // T1.5-f: Built prompt contains "GUARDIAN" or "loke" keyword
  results=str.array_push(results;assert_true("built prompt contains loke keyword";str.contains(built;"loke")));

  let all_passed=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all_passed=false }else{};
      i=i+1
    }
  };
  <all_passed
}
