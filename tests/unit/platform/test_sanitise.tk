// T8.8 — Input sanitisation unit tests.
// Verifies HTML escaping, tag stripping, SQL quoting, log-injection prevention,
// and string length clamping.

m=tests.unit.platform.test_sanitise;

i=san:loke.platform.integration.sanitise;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.8-a: strip_html escapes < to &lt;
  let stripped_html=san.strip_html("<b>hello</b>");
  results=str.array_push(results;assert_true("strip_html contains &lt;";str.contains(stripped_html;"&lt;")));

  // T8.8-b: strip_html does not contain raw "<b>"
  results=str.array_push(results;assert_false("strip_html does not contain raw <b>";str.contains(stripped_html;"<b>")));

  // T8.8-c: strip_tags removes tags and returns "hello"
  let stripped_tags=san.strip_tags("<b>hello</b>");
  results=str.array_push(results;assert_eq("strip_tags returns hello";stripped_tags;"hello"));

  // T8.8-d: sql_escape doubles single quotes
  let escaped_sql=san.sql_escape("O'Brien");
  results=str.array_push(results;assert_eq("sql_escape doubles single quote";escaped_sql;"O''Brien"));

  // T8.8-e: prevent_log_injection removes newline
  let safe_log=san.prevent_log_injection("line1\nline2");
  results=str.array_push(results;assert_false("prevent_log_injection removes newline";str.contains(safe_log;"\n")));

  // T8.8-f: clamp_length("hello"; 3) truncates and appends ellipsis — length <= 4
  let clamped=san.clamp_length("hello";3);
  results=str.array_push(results;assert_true("clamp_length hello:3 len <= 4";str.len(clamped)<=4));

  // T8.8-g: clamp_length("hi"; 10) returns "hi" unchanged
  let unclamped=san.clamp_length("hi";10);
  results=str.array_push(results;assert_eq("clamp_length hi:10 unchanged";unclamped;"hi"));

  // T8.8-h: strip_html escapes > to &gt;
  results=str.array_push(results;assert_true("strip_html contains &gt;";str.contains(stripped_html;"&gt;")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
