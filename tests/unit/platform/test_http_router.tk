// T8.2 — HTTP router unit tests.
// Verifies registry creation, route registration, exact and prefix matching,
// and independent findability of multiple routes.

m=tests.unit.platform.test_http_router;

i=router:loke.platform.http.router;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.2-a: new_registry has zero routes
  let reg=router.new_registry();
  let routes=router.list_routes(reg);
  results=str.array_push(results;assert_true("new_registry has zero routes";str.array_len(routes)==0));

  // T8.2-b: register increases count to 1
  router.register(reg;"GET";"/items";"shop";"handler_list");
  let routes_after=router.list_routes(reg);
  results=str.array_push(results;assert_true("register increases count to 1";str.array_len(routes_after)==1));

  // T8.2-c: find returns registered exact path
  let found=router.find(reg;"GET";"/api/v1/shop/items");
  results=str.array_push(results;assert_true("find exact path returns some";found.is_some()));

  // T8.2-d: find returns none for unknown path
  let not_found=router.find(reg;"GET";"/api/v1/unknown/path");
  results=str.array_push(results;assert_false("find unknown path returns none";not_found.is_some()));

  // T8.2-e: register second route — both findable independently
  router.register(reg;"POST";"/orders";"shop";"handler_create");
  let found_get=router.find(reg;"GET";"/api/v1/shop/items");
  let found_post=router.find(reg;"POST";"/api/v1/shop/orders");
  results=str.array_push(results;assert_true("first route still findable after second registered";found_get.is_some()));
  results=str.array_push(results;assert_true("second route findable independently";found_post.is_some()));

  // T8.2-f: list_routes count matches registered count
  let routes_final=router.list_routes(reg);
  results=str.array_push(results;assert_true("list_routes count is 2";str.array_len(routes_final)==2));

  // T8.2-g: GET does not match POST route
  let wrong_method=router.find(reg;"GET";"/api/v1/shop/orders");
  results=str.array_push(results;assert_false("wrong method returns none";wrong_method.is_some()));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
