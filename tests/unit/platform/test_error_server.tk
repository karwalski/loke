// T8.10 — Server error handling unit tests.
// Verifies error creation, safe JSON serialisation (no internal details exposed),
// and log_error invocation.

m=tests.unit.platform.test_error_server;

i=errsrv:loke.platform.error.server;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // Construct a server error — internal detail must not reach the client
  let err=errsrv.new_error("auth_failed";"Unauthorised";"req-abc");

  // T8.10-a: new_error has non-empty code field
  results=str.array_push(results;assert_true("new_error code field is non-empty";str.len(err.code)>0));

  // T8.10-b: new_error code matches supplied value
  results=str.array_push(results;assert_eq("new_error code is auth_failed";err.code;"auth_failed"));

  // T8.10-c: to_json contains the code
  let json=errsrv.to_json(err);
  results=str.array_push(results;assert_true("to_json contains auth_failed code";str.contains(json;"auth_failed")));

  // T8.10-d: to_json contains "message" key
  results=str.array_push(results;assert_true("to_json contains message key";str.contains(json;"\"message\"")));

  // T8.10-e: to_json does NOT contain "internal" key (internal details not exposed)
  results=str.array_push(results;assert_false("to_json does not contain internal key";str.contains(json;"\"internal\"")));

  // T8.10-f: to_json does NOT contain the internal diagnostic string "details here"
  // (new_error sets internal to "" — callers pass it via log_error only)
  results=str.array_push(results;assert_false("to_json does not expose internal detail";str.contains(json;"details here")));

  // T8.10-g: to_json output is non-empty
  results=str.array_push(results;assert_true("to_json output non-empty";str.len(json)>0));

  // T8.10-h: log_error does not crash (call with internal diagnostic)
  errsrv.log_error(err;"details here");
  results=str.array_push(results;pass("log_error does not crash"));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
