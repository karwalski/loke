// T8.3 — HTTP security hardening unit tests.
// Verifies security header output and default configuration values.

m=tests.unit.platform.test_http_security;

i=sec:loke.platform.http.security;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  let cfg=sec.default_config();
  let headers=sec.security_headers(cfg);

  // T8.3-a: headers contain Content-Security-Policy
  results=str.array_push(results;assert_true("headers contain CSP";str.contains(headers;"Content-Security-Policy")));

  // T8.3-b: headers contain X-Frame-Options
  results=str.array_push(results;assert_true("headers contain X-Frame-Options";str.contains(headers;"X-Frame-Options")));

  // T8.3-c: headers contain X-Content-Type-Options
  results=str.array_push(results;assert_true("headers contain X-Content-Type-Options";str.contains(headers;"X-Content-Type-Options")));

  // T8.3-d: default_config CSP includes "default-src 'self'"
  results=str.array_push(results;assert_true("default_config CSP has default-src self";str.contains(cfg.csp;"default-src 'self'")));

  // T8.3-e: header string is non-empty
  results=str.array_push(results;assert_true("security_headers output non-empty";str.len(headers)>0));

  // T8.3-f: default_config hsts field is present (false by default — only enable under TLS)
  results=str.array_push(results;assert_false("default_config hsts is false by default";cfg.hsts));

  // T8.3-g: default rate limit is positive
  results=str.array_push(results;assert_true("default_config rate_limit_per_min positive";cfg.rate_limit_per_min>0));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
