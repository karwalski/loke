// T8.6 — Plugin contracts unit tests.
// Verifies version constants, version_string formatting, compatibility checks,
// and breaking changes list.

m=tests.unit.platform.test_plugin_contracts;

i=contracts:loke.platform.plugin.contracts;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.6-a: current_version returns major=0
  let v=contracts.current_version();
  results=str.array_push(results;assert_true("current_version major is 0";v.major==0));

  // T8.6-b: current_version returns minor=1
  results=str.array_push(results;assert_true("current_version minor is 1";v.minor==1));

  // T8.6-c: current_version returns patch=0
  results=str.array_push(results;assert_true("current_version patch is 0";v.patch==0));

  // T8.6-d: version_string({0;1;0}) produces "0.1.0"
  let vs_current=contracts.version_string(v);
  results=str.array_push(results;assert_eq("version_string 0.1.0";vs_current;"0.1.0"));

  // T8.6-e: version_string({1;2;3}) produces "1.2.3"
  let v123=contracts.$interface_version{major:1;minor:2;patch:3};
  let vs_123=contracts.version_string(v123);
  results=str.array_push(results;assert_eq("version_string 1.2.3";vs_123;"1.2.3"));

  // T8.6-f: is_compatible — same major (0), required minor <= current minor (0<=1) → true
  let compat=contracts.is_compatible(0;0);
  results=str.array_push(results;assert_true("is_compatible same major lower minor is true";compat));

  // T8.6-g: is_compatible — different major (1 vs 0) → false
  let incompat=contracts.is_compatible(1;0);
  results=str.array_push(results;assert_false("is_compatible different major is false";incompat));

  // T8.6-h: list_breaking_changes returns empty array for 0.1.0
  let changes=contracts.list_breaking_changes();
  results=str.array_push(results;assert_true("list_breaking_changes is empty";str.array_len(changes)==0));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
