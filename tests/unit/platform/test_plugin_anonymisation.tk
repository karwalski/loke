// T8.5 — Anonymisation pattern registry unit tests.
// Verifies pre-registered Australian PII patterns, find_by_type, and confidence values.

m=tests.unit.platform.test_plugin_anonymisation;

i=anon:loke.platform.plugin.anonymisation;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.5-a: list_patterns returns at least 3 pre-registered entries (TFN, ABN, Medicare)
  let patterns=anon.list_patterns();
  results=str.array_push(results;assert_true("list_patterns has at least 3 entries";str.array_len(patterns)>=3));

  // T8.5-b: find_by_type("AU_TFN") returns at least one pattern
  let tfn_patterns=anon.find_by_type("AU_TFN");
  results=str.array_push(results;assert_true("find_by_type AU_TFN returns results";str.array_len(tfn_patterns)>=1));

  // T8.5-c: find_by_type("AU_MEDICARE") returns at least one pattern
  let medicare_patterns=anon.find_by_type("AU_MEDICARE");
  results=str.array_push(results;assert_true("find_by_type AU_MEDICARE returns results";str.array_len(medicare_patterns)>=1));

  // T8.5-d: Medicare confidence is >= 0.85
  let medicare=str.array_get(medicare_patterns;0);
  results=str.array_push(results;assert_true("medicare confidence >= 0.85";medicare.confidence>=0.85));

  // T8.5-e: TFN confidence is >= 0.80
  let tfn=str.array_get(tfn_patterns;0);
  results=str.array_push(results;assert_true("tfn confidence >= 0.80";tfn.confidence>=0.80));

  // T8.5-f: TFN and ABN patterns are distinct (different entity_type)
  let abn_patterns=anon.find_by_type("AU_ABN");
  results=str.array_push(results;assert_true("find_by_type AU_ABN returns results";str.array_len(abn_patterns)>=1));
  let abn=str.array_get(abn_patterns;0);
  results=str.array_push(results;assert_false("AU_TFN and AU_ABN entity types are distinct";str.eq(tfn.entity_type;abn.entity_type)));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
