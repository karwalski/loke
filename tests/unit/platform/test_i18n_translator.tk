// T8.7 — i18n translator unit tests.
// Verifies translation lookup, key fallback, locale round-trip,
// number formatting, and parameter interpolation.

m=tests.unit.platform.test_i18n_translator;

i=tr:loke.platform.i18n.translator;
i=loc:loke.platform.i18n.locales;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // Load default locales (en-AU and en-US) and set active locale to en-AU
  loc.init_default();

  // T8.7-a: t("loke.privacy.on") returns non-empty string
  let privacy_on=tr.t("loke.privacy.on");
  results=str.array_push(results;assert_true("t loke.privacy.on non-empty";str.len(privacy_on)>0));

  // T8.7-b: t("loke.privacy.on") does not return the key itself
  results=str.array_push(results;assert_false("t loke.privacy.on returns translation not key";str.eq(privacy_on;"loke.privacy.on")));

  // T8.7-c: t("nonexistent.key.xyz") returns the key as fallback
  let fallback=tr.t("nonexistent.key.xyz");
  results=str.array_push(results;assert_eq("t nonexistent key returns key as fallback";fallback;"nonexistent.key.xyz"));

  // T8.7-d: get_locale returns "en-AU" after init_default
  let locale=tr.get_locale();
  results=str.array_push(results;assert_eq("get_locale returns en-AU";locale;"en-AU"));

  // T8.7-e: format_number(1234.5) contains "1234"
  let num_str=tr.format_number(1234.5;"en-AU");
  results=str.array_push(results;assert_true("format_number contains 1234";str.contains(num_str;"1234")));

  // T8.7-f: t_params substitutes {{0}} with provided value
  // Load a custom locale entry with a parameterised template
  let param_entry=tr.$locale_entry{key:"loke.test.greeting";value:"Hello, {{0}}!"};
  let param_locale=tr.$locale{code:"en-AU";entries:@(tr.$locale_entry)[param_entry]};
  tr.load_locale(param_locale);
  let params=@(str)["Alice"];
  let greeted=tr.t_params("loke.test.greeting";params);
  results=str.array_push(results;assert_true("t_params substitutes placeholder";str.contains(greeted;"Alice")));

  // T8.7-g: set_locale and get_locale round-trip
  tr.set_locale("en-US");
  let us_locale=tr.get_locale();
  results=str.array_push(results;assert_eq("set_locale get_locale round-trip";us_locale;"en-US"));
  // Restore en-AU for any subsequent tests
  tr.set_locale("en-AU");

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
