// T8.1 — HTTP response envelope unit tests.
// Verifies success, error_resp, and paginated envelope shapes.

m=tests.unit.platform.test_http_response;

i=resp:loke.platform.http.response;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.1-a: success envelope contains "data" key
  let s=resp.success("{}";"req-1");
  results=str.array_push(results;assert_true("success contains data key";str.contains(s;"\"data\"")));

  // T8.1-b: success envelope is non-empty
  results=str.array_push(results;assert_true("success output non-empty";str.len(s)>0));

  // T8.1-c: success envelope contains requestId
  results=str.array_push(results;assert_true("success contains requestId";str.contains(s;"\"requestId\"")));

  // T8.1-d: error_resp envelope contains "error" key (ok=false shape)
  let e=resp.error_resp("NOT_FOUND";"not found";"req-2");
  results=str.array_push(results;assert_true("error_resp contains error key";str.contains(e;"\"error\"")));

  // T8.1-e: error_resp contains the code
  results=str.array_push(results;assert_true("error_resp contains code";str.contains(e;"NOT_FOUND")));

  // T8.1-f: error_resp does not contain "internal" field
  results=str.array_push(results;assert_false("error_resp no internal field";str.contains(e;"\"internal\"")));

  // T8.1-g: paginated envelope contains "total"
  let p=resp.paginated("[1,2,3]";10;1;3;"req-3");
  results=str.array_push(results;assert_true("paginated contains total";str.contains(p;"\"total\"")));

  // T8.1-h: paginated envelope contains "page"
  results=str.array_push(results;assert_true("paginated contains page";str.contains(p;"\"page\"")));

  // T8.1-i: paginated envelope contains "perPage"
  results=str.array_push(results;assert_true("paginated contains perPage";str.contains(p;"\"perPage\"")));

  // T8.1-j: paginated output is non-empty
  results=str.array_push(results;assert_true("paginated output non-empty";str.len(p)>0));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
