// T8.4 — Plugin registry unit tests.
// Verifies registration, lookup, and aggregation of routes and nav items.

m=tests.unit.platform.test_plugin_registry;

i=preg:loke.platform.plugin.registry;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.4-a: list() on fresh state returns empty array
  let initial=preg.list();
  results=str.array_push(results;assert_true("list returns empty on fresh registry";str.array_len(initial)==0));

  // Build a test plugin with one route and one nav item
  let route=preg.$plugin_route{
    method:"GET";
    path:"/test";
    namespace:"testplugin";
    handler_key:"test_handler"
  };
  let nav=preg.$plugin_nav_item{
    label:"Test";
    path:"/test";
    icon:"icon-test";
    section:"main"
  };
  let plugin=preg.$plugin_registration{
    id:"testplugin";
    name:"Test Plugin";
    version:"1.0.0";
    routes:@($plugin_route)[route];
    health_checks:@($plugin_health_check)[];
    nav_items:@($plugin_nav_item)[nav];
    settings_sections:@($plugin_settings_section)[]
  };

  // T8.4-b: after register, list has 1 entry
  preg.register(plugin);
  let after=preg.list();
  results=str.array_push(results;assert_true("list has 1 entry after register";str.array_len(after)==1));

  // T8.4-c: get("testplugin") returns some
  let found=preg.get("testplugin");
  results=str.array_push(results;assert_true("get registered plugin returns some";found.is_some()));

  // T8.4-d: get("unknown") returns none
  let missing=preg.get("unknown");
  results=str.array_push(results;assert_false("get unknown plugin returns none";missing.is_some()));

  // T8.4-e: all_routes returns flat list including the registered route
  let all_routes=preg.all_routes();
  results=str.array_push(results;assert_true("all_routes has at least 1 entry";str.array_len(all_routes)>=1));

  // T8.4-f: all_nav_items returns flat list including the registered nav item
  let all_nav=preg.all_nav_items();
  results=str.array_push(results;assert_true("all_nav_items has at least 1 entry";str.array_len(all_nav)>=1));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
