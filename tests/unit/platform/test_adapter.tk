// T8.9 — Integration adapter unit tests.
// Verifies adapter state lifecycle: initial status, failure counting,
// circuit opening, success reset, and status labels.

m=tests.unit.platform.test_adapter;

i=adapter:loke.platform.integration.adapter;
i=str:std.str;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results=@($result)[];

  // T8.9-a: new adapter state starts as "disconnected"
  let cfg=adapter.new_adapter("svc-a";"Service A");
  let state=adapter.new_state(cfg);
  results=str.array_push(results;assert_eq("new_state status is disconnected";state.status;"disconnected"));

  // T8.9-b: new adapter failure_count starts at 0
  results=str.array_push(results;assert_true("new_state failure_count is 0";state.failure_count==0));

  // T8.9-c: record_failure increments failure count
  let state1=adapter.record_failure(state;"timeout");
  results=str.array_push(results;assert_true("record_failure increments count to 1";state1.failure_count==1));

  // T8.9-d: is_open returns false before threshold
  results=str.array_push(results;assert_false("is_open false before threshold";adapter.is_open(state1)));

  // T8.9-e: after circuit_break_after (5) failures, is_open returns true
  let state2=adapter.record_failure(state1;"timeout");
  let state3=adapter.record_failure(state2;"timeout");
  let state4=adapter.record_failure(state3;"timeout");
  let state5=adapter.record_failure(state4;"timeout");
  results=str.array_push(results;assert_true("is_open true after threshold failures";adapter.is_open(state5)));

  // T8.9-f: record_success resets to "connected"
  let state_ok=adapter.record_success(state5);
  results=str.array_push(results;assert_eq("record_success resets status to connected";state_ok.status;"connected"));

  // T8.9-g: record_success resets failure_count to 0
  results=str.array_push(results;assert_true("record_success resets failure_count to 0";state_ok.failure_count==0));

  // T8.9-h: status_label returns non-empty string for connected state
  let label=adapter.status_label(state_ok.status);
  results=str.array_push(results;assert_true("status_label non-empty for connected";str.len(label)>0));

  // T8.9-i: status_label for "disconnected" is non-empty
  let disc_label=adapter.status_label("disconnected");
  results=str.array_push(results;assert_true("status_label non-empty for disconnected";str.len(disc_label)>0));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i>=n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
