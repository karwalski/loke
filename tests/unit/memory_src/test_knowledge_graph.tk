// T11.3 — Knowledge graph (memory_src) unit tests.
// Tests new_graph, add_node, add_relation, query_facts, detect_contradictions,
// and visualise_dot on the loke.memory.knowledge_graph module.

m=tests.unit.memory_src.test_knowledge_graph;

i=kg:loke.memory.knowledge_graph;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T11.3-a: new_graph has zero nodes
  let graph=kg.new_graph();
  let node_count=str.array_len(graph.nodes);
  results=str.array_push(results;assert_int_eq("new_graph has zero nodes";node_count;0));

  // T11.3-b: after add_node, node count = 1
  let graph1=kg.add_node(graph;"alice";"Alice Smith";"person");
  let node_count1=str.array_len(graph1.nodes);
  results=str.array_push(results;assert_int_eq("add_node increases count to 1";node_count1;1));

  // T11.3-c: after adding two nodes and one relation, relation count = 1
  let graph2=kg.add_node(graph1;"bob";"Bob Jones";"person");
  let graph3=kg.add_relation(graph2;"alice";"bob";"knows";0;0;"test";1.0);
  let rel_count=str.array_len(graph3.relations);
  results=str.array_push(results;assert_int_eq("add_relation gives relation count 1";rel_count;1));

  // T11.3-d: query_facts matching subject and predicate returns results
  let q=kg.$fact_query{
    subject:"alice";
    predicate:"knows";
    as_of:0
  };
  let facts=kg.query_facts(graph3;q);
  let facts_len=str.array_len(facts);
  results=str.array_push(results;assert_true("query_facts returns matching facts";facts_len >= 1));

  // T11.3-e: query_facts with unknown subject returns empty
  let q_unknown=kg.$fact_query{
    subject:"unknown";
    predicate:"knows";
    as_of:0
  };
  let no_facts=kg.query_facts(graph3;q_unknown);
  let no_facts_len=str.array_len(no_facts);
  results=str.array_push(results;assert_int_eq("query_facts unknown subject returns empty";no_facts_len;0));

  // T11.3-f: detect_contradictions returns empty for non-contradicting relations
  let contradictions=kg.detect_contradictions(graph3);
  let contra_len=str.array_len(contradictions);
  results=str.array_push(results;assert_int_eq("detect_contradictions empty for clean graph";contra_len;0));

  // T11.3-g: detect_contradictions finds conflicting relations
  let graph4=kg.add_node(graph3;"carol";"Carol White";"person");
  // alice knows bob (already) AND alice knows carol — same predicate, different target, overlapping time
  let graph5=kg.add_relation(graph4;"alice";"carol";"knows";0;0;"test2";0.9);
  let contradictions2=kg.detect_contradictions(graph5);
  let contra_len2=str.array_len(contradictions2);
  results=str.array_push(results;assert_true("detect_contradictions finds conflict";contra_len2 >= 1));

  // T11.3-h: visualise_dot starts with "digraph"
  let dot=kg.visualise_dot(graph3);
  results=str.array_push(results;assert_true("visualise_dot starts with digraph";str.starts_with(dot;"digraph")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
