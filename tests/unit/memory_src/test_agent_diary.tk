// T11.4 — Agent diary (memory_src) unit tests.
// Tests get_or_create_diary, append_entry, get_entries, get_recent,
// build_startup_context, and to_aaak on the loke.memory.agent_diary module.

m=tests.unit.memory_src.test_agent_diary;

i=diary:loke.memory.agent_diary;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  // Reset global state
  diary.g_diaries=@();

  let results = @($result)[];

  // T11.4-a: get_or_create_diary for new agent has zero entries
  let d=diary.get_or_create_diary("agent_1");
  let entry_count=str.array_len(d.entries);
  results=str.array_push(results;assert_int_eq("get_or_create_diary zero entries";entry_count;0));
  results=str.array_push(results;assert_eq("get_or_create_diary correct agent_id";"agent_1";d.agent_id));

  // T11.4-b: after append_entry, get_entries has 1 entry
  let entry=diary.$diary_entry{
    id:"entry_1";
    agent_id:"agent_1";
    run_id:"run_001";
    summary:"Completed analysis task";
    result:"success";
    tokens_used:512;
    cost_usd:0.01;
    duration_ms:3200;
    feedback_received:"";
    ts:0
  };
  diary.append_entry("agent_1";entry);
  let entries=diary.get_entries("agent_1");
  let entries_len=str.array_len(entries);
  results=str.array_push(results;assert_int_eq("get_entries has 1 after append";entries_len;1));

  // T11.4-c: get_recent(1) returns array with at most 1 entry
  let recent=diary.get_recent("agent_1";1);
  let recent_len=str.array_len(recent);
  results=str.array_push(results;assert_true("get_recent(1) returns at most 1";recent_len <= 1));
  results=str.array_push(results;assert_int_eq("get_recent(1) returns exactly 1";recent_len;1));

  // T11.4-d: build_startup_context for non-empty diary returns non-empty string
  let ctx=diary.build_startup_context("agent_1";5);
  results=str.array_push(results;assert_true("build_startup_context non-empty for non-empty diary";!str.eq(ctx;"")));

  // T11.4-e: build_startup_context for empty diary returns non-empty string (still has header)
  diary.g_diaries=@();
  let ctx_empty=diary.build_startup_context("agent_empty";5);
  // The function always prepends header "AGENT:agent_empty DIARY_SUMMARY:\n"
  results=str.array_push(results;assert_true("build_startup_context has header even for empty diary";str.contains(ctx_empty;"AGENT:")));

  // T11.4-f: to_aaak returns non-empty string
  let aaak=diary.to_aaak(entry);
  results=str.array_push(results;assert_true("to_aaak returns non-empty";!str.eq(aaak;"")));
  results=str.array_push(results;assert_true("to_aaak contains run_id";str.contains(aaak;"run_001")));

  let all=true;
  let i=0;
  let n=str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r=str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all=false }else{};
      i=i+1
    }
  };
  <all
}
