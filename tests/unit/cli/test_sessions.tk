// T9.1 — Session store unit tests.
// Covers new_store, create, activate, deactivate, get_active, list, find, format_list.

m=tests.unit.cli.test_sessions;

i=sessions:loke.cli.sessions;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T9.1-a: new_store returns store with zero sessions
  let store = sessions.new_store();
  let initial_count = str.array_len(sessions.list(store));
  results = str.array_push(results;assert_int_eq("new_store has zero sessions";initial_count;0));

  // T9.1-b: new_store active_id is empty
  results = str.array_push(results;assert_eq("new_store active_id empty";store.active_id;""));

  // T9.1-c: get_active returns none on fresh store
  let active_before = sessions.get_active(store);
  let none_before = true;
  if active_before == none{ }else{ none_before = false };
  results = str.array_push(results;assert_true("get_active none on fresh store";none_before));

  // T9.1-d: create adds a session (list count increases)
  let sess = sessions.create("chat";"isolated");
  let store2 = sessions.new_store();
  let updated_sessions = @(sessions.$session)[];
  updated_sessions = str.array_push(updated_sessions;sess);
  let store3 = sessions.$session_store{sessions:updated_sessions;active_id:""};
  let count_after = str.array_len(sessions.list(store3));
  results = str.array_push(results;assert_int_eq("create adds a session";count_after;1));

  // T9.1-e: created session has correct name
  results = str.array_push(results;assert_eq("created session name";sess.name;"chat"));

  // T9.1-f: created session has correct mode
  results = str.array_push(results;assert_eq("created session mode";sess.mode;"isolated"));

  // T9.1-g: created session active field is false by default
  results = str.array_push(results;assert_false("created session not active by default";sess.active));

  // T9.1-h: activate sets session as active in store
  let store4 = sessions.activate(store3;sess.id);
  results = str.array_push(results;assert_eq("activate sets active_id";store4.active_id;sess.id));

  // T9.1-i: get_active returns session after activate
  let active_opt = sessions.get_active(store4);
  let found_active = false;
  if active_opt == none{ }else{ found_active = true };
  results = str.array_push(results;assert_true("get_active returns session after activate";found_active));

  // T9.1-j: deactivate clears active flag — get_active returns none
  let store5 = sessions.deactivate(store4;sess.id);
  let store6 = sessions.$session_store{sessions:store5.sessions;active_id:""};
  let active_after_deactivate = sessions.get_active(store6);
  let none_after = true;
  if active_after_deactivate == none{ }else{ none_after = false };
  results = str.array_push(results;assert_true("get_active none after deactivate";none_after));

  // T9.1-k: list returns all sessions
  let listed = sessions.list(store4);
  let listed_count = str.array_len(listed);
  results = str.array_push(results;assert_int_eq("list returns all sessions";listed_count;1));

  // T9.1-l: find by name returns matching session
  let found_opt = sessions.find(store3;"chat");
  let found_match = false;
  if found_opt == none{ }else{ found_match = true };
  results = str.array_push(results;assert_true("find by name returns session";found_match));

  // T9.1-m: find with nonexistent name returns none
  let not_found_opt = sessions.find(store3;"nonexistent-name-xyz");
  let not_found = true;
  if not_found_opt == none{ }else{ not_found = false };
  results = str.array_push(results;assert_true("find nonexistent name returns none";not_found));

  // T9.1-n: format_list on empty store returns non-empty string (header line present)
  let formatted = sessions.format_list(sessions.new_store());
  let fmt_len = str.len(formatted);
  results = str.array_push(results;assert_true("format_list returns non-empty header";fmt_len > 0));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
