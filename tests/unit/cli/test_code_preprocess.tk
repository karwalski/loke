// T9.2 — Code preprocessing unit tests.
// Covers detect_language, find_proprietary_patterns, scrub_secrets, profile_codebase.

m=tests.unit.cli.test_code_preprocess;

i=cp:loke.cli.code_preprocess;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T9.2-a: detect_language ".py" returns "python"
  results = str.array_push(results;assert_eq("detect_language .py";cp.detect_language(".py");"python"));

  // T9.2-b: detect_language ".ts" returns "typescript"
  results = str.array_push(results;assert_eq("detect_language .ts";cp.detect_language(".ts");"typescript"));

  // T9.2-c: detect_language ".go" returns "go"
  results = str.array_push(results;assert_eq("detect_language .go";cp.detect_language(".go");"go"));

  // T9.2-d: detect_language ".unknown_xyz" returns "unknown"
  results = str.array_push(results;assert_eq("detect_language unknown ext";cp.detect_language(".unknown_xyz");"unknown"));

  // T9.2-e: detect_language ".tk" returns "toke"
  results = str.array_push(results;assert_eq("detect_language .tk";cp.detect_language(".tk");"toke"));

  // T9.2-f: detect_language ".rs" returns "rust"
  results = str.array_push(results;assert_eq("detect_language .rs";cp.detect_language(".rs");"rust"));

  // T9.2-g: find_proprietary_patterns on text with INTERNAL marker returns array with >= 1 match
  let prop_found = cp.find_proprietary_patterns("INTERNAL_ONLY: secret logic");
  let prop_count = str.array_len(prop_found);
  results = str.array_push(results;assert_true("find_proprietary_patterns INTERNAL >= 1";prop_count >= 1));

  // T9.2-h: find_proprietary_patterns on plain public code returns empty array
  let no_prop = cp.find_proprietary_patterns("normal public code");
  let no_prop_count = str.array_len(no_prop);
  results = str.array_push(results;assert_int_eq("find_proprietary_patterns clean code";no_prop_count;0));

  // T9.2-i: find_proprietary_patterns detects CONFIDENTIAL marker
  let conf_found = cp.find_proprietary_patterns("CONFIDENTIAL data here");
  let conf_count = str.array_len(conf_found);
  results = str.array_push(results;assert_true("find_proprietary_patterns CONFIDENTIAL >= 1";conf_count >= 1));

  // T9.2-j: scrub_secrets removes sk- API key from text
  let scrub_result = cp.scrub_secrets("key: sk-ant-abc123xyz456def789ghi012jkl345mno678pqr901");
  results = str.array_push(results;assert_false("scrub_secrets removes sk- key";str.contains(scrub_result.scrubbed;"sk-ant")));

  // T9.2-k: scrub_secrets on clean function text returns text unchanged
  let clean_code = "def my_function(): pass";
  let clean_result = cp.scrub_secrets(clean_code);
  results = str.array_push(results;assert_eq("scrub_secrets clean text unchanged";clean_result.scrubbed;clean_code));

  // T9.2-l: scrub_secrets result has replacements count >= 1 when secret found
  let sk_scrub = cp.scrub_secrets("key: sk-ant-abc123xyz456def789ghi012jkl345mno678pqr901");
  results = str.array_push(results;assert_true("scrub_secrets replacements >= 1 for secret";sk_scrub.replacements >= 1));

  // T9.2-m: scrub_secrets result has replacements == 0 for clean text
  results = str.array_push(results;assert_int_eq("scrub_secrets zero replacements clean";clean_result.replacements;0));

  // T9.2-n: profile_codebase result has languages field populated from filenames
  let fnames = @(str)[];
  fnames = str.array_push(fnames;"main.py");
  fnames = str.array_push(fnames;"server.go");
  let lcounts = @(i32)[];
  lcounts = str.array_push(lcounts;100);
  lcounts = str.array_push(lcounts;200);
  let profile = cp.profile_codebase(fnames;lcounts);
  let lang_count = str.array_len(profile.languages);
  results = str.array_push(results;assert_true("profile_codebase languages field populated";lang_count >= 1));

  // T9.2-o: profile_codebase result file_count matches input
  results = str.array_push(results;assert_int_eq("profile_codebase file_count";profile.file_count;2));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
