// T9.3 — Tab store unit tests.
// Covers new_store, open, close, activate, pin, list_tabs, active_tab,
// add_bookmark, remove_bookmark.

m=tests.unit.browser.test_tabs;

i=tabs:loke.browser.workspace.tabs;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T9.3-a: new_store has zero tabs
  let store = tabs.new_store();
  let initial_count = str.array_len(tabs.list_tabs(store));
  results = str.array_push(results;assert_int_eq("new_store zero tabs";initial_count;0));

  // T9.3-b: new_store active_id is empty
  results = str.array_push(results;assert_eq("new_store active_id empty";store.active_id;""));

  // T9.3-c: open returns updated store with one tab
  let store2 = tabs.open(store;"https://example.com";"Example");
  let count_after_open = str.array_len(tabs.list_tabs(store2));
  results = str.array_push(results;assert_int_eq("open adds one tab";count_after_open;1));

  // T9.3-d: open sets active_id to the new tab id
  results = str.array_push(results;assert_true("open sets active_id";str.len(store2.active_id) > 0));

  // T9.3-e: list_tabs after open has 1 tab
  let tab_list = tabs.list_tabs(store2);
  results = str.array_push(results;assert_int_eq("list_tabs count 1";str.array_len(tab_list);1));

  // T9.3-f: after open then close, list_tabs has 0 tabs
  let opened_tab = str.array_get(tab_list;0);
  let store3 = tabs.close(store2;opened_tab.id);
  let count_after_close = str.array_len(tabs.list_tabs(store3));
  results = str.array_push(results;assert_int_eq("close removes tab";count_after_close;0));

  // T9.3-g: close of active tab — active_id reset to empty
  results = str.array_push(results;assert_eq("close active tab resets active_id";store3.active_id;""));

  // T9.3-h: open two tabs then activate the first — active_tab returns first tab
  let store4 = tabs.open(store;"https://alpha.com";"Alpha");
  let store5 = tabs.open(store4;"https://beta.com";"Beta");
  let tabs_list2 = tabs.list_tabs(store5);
  let first_tab = str.array_get(tabs_list2;0);
  let store6 = tabs.activate(store5;first_tab.id);
  let active_opt = tabs.active_tab(store6);
  let found_active = false;
  if active_opt == none{ }else{ found_active = true };
  results = str.array_push(results;assert_true("activate sets active tab";found_active));

  // T9.3-i: activate sets correct active_id
  results = str.array_push(results;assert_eq("activate active_id matches";store6.active_id;first_tab.id));

  // T9.3-j: pin toggles pinned field from false to true
  let store7 = tabs.open(store;"https://pinme.com";"PinMe");
  let pin_tabs = tabs.list_tabs(store7);
  let pin_tab = str.array_get(pin_tabs;0);
  results = str.array_push(results;assert_false("tab unpinned by default";pin_tab.pinned));
  let store8 = tabs.pin(store7;pin_tab.id);
  let pinned_tabs = tabs.list_tabs(store8);
  let pinned_tab = str.array_get(pinned_tabs;0);
  results = str.array_push(results;assert_true("pin toggles pinned to true";pinned_tab.pinned));

  // T9.3-k: pin again toggles pinned back to false
  let store9 = tabs.pin(store8;pin_tab.id);
  let unpinned_tabs = tabs.list_tabs(store9);
  let unpinned_tab = str.array_get(unpinned_tabs;0);
  results = str.array_push(results;assert_false("pin toggles pinned back to false";unpinned_tab.pinned));

  // T9.3-l: add_bookmark adds to bookmarks
  let empty_tags = @(str)[];
  let store10 = tabs.add_bookmark(store;"https://example.com";"Example";empty_tags);
  let bm_count = str.array_len(store10.bookmarks);
  results = str.array_push(results;assert_int_eq("add_bookmark adds entry";bm_count;1));

  // T9.3-m: remove_bookmark removes from bookmarks
  let bm = str.array_get(store10.bookmarks;0);
  let store11 = tabs.remove_bookmark(store10;bm.id);
  let bm_count_after = str.array_len(store11.bookmarks);
  results = str.array_push(results;assert_int_eq("remove_bookmark removes entry";bm_count_after;0));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
