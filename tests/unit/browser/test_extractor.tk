// T9.4 — Content extractor unit tests.
// Covers strip_html_tags, detect_pii, extract_selection, extract_full_page.

m=tests.unit.browser.test_extractor;

i=ex:loke.browser.workspace.extractor;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T9.4-a: strip_html_tags("<p>hello world</p>") equals "hello world"
  let stripped = ex.strip_html_tags("<p>hello world</p>");
  results = str.array_push(results;assert_eq("strip_html_tags basic";stripped;"hello world"));

  // T9.4-b: strip_html_tags("") equals "" (empty in, empty out)
  let stripped_empty = ex.strip_html_tags("");
  results = str.array_push(results;assert_eq("strip_html_tags empty";stripped_empty;""));

  // T9.4-c: strip_html_tags on nested tags preserves text
  let stripped_nested = ex.strip_html_tags("<div><span>nested</span> text</div>");
  results = str.array_push(results;assert_eq("strip_html_tags nested";stripped_nested;"nested text"));

  // T9.4-d: strip_html_tags on text with no tags returns original
  let plain = "no tags here";
  let stripped_plain = ex.strip_html_tags(plain);
  results = str.array_push(results;assert_eq("strip_html_tags plain text";stripped_plain;plain));

  // T9.4-e: detect_pii returns true for text containing email address
  results = str.array_push(results;assert_true("detect_pii email";ex.detect_pii("contact john@example.com for help")));

  // T9.4-f: detect_pii returns false for clean text
  results = str.array_push(results;assert_false("detect_pii clean";ex.detect_pii("the weather is nice today")));

  // T9.4-g: detect_pii returns true for digit run > 8
  results = str.array_push(results;assert_true("detect_pii digit run";ex.detect_pii("my account 1234567890 was charged")));

  // T9.4-h: detect_pii returns false for digit run of exactly 8
  results = str.array_push(results;assert_false("detect_pii 8 digits only";ex.detect_pii("code 12345678 here")));

  // T9.4-i: extraction result has kind field set to "selection"
  let opts = ex.default_opts();
  let sel_result = ex.extract_selection("https://example.com";"Test Page";"some selected text";opts);
  results = str.array_push(results;assert_eq("extract_selection kind";sel_result.kind;"selection"));

  // T9.4-j: extraction result has raw_text matching input
  results = str.array_push(results;assert_eq("extract_selection content";sel_result.raw_text;"some selected text"));

  // T9.4-k: extract_full_page kind is "full_page"
  let page_result = ex.extract_full_page("https://example.com";"Test Page";"<p>page content</p>";opts);
  results = str.array_push(results;assert_eq("extract_full_page kind";page_result.kind;"full_page"));

  // T9.4-l: extract_full_page strips tags in raw_text
  results = str.array_push(results;assert_eq("extract_full_page strips tags";page_result.raw_text;"page content"));

  // T9.4-m: extract_selection pii_detected true when email in text
  let pii_sel = ex.extract_selection("https://x.com";"X";"email user@domain.com here";opts);
  results = str.array_push(results;assert_true("extract_selection detects pii email";pii_sel.pii_detected));

  // T9.4-n: extract_selection pii_detected false for clean text
  let clean_sel = ex.extract_selection("https://x.com";"X";"no sensitive data";opts);
  results = str.array_push(results;assert_false("extract_selection no pii clean";clean_sel.pii_detected));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
