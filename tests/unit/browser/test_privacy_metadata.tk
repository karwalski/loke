// T9.5 — Privacy metadata unit tests.
// Covers resolve_page_sensitivity, parse_robots_txt, compliance_note,
// detect_data_ai_attrs, build_metadata.

m=tests.unit.browser.test_privacy_metadata;

i=pm:loke.browser.workspace.privacy_metadata;
i=str:std.string;
i=log:std.log;

pub m.$result{ name:str; passed:bool; message:str }

f=pass(n:str):$result{ <$result{name:n;passed:true;message:"ok"} }
f=fail(n:str;msg:str):$result{ <$result{name:n;passed:false;message:msg} }

f=assert_eq(n:str;got:str;want:str):$result{
  if str.eq(got;want){ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(want;str.concat(" got=";got))))
  }
}

f=assert_true(n:str;v:bool):$result{
  if v{ <pass(n) }else{ <fail(n;"expected true") }
}

f=assert_false(n:str;v:bool):$result{
  if !v{ <pass(n) }else{ <fail(n;"expected false") }
}

f=assert_int_eq(n:str;got:i32;want:i32):$result{
  if got == want{ <pass(n) }else{
    <fail(n;str.concat("want=";str.concat(str.from_int(want);str.concat(" got=";str.from_int(got)))))
  }
}

f=log_result(r:$result){
  if r.passed{ log.info(str.concat("PASS ";r.name)) }else{
    log.error(str.concat("FAIL ";str.concat(r.name;str.concat(": ";r.message))))
  }
}

pub f=run_all():bool{
  let results = @($result)[];

  // T9.5-a: resolve_page_sensitivity([RESTRICTED, PUBLIC]) returns RESTRICTED
  let attrs_a = @(str)[];
  attrs_a = str.array_push(attrs_a;"RESTRICTED");
  attrs_a = str.array_push(attrs_a;"PUBLIC");
  results = str.array_push(results;assert_eq("resolve_page_sensitivity RESTRICTED wins";pm.resolve_page_sensitivity(attrs_a);"RESTRICTED"));

  // T9.5-b: resolve_page_sensitivity([CONFIDENTIAL, INTERNAL]) returns CONFIDENTIAL
  let attrs_b = @(str)[];
  attrs_b = str.array_push(attrs_b;"CONFIDENTIAL");
  attrs_b = str.array_push(attrs_b;"INTERNAL");
  results = str.array_push(results;assert_eq("resolve_page_sensitivity CONFIDENTIAL over INTERNAL";pm.resolve_page_sensitivity(attrs_b);"CONFIDENTIAL"));

  // T9.5-c: resolve_page_sensitivity([PUBLIC, PUBLIC]) returns PUBLIC
  let attrs_c = @(str)[];
  attrs_c = str.array_push(attrs_c;"PUBLIC");
  attrs_c = str.array_push(attrs_c;"PUBLIC");
  results = str.array_push(results;assert_eq("resolve_page_sensitivity PUBLIC";pm.resolve_page_sensitivity(attrs_c);"PUBLIC"));

  // T9.5-d: resolve_page_sensitivity([]) returns PUBLIC (no attrs)
  let attrs_empty = @(str)[];
  results = str.array_push(results;assert_eq("resolve_page_sensitivity empty attrs PUBLIC";pm.resolve_page_sensitivity(attrs_empty);"PUBLIC"));

  // T9.5-e: resolve_page_sensitivity([INTERNAL]) returns INTERNAL
  let attrs_e = @(str)[];
  attrs_e = str.array_push(attrs_e;"INTERNAL");
  results = str.array_push(results;assert_eq("resolve_page_sensitivity INTERNAL";pm.resolve_page_sensitivity(attrs_e);"INTERNAL"));

  // T9.5-f: parse_robots_txt with GPTBot Disallow sets disallow_ai=true
  let robots_gptbot = "User-agent: GPTBot\nDisallow: /";
  let directives_f = pm.parse_robots_txt(robots_gptbot;"https://example.com");
  let dir_count = str.array_len(directives_f);
  results = str.array_push(results;assert_true("parse_robots_txt GPTBot produces directives";dir_count >= 1));
  let dir_f = str.array_get(directives_f;0);
  results = str.array_push(results;assert_true("parse_robots_txt GPTBot disallow_ai true";dir_f.disallow_ai));

  // T9.5-g: parse_robots_txt with empty content sets disallow_ai=false (no directives)
  let directives_empty = pm.parse_robots_txt("";"https://example.com");
  let ai_disallowed_empty = pm.check_ai_disallowed(directives_empty);
  results = str.array_push(results;assert_false("parse_robots_txt empty disallow_ai false";ai_disallowed_empty));

  // T9.5-h: parse_robots_txt ClaudeBot Disallow sets disallow_ai=true
  let robots_claude = "User-agent: ClaudeBot\nDisallow: /";
  let directives_h = pm.parse_robots_txt(robots_claude;"https://example.com");
  let ai_disallowed_h = pm.check_ai_disallowed(directives_h);
  results = str.array_push(results;assert_true("parse_robots_txt ClaudeBot disallow_ai true";ai_disallowed_h));

  // T9.5-i: detect_data_ai_attrs returns RESTRICTED value from HTML attr
  let html_attr = "<div data-ai-sensitivity=\"RESTRICTED\">content</div>";
  let attr_vals = pm.detect_data_ai_attrs(html_attr);
  let attr_count = str.array_len(attr_vals);
  results = str.array_push(results;assert_int_eq("detect_data_ai_attrs finds one attr";attr_count;1));
  let attr_val = str.array_get(attr_vals;0);
  results = str.array_push(results;assert_eq("detect_data_ai_attrs value RESTRICTED";attr_val;"RESTRICTED"));

  // T9.5-j: detect_data_ai_attrs on HTML with no such attr returns empty array
  let html_no_attr = "<div class=\"public\">no sensitivity attr</div>";
  let no_attrs = pm.detect_data_ai_attrs(html_no_attr);
  results = str.array_push(results;assert_int_eq("detect_data_ai_attrs no attr empty";str.array_len(no_attrs);0));

  // T9.5-k: compliance_note returns non-empty string for RESTRICTED metadata
  let restricted_html = "<div data-ai-sensitivity=\"RESTRICTED\">x</div>";
  let meta_restricted = pm.build_metadata("https://x.com";"";restricted_html);
  let note = pm.compliance_note(meta_restricted);
  results = str.array_push(results;assert_true("compliance_note RESTRICTED non-empty";str.len(note) > 0));

  // T9.5-l: compliance_note returns empty string for fully PUBLIC metadata
  let meta_public = pm.build_metadata("https://x.com";"";"<div>public page</div>");
  let public_note = pm.compliance_note(meta_public);
  results = str.array_push(results;assert_eq("compliance_note PUBLIC empty";public_note;""));

  // T9.5-m: compliance_note returns non-empty string when ai training disallowed
  let robots_disallow = "User-agent: GPTBot\nDisallow: /";
  let meta_disallow = pm.build_metadata("https://x.com";robots_disallow;"<p>content</p>");
  let disallow_note = pm.compliance_note(meta_disallow);
  results = str.array_push(results;assert_true("compliance_note disallow_ai non-empty";str.len(disallow_note) > 0));

  let all = true;
  let i = 0;
  let n = str.array_len(results);
  loop{
    if i >= n{ break }else{
      let r = str.array_get(results;i);
      log_result(r);
      if !r.passed{ let all = false }else{};
      i = i+1
    }
  };
  <all
}
